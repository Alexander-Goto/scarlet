fn (left:-inf, right:@float) -inf
fn (left:@float, right:-inf) -inf
fn (left:(@byte|@int|@float|.core___add__), right:!$left) !$left
@#
fn (+)(left, right) null

#@
Побитовое логическое "и".

signature:
