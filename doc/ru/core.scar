fn (arg_1:@float, arg_2:nan) :nan_cmp
fn (left:(inf|-inf), right:$=left) :equal
fn (left:inf, right:@float) :great
fn (left:@float, right:inf) :less
fn (left:-inf, right:@float) :less
fn (left:@float, right:-inf) :great
fn (arg_1:.core_cmp, arg_2:any) (:equal|:less|:great|:not_equal|:nan_cmp)
fn (arg_1:any, arg_2:!$arg_1) (:equal|:less|:great|:not_equal|:nan_cmp)
@#
fn cmp(arg_1, arg_2) null

