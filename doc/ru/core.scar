fn (array:@byte_array, init_state:any, func:fn(in_state:any, idx:@int, byte:@byte) [box out_state:any, @byte]) [box @byte_array, result_state:any]
fn (array:@array, init_state:any, func:fn(in_state:any, idx:@int, item:common) [box out_state:any, common]) [box @array, result_state:any]
fn (container:(.core_map_kv_with_state|@table), init_state:any, func:fn(in_state:any, key:param(hash:arg), item:common) [box out_state:any, common]) [box !$container, result_state:any]
