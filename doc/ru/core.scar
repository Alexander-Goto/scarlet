#@
Сложение двух чисел.

signature:
fn (left:nan, right:@float) nan
fn (left:@float, right:nan) nan
fn (left:inf, right:-inf) nan
fn (left:-inf, right:inf) nan
fn (left:inf, right:@float) inf
