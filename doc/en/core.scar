fn (left:(-0.0|0.0), right:$left) false
fn (left:(@string|@token|@byte|@char|@int|@time|@float|@byte_array|.core_cmp|[array $left*]), right:!$left) @bool

error:
:nan_cmp - if a comparison of two constants of type 'float' occurred, but one of them is not a number (nan).
@#
