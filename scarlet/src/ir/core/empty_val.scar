fn ir__core_fn_empty_val(exp, last_use_ids, contexts, lambdas_data, unused_def_ids, exp_data, ir, final_data, dependencies, src_gconsts, is_last) {
     let [box arg, exp_data, ir, final_data, dependencies, src_gconsts] =
          exp:args.first().to_operand(last_use_ids, contexts, lambdas_data, unused_def_ids, exp_data, ir, final_data, dependencies, src_gconsts, false, false, false, true)

     let code = new (exp:name):text => _ ++ ("(" ++ arg:code:text ++ ")")

     let valid_types = [set "short_string", "string", "short_byte_array", "byte_array", "table", "set", "array", "obj", "custom"]
     arg.maybe_has_type!(valid_types)

     if arg.maybe_has_type?([set "obj", "custom"]) || not (arg.has_type?(@main.string_types) || arg.has_type?(@main.byte_array_types)) && arg:possible_types.len() /= 1 {
          let result_possible_types = if arg:possible_types.null?()
               [set "short_string", "short_byte_array", "table", "set", "array", "obj", "custom", "error"]
          else {
               let result_possible_types = arg:possible_types.filter(_.in?(valid_types))

               let result_possible_types = if "string".in?(result_possible_types)
                    result_possible_types.remove("string").append("short_string")
               else result_possible_types

               let result_possible_types = if "byte_array".in?(result_possible_types)
                    result_possible_types.remove("byte_array").append("short_byte_array")
               else result_possible_types

               if arg.has_type?([set "short_string", "string", "short_byte_array", "byte_array", "table", "set", "array"])
                    result_possible_types
               else result_possible_types.append("error")
          }

          ir__fn_call("McoreFNempty_val", [array arg], code, result_possible_types, exp_data, ir, final_data, dependencies, src_gconsts, is_last)
     } else {
          let ir      = dec_ref_cnt(arg, ir)
          let operand = new (arg) {
               :ir           <= null
               :code         <= code
               :comptime_val <=
                    switch arg:possible_types.take_one()
                    case "short_string", "string":
                         new (@main.t_comptime_val) {
                              :type  <= "string"
                              :value <= ""
                         }
                    case "short_byte_array", "byte_array":
                         new (@main.t_comptime_val) {
                              :type  <= "byte_array"
                              :value <= [byte_array]
                         }
                    case "table":
                         new (@main.t_comptime_val) {
                              :type  <= "table"
                              :value <= [table]
                         }
                    case "set":
                         new (@main.t_comptime_val) {
                              :type  <= "set"
                              :value <= [set]
                         }
                    case "array":
                         new (@main.t_comptime_val) {
                              :type  <= "array"
                              :value <= [array]
                         }
                    default:
                         unreachable()
          }
          let operand = if operand:comptime_val:type.in?([array "string", "byte_array"])
               new (operand):possible_types <= if operand:comptime_val:type == "string"; [set "short_string"] else [set "short_byte_array"]
          else operand

          if is_last {
               let [box operand, final_data, dependencies] = operand.has_ir!(final_data, dependencies)

               [box operand, exp_data, ir__raw_return(ir, operand:ir), final_data, dependencies, src_gconsts]
          } else [box operand, exp_data, ir, final_data, dependencies, src_gconsts]
     }
}