#endif
while(true){
t_any*const item_ptr=set__key_ptr(thrd_data,set,item,item_hash.qwords[0],owner);
if(item_ptr!=nullptr){
if(item_ptr->bytes[15]==tid__null||item_ptr->bytes[15]==tid__holder){
