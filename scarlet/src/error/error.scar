          fail("Error: The " ++ owner ++ " " ++ name ++ " from the " ++ module ++ " module is requred, but there is no such " ++ owner ++ " in the " ++ module ++ " module.")
     else fail("Error: The " ++ owner ++ " " ++ name ++ " from the " ++ module ++ " module is requred, but there is no such module.")

