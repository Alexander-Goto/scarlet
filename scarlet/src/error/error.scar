`cold`
fn error__invalid_type(exp, expected, has) {
     let expected = switch expected.type()
     case "core.null":
          null
     case "core.string":
          if "short_".prefix_of?(expected); expected.drop(6) else expected
     case "core.set": {
          let expected = expected.foldl([set], fn (expected, type) expected.append(if "short_".prefix_of?(type); type.drop(6) else type)).remove("holder")
          if expected.len() == 1; expected.take_one() else expected
     }
     default: unreachable()

     let has = switch has.type()
     case "core.string":
          if "short_".prefix_of?(has); has.drop(6) else has
     case "core.set": {
          let has = has.foldl([set], fn (has, type) has.append(if "short_".prefix_of?(type); type.drop(6) else type)).remove("holder")
          if has.len() == 1; has.take_one() else has
     }
     default: unreachable()

     let msg = "The expression \"" ++ exp:text ++ "\" is of an incorrect type.\n" ++ switch expected.type()
     case "core.null":
          ""
     case "core.string":
          "Expected type is " ++ expected ++ ".\n"
     case "core.set":
          "Expected types: " ++ expected.join(", ") ++ ".\n"
     default: unreachable()

     let msg = msg ++ if has.type() == "core.string"
          "Expression type is " ++ has ++ "."
     else "Expression types: " ++ has.join(", ") ++ "."

     fail("Error: " ++ msg__make(exp, msg))
}

