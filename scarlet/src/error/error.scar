`cold`
fn error__not_expected_token(token, variants) {
     let msg = switch variants.type()
     case "core.null":
          if token:text == "\n"
               "Unexpected end of line."
          else "The text \"" ++ token:text ++ "\" should not be in the place where it is."
     case "core.string":
          if token:text == "\n"
               "The end of the line should be replaced by the text \"" ++ variants ++ "\""
          else if variants == "\n"
               "Instead of the text \"" ++ token:text ++ "\" there should be a new line."
          else "Instead of the text \"" ++ token:text ++ "\" there should be the text \"" ++ variants ++ "\"."
     case "core.set":
          (if token:text == "\n"
               "At the end of the line "
          else "In place of the text \"" ++ token:text ++ "\"") ++
               " must be one of the following options: " ++
               variants.foldl([set], fn (variants, variant) variants.append(if variant == "\n"; "a new line" else "\"" ++ variant ++ "\"")).join(", ") ++ "."
     default: unreachable()

     fail("Error: " ++ msg__make(token, msg))
}

