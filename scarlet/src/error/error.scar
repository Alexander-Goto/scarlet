`cold`
fn error__invalid_char_in_src(char) {
     let msg = if char:text.first().graphic?() && not char:text.first().space?();
          "The use of the '" ++ char:text ++ "' character is allowed only in a comment, string(\"\") and character('')"
     else "The use of a character with corsar code " ++ char:text.first().to_int().to_string() ++ " is allowed only in a comment, string(\"\") and character('')"

     fail("Error: " ++ msg__make(char, msg))
}

