let t_final_data = [obj
     :modules_names = [set "core"]

     # [table const_name:@string = [table module_name:@string = @t_final_gconst]]
     :gconsts = [table
          "cli_args" = [table "core" = new (@main.t_final_gconst) {
               :ir_name        <= "McoreGCcli_args"
               :ir             <= "return gconst__cli_args(thrd_data);"
               :possible_types <= [set "array"]
               :attributes     <= [table "export" = :no_final_data]
               :name_ir_const  <= "core_cli_args_gconst_name"
          }]
          "cpu_cores_num" = [table "core" = new (@main.t_final_gconst) {
               :ir_name        <= "McoreGCcpu_cores_num"
               :ir             <= "return (const t_any){.structure={.value=cpu_cores_num,.type=tid__int}};\n"
               :possible_types <= [set "int"]
               :attributes     <= [table "export" = :no_final_data]
          }]
          "env_vars" = [table "core" = new (@main.t_final_gconst) {
               :ir_name        <= "McoreGCenv_vars"
               :ir             <= "return gconst__env_vars(thrd_data);\n"
               :possible_types <= [set "table"]
               :attributes     <= [table "export" = :no_final_data]
               :name_ir_const  <= "core_env_vars_gconst_name"
          }]
          "log_lvl__minimum" = [table "core" = new (@main.t_final_gconst) {
               :ir_name        <= "McoreGClog_lvl__minimum"
               :operand_ir     <= "(const t_any){.structure={.value=1,.type=tid__int}}"
               :ir             <= "return (const t_any){.structure={.value=1,.type=tid__int}};\n"
               :comptime_val   <= new (@main.t_comptime_val) {
                    :type  <= "int"
                    :value <= 1
               }
               :possible_types <= [set "int"]
               :attributes     <= [table "export" = :no_final_data]
          }]
          "log_lvl__hint" = [table "core" = new (@main.t_final_gconst) {
               :ir_name        <= "McoreGClog_lvl__hint"
               :operand_ir     <= "(const t_any){.structure={.value=2,.type=tid__int}}"
               :ir             <= "return (const t_any){.structure={.value=2,.type=tid__int}};\n"
               :comptime_val   <= new (@main.t_comptime_val) {
                    :type  <= "int"
