     :always_use_gconsts = [table] # [table ir_name:@string = full_name:@string]
]

fn get_gconst(final_data, name) {
     let [box module, short_name] = if name:text.first() == '@' {
          let dot_idx = '.'.look_in(name:text)
          [box name:text[1, dot_idx], name:text.drop(dot_idx + 1)]
     } else [box "", name:text]

     let gconsts_with_same_name = final_data:gconsts[short_name]
     if gconsts_with_same_name.null?()
          error__not_found(name, "global constant")
     else null

     if module.empty?() {
          let [box gconst, modules] = gconsts_with_same_name.foldl_kv(null, fn (state, module, variant) {
               let [box gconst, modules] = state

               if @main.compiled_module_name == module || "export".key_of?(variant:attributes)
                    if modules.null?()
                         [box variant, module]
                    else if modules.type() == "core.string"
                         [box null, [array modules, module]]
                    else [box null, modules.append(module)]
               else [box gconst, modules]
          })

          switch modules.type()
          case "core.string":
               gconst
          case "core.null":
               error__not_found(name, "global constant")
          case "core.array":
               error__found_few_variants(name, "global constant", modules)
          default:
               unreachable()
     } else {
          let gconst = gconsts_with_same_name[module]
          if not gconst.null?() && (@main.compiled_module_name == module || "export".key_of?(gconst:attributes))
               gconst
          else error__not_found(name, "global constant")
     }
}

fn get_fn(final_data, name) {
     let [box module, short_name] = if name:text.first() == '@' {
          let dot_idx = '.'.look_in(name:text)
          [box name:text[1, dot_idx], name:text.drop(dot_idx + 1)]
     } else [box "", name:text]

     let fns_with_same_name = final_data:fns[short_name]
     if fns_with_same_name.null?()
          error__not_found(name, "function")
     else null

     if module.empty?() {
          let [box func, modules] = fns_with_same_name.foldl_kv(null, fn (state, module, variant) {
               let [box func, modules] = state

               if @main.compiled_module_name == module || "export".key_of?(variant:attributes)
                    if modules.null?()
                         [box variant, module]
                    else if modules.type() == "core.string"
                         [box null, [array modules, module]]
                    else [box null, modules.append(module)]
               else [box func, modules]
          })

          switch modules.type()
          case "core.string":
               func
          case "core.null":
               error__not_found(name, "function")
          case "core.array":
               error__found_few_variants(name, "function", modules)
          default:
               unreachable()
     } else {
          let func = fns_with_same_name[module]
          if not func.null?() && (@main.compiled_module_name == module || "export".key_of?(func:attributes))
               func
          else error__not_found(name, "function")
     }
}