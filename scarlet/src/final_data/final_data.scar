          "pi" = [table "core" = new (@main.t_final_gconst) {
               :ir_name        <= "McoreGCpi"
               :operand_ir     <= "(const t_any){.structure={.value=0x400921fb54442d18ull,.type=tid__float}}"
               :ir             <= "return (const t_any){.structure={.value=0x400921fb54442d18ull,.type=tid__float}};\n"
               :comptime_val   <= new (@main.t_comptime_val) {
