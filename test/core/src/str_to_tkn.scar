`noinline`
fn test__str_to_tkn() {
     test("0".str_to_tkn() === :0)
     test("9".str_to_tkn() === :9)
     test("a".str_to_tkn() === :a)
     test("z".str_to_tkn() === :z)
     test("_".str_to_tkn() === :_)
     test("0!".str_to_tkn() === :0!)
     test("9!".str_to_tkn() === :9!)
     test("a!".str_to_tkn() === :a!)
     test("z!".str_to_tkn() === :z!)
     test("_!".str_to_tkn() === :_!)
     test("0!!!".str_to_tkn() === :0!!!)
     test("9!!!".str_to_tkn() === :9!!!)
     test("a!!!".str_to_tkn() === :a!!!)
     test("z!!!".str_to_tkn() === :z!!!)
     test("_!!!".str_to_tkn() === :_!!!)
     test("0?".str_to_tkn() === :0?)
     test("9?".str_to_tkn() === :9?)
     test("a?".str_to_tkn() === :a?)
     test("z?".str_to_tkn() === :z?)
     test("_?".str_to_tkn() === :_?)

     test("0000000000000000000000".str_to_tkn() === :0000000000000000000000)
     test("9999999999999999999999".str_to_tkn() === :9999999999999999999999)
     test("aaaaaaaaaaaaaaaaaaaaaa".str_to_tkn() === :aaaaaaaaaaaaaaaaaaaaaa)
     test("zzzzzzzzzzzzzzzzzzzzzz".str_to_tkn() === :zzzzzzzzzzzzzzzzzzzzzz)
     test("______________________".str_to_tkn() === :______________________)
     test("0000000000000000000000!".str_to_tkn() === :0000000000000000000000!)
     test("9999999999999999999999!".str_to_tkn() === :9999999999999999999999!)
     test("aaaaaaaaaaaaaaaaaaaaaa!".str_to_tkn() === :aaaaaaaaaaaaaaaaaaaaaa!)
     test("zzzzzzzzzzzzzzzzzzzzzz!".str_to_tkn() === :zzzzzzzzzzzzzzzzzzzzzz!)
     test("______________________!".str_to_tkn() === :______________________!)
     test("0000000000000000000000!!!".str_to_tkn() === :0000000000000000000000!!!)
     test("9999999999999999999999!!!".str_to_tkn() === :9999999999999999999999!!!)
     test("aaaaaaaaaaaaaaaaaaaaaa!!!".str_to_tkn() === :aaaaaaaaaaaaaaaaaaaaaa!!!)
     test("zzzzzzzzzzzzzzzzzzzzzz!!!".str_to_tkn() === :zzzzzzzzzzzzzzzzzzzzzz!!!)
     test("______________________!!!".str_to_tkn() === :______________________!!!)
     test("0000000000000000000000?".str_to_tkn() === :0000000000000000000000?)
     test("9999999999999999999999?".str_to_tkn() === :9999999999999999999999?)
     test("aaaaaaaaaaaaaaaaaaaaaa?".str_to_tkn() === :aaaaaaaaaaaaaaaaaaaaaa?)
     test("zzzzzzzzzzzzzzzzzzzzzz?".str_to_tkn() === :zzzzzzzzzzzzzzzzzzzzzz?)
     test("______________________?".str_to_tkn() === :______________________?)

     test("0123456789abcdef_gz012".str_to_tkn() === :0123456789abcdef_gz012)
     test("__0123124bmnbsdfkkjsdd".str_to_tkn() === :__0123124bmnbsdfkkjsdd)
     test("aasasdasdd_asdasdazzaa".str_to_tkn() === :aasasdasdd_asdasdazzaa)
     test("0123456789abcdef_gz012!".str_to_tkn() === :0123456789abcdef_gz012!)
     test("__0123124bmnbsdfkkjsdd!".str_to_tkn() === :__0123124bmnbsdfkkjsdd!)
     test("aasasdasdd_asdasdazzaa!".str_to_tkn() === :aasasdasdd_asdasdazzaa!)
     test("0123456789abcdef_gz012!!!".str_to_tkn() === :0123456789abcdef_gz012!!!)
     test("__0123124bmnbsdfkkjsdd!!!".str_to_tkn() === :__0123124bmnbsdfkkjsdd!!!)
     test("aasasdasdd_asdasdazzaa!!!".str_to_tkn() === :aasasdasdd_asdasdazzaa!!!)
     test("0123456789abcdef_gz012?".str_to_tkn() === :0123456789abcdef_gz012?)
     test("__0123124bmnbsdfkkjsdd?".str_to_tkn() === :__0123124bmnbsdfkkjsdd?)
     test("aasasdasdd_asdasdazzaa?".str_to_tkn() === :aasasdasdd_asdasdazzaa?)

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.str_to_tkn().get_error_id() === :1)

     test(heap_table().str_to_tkn().get_error_id() === :invalid_type)

     test(":1".str_to_tkn().null?())
     test(":".str_to_tkn().null?())
     test("__01!0".str_to_tkn().null?())
     test("__01!00!".str_to_tkn().null?())
     test("".str_to_tkn().null?())
     test(("0000000000000000000000" ++ "0").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "0!").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "0!!!").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "0?").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "~").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "00000000000000000000").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "00000000000000000000!").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "00000000000000000000!!!").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "00000000000000000000?").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "0000000000000000000~").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "000").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "00!").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "00?").str_to_tkn().null?())
     test(("0000000000000000000000" ++ "00~").str_to_tkn().null?())
}