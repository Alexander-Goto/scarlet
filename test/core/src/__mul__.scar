let num__mul = [obj
     :value = 0

     :_ = [obj
          :core___mul__   = fn (num_1, num_2) to_num__mul(num_1:value * num_2:value)
          :core___equal__ = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__mul(arg) new (@main.num__mul):value <= arg

fn to_custom_num__mul(arg) custom__create(
     arg
     [obj
          :core___mul__   = fn (num_1, num_2) to_custom_num__mul(num_1.custom__get_data() * num_2.custom__get_data())
          :core___equal__ = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__mul = [obj
     :value = 0

     :_ = [obj
          :core___mul__ = fn (_, _) heap_string()
     ]
]

fn to_broken_num__mul(arg) new (@main.broken_num__mul):value <= arg

fn to_broken_custom_num__mul(arg) custom__create(
     arg
     [obj
          :core___mul__ = fn (_, _) heap_string()
     ]
)

let error_num__mul = [obj
     :value = 0

     :_ = [obj
          :core___mul__ = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__mul(arg) new (@main.error_num__mul):value <= arg

fn to_error_custom_num__mul(arg) custom__create(
     arg
     [obj
          :core___mul__ = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test____mul__() {
     test((0b00 * 0b00) === 0b00)
     test((0b00 * 0b01) === 0b00)
     test((0b01 * 0b00) === 0b00)
     test((0b01 * 0b01) === 0b01)
     test((0bf0 * 0b01) === 0bf0)
     test((0b01 * 0bf0) === 0bf0)
     test((0b0f * 0b0f) === 0be1)
     test((0bff * 0b00) === 0b00)
     test((0b00 * 0bff) === 0b00)
     test((0bff * 0b01) === 0bff)
     test((0b01 * 0bff) === 0bff)
     test((0bff * 0b25) === 0bdb)
     test((0b25 * 0bff) === 0bdb)
     test((0bff * 0bff) === 0b01)

     test((0 * 0) === 0)
     test((0 * 1) === 0)
     test((1 * 0) === 0)
     test((1 * 1) === 1)
     test((0 * -1) === 0)
     test((-1 * 0) === 0)
     test((-1 * -1) === 1)
     test((-1 * 1) === -1)
     test((-708044971986000615 * 8401028929648066925) === -7141666615086832475)
     test((-1964724193136850828 * -708044971986000615) === -6923877205770447020)
     test((-9223372036854775808 * 0) === 0)
     test((0 * -9223372036854775808) === 0)
     test((1 * -9223372036854775808) === -9223372036854775808)
     test((-1 * -9223372036854775808) === -9223372036854775808)
     test((-9223372036854775808 * -9223372036854775808) === 0)
     test((9223372036854775807 * 0) === 0)
     test((0 * 9223372036854775807) === 0)
     test((1 * 9223372036854775807) === 9223372036854775807)
     test((-1 * 9223372036854775807) === -9223372036854775807)
     test((9223372036854775807 * 9223372036854775807) === 1)

     test((0.0 * 0.0).in_range?(-0.01, 0.01))
     test((-0.0 * -0.0).in_range?(-0.01, 0.01))
     test((-0.0 * 0.0).in_range?(-0.01, 0.01))
     test((0.0 * -0.0).in_range?(-0.01, 0.01))
     test((0.0 * 0.1).in_range?(-0.01, 0.01))
     test((0.1 * 0.0).in_range?(-0.01, 0.01))
     test((0.0 * -0.1).in_range?(-0.01, 0.01))
     test((-0.1 * 0.0).in_range?(-0.01, 0.01))
     test((0.1 * 0.2).in_range?(0.019, 0.021))
     test((0.2 * 0.1).in_range?(0.019, 0.021))
     test((-0.1 * 0.2).in_range?(-0.021, -0.019))
     test((-0.2 * 0.1).in_range?(-0.021, -0.019))
     test((11122.3 * 4879.111002).in_range?(54266935.0, 54266937.0))
     test((nan() * 1.0).nan?())
     test((1.0 * nan()).nan?())
     test((nan() * nan()).nan?())
     test((nan() * inf()).nan?())
     test((inf() * nan()).nan?())
     test((nan() * neg_inf()).nan?())
     test((neg_inf() * nan()).nan?())
     test((inf() * 0.0).nan?())
     test((inf() * -0.0).nan?())
     test((neg_inf() * 0.0).nan?())
     test((neg_inf() * -0.0).nan?())
     test((0.0 * inf()).nan?())
     test((-0.0 * inf()).nan?())
     test((0.0 * neg_inf()).nan?())
     test((-0.0 * neg_inf()).nan?())
     test((inf() * inf()).inf?())
     test((1.0 * inf()).inf?())
     test((inf() * 1.0).inf?())
     test((-1.0 * inf()).neg_inf?())
     test((inf() * -1.0).neg_inf?())
     test((neg_inf() * neg_inf()).inf?())
     test((1.0 * neg_inf()).neg_inf?())
     test((neg_inf() * 1.0).neg_inf?())
     test((-1.0 * neg_inf()).inf?())
     test((neg_inf() * -1.0).inf?())

     test((to_num__mul(0) * to_num__mul(0)) === to_num__mul(0))
     test((to_num__mul(-708044971986000615) * to_num__mul(8401028929648066925)) === to_num__mul(-7141666615086832475))

     test((to_custom_num__mul(0) * to_custom_num__mul(0)) === to_custom_num__mul(0))
     test((to_custom_num__mul(-708044971986000615) * to_custom_num__mul(8401028929648066925)) === to_custom_num__mul(-7141666615086832475))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let string  = heap_string()
     test((error_1 * 1).get_error_id() === :1)
     test((1 * error_1).get_error_id() === :1)
     test((error_1 * error_2).get_error_id() === :1)
     test((error_2 * error_1).get_error_id() === :2)
     test((error_1 * string).get_error_id() === :1)
     test((string * error_1).get_error_id() === :1)

     test((string * string).get_error_id() === :invalid_type)
     test((string * 1).get_error_id() === :invalid_type)
     test((1 * string).get_error_id() === :invalid_type)
     test((1.scarlet__erase_info() * 1.0).get_error_id() === :invalid_type)
     test((1.0.scarlet__erase_info() * 1).get_error_id() === :invalid_type)

     test((to_num__mul(1) * error_1).get_error_id() === :1)
     test((error_1 * to_num__mul(1)).get_error_id() === :1)
     test((to_num__mul(1) * string).get_error_id() === :invalid_type)
     test((string * to_num__mul(1)).get_error_id() === :invalid_type)
     test((to_num__mul(1) * 1).get_error_id() === :invalid_type)
     test((1 * to_num__mul(1)).get_error_id() === :invalid_type)
     test((to_num__mul(1) * to_num__mul(1.0)).get_error_id() === :invalid_type)

     test((to_custom_num__mul(1) * error_1).get_error_id() === :1)
     test((error_1 * to_custom_num__mul(1)).get_error_id() === :1)
     test((to_custom_num__mul(1) * string).get_error_id() === :invalid_type)
     test((string * to_custom_num__mul(1)).get_error_id() === :invalid_type)
     test((to_custom_num__mul(1) * 1).get_error_id() === :invalid_type)
     test((1 * to_custom_num__mul(1)).get_error_id() === :invalid_type)
     test((to_custom_num__mul(1) * to_custom_num__mul(1.0)).get_error_id() === :invalid_type)

     test((to_broken_num__mul(1) * to_broken_num__mul(0)).get_error_id() === :invalid_type)
     test((to_broken_custom_num__mul(1) * to_broken_custom_num__mul(0)).get_error_id() === :invalid_type)
     test((to_error_num__mul(1) * to_error_num__mul(0)).get_error_id() === :3)
     test((to_error_custom_num__mul(1) * to_error_custom_num__mul(0)).get_error_id() === :4)
}