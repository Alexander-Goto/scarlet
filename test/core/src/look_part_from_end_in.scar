`noinline`
fn test__look_part_from_end_in() {
     test("".look_part_from_end_in("") === 0)
     test("1".look_part_from_end_in("").null?())
     test("".look_part_from_end_in("a") === 1)
     test("1".look_part_from_end_in("1") === 0)
     test("1".look_part_from_end_in("2").null?())
     test("2".look_part_from_end_in("1").null?())
     test("".look_part_from_end_in("122333444455555") === 15)
     test("1".look_part_from_end_in("122333444455555") === 0)
     test("2".look_part_from_end_in("122333444455555") === 2)
     test("3".look_part_from_end_in("122333444455555") === 5)
     test("4".look_part_from_end_in("122333444455555") === 9)
     test("5".look_part_from_end_in("122333444455555") === 14)
     test("6".look_part_from_end_in("122333444455555").null?())
     test("54".look_part_from_end_in("122333444455555").null?())
     test("35".look_part_from_end_in("122333444455555").null?())
     test("01".look_part_from_end_in("122333444455555").null?())
     test("11".look_part_from_end_in("122333444455555").null?())
     test("122333444455556".look_part_from_end_in("122333444455555").null?())
     test("222333444455555".look_part_from_end_in("122333444455555").null?())
     test("12".look_part_from_end_in("122333444455555") === 0)
     test("23".look_part_from_end_in("122333444455555") === 2)
     test("33".look_part_from_end_in("122333444455555") === 4)
     test("555".look_part_from_end_in("122333444455555") === 12)
     test("4455".look_part_from_end_in("122333444455555") === 8)
     test("122333444455555".look_part_from_end_in("122333444455555") === 0)

     test("1223334444555555".look_part_from_end_in("122333444455555").null?())
     test(heap_string().look_part_from_end_in("122333444455555").null?())

     test("\000091".look_part_from_end_in("").null?())
     test("".look_part_from_end_in("\00009a") === 1)
     test("\000091".look_part_from_end_in("\000091") === 0)
     test("1".look_part_from_end_in("\000091").null?())
     test("\000091".look_part_from_end_in("1").null?())
     test("\000091".look_part_from_end_in("\000092").null?())
     test("\000092".look_part_from_end_in("\000091").null?())
     test("".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 8)
     test("\000091".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 0)
     test("\000092".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 2)
     test("2".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 1)
     test("\000093".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 5)
     test("\000094".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 7)

     test("\000095".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094").null?())
     test("\000094\000093".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094").null?())
     test("\000092\000094".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094").null?())
     test("\000092\000092".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094").null?())
     test("\000090\000091".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094").null?())
     test("\000091\000091".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094").null?())
     test("\0000912\000092\000093\000093\000093\000094\000095".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094").null?())
     test("\0000902\000092\000093\000093\000093\000094\000094".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094").null?())
     test("\0000912".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 0)
     test("2\000092".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 1)
     test("\000092\000093".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 2)
     test("\000093\000093".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 4)
     test("\000093\000094\000094".look_part_from_end_in("\0000912\000092\000093\000093\000093\000094\000094") === 5)

     let string = ("0122333444455555666666" ++ "0")[1, 22]
     test("".look_part_from_end_in(string) === 21)
     test("1".look_part_from_end_in(string) === 0)
     test("2".look_part_from_end_in(string) === 2)
     test("3".look_part_from_end_in(string) === 5)
     test("4".look_part_from_end_in(string) === 9)
     test("5".look_part_from_end_in(string) === 14)
     test("6".look_part_from_end_in(string) === 20)
     test("7".look_part_from_end_in(string).null?())
     test("65".look_part_from_end_in(string).null?())
     test("54".look_part_from_end_in(string).null?())
     test("35".look_part_from_end_in(string).null?())
     test("01".look_part_from_end_in(string).null?())
     test("60".look_part_from_end_in(string).null?())
     test("11".look_part_from_end_in(string).null?())
     test("122333444455556".look_part_from_end_in(string).null?())
     test("222333444455555".look_part_from_end_in(string).null?())
     test("12".look_part_from_end_in(string) === 0)
     test("23".look_part_from_end_in(string) === 2)
     test("33".look_part_from_end_in(string) === 4)
     test("555".look_part_from_end_in(string) === 12)
     test("4455".look_part_from_end_in(string) === 8)
     test("56666".look_part_from_end_in(string) === 14)
     test("666".look_part_from_end_in(string) === 18)

     let string = ("0\000091\000092\000092\000093\000093\000093\000094\000094\000094\000094\000095\000095\000095\000095\000095\000096\000096\000096\000096\000096\000096" ++ "0")[1, 22]
     test("".look_part_from_end_in(string) === 21)
     test("\000091".look_part_from_end_in(string) === 0)
     test("\000092".look_part_from_end_in(string) === 2)
     test("\000093".look_part_from_end_in(string) === 5)
     test("\000094".look_part_from_end_in(string) === 9)
     test("\000095".look_part_from_end_in(string) === 14)
     test("\000096".look_part_from_end_in(string) === 20)
     test("\000097".look_part_from_end_in(string).null?())
     test("\000096\000095".look_part_from_end_in(string).null?())
     test("\000095\000094".look_part_from_end_in(string).null?())
     test("\000093\000095".look_part_from_end_in(string).null?())
     test("\000090\000091".look_part_from_end_in(string).null?())
     test("\000096\000090".look_part_from_end_in(string).null?())
     test("\000091\000091".look_part_from_end_in(string).null?())
     test("\000091\000092\000092\000093\000093\000093\000094\000094\000094\000094\000095\000095\000095\000095\000096".look_part_from_end_in(string).null?())
     test("\000092\000092\000092\000093\000093\000093\000094\000094\000094\000094\000095\000095\000095\000095\000095".look_part_from_end_in(string).null?())
     test("\000091\000092".look_part_from_end_in(string) === 0)
     test("\000092\000093".look_part_from_end_in(string) === 2)
     test("\000093\000093".look_part_from_end_in(string) === 4)
     test("\000095\000095\000095".look_part_from_end_in(string) === 12)
     test("\000094\000094\000095\000095".look_part_from_end_in(string) === 8)
     test("\000095\000096\000096\000096\000096".look_part_from_end_in(string) === 14)
     test("\000096\000096\000096".look_part_from_end_in(string) === 18)

     let string = ("0122333444455555666666" ++ "0")[1, 22]
     test(("01223334444555556" ++ "0")[1, 17].look_part_from_end_in(string) === 0)
     test(("01223334444555555" ++ "0")[1, 17].look_part_from_end_in(string).null?())
     test(("00223334444555556" ++ "0")[1, 17].look_part_from_end_in(string).null?())
     test(("03444455555666666" ++ "0")[1, 17].look_part_from_end_in(string) === 5)
     test(("03444455555666660" ++ "0")[1, 17].look_part_from_end_in(string).null?())
     test(("00444455555666666" ++ "0")[1, 17].look_part_from_end_in(string).null?())
     test(string.look_part_from_end_in(string) === 0)

     let string = ("0\000091\000092\000092\000093\000093\000093\000094\000094\000094\000094\000095\000095\000095\000095\000095\000096\000096\000096\000096\000096\000096" ++ "0")[1, 22]
     test(("0\000091\000092\000092\000093\000093\000093\000094\000094\000094\000094\000095\000095\000095\000095\000095\000096" ++ "0")[1, 17].look_part_from_end_in(string) === 0)
     test(("0\000091\000092\000092\000093\000093\000093\000094\000094\000094\000094\000095\000095\000095\000095\000095\000095" ++ "0")[1, 17].look_part_from_end_in(string).null?())
     test(("0\000090\000092\000092\000093\000093\000093\000094\000094\000094\000094\000095\000095\000095\000095\000095\000096" ++ "0")[1, 17].look_part_from_end_in(string).null?())
     test(("0\000093\000094\000094\000094\000094\000095\000095\000095\000095\000095\000096\000096\000096\000096\000096\000096" ++ "0")[1, 17].look_part_from_end_in(string) === 5)
     test(("0\000093\000094\000094\000094\000094\000095\000095\000095\000095\000095\000096\000096\000096\000096\000096\000090" ++ "0")[1, 17].look_part_from_end_in(string).null?())
     test(("0\000090\000094\000094\000094\000094\000095\000095\000095\000095\000095\000096\000096\000096\000096\000096\000096" ++ "0")[1, 17].look_part_from_end_in(string).null?())
     test(string.look_part_from_end_in(string) === 0)

     let string = rnd_string()
     let part   = if rnd_bool()
          rnd_string()
     else {
          let from = (rnd() & 0xffff'ffff) % len(string)
          let to   = from + (rnd() & 0xffff'ffff) % (len(string) - from)
          string[from, to]
     }
     let expected_idx = if part.empty?()
          len(string)
     else if len(part) > len(string)
          -1
     else loop(len(string) - len(part), fn (idx) {
          if string[idx, idx + len(part)] === part
               [breaker idx]
          else break(idx === 0, idx - 1)
     })
     test((part.look_part_from_end_in(string) <? -1) === expected_idx)

     test(u"".look_part_from_end_in(u"") === 0)
     test(u"1".look_part_from_end_in(u"").null?())
     test(u"".look_part_from_end_in(u"a") === 1)
     test(u"1".look_part_from_end_in(u"1") === 0)
     test(u"1".look_part_from_end_in(u"2").null?())
     test(u"2".look_part_from_end_in(u"1").null?())
     test(u"".look_part_from_end_in(u"12233344445555") === 14)
     test(u"1".look_part_from_end_in(u"12233344445555") === 0)
     test(u"2".look_part_from_end_in(u"12233344445555") === 2)
     test(u"3".look_part_from_end_in(u"12233344445555") === 5)
     test(u"4".look_part_from_end_in(u"12233344445555") === 9)
     test(u"5".look_part_from_end_in(u"12233344445555") === 13)
     test(u"6".look_part_from_end_in(u"12233344445555").null?())
     test(u"54".look_part_from_end_in(u"12233344445555").null?())
     test(u"35".look_part_from_end_in(u"12233344445555").null?())
     test(u"01".look_part_from_end_in(u"12233344445555").null?())
     test(u"11".look_part_from_end_in(u"12233344445555").null?())
     test(u"12233344445556".look_part_from_end_in(u"12233344445555").null?())
     test(u"22233344445555".look_part_from_end_in(u"12233344445555").null?())
     test(u"12".look_part_from_end_in(u"12233344445555") === 0)
     test(u"23".look_part_from_end_in(u"12233344445555") === 2)
     test(u"33".look_part_from_end_in(u"12233344445555") === 4)
     test(u"555".look_part_from_end_in(u"12233344445555") === 11)
     test(u"4455".look_part_from_end_in(u"12233344445555") === 8)
     test(u"12233344445555".look_part_from_end_in(u"12233344445555") === 0)

     test(u"122333444455555".look_part_from_end_in(u"12233344445555").null?())
     test(heap_byte_array().look_part_from_end_in(u"12233344445555").null?())

     let array = (u"0122333444455555666666" ++ u"0")[1, 22]
     test(u"".look_part_from_end_in(array) === 21)
     test(u"1".look_part_from_end_in(array) === 0)
     test(u"2".look_part_from_end_in(array) === 2)
     test(u"3".look_part_from_end_in(array) === 5)
     test(u"4".look_part_from_end_in(array) === 9)
     test(u"5".look_part_from_end_in(array) === 14)
     test(u"6".look_part_from_end_in(array) === 20)
     test(u"7".look_part_from_end_in(array).null?())
     test(u"65".look_part_from_end_in(array).null?())
     test(u"54".look_part_from_end_in(array).null?())
     test(u"35".look_part_from_end_in(array).null?())
     test(u"01".look_part_from_end_in(array).null?())
     test(u"60".look_part_from_end_in(array).null?())
     test(u"11".look_part_from_end_in(array).null?())
     test(u"122333444455556".look_part_from_end_in(array).null?())
     test(u"222333444455555".look_part_from_end_in(array).null?())
     test(u"12".look_part_from_end_in(array) === 0)
     test(u"23".look_part_from_end_in(array) === 2)
     test(u"33".look_part_from_end_in(array) === 4)
     test(u"555".look_part_from_end_in(array) === 12)
     test(u"4455".look_part_from_end_in(array) === 8)
     test(u"56666".look_part_from_end_in(array) === 14)
     test(u"666".look_part_from_end_in(array) === 18)

     let array = (u"0122333444455555666666" ++ u"0")[1, 22]
     test((u"01223334444555556" ++ u"0")[1, 17].look_part_from_end_in(array) === 0)
     test((u"01223334444555555" ++ u"0")[1, 17].look_part_from_end_in(array).null?())
     test((u"00223334444555556" ++ u"0")[1, 17].look_part_from_end_in(array).null?())
     test((u"03444455555666666" ++ u"0")[1, 17].look_part_from_end_in(array) === 5)
     test((u"03444455555666660" ++ u"0")[1, 17].look_part_from_end_in(array).null?())
     test((u"00444455555666666" ++ u"0")[1, 17].look_part_from_end_in(array).null?())
     test(array.look_part_from_end_in(array) === 0)

     let array = rnd_byte_array()
     let part  = if rnd_bool()
          rnd_byte_array()
     else {
          let from = (rnd() & 0xffff'ffff) % len(array)
          let to   = from + (rnd() & 0xffff'ffff) % (len(array) - from)
          array[from, to]
     }
     let expected_idx = if part.empty?()
          len(array)
     else if len(part) > len(array)
          -1
     else loop(len(array) - len(part), fn (idx) {
          if array[idx, idx + len(part)] === part
               [breaker idx]
          else break(idx === 0, idx - 1)
     })
     test((part.look_part_from_end_in(array) <? -1) === expected_idx)

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     let string_3 = string_0 ++ "3"
     let string_4 = string_0 ++ "4"
     let string_5 = string_0 ++ "5"
     test([array].look_part_from_end_in([array]) === 0)
     test([array].init(10).look_part_from_end_in([array].init(10)) === 0)
     test([array string_1].look_part_from_end_in([array].init(10)).null?())
     test([array].init(10).look_part_from_end_in([array string_5]) === 1)
     test([array string_1].look_part_from_end_in([array string_1]) === 0)
     test([array string_1].look_part_from_end_in([array string_2]).null?())
     test([array string_2].look_part_from_end_in([array string_1]).null?())
