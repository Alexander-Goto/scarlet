     test([array string_0, string_1].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]).null?())
     test([array string_1, string_1].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]).null?())
     test([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_0].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]).null?())
     test([array string_2, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]).null?())
     test([array string_1, string_2].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 0)
     test([array string_2, string_3].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 2)
     test([array string_3, string_3].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 4)
     test([array string_5, string_5, string_5].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 12)
     test([array string_4, string_4, string_5, string_5].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 8)
     test([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 0)
     test([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5, string_5].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]).null?())

     let array = rnd_string_array()
     let part  = if rnd_bool()
          rnd_string_array()
     else {
          let from = (rnd() & 0xffff'ffff) % len(array)
          let to   = from + (rnd() & 0xffff'ffff) % (len(array) - from)
          array[from, to]
     }
     let expected_idx = if part.empty?()
          len(array)
     else if len(part) > len(array)
          -1
     else loop(len(array) - len(part), fn (idx) {
          if array[idx, idx + len(part)] === part
               [breaker idx]
          else break(idx === 0, idx - 1)
     })
     test((part.look_part_from_end_in(array) <? -1) === expected_idx)

     test("23".to_array__look_part_from_end_in().look_part_from_end_in("123123".to_array__look_part_from_end_in()) === 4)
     test("".to_array__look_part_from_end_in().look_part_from_end_in("123123".to_array__look_part_from_end_in()) === 6)
     test("33".to_array__look_part_from_end_in().look_part_from_end_in("123123".to_array__look_part_from_end_in()).null?())
     test("23".to_custom_array__look_part_from_end_in().look_part_from_end_in("123123".to_custom_array__look_part_from_end_in()) === 4)
     test("".to_custom_array__look_part_from_end_in().look_part_from_end_in("123123".to_custom_array__look_part_from_end_in()) === 6)
     test("33".to_custom_array__look_part_from_end_in().look_part_from_end_in("123123".to_custom_array__look_part_from_end_in()).null?())

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.look_part_from_end_in(heap_string()).get_error_id() === :1)
     test(heap_string().look_part_from_end_in(error_1).get_error_id() === :1)
     test(error_1.look_part_from_end_in(error_2).get_error_id() === :1)
     test(error_2.look_part_from_end_in(error_1).get_error_id() === :2)

     test([box heap_string()].scarlet__erase_info().look_part_from_end_in(heap_string()).get_error_id() === :invalid_type)
     test([box heap_string()].scarlet__erase_info().look_part_from_end_in([box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)

     test([array].to_broken_array__look_part_from_end_in().look_part_from_end_in(to_broken_array__look_part_from_end_in([array])).get_error_id() === :invalid_type)
     test([array].to_broken_custom_array__look_part_from_end_in().look_part_from_end_in(to_broken_custom_array__look_part_from_end_in([array])).get_error_id() === :invalid_type)
     test([array].to_error_array__look_part_from_end_in().look_part_from_end_in(to_error_array__look_part_from_end_in([array])).get_error_id() === :3)
     test([array].to_error_custom_array__look_part_from_end_in().look_part_from_end_in(to_error_custom_array__look_part_from_end_in([array])).get_error_id() === :4)
}