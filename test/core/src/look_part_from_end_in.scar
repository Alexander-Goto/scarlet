     test([array string_1].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 0)
     test([array string_2].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 2)
     test([array string_3].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 5)
     test([array string_4].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 9)
     test([array string_5].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]) === 14)
     test([array string_0].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]).null?())
     test([array string_5, string_4].look_part_from_end_in([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]).null?())
