     let [box array_1, array_2] = if (rnd() & 1) === 0 {
          let array_1 = rnd_byte_array()
          let array_2 = if (rnd() & 1) === 0; array_1 else null
          [box array_1, array_2]
     } else [box u"Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let len             = len(array_1)
     let from            = (rnd() >> 1) % (len + 1)
     let to              = from + (rnd() >> 1) % (len - from + 1)
     let expected_array  = array_1.foldl_kv(u"", fn (expected_array, idx, byte) if idx >= from && idx < to; expected_array.append(byte) else expected_array)
     test(array_1[from, to] === expected_array)
     array_2.ignore()

