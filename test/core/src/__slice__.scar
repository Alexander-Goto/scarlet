     test([array 1, 2, 3, 4, 5].to_array__slice()[0, 1] === [array 1].to_array__slice())
     test([array 1, 2, 3, 4, 5].to_array__slice()[0, 2] === [array 1, 2].to_array__slice())
     test([array 1, 2, 3, 4, 5].to_array__slice()[0, 5] === [array 1, 2, 3, 4, 5].to_array__slice())
     test([array 1, 2, 3, 4, 5].to_array__slice()[1, 5] === [array 2, 3, 4, 5].to_array__slice())
     test([array 1, 2, 3, 4, 5].to_array__slice()[3, 5] === [array 4, 5].to_array__slice())

     test([array].to_custom_array__slice()[0, 0] === [array].to_custom_array__slice())
