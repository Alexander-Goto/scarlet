     test([array 1, 2, 3, 4, 5].to_custom_array__slice()[1, 5] === [array 2, 3, 4, 5].to_custom_array__slice())
     test([array 1, 2, 3, 4, 5].to_custom_array__slice()[3, 5] === [array 4, 5].to_custom_array__slice())

     let error_1    = expected_error(:1, heap_string(), heap_string())
     let error_2    = expected_error(:2, heap_string(), heap_string())
     let error_3    = expected_error(:7, heap_string(), heap_string())
     let heap_table = heap_table()
     test(error_1[0, 0].get_error_id() === :1)
     test(""[error_1, 0].get_error_id() === :1)
     test(""[0, error_1].get_error_id() === :1)
     test(error_1[0, error_2].get_error_id() === :1)
     test(error_2[0, error_1].get_error_id() === :2)
     test(""[error_1, error_2].get_error_id() === :1)
     test(""[error_2, error_1].get_error_id() === :2)
     test(error_1[error_2, error_3].get_error_id() === :1)
