     let [box array_1, array_2] = if (rnd() & 1) === 0 {
          let array_1 = rnd_string_array()
          let array_2 = if (rnd() & 1) === 0; array_1 else null
          [box array_1, array_2]
     } else [box [array 7, 2, 4, 1, "dfsdf", 0, -14, [table]], null]
     let len             = len(array_1)
     let from            = (rnd() >> 1) % (len + 1)
     let to              = from + (rnd() >> 1) % (len - from + 1)
     let expected_array  = array_1.foldl_kv([array], fn (expected_array, idx, item) if idx >= from && idx < to; expected_array.append(item) else expected_array)
     test(array_1[from, to] === expected_array)
     array_2.ignore()

     test([array].to_array__slice()[0, 0] === [array].to_array__slice())
     test([array 1].to_array__slice()[0, 0] === [array].to_array__slice())
