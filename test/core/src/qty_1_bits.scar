let num__qty_1_bits = [obj
     :value = 0

     :_ = [obj
          :core_qty_1_bits = fn (num) num:value.qty_1_bits()
     ]
]

fn to_num__qty_1_bits(arg) new (@main.num__qty_1_bits):value <= arg

fn to_custom_num__qty_1_bits(arg) custom__create(
     arg
     [obj
          :core_qty_1_bits = fn (num) num.custom__get_data().qty_1_bits()
     ]
)

let broken_num__qty_1_bits = [obj
     :value = 0

     :_ = [obj
          :core_qty_1_bits = fn (_) heap_string()
     ]
]

fn to_broken_num__qty_1_bits(arg) new (@main.broken_num__qty_1_bits):value <= arg

fn to_broken_custom_num__qty_1_bits(arg) custom__create(
     arg
     [obj
          :core_qty_1_bits = fn (_) heap_string()
     ]
)

let error_num__qty_1_bits = [obj
     :value = 0

     :_ = [obj
          :core_qty_1_bits = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__qty_1_bits(arg) new (@main.error_num__qty_1_bits):value <= arg

fn to_error_custom_num__qty_1_bits(arg) custom__create(
     arg
     [obj
          :core_qty_1_bits = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__qty_1_bits() {
     test(0.qty_1_bits() === 0)
     test(2.qty_1_bits() === 1)
     test(9223372036854775806.qty_1_bits() === 62)
     test(-2.qty_1_bits() === 63)
     test(-9223372036854775808.qty_1_bits() === 1)
     test(1.qty_1_bits() === 1)
     test(3.qty_1_bits() === 2)
     test(9223372036854775807.qty_1_bits() === 63)
     test(-1.qty_1_bits() === 64)
     test(-3.qty_1_bits() === 63)
     test(-9223372036854775807.qty_1_bits() === 2)
     test(0x5555'55ff'ffff'aaaa.qty_1_bits() === 44)

     let int      = rnd()
     let expected = loop([box 0, int], fn (state) {
          let [box result, int] = state

          if int === 0
               [breaker result]
          else [box result + (int & 1), int >> 1]
     })
     test(expected === int.qty_1_bits())

     test(0b00.qty_1_bits() === 0)
     test(0b02.qty_1_bits() === 1)
     test(0bfe.qty_1_bits() === 7)
     test(0b01.qty_1_bits() === 1)
     test(0b03.qty_1_bits() === 2)
     test(0bff.qty_1_bits() === 8)

     let byte     = rnd_byte()
     let expected = loop([box 0, byte.to_int()], fn (state) {
          let [box result, byte] = state

          if byte === 0
               [breaker result]
          else [box result + (byte & 1), byte >> 1]
     })
     test(expected === byte.qty_1_bits())

     test(to_num__qty_1_bits(0x5555'55ff'ffff'aaaa).qty_1_bits() === 44)
     test(to_num__qty_1_bits(11).qty_1_bits() === 3)
     test(to_num__qty_1_bits(17).qty_1_bits() === 2)

     test(to_custom_num__qty_1_bits(0x5555'55ff'ffff'aaaa).qty_1_bits() === 44)
     test(to_custom_num__qty_1_bits(11).qty_1_bits() === 3)
     test(to_custom_num__qty_1_bits(17).qty_1_bits() === 2)

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.qty_1_bits().get_error_id() === :1)
     test(heap_table().qty_1_bits().get_error_id() === :invalid_type)

     test(to_broken_num__qty_1_bits(0).qty_1_bits().get_error_id() === :invalid_type)
     test(to_broken_custom_num__qty_1_bits(0).qty_1_bits().get_error_id() === :invalid_type)
     test(to_error_num__qty_1_bits(0).qty_1_bits().get_error_id() === :3)
     test(to_error_custom_num__qty_1_bits(0).qty_1_bits().get_error_id() === :4)
}