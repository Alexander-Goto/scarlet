let char__ctrl = [obj
     :value = 0

     :_ = [obj
          :core_ctrl? = fn (char) char:value.ctrl?()
     ]
]

fn to_char__ctrl?(arg) new (@main.char__ctrl):value <= arg

fn to_custom_char__ctrl?(arg) custom__create(
     arg
     [obj
          :core_ctrl? = fn (char) char.custom__get_data().ctrl?()
     ]
)

let broken_char__ctrl = [obj
     :value = 0

     :_ = [obj
          :core_ctrl? = fn (_) heap_string()
     ]
]

fn to_broken_char__ctrl?(arg) new (@main.broken_char__ctrl):value <= arg

fn to_broken_custom_char__ctrl?(arg) custom__create(
     arg
     [obj
          :core_ctrl? = fn (_) heap_string()
     ]
)

let error_char__ctrl = [obj
     :value = 0

     :_ = [obj
          :core_ctrl? = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_char__ctrl?(arg) new (@main.error_char__ctrl):value <= arg

fn to_error_custom_char__ctrl?(arg) custom__create(
     arg
     [obj
          :core_ctrl? = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__ctrl?() {
     test('\000001'.ctrl?())
     test('\000002'.ctrl?())
     test('\000003'.ctrl?())
     test('\000004'.ctrl?())
     test('\000005'.ctrl?())
     test('\000006'.ctrl?())
     test('\000007'.ctrl?())
     test('\000008'.ctrl?())
     test(not '\000009'.ctrl?())
     test('\00000a'.ctrl?())
     test('\00000b'.ctrl?())
     test('\00000c'.ctrl?())
     test('\00000d'.ctrl?())
     test('\00000e'.ctrl?())
     test('\00000f'.ctrl?())
     test('\000010'.ctrl?())
     test('\000011'.ctrl?())
     test('\000012'.ctrl?())
     test('\000013'.ctrl?())
     test('\000014'.ctrl?())
     test('\000015'.ctrl?())
     test('\000016'.ctrl?())
     test('\000017'.ctrl?())
     test('\000018'.ctrl?())
     test('\000019'.ctrl?())
     test('\00001a'.ctrl?())
     test('\00001b'.ctrl?())
     test('\00001c'.ctrl?())
     test('\00001d'.ctrl?())
     test('\00001e'.ctrl?())
     test('\00001f'.ctrl?())
     test(not '\000020'.ctrl?())
     test(not 'a'.ctrl?())
     test(not 'z'.ctrl?())
     test(not '\00008b'.ctrl?())

     let string = rnd_string()
     test(string.filter(fn (char) char.in_range?('\000001', '\000009') || char.in_range?('\00000a', '\000020') || char === '\00007f') === string.filter(ctrl?(_)))

     test(to_char__ctrl?('\000001').ctrl?())
     test(not to_char__ctrl?('\000009').ctrl?())

     test(to_custom_char__ctrl?('\000001').ctrl?())
     test(not to_custom_char__ctrl?('\000009').ctrl?())

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.ctrl?().get_error_id() === :1)
     test(heap_table().ctrl?().get_error_id() === :invalid_type)

     test(to_broken_char__ctrl?('a').ctrl?().get_error_id() === :invalid_type)
     test(to_broken_custom_char__ctrl?('a').ctrl?().get_error_id() === :invalid_type)
     test(to_error_char__ctrl?('a').ctrl?().get_error_id() === :3)
     test(to_error_custom_char__ctrl?('a').ctrl?().get_error_id() === :4)
}