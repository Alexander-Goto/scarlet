     arg
     [obj
          :core_self_copy = fn (array, from, to, len) to_custom_array__self_copy(array.custom__get_data().self_copy(from, to, len))
          :core___equal__ = fn (array_1, array_2) array_1.custom__get_data() === array_2.custom__get_data()
