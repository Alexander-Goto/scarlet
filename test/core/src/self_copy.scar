     test([array].self_copy(0, 0, 1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array].self_copy(-1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array].self_copy(-1.scarlet__erase_info(), 0, 0).get_error_id() === :out_of_bounds)
     test([array].self_copy(1.scarlet__erase_info(), 1.scarlet__erase_info(), -1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array].self_copy(-9223372036854775808.scarlet__erase_info(), -9223372036854775808.scarlet__erase_info(), -9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(-9223372036854775808.scarlet__erase_info(), 0, 0).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(2, 0, 0).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(9223372036854775807.scarlet__erase_info(), 0, 0).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(0, -1.scarlet__erase_info(), 0).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(0, -9223372036854775808.scarlet__erase_info(), 0).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(0, 2.scarlet__erase_info(), 0).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(0, 9223372036854775807.scarlet__erase_info(), 0).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(0, 0, -1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(0, 0, -9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(0, 0, 2).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(-1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(1, 1, -1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].self_copy(-9223372036854775808.scarlet__erase_info(), -9223372036854775808.scarlet__erase_info(), -9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)

     let error_1     = expected_error(:1, heap_string(), heap_string())
     let error_2     = expected_error(:2, heap_string(), heap_string())
     let error_3     = expected_error(:3, heap_string(), heap_string())
     let error_4     = expected_error(:4, heap_string(), heap_string())
     test(error_1.self_copy(0, 0, 0).get_error_id() === :1)
     test(heap_string().self_copy(error_1, 0, 0).get_error_id() === :1)
     test(heap_string().self_copy(0, error_1, 0).get_error_id() === :1)
     test(heap_string().self_copy(0, 0, error_1).get_error_id() === :1)
     test(error_1.self_copy(error_2, error_3, error_4).get_error_id() === :1)
     test(error_4.self_copy(error_3, error_2, error_1).get_error_id() === :4)
     test(error_1.self_copy(heap_string(), heap_string(), heap_string()).get_error_id() === :1)
     test(heap_table().self_copy(error_1, heap_string(), heap_string()).get_error_id() === :1)
     test(heap_table().self_copy(heap_string(), error_1, heap_string()).get_error_id() === :1)
     test(heap_table().self_copy(heap_string(), heap_string(), error_1).get_error_id() === :1)

     test(heap_table().self_copy(heap_string(), heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(heap_table().self_copy(0, 0, 0).get_error_id() === :invalid_type)
     test(heap_string().self_copy(heap_string(), 0, 0).get_error_id() === :invalid_type)
     test(heap_string().self_copy(0, heap_string(), 0).get_error_id() === :invalid_type)
     test(heap_string().self_copy(0, 0, heap_string()).get_error_id() === :invalid_type)

     test(to_broken_array__self_copy([array heap_string()]).self_copy(0, 0, 0).get_error_id() === :invalid_type)
     test(to_broken_custom_array__self_copy([array heap_string()]).self_copy(0, 0, 0).get_error_id() === :invalid_type)
     test(to_error_array__self_copy([array heap_string()]).self_copy(0, 0, 0).get_error_id() === :3)
     test(to_error_custom_array__self_copy([array heap_string()]).self_copy(0, 0, 0).get_error_id() === :4)
}
