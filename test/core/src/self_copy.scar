let array__self_copy = [obj
     :value = [array]

     :_ = [obj
          :core_self_copy = fn (array, from, to, len) to_array__self_copy(array:value.self_copy(from, to, len))
          :core___equal__ = fn (array_1, array_2) array_1:value === array_2:value
     ]
]

fn to_array__self_copy(arg) new (@main.array__self_copy):value <= arg

