`noinline`
fn test__short_type?() {
     test("".short_type?())
     test("0".short_type?())
     test("01".short_type?())
     test("012".short_type?())
     test("0123".short_type?())
     test("01234".short_type?())
     test("012345".short_type?())
     test("0123456".short_type?())
     test("01234567".short_type?())
     test("012345678".short_type?())
     test("0123456789".short_type?())
     test("0123456789a".short_type?())
     test("0123456789ab".short_type?())
     test("0123456789abc".short_type?())
     test("0123456789abcd".short_type?())
     test("0123456789abcde".short_type?())
     test("0123456789abcde".short_type?())
     test("\000090".short_type?())
     test("\000090\000090".short_type?())
     test("\000090\000090\000090".short_type?())
     test("\000090\000090\000090\000090".short_type?())
     test("\000090\000090\000090\000090\000090".short_type?())
     test("\000090\000090\000090\000090\000090\000090".short_type?())
     test("\000090\000090\000090\000090\000090\000090\000090".short_type?())
     test("\000090\000090\000090\000090\000090\000090\0000901".short_type?())
     test(not "0123456789abcdef".short_type?())
     test(not ("0123456789abcde" ++ "f").short_type?())
     test(not "\000090\000090\000090\000090\000090\000090\000090\000090".short_type?())

     test(expected_error(:1, heap_string(), heap_string()).short_type?().get_error_id() === :1)
     test(heap_table().short_type?().get_error_id() === :invalid_type)
}
