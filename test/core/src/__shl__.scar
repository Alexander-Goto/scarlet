     test((9223372036854775807 << 17) === -131072)
     test((9223372036854775807 << 62) === -4611686018427387904)
     test((9223372036854775807 << 63) === -9223372036854775808)
     test((9223372036854775807 << 64) === 0)

     test((0 << 0b00) === 0)
     test((0 << 0b01) === 0)
     test((1 << 0b00) === 1)
     test((1 << 0b01) === 2)
     test((-1 << 0b00) === -1)
     test((-1 << 0b01) === -2)
     test((-708044971986000615 << 0b03) === -5664359775888004920)
     test((-708044971986000615 << 0b3a) === 7205759403792793600)
     test((-708044971986000615 << 0b3b) === -4035225266123964416)
