     test((-9223372036854775808 << 0b00) === -9223372036854775808)
     test((-9223372036854775808 << 0b01) === 0)
     test((-9223372036854775808 << 0b3e) === 0)
     test((-9223372036854775808 << 0b3f) === 0)
     test((-9223372036854775808 << 0b40) === 0)
     test((9223372036854775807 << 0b00) === 9223372036854775807)
     test((9223372036854775807 << 0b01) === -2)
     test((9223372036854775807 << 0b11) === -131072)
     test((9223372036854775807 << 0b3e) === -4611686018427387904)
     test((9223372036854775807 << 0b3f) === -9223372036854775808)
     test((9223372036854775807 << 0b40) === 0)

     test((0b00 << 0) === 0b00)
     test((0b00 << 1) === 0b00)
     test((0b01 << 0) === 0b01)
     test((0b01 << 1) === 0b02)
     test((0bff << 0) === 0bff)
     test((0bff << 1) === 0bfe)
     test((0bff << 2) === 0bfc)
     test((0bff << 3) === 0bf8)
     test((0bff << 4) === 0bf0)
     test((0bff << 5) === 0be0)
     test((0bff << 6) === 0bc0)
     test((0bff << 7) === 0b80)
     test((0bff << 8) === 0b00)
     test((0b78 << 0) === 0b78)
     test((0b78 << 1) === 0bf0)
     test((0b78 << 2) === 0be0)
     test((0b78 << 3) === 0bc0)
     test((0b78 << 4) === 0b80)
     test((0b78 << 5) === 0b00)
     test((0b78 << 6) === 0b00)
     test((0b78 << 7) === 0b00)
     test((0b78 << 8) === 0b00)

     test((0b00 << 0b00) === 0b00)
     test((0b00 << 0b01) === 0b00)
     test((0b01 << 0b00) === 0b01)
     test((0b01 << 0b01) === 0b02)
     test((0bff << 0b00) === 0bff)
     test((0bff << 0b01) === 0bfe)
     test((0bff << 0b02) === 0bfc)
