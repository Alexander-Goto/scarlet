let num__shl = [obj
     :value = 0

     :_ = [obj
          :core___shl__   = fn (num, shifts) to_num__shl(num:value << shifts)
          :core___equal__ = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__shl(arg) new (@main.num__shl):value <= arg

fn to_custom_num__shl(arg) custom__create(
     arg
     [obj
          :core___shl__   = fn (num, shifts) to_custom_num__shl(num.custom__get_data() << shifts)
          :core___equal__ = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__shl = [obj
     :value = 0

     :_ = [obj
          :core___shl__ = fn (_, _) heap_string()
     ]
]

fn to_broken_num__shl(arg) new (@main.broken_num__shl):value <= arg

fn to_broken_custom_num__shl(arg) custom__create(
     arg
     [obj
          :core___shl__ = fn (_, _) heap_string()
     ]
)

let error_num__shl = [obj
     :value = 0

     :_ = [obj
          :core___shl__ = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__shl(arg) new (@main.error_num__shl):value <= arg

fn to_error_custom_num__shl(arg) custom__create(
     arg
     [obj
          :core___shl__ = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test____shl__() {
     test((0 << 0) === 0)
     test((0 << 1) === 0)
     test((1 << 0) === 1)
     test((1 << 1) === 2)
     test((-1 << 0) === -1)
     test((-1 << 1) === -2)
     test((-708044971986000615 << 3) === -5664359775888004920)
     test((-708044971986000615 << 58) === 7205759403792793600)
     test((-708044971986000615 << 59) === -4035225266123964416)
     test((-708044971986000615 << 60) === -8070450532247928832)
     test((-708044971986000615 << 61) === 2305843009213693952)
     test((-708044971986000615 << 62) === 4611686018427387904)
     test((-708044971986000615 << 63) === -9223372036854775808)
     test((-708044971986000615 << 64) === 0)
     test((-9223372036854775808 << 0) === -9223372036854775808)
     test((-9223372036854775808 << 1) === 0)
     test((-9223372036854775808 << 62) === 0)
     test((-9223372036854775808 << 63) === 0)
     test((-9223372036854775808 << 64) === 0)
     test((9223372036854775807 << 0) === 9223372036854775807)
