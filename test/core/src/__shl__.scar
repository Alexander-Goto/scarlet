     test((0bff << 0b06) === 0bc0)
     test((0bff << 0b07) === 0b80)
     test((0bff << 0b08) === 0b00)
     test((0b78 << 0b00) === 0b78)
     test((0b78 << 0b01) === 0bf0)
     test((0b78 << 0b02) === 0be0)
     test((0b78 << 0b03) === 0bc0)
     test((0b78 << 0b04) === 0b80)
     test((0b78 << 0b05) === 0b00)
     test((0b78 << 0b06) === 0b00)
     test((0b78 << 0b07) === 0b00)
     test((0b78 << 0b08) === 0b00)

     test((to_num__shl(0) << 0) === to_num__shl(0))
     test((to_num__shl(-708044971986000615) << 3) === to_num__shl(-5664359775888004920))

     test((to_custom_num__shl(0) << 0) === to_custom_num__shl(0))
     test((to_custom_num__shl(-708044971986000615) << 3) === to_custom_num__shl(-5664359775888004920))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let string  = heap_string()
     test((error_1 << 1).get_error_id() === :1)
     test((1 << error_1).get_error_id() === :1)
     test((error_1 << error_2).get_error_id() === :1)
     test((error_2 << error_1).get_error_id() === :2)
     test((error_1 << string).get_error_id() === :1)
     test((string << error_1).get_error_id() === :1)

     test((string << string).get_error_id() === :invalid_type)
     test((string << 1).get_error_id() === :invalid_type)
     test((1 << string).get_error_id() === :invalid_type)

     test((to_num__shl(1) << error_1).get_error_id() === :1)
