let num__acos = [obj
     :value = 0.0

     :_ = [obj
          :core_acos      = fn (num) to_num__acos(num:value.acos())
          :core___equal__ = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__acos(arg) new (@main.num__acos):value <= arg

fn to_custom_num__acos(arg) custom__create(
     arg
     [obj
          :core_acos      = fn (num) to_custom_num__acos(num.custom__get_data().acos())
          :core___equal__ = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__acos = [obj
     :value = 0.0

     :_ = [obj
          :core_acos = fn (_) heap_string()
     ]
]

fn to_broken_num__acos(arg) new (@main.broken_num__acos):value <= arg

fn to_broken_custom_num__acos(arg) custom__create(
     arg
     [obj
          :core_acos = fn (_) heap_string()
     ]
)

let error_num__acos = [obj
     :value = 0.0

     :_ = [obj
          :core_acos = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__acos(arg) new (@main.error_num__acos):value <= arg

fn to_error_custom_num__acos(arg) custom__create(
     arg
     [obj
          :core_acos = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__acos() {
     test(0.0.acos().in_range?(1.56, 1.58))
     test(-0.0.acos().in_range?(1.56, 1.58))
     test(0.1.acos().in_range?(1.46, 1.48))
     test(-0.1.acos().in_range?(1.66, 1.68))
     test(1.0.acos().in_range?(-0.01, 0.01))
     test(-1.0.acos().in_range?(3.13, 3.15))
     test(1.01.acos().nan?())
     test(-1.01.acos().nan?())
     test(inf().acos().nan?())
     test(neg_inf().acos().nan?())
     test(nan().acos().nan?())

     test(to_num__acos(0.0).acos():value.in_range?(1.56, 1.58))
     test(to_num__acos(-1.0).acos():value.in_range?(3.13, 3.15))

     test(to_custom_num__acos(0.0).acos().custom__get_data().in_range?(1.56, 1.58))
     test(to_custom_num__acos(-1.0).acos().custom__get_data().in_range?(3.13, 3.15))

     let error = expected_error(:1, heap_string(), heap_string())
     let string  = heap_string()
     test(error.acos().get_error_id() === :1)
     test(string.acos().get_error_id() === :invalid_type)

     test(to_broken_num__acos(1.0).acos().get_error_id() === :invalid_type)
     test(to_broken_custom_num__acos(1.0).acos().get_error_id() === :invalid_type)
     test(to_error_num__acos(1.0).acos().get_error_id() === :3)
     test(to_error_custom_num__acos(1.0).acos().get_error_id() === :4)
}