     let big_table = loop([table], fn (table) {
          let len           = len(table)
          let len_as_string = len.to_string()
          let table         = new (table)["1113456789abcde" ++ len_as_string] <= "0123456789abcde" ++ len_as_string
          break(len == 10, table)
     })
     test(([table] == [table]))
     test(([table 1 = 10] == [table 1 = 10]))
     test(([table 1 = 10, 2 = 30] == [table 1 = 10, 2 = 30]))
     test(not ([table 1 = 10] == [table]))
     test(not ([table 1 = 10] == [table 1 = 10, 2 = 9]))
