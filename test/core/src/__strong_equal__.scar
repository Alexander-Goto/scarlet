     test(not ("\0000b2\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3" == "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3"))
