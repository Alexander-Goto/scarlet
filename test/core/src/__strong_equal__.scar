     test(not ([array 2.scarlet__erase_info(), 1].to_const__strong_equal() == [array 1.scarlet__erase_info(), 2].to_const__strong_equal()))

     test(([array].to_custom_const__strong_equal() == [array].to_custom_const__strong_equal()))
     test(([array 10.scarlet__erase_info()].to_custom_const__strong_equal() == [array 10.scarlet__erase_info()].to_custom_const__strong_equal()))
     test(([array 1.scarlet__erase_info(), 2].to_custom_const__strong_equal() == [array 1, 2.scarlet__erase_info()].to_custom_const__strong_equal()))
     test(not ([array 1.scarlet__erase_info()].to_custom_const__strong_equal() == [array].to_custom_const__strong_equal()))
     test(not ([array 1.scarlet__erase_info()].to_custom_const__strong_equal() == [array 1.scarlet__erase_info(), 2].to_custom_const__strong_equal()))
     test(not ([array 1.scarlet__erase_info(), 2].to_custom_const__strong_equal() == [array 1.scarlet__erase_info()].to_custom_const__strong_equal()))
     test(not ([array 2.scarlet__erase_info(), 1].to_custom_const__strong_equal() == [array 1.scarlet__erase_info(), 2].to_custom_const__strong_equal()))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let string  = heap_string()
     let obj     = [obj :1 = string]
     test((error_1 == error_2).get_error_id() == :1)
     test((error_2 == error_1).get_error_id() == :2)
     test((error_1 == string).get_error_id() == :1)
     test((string == error_1).get_error_id() == :1)
     test((error_1 == null.scarlet__erase_info()).get_error_id() == :1)
     test((null.scarlet__erase_info() == error_1).get_error_id() == :1)
     test((string == obj).get_error_id() == :invalid_type)
     test((obj == string).get_error_id() == :invalid_type)
     test((obj == obj).get_error_id() == :invalid_type)
     test((string == null.scarlet__erase_info()).get_error_id() == :invalid_type)
     test((null.scarlet__erase_info() == null.scarlet__erase_info()).get_error_id() == :invalid_type)
