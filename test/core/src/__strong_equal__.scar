          "1113456789abcde7"  = "0123456789abcde7"
          "1113456789abcde9"  = "0123456789abcde9"
     ]))
     test(not (big_table == new (big_table)["1113456789abcde0"] <= null))

     let big_set = loop([set], fn (set) {
          let len           = len(set)
          let len_as_string = len.to_string()
          let set           = set.append("0123456789abcde" ++ len_as_string)
          break(len == 10, set)
     })
     test(([set] == [set]))
     test(([set 10] == [set 10]))
     test(([set 1, 2] == [set 1, 2]))
     test(not ([set 1] == [set]))
     test(not ([set 1] == [set 1, 2]))
     test(not ([set 1, 2] == [set 1]))
     test((big_set == big_set))
     test((big_set == [set
          "0123456789abcde0"
          "0123456789abcde3"
          "0123456789abcde9"
          "0123456789abcde4"
          "0123456789abcde5"
          "0123456789abcde6"
          "0123456789abcde7"
          "0123456789abcde10"
          "0123456789abcde1"
          "0123456789abcde2"
          "0123456789abcde8"
     ]))
     test(not (big_set == big_set.remove("0123456789abcde0")))

     let big_array = loop([array], fn (array) {
          let len           = len(array)
          let len_as_string = len.to_string()
          let array         = array.append("0123456789abcde" ++ len_as_string)
          break(len == 10, array)
     })
     test(([array] == [array]))
     test(([array 10] == [array 10]))
     test(([array 1, 2] == [array 1, 2]))
     test(not ([array 1] == [array]))
     test(not ([array 1] == [array 1, 2]))
     test(not ([array 1, 2] == [array 1]))
     test(not ([array 2, 1] == [array 1, 2]))
     test((big_array == big_array))
     test((big_array == [array
          "0123456789abcde0"
          "0123456789abcde1"
          "0123456789abcde2"
          "0123456789abcde3"
          "0123456789abcde4"
          "0123456789abcde5"
          "0123456789abcde6"
          "0123456789abcde7"
          "0123456789abcde8"
          "0123456789abcde9"
          "0123456789abcde10"
     ]))
     test(not (big_array == big_array.drop(1)))

     let string = heap_string()
     test(not ([array 1, string] == [array string, 1]))
     test([array 1, string] == [array 1, string])
     test(not ([box 1, string] == [box string, 1]))
     test([box 1, string] == [box 1, string])
     test(not ([box null, string] == [box string, null]))
     test(not ([box null, string] == [box null, string]))
     test(not ([set 2, string] == [set string, 1]))
     test([set 1, string] == [set 1, string])
     test(not ([table 1 = 2, string = 3] == [table 3 = string, 2 = 1]))
     test([table 1 = 2, string = 3] == [table 1 = 2, string = 3])

     test(([array].to_const__strong_equal() == [array].to_const__strong_equal()))
     test(([array 10.scarlet__erase_info()].to_const__strong_equal() == [array 10.scarlet__erase_info()].to_const__strong_equal()))
     test(([array 1.scarlet__erase_info(), 2].to_const__strong_equal() == [array 1, 2.scarlet__erase_info()].to_const__strong_equal()))
     test(not ([array 1.scarlet__erase_info()].to_const__strong_equal() == [array].to_const__strong_equal()))
     test(not ([array 1.scarlet__erase_info()].to_const__strong_equal() == [array 1.scarlet__erase_info(), 2].to_const__strong_equal()))
