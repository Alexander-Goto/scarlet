`noinline`
fn test__scarlet__erase_info() {
     test(rnd_string().scarlet__erase_info().type() === "core.string")
     test(rnd_byte_array().scarlet__erase_info().type() === "core.byte_array")
     test(null.scarlet__erase_info().type() === "core.null")
     test(rnd_token().scarlet__erase_info().type() === "core.token")
     test(true.scarlet__erase_info().type() === "core.bool")
     test(false.scarlet__erase_info().type() === "core.bool")
     test(rnd_byte().scarlet__erase_info().type() === "core.byte")
     test(rnd_char().scarlet__erase_info().type() === "core.char")
     test(rnd().scarlet__erase_info().type() === "core.int")
     test((rnd() >> 2).int_to_time().scarlet__erase_info().type() === "core.time")
     test(rnd_float().scarlet__erase_info().type() === "core.float")
     test((_ ++ _).scarlet__erase_info().type() === "core.fn")
     test((heap_string() ++ _).scarlet__erase_info().type() === "core.fn")
     test([box].scarlet__erase_info().type() === "core.box")
     test([box heap_string()].scarlet__erase_info().type() === "core.box")
     test(rnd_string_array().scarlet__erase_info().type() === "core.array")
     test(rnd_string_obj().scarlet__erase_info().type() === "core.obj")
     test(rnd_string_table().scarlet__erase_info().type() === "core.table")
     test(thread(fn () heap_string()).scarlet__erase_info().type() === "core.thread")
     test(make_channel()[0].scarlet__erase_info().type() === "core.channel")
     test(custom__create(heap_string(), [obj]).scarlet__erase_info().type() === "main.custom")
     test([array expected_error(:1, heap_string(), heap_string()).scarlet__erase_info()].get_error_id() === :1)
     test([array null.scarlet__erase_info()].get_error_id() === :invalid_type)
}