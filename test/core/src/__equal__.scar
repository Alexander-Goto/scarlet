     test(not ([array [obj :1 = 10]] === [array [obj :1 = 9]]))
     test(not ([array [obj :1 = 10, :2 = 9]] === [array [obj :1 = 10, :2 = 10]]))
     test(not ([array [obj :1 = 10, :2 = 9]] === [array [obj :1 = 9, :2 = 9]]))
     test(not ([array [obj :1 = 10, :2 = 9]] === [array [obj :1 = 7, :2 = 7]]))
     test((big_obj === big_obj))
     test((big_obj === [array [obj
          :3  = "0123456789abcde3"
