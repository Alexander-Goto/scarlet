     let big_obj = [array loop([obj], fn (obj) {
          let len           = len(obj)
          let len_as_string = len.to_string()
          let obj           = new (obj)[len_as_string.str_to_tkn()] <= "0123456789abcde" ++ len_as_string
          break(len === 10, obj)
     })]
     test(([array [obj]] === [array [obj]]))
     test(([array [obj :1 = 10]] === [array [obj :1 = 10]]))
