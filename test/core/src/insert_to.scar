     test([array heap_string()].insert_to([array].init(10), -9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].insert_to([array heap_string()], 2.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].insert_to([array heap_string()], 9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].insert_to([array heap_string()], -1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].insert_to([array heap_string()], -9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let error_3 = expected_error(:3, heap_string(), heap_string())
     test(error_1.insert_to(heap_string(), 0).get_error_id() === :1)
     test('1'.insert_to(error_1, 0).get_error_id() === :1)
     test('1'.insert_to(heap_string(), error_1).get_error_id() === :1)
     test(error_1.insert_to(error_2, error_3).get_error_id() === :1)
     test(error_3.insert_to(error_2, error_1).get_error_id() === :3)
     test(error_1.insert_to(heap_table(), heap_table()).get_error_id() === :1)
     test(heap_table().insert_to(error_1, heap_table()).get_error_id() === :1)
     test(heap_table().insert_to(heap_table(), error_1).get_error_id() === :1)

     test(heap_string().insert_to(heap_byte_array(), 0).get_error_id() === :invalid_type)
     test(heap_byte_array().insert_to(heap_string(), 0).get_error_id() === :invalid_type)
     test(heap_table().insert_to(heap_table(), 0).get_error_id() === :invalid_type)
     test(heap_string().insert_to(heap_string(), heap_table()).get_error_id() === :invalid_type)
     test(heap_table().insert_to(heap_table(), heap_table()).get_error_id() === :invalid_type)
     test(heap_string().insert_to(heap_string(), 0).get_error_id() === :invalid_type)
     test(heap_byte_array().insert_to(heap_byte_array(), 0).get_error_id() === :invalid_type)
     test("".insert_to(heap_string(), 0).get_error_id() === :invalid_type)
     test(u"".insert_to(heap_byte_array(), 0).get_error_id() === :invalid_type)
     test(heap_string().insert_to("", 0).get_error_id() === :invalid_type)
     test(heap_byte_array().insert_to(u"", 0).get_error_id() === :invalid_type)
     test("".insert_to("".scarlet__erase_info(), 0).get_error_id() === :invalid_type)
     test(u"".insert_to(u"".scarlet__erase_info(), 0).get_error_id() === :invalid_type)
     test([box heap_string()].scarlet__erase_info().insert_to([array].init(10), 0).get_error_id() === :invalid_type)
     test(null.scarlet__erase_info().insert_to([array].init(10), 0).get_error_id() === :invalid_type)
     test([box heap_string()].scarlet__erase_info().insert_to("".to_error_array__insert_to(), 0).get_error_id() === :invalid_type)
     test(null.scarlet__erase_info().insert_to("".to_error_array__insert_to(), 0).get_error_id() === :invalid_type)
     test([box heap_string()].scarlet__erase_info().insert_to("".to_error_custom_array__insert_to(), 0).get_error_id() === :invalid_type)
     test(null.scarlet__erase_info().insert_to("".to_error_custom_array__insert_to(), 0).get_error_id() === :invalid_type)

     test('1'.insert_to(to_broken_array__insert_to(""), 0).get_error_id() === :invalid_type)
     test('1'.insert_to(to_broken_custom_array__insert_to(""), 0).get_error_id() === :invalid_type)
     test('1'.insert_to(to_error_array__insert_to(""), 0).get_error_id() === :3)
     test('1'.insert_to(to_error_custom_array__insert_to(""), 0).get_error_id() === :4)
}
