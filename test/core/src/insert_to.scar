     test('f'.insert_to("0123456789abcde", 6) === "012345f6789abcde")
     test('f'.insert_to("0123456789abcde", 7) === "0123456f789abcde")
     test('f'.insert_to("0123456789abcde", 8) === "01234567f89abcde")
     test('f'.insert_to("0123456789abcde", 9) === "012345678f9abcde")
     test('f'.insert_to("0123456789abcde", 10) === "0123456789fabcde")
     test('f'.insert_to("0123456789abcde", 11) === "0123456789afbcde")
