     let string_5 = string_0 ++ "5"
     test([array].insert_to([array], 0) === [array [array]])
     test([array].init(10).insert_to([array].init(10), 0) === [array [array]])
     test([array 0].insert_to([array], 0) === [array [array 0]])
     test([array 0].insert_to([array].init(10), 0) === [array [array 0]])
     test([array].insert_to([array 0], 0) === [array [array], 0])
     test([array].init(10).insert_to([array 0], 0) === [array [array], 0])
     test([array 1, 2].insert_to([array 3, 4, 5], 0) === [array [array 1, 2], 3, 4, 5])
     test([array 1, 2].insert_to([array 3, 4, 5], 1) === [array 3, [array 1, 2], 4, 5])
     test([array 1, 2].insert_to([array 3, 4, 5], 2) === [array 3, 4, [array 1, 2], 5])
     test([array 1, 2].insert_to([array 3, 4, 5], 3) === [array 3, 4, 5, [array 1, 2]])

