     test('g'.insert_to("0123456789abcdef", 12) === "0123456789abgcdef")
     test('g'.insert_to("0123456789abcdef", 13) === "0123456789abcgdef")
     test('g'.insert_to("0123456789abcdef", 14) === "0123456789abcdgef")
     test('g'.insert_to("0123456789abcdef", 15) === "0123456789abcdegf")
     test('g'.insert_to("0123456789abcdef", 16) === "0123456789abcdefg")

     test('\000080'.insert_to("\0000901\000092\000093\00009456\000097\000098\000099\00009a\00009b\00009c\00009de\00009f", 0) === "\000080\0000901\000092\000093\00009456\000097\000098\000099\00009a\00009b\00009c\00009de\00009f")
