`noinline`
fn test__insert_to() {
     test('1'.insert_to("", 0) === "1")
     test('e'.insert_to("0123456789abcd", 0) === "e0123456789abcd")
     test('e'.insert_to("0123456789abcd", 1) === "0e123456789abcd")
     test('e'.insert_to("0123456789abcd", 2) === "01e23456789abcd")
     test('e'.insert_to("0123456789abcd", 3) === "012e3456789abcd")
     test('e'.insert_to("0123456789abcd", 4) === "0123e456789abcd")
     test('e'.insert_to("0123456789abcd", 5) === "01234e56789abcd")
     test('e'.insert_to("0123456789abcd", 6) === "012345e6789abcd")
     test('e'.insert_to("0123456789abcd", 7) === "0123456e789abcd")
     test('e'.insert_to("0123456789abcd", 8) === "01234567e89abcd")
     test('e'.insert_to("0123456789abcd", 9) === "012345678e9abcd")
     test('e'.insert_to("0123456789abcd", 10) === "0123456789eabcd")
     test('e'.insert_to("0123456789abcd", 11) === "0123456789aebcd")
     test('e'.insert_to("0123456789abcd", 12) === "0123456789abecd")
     test('e'.insert_to("0123456789abcd", 13) === "0123456789abced")
     test('e'.insert_to("0123456789abcd", 14) === "0123456789abcde")

     test('f'.insert_to("0123456789abcde", 0) === "f0123456789abcde")
     test('f'.insert_to("0123456789abcde", 1) === "0f123456789abcde")
     test('f'.insert_to("0123456789abcde", 2) === "01f23456789abcde")
