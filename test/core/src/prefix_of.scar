let array__prefix_of = [obj
     :value = [array]

     :_ = [obj
          :core_prefix_of? = fn (prefix, array) prefix:value.prefix_of?(array:value)
     ]
]

fn to_array__prefix_of(arg) new (@main.array__prefix_of):value <= arg

fn to_custom_array__prefix_of(arg) custom__create(
     arg
     [obj
          :core_prefix_of? = fn (prefix, array) prefix.custom__get_data().prefix_of?(array.custom__get_data())
     ]
)

let broken_array__prefix_of = [obj
     :value = [array]

     :_ = [obj
          :core_prefix_of? = fn (_, _) heap_string()
     ]
]

fn to_broken_array__prefix_of(arg) new (@main.broken_array__prefix_of):value <= arg

fn to_broken_custom_array__prefix_of(arg) custom__create(
     arg
     [obj
          :core_prefix_of? = fn (_, _) heap_string()
     ]
)

let error_array__prefix_of = [obj
     :value = [array]

     :_ = [obj
          :core_prefix_of? = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__prefix_of(arg) new (@main.error_array__prefix_of):value <= arg

fn to_error_custom_array__prefix_of(arg) custom__create(
     arg
     [obj
          :core_prefix_of? = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__prefix_of?() {
     test("".prefix_of?(""))
     test(not "1".prefix_of?(""))
     test("".prefix_of?("a"))
     test("1".prefix_of?("1"))
     test(not "1".prefix_of?("2"))
     test(not "2".prefix_of?("1"))
     test(not "12".prefix_of?("1"))
     test("".prefix_of?("122333444455555"))
     test("1".prefix_of?("122333444455555"))
     test(not "2".prefix_of?("122333444455555"))
     test(not "3".prefix_of?("122333444455555"))
     test(not "4".prefix_of?("122333444455555"))
     test(not "5".prefix_of?("122333444455555"))
     test(not "6".prefix_of?("122333444455555"))
     test("1223".prefix_of?("122333444455555"))
     test("122333444455555".prefix_of?("122333444455555"))
     test(not "123".prefix_of?("122333444455555"))
     test(not "1224".prefix_of?("122333444455555"))
     test(not "122333444455554".prefix_of?("122333444455555"))
     test(not "022333444455555".prefix_of?("122333444455555"))
     test(not "22333444455555".prefix_of?("122333444455555"))

     test(not "1223334444555555".prefix_of?("122333444455555"))
     test(not heap_string().prefix_of?("122333444455555"))

     let string = ("0122333444455555666666" ++ "0")[1, 22]
     test("".prefix_of?(string))
     test("1".prefix_of?(string))
     test("12".prefix_of?(string))
     test("122".prefix_of?(string))
     test("1223".prefix_of?(string))
     test("12233".prefix_of?(string))
     test("122333".prefix_of?(string))
     test("122333444455555666666".prefix_of?(string))
     test(string.prefix_of?(string))
     test(not "2".prefix_of?(string))
     test(not "3".prefix_of?(string))
     test(not "4".prefix_of?(string))
     test(not "5".prefix_of?(string))
     test(not "6".prefix_of?(string))
     test(not "7".prefix_of?(string))
     test(not "65".prefix_of?(string))
     test(not "54".prefix_of?(string))
     test(not "35".prefix_of?(string))
     test(not "01".prefix_of?(string))
     test(not "60".prefix_of?(string))
     test(not "11".prefix_of?(string))
     test(not "122333444455556".prefix_of?(string))
     test(not "22333444455555".prefix_of?(string))
     test(not "1223334444555556666666".prefix_of?(string))
     test(not "1223334444555556666661".prefix_of?(string))
     test(not "223334444555556666661".prefix_of?(string))

     let string = rnd_string()
     let prefix = if rnd_bool()
          rnd_string()
     else string.take((rnd() & 0xffff'ffff) % len(string))
     test((if len(prefix) > len(string); false else string.take(len(prefix)) === prefix) === prefix.prefix_of?(string))

     test(u"".prefix_of?(u""))
     test(not u"1".prefix_of?(u""))
     test(u"".prefix_of?(u"a"))
     test(u"1".prefix_of?(u"1"))
     test(not u"1".prefix_of?(u"2"))
     test(not u"2".prefix_of?(u"1"))
     test(not u"12".prefix_of?(u"1"))
     test(u"".prefix_of?(u"12233344445555"))
     test(u"1".prefix_of?(u"12233344445555"))
     test(not u"2".prefix_of?(u"12233344445555"))
     test(not u"3".prefix_of?(u"12233344445555"))
     test(not u"4".prefix_of?(u"12233344445555"))
     test(not u"5".prefix_of?(u"12233344445555"))
     test(not u"6".prefix_of?(u"12233344445555"))
     test(u"1223".prefix_of?(u"12233344445555"))
     test(u"12233344445555".prefix_of?(u"12233344445555"))
     test(not u"123".prefix_of?(u"12233344445555"))
     test(not u"1224".prefix_of?(u"12233344445555"))
     test(not u"12233344445554".prefix_of?(u"12233344445555"))
     test(not u"02233344445555".prefix_of?(u"12233344445555"))
     test(not u"2233344445555".prefix_of?(u"12233344445555"))

     test(not u"122333444455555".prefix_of?(u"12233344445555"))
     test(not heap_byte_array().prefix_of?(u"12233344445555"))

     let string = (u"0122333444455555666666" ++ u"0")[1, 22]
     test(u"".prefix_of?(string))
     test(u"1".prefix_of?(string))
     test(u"12".prefix_of?(string))
     test(u"122".prefix_of?(string))
     test(u"1223".prefix_of?(string))
     test(u"12233".prefix_of?(string))
     test(u"122333".prefix_of?(string))
     test(u"122333444455555666666".prefix_of?(string))
     test(string.prefix_of?(string))
     test(not u"2".prefix_of?(string))
     test(not u"3".prefix_of?(string))
     test(not u"4".prefix_of?(string))
     test(not u"5".prefix_of?(string))
     test(not u"6".prefix_of?(string))
     test(not u"7".prefix_of?(string))
     test(not u"65".prefix_of?(string))
     test(not u"54".prefix_of?(string))
     test(not u"35".prefix_of?(string))
     test(not u"01".prefix_of?(string))
     test(not u"60".prefix_of?(string))
     test(not u"11".prefix_of?(string))
     test(not u"122333444455556".prefix_of?(string))
     test(not u"22333444455555".prefix_of?(string))
     test(not u"1223334444555556666666".prefix_of?(string))
     test(not u"1223334444555556666661".prefix_of?(string))
     test(not u"223334444555556666661".prefix_of?(string))

     let array = rnd_byte_array()
     let prefix = if rnd_bool()
          rnd_byte_array()
     else array.take((rnd() & 0xffff'ffff) % len(array))
     test((if len(prefix) > len(array); false else array.take(len(prefix)) === prefix) === prefix.prefix_of?(array))

     let string_6 = heap_string()
     let string_1 = string_6 ++ "1"
     let string_2 = string_6 ++ "2"
     let string_3 = string_6 ++ "3"
     let string_4 = string_6 ++ "4"
     let string_5 = string_6 ++ "5"
     test([array].prefix_of?([array]))
     test([array].init(10).prefix_of?([array].init(10)))
     test(not [array string_1].prefix_of?([array]))
     test(not [array string_1].prefix_of?([array].init(10)))
     test([array].prefix_of?([array string_1]))
     test([array string_1].prefix_of?([array string_1]))
     test(not [array string_1].prefix_of?([array string_2]))
     test(not [array string_2].prefix_of?([array string_1]))
     test(not [array string_1, string_2].prefix_of?([array string_1]))
     test([array].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test([array string_1].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_2].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_3].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_4].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_5].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_6].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test([array string_1, string_2, string_2, string_3].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_1, string_2, string_3].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_1, string_2, string_2, string_4].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_4].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_6, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5].prefix_of?([array string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_4, string_4, string_4, string_5, string_5, string_5, string_5, string_5]))
     test(not [array _ + _].prefix_of?([array _ + _]))

     let array = rnd_string_array()
     let prefix = if rnd_bool()
          rnd_string_array()
     else array.take((rnd() & 0xffff'ffff) % len(array))
     test((if len(prefix) > len(array); false else array.take(len(prefix)) === prefix) === prefix.prefix_of?(array))

     test("12".to_array__prefix_of().prefix_of?("123123".to_array__prefix_of()))
     test("".to_array__prefix_of().prefix_of?("123123".to_array__prefix_of()))
     test(not "23".to_array__prefix_of().prefix_of?("123123".to_array__prefix_of()))
     test("12".to_custom_array__prefix_of().prefix_of?("123123".to_custom_array__prefix_of()))
     test("".to_custom_array__prefix_of().prefix_of?("123123".to_custom_array__prefix_of()))
     test(not "23".to_custom_array__prefix_of().prefix_of?("123123".to_custom_array__prefix_of()))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.prefix_of?(heap_string()).get_error_id() === :1)
     test(heap_string().prefix_of?(error_1).get_error_id() === :1)
     test(error_1.prefix_of?(error_2).get_error_id() === :1)
     test(error_2.prefix_of?(error_1).get_error_id() === :2)

     test([box heap_string()].scarlet__erase_info().prefix_of?(heap_string()).get_error_id() === :invalid_type)
     test(heap_string().prefix_of?([box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test([box heap_string()].scarlet__erase_info().prefix_of?([box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)

     test([array].to_broken_array__prefix_of().prefix_of?(to_broken_array__prefix_of([array])).get_error_id() === :invalid_type)
     test([array].to_broken_custom_array__prefix_of().prefix_of?(to_broken_custom_array__prefix_of([array])).get_error_id() === :invalid_type)
     test([array].to_error_array__prefix_of().prefix_of?(to_error_array__prefix_of([array])).get_error_id() === :3)
     test([array].to_error_custom_array__prefix_of().prefix_of?(to_error_custom_array__prefix_of([array])).get_error_id() === :4)
}