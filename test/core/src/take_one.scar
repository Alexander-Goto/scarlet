let container__take_one = [obj
     :value = [table]

     :_ = [obj
          :core_take_one = fn (container) container:value.take_one()
     ]
]

fn to_container__take_one(arg) new (@main.container__take_one):value <= arg

fn to_custom_container__take_one(arg) custom__create(
     arg
     [obj
          :core_take_one = fn (container) custom__get_data(container).take_one()
     ]
)

let broken_container__take_one = [obj
     :value = [table]

     :_ = [obj
          :core_take_one = fn (_) [box heap_string()]
     ]
]

fn to_broken_container__take_one(arg) new (@main.broken_container__take_one):value <= arg

fn to_broken_custom_container__take_one(arg) custom__create(
     arg
     [obj
          :core_take_one = fn (_) [box heap_string()]
     ]
)

let error_container__take_one = [obj
     :value = [table]

     :_ = [obj
          :core_take_one = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_container__take_one(arg) new (@main.error_container__take_one):value <= arg

fn to_error_custom_container__take_one(arg) custom__create(
     arg
     [obj
          :core_take_one = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__take_one() {
     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     let string_3 = string_0 ++ "3"
     let string_4 = string_0 ++ "4"
     let string_5 = string_0 ++ "5"
     test([table].take_one().null?())
     test([table].init(10).take_one().null?())
     test([table string_0 = string_1].take_one() === string_1)
     test([table string_0 = string_1, string_2 = string_3, string_4 = string_5].take_one().in?([array string_1, string_3, string_5]))

     let table = rnd_string_table()
     test(table.take_one().in?(table))

     test([set].take_one().null?())
     test([set].init(10).take_one().null?())
     test([set string_1].take_one() === string_1)
     test([set string_1, string_3, string_5].take_one().in?([array string_1, string_3, string_5]))

     let set = rnd_string_set()
     test(set.take_one().key_of?(set))

     test([obj].take_one().null?())
     test([obj].init(10).take_one().null?())
     test([obj :_ = [obj :1 = string_1]].take_one().null?())
     test([obj :1 = string_1].take_one() === string_1)
     test([obj :1 = string_1, :_ = [obj]].take_one() === string_1)
     test([obj :1 = string_1, :3 = string_3, :5 = string_5].take_one().in?([array string_1, string_3, string_5]))
     test([obj :1 = string_1, :3 = string_3, :5 = string_5, :_ = [obj]].take_one().in?([array string_1, string_3, string_5]))

     let obj = rnd_string_obj()
     test(obj.take_one().in?(obj))

     test([table].to_container__take_one().take_one().null?())
     test([table 0 = 1].to_container__take_one().take_one() === 1)

     test([table].to_custom_container__take_one().take_one().null?())
     test([table 0 = 1].to_custom_container__take_one().take_one() === 1)

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.take_one().get_error_id() === :1)

     test(heap_string().take_one().get_error_id() === :invalid_type)

     test(to_broken_container__take_one([table]).take_one().get_error_id() === :invalid_type)
     test(to_broken_custom_container__take_one([table]).take_one().get_error_id() === :invalid_type)
     test(to_error_container__take_one([table]).take_one().get_error_id() === :3)
     test(to_error_custom_container__take_one([table]).take_one().get_error_id() === :4)
}