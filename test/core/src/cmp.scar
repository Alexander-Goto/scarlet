let const__cmp = [obj
     :value = 0

     :_ = [obj
          :core_cmp = fn (const_1, const_2) const_1:value.cmp(const_2:value)
     ]
]

fn to_const__cmp(arg) new (@main.const__cmp):value <= arg

fn to_custom_const__cmp(arg) custom__create(
     arg
     [obj
          :core_cmp = fn (const_1, const_2) const_1.custom__get_data().cmp(const_2.custom__get_data())
     ]
)

`noinline`
fn test__cmp() {
     test(cmp("", "") === :equal)
     test(cmp("0", "") === :great)
     test(cmp("", "0") === :less)
     test(cmp("1", "1") === :equal)
     test(cmp("0", "1") === :less)
     test(cmp("1", "0") === :great)
     test(cmp("11", "11") === :equal)
     test(cmp("11", "1") === :great)
     test(cmp("1", "11") === :less)
     test(cmp("0123456789abcde", "0123456789abcde") === :equal)
     test(cmp("1123456789abcde", "0123456789abcde") === :great)
     test(cmp("0123456789abcde", "1123456789abcde") === :less)
     test(cmp("0123456789abcdd", "0123456789abcde") === :less)
     test(cmp("0123456789abcde", "0123456789abcdd") === :great)
     test(cmp("0123456789abcd", "0123456789abcde") === :less)
     test(cmp("0123456789abcde", "0123456789abcd") === :great)
     test(cmp("", "0123456789abcde") === :less)
     test(cmp("0123456789abcde", "") === :great)
     test(cmp("\000091\0000b3\0000ab\0000a4\0000a7\0000b5", "\000091\0000b3\0000ab\0000a4\0000a7\0000b5") === :equal)
     test(cmp("\0000b2\0000b3\0000ab\0000a4\0000a7\0000b5", "\000091\0000b3\0000ab\0000a4\0000a7\0000b5") === :great)
     test(cmp("\000091\0000b3\0000ab\0000a4\0000a7\0000b5", "\000091\0000b3\0000ab\0000a4\0000a7") === :great)
     test(cmp("\000091\0000b3\0000ab\0000a4\0000a7\0000b5", "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 ") === :less)
     test(cmp("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 ", "\000091\0000b3\0000ab\0000a4\0000a7\0000b5") === :great)
     test(cmp("0123456789abcdef", "0123456789abcdef") === :equal)
     test(cmp("0123456789abcdef", "0123456789abcde") === :great)
     test(cmp("0123456789abcde", "0123456789abcdef") === :less)
     test(cmp("0123456789abcdef", "0123456789abcdefg") === :less)
     test(cmp("0123456789abcdefg", "0123456789abcdef") === :great)
     test(cmp("", "0123456789abcdef") === :less)
     test(cmp("0123456789abcdef", "") === :great)
     test(cmp("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3", "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3") === :equal)
     test(cmp("\0000b2\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3", "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3") === :great)
     test(cmp("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3", "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\000092") === :great)
     test(cmp("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3", "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3 ") === :less)
     test(cmp("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3 ", "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3") === :great)
     test(cmp("0123456789abcde" ++ "f", "0123456789abcdef") === :equal)
     test(cmp("0123456789abcde" ++ "f", "0123456789abcde") === :great)
     test(cmp("0123456789abcdef", "0123456789abcde" ++ "f") === :equal)
     test(cmp("0123456789abcde", "0123456789abcde" ++ "f") === :less)
     test(cmp("0123456789abcde" ++ "f", "0123456789abcde" ++ "f") === :equal)
     test(cmp("0123456789abcde" ++ "ff", "0123456789abcde" ++ "f") === :great)
     let string_1    = rnd_string()
     let string_2    = rnd_string()
     let short_len   = if len(string_1) < len(string_2); len(string_1) else len(string_2)
     let cmp_result  = loop(0, fn (idx) {
          if idx === short_len
               [breaker len(string_1).cmp(len(string_2))]
          else {
               let char_1 = string_1[idx]
               let char_2 = string_2[idx]
               if char_1 =/= char_2
                    [breaker char_1.cmp(char_2)]
               else idx + 1
          }
     })
     test(cmp(string_1, string_2) === cmp_result)

     test(cmp(null, null) === :not_equal)

     test(cmp(:_, :_) === :equal)
     test(cmp(:0, :_) === :less)
     test(cmp(:_, :0) === :great)
     test(cmp(:1, :1) === :equal)
     test(cmp(:0, :1) === :less)
     test(cmp(:1, :0) === :great)
     test(cmp(:11, :11) === :equal)
     test(cmp(:11, :1) === :great)
     test(cmp(:1, :11) === :less)
     test(cmp(:0123456789abcdefghijkl, :0123456789abcdefghijkl) === :equal)
     test(cmp(:1123456789abcdefghijkl, :0123456789abcdefghijkl) === :great)
     test(cmp(:0123456789abcdefghijkl, :1123456789abcdefghijkl) === :less)
     test(cmp(:0123456789abcdefghijkl, :0123456789abcdefghijkm) === :less)
     test(cmp(:0123456789abcdefghijkm, :0123456789abcdefghijkl) === :great)
     test(cmp(:1!, :1!) === :equal)
     test(cmp(:1!, :1) === :great)
     test(cmp(:1!, :1!!!) === :less)
     test(cmp(:1!, :1?) === :less)
     test(cmp(:1!!!, :1!!!) === :equal)
     test(cmp(:1!!!, :1) === :great)
     test(cmp(:1!!!, :1!) === :great)
     test(cmp(:1!!!, :1?) === :less)
     test(cmp(:1?, :1?) === :equal)
     test(cmp(:1?, :1) === :great)
     test(cmp(:1?, :1!) === :great)
     test(cmp(:1?, :1!!!) === :great)
     test(cmp(:0000000000000000000000, :0000000000000000000000) === :equal)
     test(cmp(:0000000000000000000000, :0000000000000000000000!) === :less)
     test(cmp(:0000000000000000000000!, :0000000000000000000000) === :great)
     test(cmp(:zzzzzzzzzzzzzzzzzzzzzz, :zzzzzzzzzzzzzzzzzzzzzz) === :equal)
     test(cmp(:zzzzzzzzzzzzzzzzzzzzzz, :zzzzzzzzzzzzzzzzzzzzzz!) === :less)
     test(cmp(:zzzzzzzzzzzzzzzzzzzzzz!, :zzzzzzzzzzzzzzzzzzzzzz) === :great)
     test(cmp(:0000000000000000000000, :zzzzzzzzzzzzzzzzzzzzzz) === :less)
     test(cmp(:zzzzzzzzzzzzzzzzzzzzzz, :0000000000000000000000) === :great)

     test(cmp(true, true) === :equal)
     test(cmp(false, false) === :equal)
     test(cmp(true, false) === :not_equal)
     test(cmp(false, true) === :not_equal)

     test(cmp(0b00, 0b00) === :equal)
     test(cmp(0bff, 0bff) === :equal)
     test(cmp(0bf0, 0bf0) === :equal)
     test(cmp(0b0f, 0b0f) === :equal)
     test(cmp(0b00, 0b01) === :less)
     test(cmp(0b01, 0b00) === :great)
     test(cmp(0b10, 0b01) === :great)
     test(cmp(0b01, 0b10) === :less)
     test(cmp(0b00, 0bff) === :less)
     test(cmp(0bff, 0b00) === :great)

     test(cmp('a', 'a') === :equal)
     test(cmp('z', 'z') === :equal)
     test(cmp('0', '0') === :equal)
     test(cmp('\00008b', '\00008b') === :equal)
     test(cmp('\00009b', '\00009b') === :equal)
     test(cmp('a', 'z') === :less)
     test(cmp('z', 'a') === :great)
     test(cmp('a', '0') === :great)
     test(cmp('0', 'a') === :less)
     test(cmp('a', '\0000ac') === :less)
     test(cmp('\0000ac', 'a') === :great)
     test(cmp('\00008b', '\0000ac') === :less)
     test(cmp('A', 'a') === :less)
     test(cmp('a', 'A') === :great)

     test(cmp(0, 0) === :equal)
     test(cmp(1, 1) === :equal)
     test(cmp(1654654, 1654654) === :equal)
     test(cmp(9223372036854775807, 9223372036854775807) === :equal)
     test(cmp(-1, -1) === :equal)
     test(cmp(-664654, -664654) === :equal)
     test(cmp(-9223372036854775808, -9223372036854775808) === :equal)
     test(cmp(0, 1) === :less)
     test(cmp(0, 1654654) === :less)
     test(cmp(0, 9223372036854775807) === :less)
     test(cmp(0, -1) === :great)
     test(cmp(0, -664654) === :great)
     test(cmp(0, -9223372036854775808) === :great)
     test(cmp(1, 1654654) === :less)
     test(cmp(1, 9223372036854775807) === :less)
     test(cmp(1, -1) === :great)
     test(cmp(1, -664654) === :great)
     test(cmp(1, -9223372036854775808) === :great)
     test(cmp(1654654, 9223372036854775807) === :less)
     test(cmp(1654654, -1) === :great)
     test(cmp(1654654, -664654) === :great)
     test(cmp(1654654, -9223372036854775808) === :great)
     test(cmp(9223372036854775807, -1) === :great)
     test(cmp(9223372036854775807, -664654) === :great)
     test(cmp(9223372036854775807, -9223372036854775808) === :great)
     test(cmp(-1, -664654) === :great)
     test(cmp(-1, -9223372036854775808) === :great)
     test(cmp(-664654, -9223372036854775808) === :great)
     test(cmp(-9223372036854775808, -664654) === :less)
     test(cmp(8, 9) === :less)
     test(cmp(8, 4) === :great)

     test(cmp(0.int_to_time(), 0.int_to_time()) === :equal)
     test(cmp(1.int_to_time(), 1.int_to_time()) === :equal)
     test(cmp(1654654.int_to_time(), 1654654.int_to_time()) === :equal)
     test(cmp(9223372036825516799.int_to_time(), 9223372036825516799.int_to_time()) === :equal)
     test(cmp(0.int_to_time(), 1.int_to_time()) === :less)
     test(cmp(0.int_to_time(), 1654654.int_to_time()) === :less)
     test(cmp(0.int_to_time(), 9223372036825516799.int_to_time()) === :less)
     test(cmp(1.int_to_time(), 1654654.int_to_time()) === :less)
     test(cmp(1.int_to_time(), 9223372036825516799.int_to_time()) === :less)
     test(cmp(1654654.int_to_time(), 9223372036825516799.int_to_time()) === :less)
     test(cmp(8.int_to_time(), 9.int_to_time()) === :less)
     test(cmp(8.int_to_time(), 4.int_to_time()) === :great)

     let float_1 = 0.0
     let float_2 = 1.0
     let float_3 = 654659.333
     let float_4 = inf()
     let float_5 = -0.0
     let float_6 = -1.0
     let float_7 = -654659.33
     let float_8 = neg_inf()
     test(cmp(float_1, float_1) === :equal)
     test(cmp(float_2, float_2) === :equal)
     test(cmp(float_3, float_3) === :equal)
     test(cmp(float_4, float_4) === :equal)
     test(cmp(float_5, float_5) === :equal)
     test(cmp(float_6, float_6) === :equal)
     test(cmp(float_7, float_7) === :equal)
     test(cmp(float_8, float_8) === :equal)
     test(cmp(float_1, float_2) === :less)
     test(cmp(float_1, float_3) === :less)
     test(cmp(float_1, float_4) === :less)
     test(cmp(float_1, float_5) === :equal)
     test(cmp(float_1, float_6) === :great)
     test(cmp(float_1, float_7) === :great)
     test(cmp(float_1, float_8) === :great)
     test(cmp(float_2, float_3) === :less)
     test(cmp(float_2, float_4) === :less)
     test(cmp(float_2, float_5) === :great)
     test(cmp(float_2, float_6) === :great)
     test(cmp(float_2, float_7) === :great)
     test(cmp(float_2, float_8) === :great)
     test(cmp(float_3, float_4) === :less)
     test(cmp(float_3, float_5) === :great)
     test(cmp(float_3, float_6) === :great)
     test(cmp(float_3, float_7) === :great)
     test(cmp(float_3, float_8) === :great)
     test(cmp(float_4, float_5) === :great)
     test(cmp(float_4, float_6) === :great)
     test(cmp(float_4, float_7) === :great)
     test(cmp(float_4, float_8) === :great)
     test(cmp(float_5, float_6) === :great)
     test(cmp(float_5, float_7) === :great)
     test(cmp(float_5, float_8) === :great)
     test(cmp(float_6, float_7) === :great)
     test(cmp(float_6, float_8) === :great)
     test(cmp(float_7, float_8) === :great)
     test(cmp(float_8, float_7) === :less)

     test(cmp(nan(), 1) === :not_equal)
     test(cmp(1, nan()) === :not_equal)
     test(cmp(nan(), nan()) === :nan_cmp)
     test(cmp(1.0, nan()) === :nan_cmp)
     test(cmp(nan(), 1.0) === :nan_cmp)

     test(cmp(u"", u"") === :equal)
     test(cmp(u"0", u"") === :great)
     test(cmp(u"", u"0") === :less)
     test(cmp(u"1", u"1") === :equal)
     test(cmp(u"0", u"1") === :less)
     test(cmp(u"1", u"0") === :great)
     test(cmp(u"11", u"11") === :equal)
     test(cmp(u"11", u"1") === :great)
     test(cmp(u"1", u"11") === :less)
     test(cmp(u"0123456789abcd", u"0123456789abcd") === :equal)
     test(cmp(u"1123456789abcd", u"0123456789abcd") === :great)
     test(cmp(u"0123456789abcd", u"1123456789abcd") === :less)
     test(cmp(u"0123456789abcd", u"0123456789abcc") === :great)
     test(cmp(u"0123456789abcc", u"0123456789abcd") === :less)
     test(cmp(u"0123456789abc", u"0123456789abcd") === :less)
     test(cmp(u"0123456789abcd", u"0123456789abc") === :great)
     test(cmp(u"", u"0123456789abcd") === :less)
     test(cmp(u"0123456789abcd", u"") === :great)
     test(cmp(u"0123456789abcde", u"0123456789abcde") === :equal)
     test(cmp(u"0123456789abcde", u"0123456789abcd") === :great)
     test(cmp(u"0123456789abcd", u"0123456789abcde") === :less)
     test(cmp(u"0123456789abcde", u"0123456789abcdef") === :less)
     test(cmp(u"0123456789abcdef", u"0123456789abcde") === :great)
     test(cmp(u"", u"0123456789abcde") === :less)
     test(cmp(u"0123456789abcde", u"") === :great)
     test(cmp(u"0123456789abcd" ++ u"e", u"0123456789abcde") === :equal)
     test(cmp(u"0123456789abcd" ++ u"e", u"0123456789abcd") === :great)
     test(cmp(u"0123456789abcde", u"0123456789abcd" ++ u"e") === :equal)
     test(cmp(u"0123456789abcd", u"0123456789abcd" ++ u"e") === :less)
     test(cmp(u"0123456789abcd" ++ u"e", u"0123456789abcd" ++ u"e") === :equal)
     test(cmp(u"0123456789abcd" ++ u"ee", u"0123456789abcd" ++ u"e") === :great)
     let array_1    = rnd_byte_array()
     let array_2    = rnd_byte_array()
     let short_len   = if len(array_1) < len(array_2); len(array_1) else len(array_2)
     let cmp_result  = loop(0, fn (idx) {
          if idx === short_len
               [breaker len(array_1).cmp(len(array_2))]
          else {
               let byte_1 = array_1[idx]
               let byte_2 = array_2[idx]
               if byte_1 =/= byte_2
                    [breaker byte_1.cmp(byte_2)]
               else idx + 1
          }
     })
     test(cmp(array_1, array_2) === cmp_result)

     let string = heap_string()
     test(cmp([box], [box]) === :equal)
     test(cmp([box 10], [box 10]) === :equal)
     test(cmp([box 1, 2], [box 1, 2]) === :equal)
     test(cmp([box 1], [box]) === :great)
     test(cmp([box 1], [box 1, 2]) === :less)
     test(cmp([box 1, 2], [box 1]) === :great)
     test(cmp([box 2, 1], [box 1, 2]) === :great)
     test(cmp([box string], [box string]) === :equal)
     test(cmp([box string], [box string, 1]) === :less)
     test(cmp([box 2, string], [box string, 1]) === :not_equal)
     test(cmp([box string, string, string, string, string, string, string, string, string, string, string, string, string, string, string, string], [box string, string, string, string, string, string, string, string, string, string, string, string, string, string, string, string]) === :equal)
     test(cmp([box null, string, string, string, string, string, string, string, string, string, string, string, string, string, string, string], [box string, string, string, string, string, string, string, string, string, string, string, string, string, string, string, string]) === :not_equal)
     test(cmp([box string, string, string, string, string, string, string, string, string, string, string, string, string, string, string, null], [box string, string, string, string, string, string, string, string, string, string, string, string, string, string, string, string]) === :not_equal)
     test(cmp([box string, string, string, string, string, string, string, string, string, string, string, string, string, string, string, string], [box null, string, string, string, string, string, string, string, string, string, string, string, string, string, string, string]) === :not_equal)
     test(cmp([box string, string, string, string, string, string, string, string, string, string, string, string, string, string, string, string], [box string, string, string, string, string, string, string, string, string, string, string, string, string, string, string, null]) === :not_equal)

     test(cmp([box nan()], [box 1]) === :not_equal)
     test(cmp([box 1], [box nan()]) === :not_equal)
     test(cmp([box nan()], [box nan()]) === :nan_cmp)
     test(cmp([box 1.0], [box nan()]) === :nan_cmp)
     test(cmp([box nan()], [box 1.0]) === :nan_cmp)

     let big_obj = loop([obj], fn (obj) {
          let len           = len(obj)
          let len_as_string = len.to_string()
          let obj           = new (obj)[len_as_string.str_to_tkn()] <= "0123456789abcde" ++ len_as_string
          break(len === 10, obj)
     })
     test(cmp([obj], [obj]) === :equal)
     test(cmp([obj :1 = 10], [obj :1 = 10]) === :equal)
     test(cmp([obj :1 = 10, :2 = 30], [obj :2 = 30, :1 = 10]) === :equal)
     test(cmp([obj :1 = 10], [obj]) === :not_equal)
     test(cmp([obj :1 = 10], [obj :1 = 10, :2 = 9]) === :not_equal)
     test(cmp([obj :1 = 10, :2 = 9], [obj :1 = 10]) === :not_equal)
     test(cmp([obj :1 = 10], [obj :1 = 9]) === :not_equal)
     test(cmp([obj :1 = 10, :2 = 9], [obj :1 = 10, :2 = 10]) === :not_equal)
     test(cmp([obj :1 = 10, :2 = 9], [obj :1 = 9, :2 = 9]) === :not_equal)
     test(cmp([obj :1 = 10, :2 = 9], [obj :1 = 7, :2 = 7]) === :not_equal)
     test(cmp([obj :1 = 10, :_ = [obj]], [obj :1 = 10]) === :equal)
     test(cmp([obj :1 = 10], [obj :1 = 10, :_ = [obj]]) === :equal)
     test(cmp([obj :1 = 10, :_ = [obj :1 = 2]], [obj :1 = 10]) === :equal)
     test(cmp([obj :1 = 10], [obj :1 = 10, :_ = [obj :1 = 2]]) === :equal)
     test(cmp([obj :1 = 10, :_ = [obj :1 = 2]], [obj :1 = 10, :_ = [obj :1 = 3]]) === :equal)
     test(cmp([obj :1 = 10, :_ = [obj :1 = 2]], [obj :1 = 10, :_ = [obj :1 = 4]]) === :equal)
     test(cmp([obj :1 = 10, :_ = [obj :2 = 2]], [obj :1 = 10, :_ = [obj :1 = 2]]) === :equal)
     test(cmp([obj :1 = 10, :_ = [obj :1 = 2]], [obj :1 = 10, :_ = [obj :2 = 2]]) === :equal)
     test(cmp(big_obj, big_obj) === :equal)
     test(cmp(big_obj, [obj
          :3  = "0123456789abcde3"
          :9  = "0123456789abcde9"
          :4  = "0123456789abcde4"
          :5  = "0123456789abcde5"
          :6  = "0123456789abcde6"
          :7  = "0123456789abcde7"
          :2  = "0123456789abcde2"
          :10 = "0123456789abcde10"
          :0  = "0123456789abcde0"
          :1  = "0123456789abcde1"
          :8  = "0123456789abcde8"
     ]) === :equal)
     test(cmp(big_obj, new (big_obj):0 <= null) === :not_equal)

     test(cmp([obj :1 = nan()], [obj :1 = 1]) === :not_equal)
     test(cmp([obj :1 = 1], [obj :1 = nan()]) === :not_equal)
     test(cmp([obj :1 = nan()], [obj :1 = nan()]) === :not_equal)
     test(cmp([obj :1 = 1.0], [obj :1 = nan()]) === :not_equal)
     test(cmp([obj :1 = nan()], [obj :1 = 1.0]) === :not_equal)

     let big_table = loop([table], fn (table) {
          let len           = len(table)
          let len_as_string = len.to_string()
          let table         = new (table)["1113456789abcde" ++ len_as_string] <= "0123456789abcde" ++ len_as_string
          break(len === 10, table)
     })
     test(cmp([table], [table]) === :equal)
     test(cmp([table 1 = 10], [table 1 = 10]) === :equal)
     test(cmp([table 1 = 10, 2 = 30], [table 1 = 10, 2 = 30]) === :equal)
     test(cmp([table 1 = 10], [table]) === :not_equal)
     test(cmp([table 1 = 10], [table 1 = 10, 2 = 9]) === :not_equal)
     test(cmp([table 1 = 10, 2 = 9], [table 1 = 10]) === :not_equal)
     test(cmp([table 1 = 10], [table 1 = 9]) === :not_equal)
     test(cmp([table 1 = 10, 2 = 9], [table 1 = 10, 2 = 10]) === :not_equal)
     test(cmp([table 1 = 10, 2 = 9], [table 1 = 9, 2 = 9]) === :not_equal)
     test(cmp([table 1 = 10, 2 = 9], [table 1 = 7, 2 = 7]) === :not_equal)
     test(cmp(big_table, big_table) === :equal)
     test(cmp(big_table, [table
          "1113456789abcde3"  = "0123456789abcde3"
          "1113456789abcde0"  = "0123456789abcde0"
          "1113456789abcde8"  = "0123456789abcde8"
          "1113456789abcde4"  = "0123456789abcde4"
          "1113456789abcde5"  = "0123456789abcde5"
          "1113456789abcde6"  = "0123456789abcde6"
          "1113456789abcde2"  = "0123456789abcde2"
          "1113456789abcde1"  = "0123456789abcde1"
          "1113456789abcde10" = "0123456789abcde10"
          "1113456789abcde7"  = "0123456789abcde7"
          "1113456789abcde9"  = "0123456789abcde9"
     ]) === :equal)
     test(cmp(big_table, new (big_table)["1113456789abcde0"] <= null) === :not_equal)

     test(cmp([table :1 = nan()], [table :1 = 1]) === :not_equal)
     test(cmp([table :1 = 1], [table :1 = nan()]) === :not_equal)
     test(cmp([table :1 = nan()], [table :1 = nan()]) === :not_equal)
     test(cmp([table :1 = 1.0], [table :1 = nan()]) === :not_equal)
     test(cmp([table :1 = nan()], [table :1 = 1.0]) === :not_equal)

     let big_set = loop([set], fn (set) {
          let len           = len(set)
          let len_as_string = len.to_string()
          let set           = set.append("0123456789abcde" ++ len_as_string)
          break(len === 10, set)
     })
     test(cmp([set], [set]) === :equal)
     test(cmp([set 10], [set 10]) === :equal)
     test(cmp([set 1, 2], [set 1, 2]) === :equal)
     test(cmp([set 1], [set]) === :not_equal)
     test(cmp([set 1], [set 1, 2]) === :not_equal)
     test(cmp([set 1, 2], [set 1]) === :not_equal)
     test(cmp(big_set, big_set) === :equal)
     test(cmp(big_set, [set
          "0123456789abcde0"
          "0123456789abcde3"
          "0123456789abcde9"
          "0123456789abcde4"
          "0123456789abcde5"
          "0123456789abcde6"
          "0123456789abcde7"
          "0123456789abcde10"
          "0123456789abcde1"
          "0123456789abcde2"
          "0123456789abcde8"
     ]) === :equal)
     test(cmp(big_set, big_set.remove("0123456789abcde0")) === :not_equal)

     test(cmp([array], [array]) === :equal)
     test(cmp([array 10], [array 10]) === :equal)
     test(cmp([array 1, 2], [array 1, 2]) === :equal)
     test(cmp([array 1], [array]) === :great)
     test(cmp([array 1], [array 1, 2]) === :less)
     test(cmp([array 1, 2], [array 1]) === :great)
     test(cmp([array 2, 1], [array 1, 2]) === :great)
     let array_1    = rnd_string_array()
     let array_2    = rnd_string_array()
     let short_len   = if len(array_1) < len(array_2); len(array_1) else len(array_2)
     let cmp_result  = loop(0, fn (idx) {
          if idx === short_len
               [breaker len(array_1).cmp(len(array_2))]
          else {
               let string_1 = array_1[idx]
               let string_2 = array_2[idx]
               if string_1 =/= string_2
                    [breaker string_1.cmp(string_2)]
               else idx + 1
          }
     })
     test(cmp(array_1, array_2) === cmp_result)

     test(cmp([array nan()], [array 1]) === :not_equal)
     test(cmp([array 1], [array nan()]) === :not_equal)
     test(cmp([array nan()], [array nan()]) === :nan_cmp)
     test(cmp([array 1.0], [array nan()]) === :nan_cmp)
     test(cmp([array nan()], [array 1.0]) === :nan_cmp)

     test(cmp([array].to_const__cmp(), [array].to_const__cmp()) === :equal)
     test(cmp([array 10.scarlet__erase_info()].to_const__cmp(), [array 10.scarlet__erase_info()].to_const__cmp()) === :equal)
     test(cmp([array 1.scarlet__erase_info(), 2].to_const__cmp(), [array 1, 2.scarlet__erase_info()].to_const__cmp()) === :equal)
     test(cmp([array 1.scarlet__erase_info()].to_const__cmp(), [array].to_const__cmp()) === :great)
     test(cmp([array 1.scarlet__erase_info()].to_const__cmp(), [array 1.scarlet__erase_info(), 2].to_const__cmp()) === :less)
     test(cmp([array 1.scarlet__erase_info(), 2].to_const__cmp(), [array 1.scarlet__erase_info()].to_const__cmp()) === :great)
     test(cmp([array 2.scarlet__erase_info(), 1].to_const__cmp(), [array 1.scarlet__erase_info(), 2].to_const__cmp()) === :great)

     test(cmp([array].to_custom_const__cmp(), [array].to_custom_const__cmp()) === :equal)
