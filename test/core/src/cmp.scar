     test(cmp([array 1.scarlet__erase_info(), 2].to_custom_const__cmp(), [array 1, 2.scarlet__erase_info()].to_custom_const__cmp()) === :equal)
     test(cmp([array 1.scarlet__erase_info()].to_custom_const__cmp(), [array].to_custom_const__cmp()) === :great)
     test(cmp([array 1.scarlet__erase_info()].to_custom_const__cmp(), [array 1.scarlet__erase_info(), 2].to_custom_const__cmp()) === :less)
     test(cmp([array 1.scarlet__erase_info(), 2].to_custom_const__cmp(), [array 1.scarlet__erase_info()].to_custom_const__cmp()) === :great)
     test(cmp([array 2.scarlet__erase_info(), 1].to_custom_const__cmp(), [array 1.scarlet__erase_info(), 2].to_custom_const__cmp()) === :great)

