     let string_1    = rnd_string()
     let string_2    = rnd_string()
     let short_len   = if len(string_1) < len(string_2); len(string_1) else len(string_2)
     let cmp_result  = loop(0, fn (idx) {
          if idx === short_len
               [breaker len(string_1).cmp(len(string_2))]
          else {
               let char_1 = string_1[idx]
               let char_2 = string_2[idx]
               if char_1 =/= char_2
                    [breaker char_1.cmp(char_2)]
               else idx + 1
          }
     })
     test(cmp([array string_1], [array string_2]) === cmp_result)

