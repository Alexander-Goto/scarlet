let num__round = [obj
     :value = 0.0

     :_ = [obj
          :core_round     = fn (num) to_num__round(num:value.round())
          :core___equal__ = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__round(arg) new (@main.num__round):value <= arg

fn to_custom_num__round(arg) custom__create(
     arg
     [obj
          :core_round     = fn (num) to_custom_num__round(num.custom__get_data().round())
          :core___equal__ = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__round = [obj
     :value = 0.0

     :_ = [obj
          :core_round = fn (_) heap_string()
     ]
]

fn to_broken_num__round(arg) new (@main.broken_num__round):value <= arg

fn to_broken_custom_num__round(arg) custom__create(
     arg
     [obj
          :core_round = fn (_) heap_string()
     ]
)

let error_num__round = [obj
     :value = 0.0

     :_ = [obj
          :core_round = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__round(arg) new (@main.error_num__round):value <= arg

fn to_error_custom_num__round(arg) custom__create(
     arg
     [obj
          :core_round = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__round() {
     let inf     = inf()
     let neg_inf = neg_inf()
     test(0.0.round().scarlet__split!!!()[0] === 0.0.scarlet__split!!!()[0])
     test(-0.0.round().scarlet__split!!!()[0] === -0.0.scarlet__split!!!()[0])
     test(0.1.round().in_range?(-0.01, 0.01))
     test(-0.1.round().in_range?(-0.01, 0.01))
     test(1.0.round().in_range?(0.99, 1.01))
     test(-1.0.round().in_range?(-1.01, -0.99))
     test(1.01.round().in_range?(0.99, 1.01))
     test(-1.01.round().in_range?(-1.01, -0.99))
     test(0.5.round().in_range?(0.99, 1.01))
     test(-0.5.round().in_range?(-1.01, -0.99))
     test(0.49.round().in_range?(-0.01, 0.01))
     test(-0.49.round().in_range?(-0.01, 0.01))
     test(0.51.round().in_range?(0.99, 1.01))
     test(-0.51.round().in_range?(-1.01, -0.99))

     test(inf.round().scarlet__split!!!()[0] === inf.scarlet__split!!!()[0])
     test(neg_inf.round().scarlet__split!!!()[0] === neg_inf.scarlet__split!!!()[0])
     test(nan().round().nan?())

     test(to_num__round(-0.49).round():value.in_range?(-0.01, 0.01))
     test(to_num__round(-0.51).round():value.in_range?(-1.01, -0.99))

     test(to_custom_num__round(-0.49).round().custom__get_data().in_range?(-0.01, 0.01))
     test(to_custom_num__round(-0.51).round().custom__get_data().in_range?(-1.01, -0.99))

     let error  = expected_error(:1, heap_string(), heap_string())
     test(error.round().get_error_id() === :1)
     test(heap_string().round().get_error_id() === :invalid_type)

     test(to_broken_num__round(1.0).round().get_error_id() === :invalid_type)
     test(to_broken_custom_num__round(1.0).round().get_error_id() === :invalid_type)
     test(to_error_num__round(1.0).round().get_error_id() === :3)
     test(to_error_custom_num__round(1.0).round().get_error_id() === :4)
}