let char__ascii_lower = [obj
     :value = 0

     :_ = [obj
          :core_ascii_lower? = fn (char) char:value.ascii_lower?()
     ]
]

fn to_char__ascii_lower?(arg) new (@main.char__ascii_lower):value <= arg

fn to_custom_char__ascii_lower?(arg) custom__create(
     arg
     [obj
          :core_ascii_lower? = fn (char) char.custom__get_data().ascii_lower?()
     ]
)

let broken_char__ascii_lower = [obj
     :value = 0

     :_ = [obj
          :core_ascii_lower? = fn (_) heap_string()
     ]
]

fn to_broken_char__ascii_lower?(arg) new (@main.broken_char__ascii_lower):value <= arg

fn to_broken_custom_char__ascii_lower?(arg) custom__create(
     arg
     [obj
          :core_ascii_lower? = fn (_) heap_string()
     ]
)

let error_char__ascii_lower = [obj
     :value = 0

     :_ = [obj
          :core_ascii_lower? = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_char__ascii_lower?(arg) new (@main.error_char__ascii_lower):value <= arg

fn to_error_custom_char__ascii_lower?(arg) custom__create(
     arg
     [obj
          :core_ascii_lower? = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__ascii_lower?() {
     test(not '\000001'.ascii_lower?())
     test(not '\000008'.ascii_lower?())
     test(not '\00000a'.ascii_lower?())
     test(not '\00001f'.ascii_lower?())
     test(not '\00007f'.ascii_lower?())
     test(not '\000009'.ascii_lower?())
     test(not '\t'.ascii_lower?())
     test(not '\000020'.ascii_lower?())
     test(not '\00007e'.ascii_lower?())
     test(not ' '.ascii_lower?())
     test('a'.ascii_lower?())
     test('z'.ascii_lower?())
     test(not 'A'.ascii_lower?())
     test(not 'Z'.ascii_lower?())
     test(not '\00008b'.ascii_lower?())
     test(not '\0000ac'.ascii_lower?())
     test(not '0'.ascii_lower?())
     test(not '9'.ascii_lower?())

     let string = rnd_string()
     test(string.filter(_.in_range?('a', '{')) === string.filter(ascii_lower?(_)))

     test(to_char__ascii_lower?('a').ascii_lower?())
     test(not to_char__ascii_lower?('A').ascii_lower?())

     test(to_custom_char__ascii_lower?('a').ascii_lower?())
     test(not to_custom_char__ascii_lower?('A').ascii_lower?())

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.ascii_lower?().get_error_id() === :1)
     test(heap_table().ascii_lower?().get_error_id() === :invalid_type)

     test(to_broken_char__ascii_lower?('a').ascii_lower?().get_error_id() === :invalid_type)
     test(to_broken_custom_char__ascii_lower?('a').ascii_lower?().get_error_id() === :invalid_type)
     test(to_error_char__ascii_lower?('a').ascii_lower?().get_error_id() === :3)
     test(to_error_custom_char__ascii_lower?('a').ascii_lower?().get_error_id() === :4)
}