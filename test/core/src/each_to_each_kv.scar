let container__each_to_each_kv = [obj
     :value = [array]

     :_ = [obj
          :core_each_to_each_kv = fn (container, func) to_container__each_to_each_kv(container:value.each_to_each_kv(func))
          :core___equal__       = fn (container_1, container_2) container_1:value === container_2:value
     ]
]

fn to_container__each_to_each_kv(arg) new (@main.container__each_to_each_kv):value <= arg

fn to_custom_container__each_to_each_kv(arg) custom__create(
     arg
     [obj
          :core_each_to_each_kv = fn (container, func) to_custom_container__each_to_each_kv(custom__get_data(container).each_to_each_kv(func))
          :core___equal__       = fn (container_1, container_2) container_1.custom__get_data() === container_2.custom__get_data()
     ]
)

let broken_container__each_to_each_kv = [obj
     :value = [array]

     :_ = [obj
          :core_each_to_each_kv = fn (_, _) _ ++ heap_table()
     ]
]

fn to_broken_container__each_to_each_kv(arg) new (@main.broken_container__each_to_each_kv):value <= arg

fn to_broken_custom_container__each_to_each_kv(arg) custom__create(
