     test([obj].each_to_each_kv(fn (key_1, _, key_2, _) [box key_1, key_2]) === [obj])
     test([obj].init(10).each_to_each_kv(fn (key_1, _, key_2, _) [box key_1, key_2]) === [obj])
     test([obj :1 = string_2].each_to_each_kv(fn (key_1, _, key_2, _) [box key_1, key_2]) === [obj :1 = string_2])
     test([obj :1 = string_2, :2 = string_1].each_to_each_kv(fn (key_1, _, key_2, _) [box key_1, key_2]) === [obj :1 = :1, :2 = :2])
     test([obj :1 = string_3, :2 = string_1, :3 = string_2].each_to_each_kv(fn (key_1, _, key_2, _) [box key_1, key_2]) === [obj :1 = :1, :2 = :2, :3 = :3])

     let array        = rnd_string_array()
     let idx_1        = (rnd() >> 1) % array.len()
     let idx_2        = (rnd() >> 1) % array.len()
     let idx_tkn_1    = idx_1.to_string().str_to_tkn()
     let idx_tkn_2    = idx_2.to_string().str_to_tkn()
     let item_1       = array[idx_1]
     let item_2       = array[idx_2]
     let obj_1        = array.foldl_kv([obj].init(array.len()), fn (obj, idx, item) new (obj)[idx.to_string().str_to_tkn()] <= item)
     let obj_2        = if rnd_bool(); obj_1 else null
     let expected_obj = new (obj_1) {
          [idx_tkn_1] <= item_2
          [idx_tkn_2] <= item_1
     }
     let have_obj = obj_1.each_to_each_kv(fn (key_1, value_1, key_2, value_2)
          if key_1 == idx_tkn_1 && key_2 == idx_tkn_2 && value_1 == item_1 && value_2 == item_2 ||
                    key_1 == idx_tkn_2 && key_2 == idx_tkn_1 && value_1 == item_2 && value_2 == item_1
               [box value_2, value_1]
          else [box value_1, value_2]
     )
     test(expected_obj === have_obj)
     obj_2.ignore()

     test(to_container__each_to_each_kv("abab").each_to_each_kv(fn (idx_1, char_1, idx_2, char_2) if idx_1 == 0 && idx_2 == 3 && char_1 == 'a' && char_2 == 'b'; [box 'c', 'd'] else [box char_1, char_2]) === to_container__each_to_each_kv("cbad"))
     test(to_container__each_to_each_kv("abab").each_to_each_kv(fn (idx_1, char_1, idx_2, char_2) if idx_1 /= 0 && idx_2 == 3 && char_1 == 'a' && char_2 == 'b'; [box 'c', 'd'] else [box char_1, char_2]) === to_container__each_to_each_kv("abcd"))
     test(to_custom_container__each_to_each_kv("abab").each_to_each_kv(fn (idx_1, char_1, idx_2, char_2) if idx_1 == 0 && idx_2 == 3 && char_1 == 'a' && char_2 == 'b'; [box 'c', 'd'] else [box char_1, char_2]) === to_custom_container__each_to_each_kv("cbad"))
     test(to_custom_container__each_to_each_kv("abab").each_to_each_kv(fn (idx_1, char_1, idx_2, char_2) if idx_1 /= 0 && idx_2 == 3 && char_1 == 'a' && char_2 == 'b'; [box 'c', 'd'] else [box char_1, char_2]) === to_custom_container__each_to_each_kv("abcd"))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.each_to_each_kv(heap_string().insert_to(_, _)).get_error_id() === :1)
     test(heap_string().each_to_each_kv(error_1).get_error_id() === :1)
     test(error_1.each_to_each_kv(error_2).get_error_id() === :1)
     test(error_2.each_to_each_kv(error_1).get_error_id() === :2)
     test(error_1.each_to_each_kv(heap_string()).get_error_id() === :1)
     test((_ === heap_string()).scarlet__erase_info().each_to_each_kv(error_1).get_error_id() === :1)

     test((_ === heap_string()).scarlet__erase_info().each_to_each_kv(heap_string().insert_to(_, _)).get_error_id() === :invalid_type)
     test(heap_string().each_to_each_kv(heap_table()).get_error_id() === :invalid_type)
     test((_ === heap_string()).scarlet__erase_info().each_to_each_kv(heap_table()).get_error_id() === :invalid_type)

     test(to_broken_container__each_to_each_kv("").each_to_each_kv(_ === heap_string()).get_error_id() === :invalid_type)
     test(to_broken_custom_container__each_to_each_kv("").each_to_each_kv(_ === heap_string()).get_error_id() === :invalid_type)
     test(to_error_container__each_to_each_kv("").each_to_each_kv(_ === heap_string()).get_error_id() === :3)
     test(to_error_custom_container__each_to_each_kv("").each_to_each_kv(_ === heap_string()).get_error_id() === :4)

     test("".each_to_each_kv(fn (_) string_1) === "")
     test(u"".each_to_each_kv(fn (_) string_1) === u"")
     test([array].each_to_each_kv(fn (_) string_1) === [array])
     test([table].each_to_each_kv(fn (_) string_1) === [table])
     test([obj].each_to_each_kv(fn (_) string_1) === [obj])
     test([obj :_ = [obj]].each_to_each_kv(fn (_) string_1) === [obj])
     test([obj :_ = [obj]].each_to_each_kv(fn (_) string_1):_ === [obj])

     test("01".each_to_each_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().each_to_each_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"01".each_to_each_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().each_to_each_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([array 0, heap_string()].each_to_each_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([table 0 = 1, heap_string() = heap_string()].each_to_each_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([obj :0 = 0, :1 = heap_string()].each_to_each_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)

     test("01".each_to_each_kv(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().each_to_each_kv(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"01".each_to_each_kv(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().each_to_each_kv(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([array 0, heap_string()].each_to_each_kv(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([table 0 = 1, heap_string() = heap_string()].each_to_each_kv(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([obj :0 = 0, :1 = heap_string()].each_to_each_kv(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)

     test("01".each_to_each_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().each_to_each_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"01".each_to_each_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().each_to_each_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([array 0, heap_string()].each_to_each_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([table 0 = 1, heap_string() = heap_string()].each_to_each_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([obj :0 = 0, :1 = heap_string()].each_to_each_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)

     test("01".each_to_each_kv(fn (_, _, _, _) string_1).get_error_id() === :invalid_type)
     test(heap_string().each_to_each_kv(fn (_, _, _, _) string_1).get_error_id() === :invalid_type)
     test(u"01".each_to_each_kv(fn (_, _, _, _) string_1).get_error_id() === :invalid_type)
     test(heap_byte_array().each_to_each_kv(fn (_, _, _, _) string_1).get_error_id() === :invalid_type)
     test([array 0, heap_string()].each_to_each_kv(fn (_, _, _, _) string_1).get_error_id() === :invalid_type)
     test([table 0 = 1, heap_string() = heap_string()].each_to_each_kv(fn (_, _, _, _) string_1).get_error_id() === :invalid_type)
     test([obj :0 = 0, :1 = heap_string()].each_to_each_kv(fn (_, _, _, _) string_1).get_error_id() === :invalid_type)

     test("01".each_to_each_kv(fn (_, _, _, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test(heap_string().each_to_each_kv(fn (_, _, _, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test(u"01".each_to_each_kv(fn (_, _, _, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test(heap_byte_array().each_to_each_kv(fn (_, _, _, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test([array 0, heap_string()].each_to_each_kv(fn (_, _, _, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test([table 0 = 1, heap_string() = heap_string()].each_to_each_kv(fn (_, _, _, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test([obj :0 = 0, :1 = heap_string()].each_to_each_kv(fn (_, _, _, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
}