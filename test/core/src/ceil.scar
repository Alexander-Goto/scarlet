let num__ceil = [obj
     :value = 0.0

     :_ = [obj
          :core_ceil      = fn (num) to_num__ceil(num:value.ceil())
          :core___equal__ = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__ceil(arg) new (@main.num__ceil):value <= arg

fn to_custom_num__ceil(arg) custom__create(
     arg
     [obj
          :core_ceil      = fn (num) to_custom_num__ceil(num.custom__get_data().ceil())
          :core___equal__ = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__ceil = [obj
     :value = 0.0

     :_ = [obj
          :core_ceil = fn (_) heap_string()
     ]
]

fn to_broken_num__ceil(arg) new (@main.broken_num__ceil):value <= arg

fn to_broken_custom_num__ceil(arg) custom__create(
     arg
     [obj
          :core_ceil = fn (_) heap_string()
     ]
)

let error_num__ceil = [obj
     :value = 0.0

     :_ = [obj
          :core_ceil = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__ceil(arg) new (@main.error_num__ceil):value <= arg

fn to_error_custom_num__ceil(arg) custom__create(
     arg
     [obj
          :core_ceil = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__ceil() {
     let inf     = inf()
     let neg_inf = neg_inf()
     test(0.0.ceil().scarlet__split!!!()[0] === 0.0.scarlet__split!!!()[0])
     test(-0.0.ceil().scarlet__split!!!()[0] === -0.0.scarlet__split!!!()[0])
     test(0.1.ceil().in_range?(0.99, 1.01))
     test(-0.1.ceil().in_range?(-0.01, 0.01))
     test(1.0.ceil().in_range?(0.99, 1.01))
     test(-1.0.ceil().in_range?(-1.01, -0.99))
     test(1.01.ceil().in_range?(1.99, 2.01))
     test(-1.01.ceil().in_range?(-1.01, -0.99))
     test(0.5.ceil().in_range?(0.99, 1.01))
     test(-0.5.ceil().in_range?(-0.01, 0.01))
     test(0.49.ceil().in_range?(0.99, 1.01))
     test(-0.49.ceil().in_range?(-0.01, 0.01))
     test(0.51.ceil().in_range?(0.99, 1.01))
     test(-0.51.ceil().in_range?(-0.01, 0.01))

     test(inf.ceil().scarlet__split!!!()[0] === inf.scarlet__split!!!()[0])
     test(neg_inf.ceil().scarlet__split!!!()[0] === neg_inf.scarlet__split!!!()[0])
     test(nan().ceil().nan?())

     test(to_num__ceil(-0.49).ceil():value.in_range?(-0.01, 0.01))
     test(to_num__ceil(-0.51).ceil():value.in_range?(-0.01, 0.01))

     test(to_custom_num__ceil(-0.49).ceil().custom__get_data().in_range?(-0.01, 0.01))
     test(to_custom_num__ceil(-0.51).ceil().custom__get_data().in_range?(-0.01, 0.01))

     let error  = expected_error(:1, heap_string(), heap_string())
     let string = heap_string()
     test(error.ceil().get_error_id() === :1)
     test(string.ceil().get_error_id() === :invalid_type)

     test(to_broken_num__ceil(1.0).ceil().get_error_id() === :invalid_type)
     test(to_broken_custom_num__ceil(1.0).ceil().get_error_id() === :invalid_type)
     test(to_error_num__ceil(1.0).ceil().get_error_id() === :3)
     test(to_error_custom_num__ceil(1.0).ceil().get_error_id() === :4)
}