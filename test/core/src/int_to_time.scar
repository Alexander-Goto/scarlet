`noinline`
fn test__int_to_time() {
     test(0.int_to_time() == assemble_time(0, 1970, 1, 1, 0, 0, 0))
     test(11002.int_to_time() == assemble_time(0, 1970, 1, 1, 3, 3, 22))
     test(63072000.int_to_time() == assemble_time(0, 1972, 1, 1, 0, 0, 0))
     test(63079789.int_to_time() == assemble_time(0, 1972, 1, 1, 2, 9, 49))
     test(946684800.int_to_time() == assemble_time(0, 2000, 1, 1, 0, 0, 0))
     test(946685978.int_to_time() == assemble_time(0, 2000, 1, 1, 0, 19, 38))
     test(3071675727.int_to_time() == assemble_time(0, 2067, 5, 3, 19, 15, 27))
     test(2982223890.int_to_time() == assemble_time(0, 2064, 7, 2, 11, 31, 30))
     test(1056498668.int_to_time() == assemble_time(0, 2003, 6, 24, 23, 51, 8))
     test(549784052.int_to_time() == assemble_time(0, 1987, 6, 4, 5, 47, 32))
     test(2953582074.int_to_time() == assemble_time(0, 2063, 8, 5, 23, 27, 54))
     test(8689046.int_to_time() == assemble_time(0, 1970, 4, 11, 13, 37, 26))
     test(1376809701.int_to_time() == assemble_time(0, 2013, 8, 18, 7, 8, 21))
     test(3824707036.int_to_time() == assemble_time(0, 2091, 3, 14, 10, 37, 16))
     test(1158132353.int_to_time() == assemble_time(0, 2006, 9, 13, 7, 25, 53))
     test(949624230.int_to_time() == assemble_time(0, 2000, 2, 4, 0, 30, 30))
     test(1281717032.int_to_time() == assemble_time(0, 2010, 8, 13, 16, 30, 32))
     test(781467978.int_to_time() == assemble_time(0, 1994, 10, 6, 18, 26, 18))
     test(1662330597.int_to_time() == assemble_time(0, 2022, 9, 4, 22, 29, 57))
     test(3641724393.int_to_time() == assemble_time(0, 2085, 5, 26, 14, 6, 33))
     test(2074699765.int_to_time() == assemble_time(0, 2035, 9, 29, 17, 29, 25))
     test(2666241882.int_to_time() == assemble_time(0, 2054, 6, 28, 6, 44, 42))
     test(2639079008.int_to_time() == assemble_time(0, 2053, 8, 17, 21, 30, 8))
     test(3248551025.int_to_time() == assemble_time(0, 2072, 12, 9, 23, 17, 5))
     test(2715062736.int_to_time() == assemble_time(0, 2056, 1, 14, 8, 5, 36))
     test(1228890761.int_to_time() == assemble_time(0, 2008, 12, 10, 6, 32, 41))

     test(9223372036825516799.int_to_time() == assemble_time(0, 292277026595, 12, 31, 23, 59, 59))
     test(9223372036825516799.int_to_time() == assemble_time(86400, 292277026596, 1, 1, 23, 59, 59))
     test(9223372036825516799.int_to_time() == assemble_time(-86400, 292277026595, 12, 30, 23, 59, 59))
     test(0.int_to_time() == assemble_time(86400, 1970, 1, 2, 0, 0, 0))
     test(0.int_to_time() == assemble_time(-86400, 1969, 12, 31, 0, 0, 0))

     test(5011200.int_to_time() == assemble_time(0, 1970, 2, 28, 0, 0, 0))
     test(5097600.int_to_time() == assemble_time(0, 1970, 3, 1, 0, 0, 0))
     test(68169600.int_to_time() == assemble_time(0, 1972, 2, 29, 0, 0, 0))
     test(951782400.int_to_time() == assemble_time(0, 2000, 2, 29, 0, 0, 0))
     test(1078012800.int_to_time() == assemble_time(0, 2004, 2, 29, 0, 0, 0))
     test(4107456000.int_to_time() == assemble_time(0, 2100, 2, 28, 0, 0, 0))
     test(4107542400.int_to_time() == assemble_time(0, 2100, 3, 1, 0, 0, 0))

     test(9223372036825516800.scarlet__erase_info().int_to_time().get_error_id() === :out_of_bounds)
     test(-9223372036825516801.scarlet__erase_info().int_to_time().get_error_id() === :out_of_bounds)
     test(9223372036854775807.scarlet__erase_info().int_to_time().get_error_id() === :out_of_bounds)
     test(-9223372036854775808.scarlet__erase_info().int_to_time().get_error_id() === :out_of_bounds)
     test(-1.scarlet__erase_info().int_to_time().get_error_id() === :out_of_bounds)
     test(time().scarlet__erase_info().int_to_time().get_error_id() === :invalid_type)
     test("".scarlet__erase_info().int_to_time().get_error_id() === :invalid_type)
     test(heap_string().int_to_time().get_error_id() === :invalid_type)

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.int_to_time().get_error_id() === :1)
}