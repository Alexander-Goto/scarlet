let array__move = [obj
     :value = [array]

     :_ = [obj
          :core_move      = fn (array, from, to, len) to_array__move(array:value.move(from, to, len))
          :core___equal__ = fn (array_1, array_2) array_1:value === array_2:value
     ]
]

fn to_array__move(arg) new (@main.array__move):value <= arg

fn to_custom_array__move(arg) custom__create(
     arg
     [obj
          :core_move      = fn (array, from, to, len) to_custom_array__move(array.custom__get_data().move(from, to, len))
          :core___equal__ = fn (array_1, array_2) array_1.custom__get_data() === array_2.custom__get_data()
     ]
)

let broken_array__move = [obj
     :value = [array]

     :_ = [obj
          :core_move = fn (_, _, _, _) heap_table()
     ]
]

fn to_broken_array__move(arg) new (@main.broken_array__move):value <= arg

fn to_broken_custom_array__move(arg) custom__create(
     arg
     [obj
          :core_move = fn (_, _, _, _) heap_table()
     ]
)

let error_array__move = [obj
     :value = [array]

     :_ = [obj
          :core_move = fn (_, _, _, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__move(arg) new (@main.error_array__move):value <= arg

fn to_error_custom_array__move(arg) custom__create(
     arg
     [obj
          :core_move = fn (_, _, _, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__move() {
     test("".move(0, 0, 0) === "")
     test("1".move(0, 0, 0) === "1")
     test("1".move(1, 0, 0) === "1")
     test("1".move(1, 1, 0) === "1")
     test("1".move(0, 0, 1) === "1")
     test("0123456789abcde".move(0, 0, 0) === "0123456789abcde")
     test("0123456789abcde".move(15, 15, 0) === "0123456789abcde")
     test("0123456789abcde".move(0, 0, 15) === "0123456789abcde")
     test("0123456789abcde".move(0, 10, 1) === "123456789a0bcde")
     test("0123456789abcde".move(10, 0, 1) === "a0123456789bcde")
     test("0123456789abcde".move(0, 10, 2) === "23456789ab01cde")
     test("0123456789abcde".move(10, 0, 2) === "ab0123456789cde")
     test("0123456789abcde".move(0, 10, 5) === "56789abcde01234")
     test("0123456789abcde".move(10, 0, 5) === "abcde0123456789")
     test("0123456789abcde".move(0, 1, 14) === "e0123456789abcd")
     test("0123456789abcde".move(1, 0, 14) === "123456789abcde0")
     test("0123456789abcde".move(3, 3, 7) === "0123456789abcde")
     test("0123456789abcde".move(3, 7, 3) === "0126789345abcde")
     test("0123456789abcde".move(7, 3, 3) === "0127893456abcde")

     test("0123456789abcdef".move(0, 0, 0) === "0123456789abcdef")
     test("0123456789abcdef".move(16, 16, 0) === "0123456789abcdef")
     test("0123456789abcdef".move(0, 0, 16) === "0123456789abcdef")
     test("0123456789abcdef".move(0, 10, 1) === "123456789a0bcdef")
     test("0123456789abcdef".move(10, 0, 1) === "a0123456789bcdef")
     test("0123456789abcdef".move(0, 10, 2) === "23456789ab01cdef")
     test("0123456789abcdef".move(10, 0, 2) === "ab0123456789cdef")
     test("0123456789abcdef".move(0, 10, 5) === "56789abcde01234f")
     test("0123456789abcdef".move(10, 0, 5) === "abcde0123456789f")
     test("0123456789abcdef".move(0, 10, 6) === "6789abcdef012345")
     test("0123456789abcdef".move(10, 0, 6) === "abcdef0123456789")
     test("0123456789abcdef".move(0, 1, 15) === "f0123456789abcde")
     test("0123456789abcdef".move(1, 0, 15) === "123456789abcdef0")
     test("0123456789abcdef".move(3, 3, 7) === "0123456789abcdef")
     test("0123456789abcdef".move(3, 7, 3) === "0126789345abcdef")
     test("0123456789abcdef".move(7, 3, 3) === "0127893456abcdef")

     let string = "0123456789abcde" ++ "f"
     test(string.move(0, 0, 0) === "0123456789abcdef")
     test(string.move(16, 16, 0) === "0123456789abcdef")
     test(string.move(0, 0, 16) === "0123456789abcdef")
     test(string.move(0, 10, 1) === "123456789a0bcdef")
     test(string.move(10, 0, 1) === "a0123456789bcdef")
     test(string.move(0, 10, 2) === "23456789ab01cdef")
     test(string.move(10, 0, 2) === "ab0123456789cdef")
     test(string.move(0, 10, 5) === "56789abcde01234f")
     test(string.move(10, 0, 5) === "abcde0123456789f")
     test(string.move(0, 10, 6) === "6789abcdef012345")
     test(string.move(10, 0, 6) === "abcdef0123456789")
     test(string.move(0, 1, 15) === "f0123456789abcde")
     test(string.move(1, 0, 15) === "123456789abcdef0")
     test(string.move(3, 3, 7) === "0123456789abcdef")
     test(string.move(3, 7, 3) === "0126789345abcdef")
     test(string.move(7, 3, 3) === "0127893456abcdef")
     string.ignore()

     let string = ("00123456789abcde" ++ "f0")[1, 17]
     test(string.move(0, 0, 0) === "0123456789abcdef")
     test(string.move(16, 16, 0) === "0123456789abcdef")
     test(string.move(0, 0, 16) === "0123456789abcdef")
     test(string.move(0, 10, 1) === "123456789a0bcdef")
     test(string.move(10, 0, 1) === "a0123456789bcdef")
     test(string.move(0, 10, 2) === "23456789ab01cdef")
     test(string.move(10, 0, 2) === "ab0123456789cdef")
     test(string.move(0, 10, 5) === "56789abcde01234f")
     test(string.move(10, 0, 5) === "abcde0123456789f")
     test(string.move(0, 10, 6) === "6789abcdef012345")
     test(string.move(10, 0, 6) === "abcdef0123456789")
     test(string.move(0, 1, 15) === "f0123456789abcde")
     test(string.move(1, 0, 15) === "123456789abcdef0")
     test(string.move(3, 3, 7) === "0123456789abcdef")
     test(string.move(3, 7, 3) === "0126789345abcdef")
     test(string.move(7, 3, 3) === "0127893456abcdef")
     string.ignore()

     test(("0123456789abcde" ++ "f").move(0, 0, 0) === "0123456789abcdef")
     test(("0123456789abcde" ++ "f").move(16, 16, 0) === "0123456789abcdef")
     test(("0123456789abcde" ++ "f").move(0, 0, 16) === "0123456789abcdef")
     test(("0123456789abcde" ++ "f").move(0, 10, 1) === "123456789a0bcdef")
     test(("0123456789abcde" ++ "f").move(10, 0, 1) === "a0123456789bcdef")
     test(("0123456789abcde" ++ "f").move(0, 10, 2) === "23456789ab01cdef")
     test(("0123456789abcde" ++ "f").move(10, 0, 2) === "ab0123456789cdef")
     test(("0123456789abcde" ++ "f").move(0, 10, 5) === "56789abcde01234f")
     test(("0123456789abcde" ++ "f").move(10, 0, 5) === "abcde0123456789f")
     test(("0123456789abcde" ++ "f").move(0, 10, 6) === "6789abcdef012345")
     test(("0123456789abcde" ++ "f").move(10, 0, 6) === "abcdef0123456789")
     test(("0123456789abcde" ++ "f").move(0, 1, 15) === "f0123456789abcde")
     test(("0123456789abcde" ++ "f").move(1, 0, 15) === "123456789abcdef0")
     test(("0123456789abcde" ++ "f").move(3, 3, 7) === "0123456789abcdef")
     test(("0123456789abcde" ++ "f").move(3, 7, 3) === "0126789345abcdef")
     test(("0123456789abcde" ++ "f").move(7, 3, 3) === "0127893456abcdef")

     test(("00123456789abcde" ++ "f0")[1, 17].move(0, 0, 0) === "0123456789abcdef")
     test(("00123456789abcde" ++ "f0")[1, 17].move(16, 16, 0) === "0123456789abcdef")
     test(("00123456789abcde" ++ "f0")[1, 17].move(0, 0, 16) === "0123456789abcdef")
     test(("00123456789abcde" ++ "f0")[1, 17].move(0, 10, 1) === "123456789a0bcdef")
     test(("00123456789abcde" ++ "f0")[1, 17].move(10, 0, 1) === "a0123456789bcdef")
     test(("00123456789abcde" ++ "f0")[1, 17].move(0, 10, 2) === "23456789ab01cdef")
     test(("00123456789abcde" ++ "f0")[1, 17].move(10, 0, 2) === "ab0123456789cdef")
     test(("00123456789abcde" ++ "f0")[1, 17].move(0, 10, 5) === "56789abcde01234f")
     test(("00123456789abcde" ++ "f0")[1, 17].move(10, 0, 5) === "abcde0123456789f")
     test(("00123456789abcde" ++ "f0")[1, 17].move(0, 10, 6) === "6789abcdef012345")
     test(("00123456789abcde" ++ "f0")[1, 17].move(10, 0, 6) === "abcdef0123456789")
     test(("00123456789abcde" ++ "f0")[1, 17].move(0, 1, 15) === "f0123456789abcde")
     test(("00123456789abcde" ++ "f0")[1, 17].move(1, 0, 15) === "123456789abcdef0")
     test(("00123456789abcde" ++ "f0")[1, 17].move(3, 3, 7) === "0123456789abcdef")
     test(("00123456789abcde" ++ "f0")[1, 17].move(3, 7, 3) === "0126789345abcdef")
     test(("00123456789abcde" ++ "f0")[1, 17].move(7, 3, 3) === "0127893456abcdef")

     let string_1        = rnd_string()
     let string_2        = if rnd_bool(); string_1 else null
     let from            = (rnd() & 0xffff'ffff) % len(string_1)
     let to              = (rnd() & 0xffff'ffff) % len(string_1)
     let len             = (rnd() & 0xffff'ffff) % (len(string_1) - max(from, to))
     let expected_string = string_1[from, from + len].insert_part_to(string_1.delete(from, from + len), to)
     test(expected_string === string_1.move(from, to, len))
     string_2.ignore()

     test(u"".move(0, 0, 0) === u"")
     test(u"1".move(0, 0, 0) === u"1")
     test(u"1".move(1, 0, 0) === u"1")
     test(u"1".move(1, 1, 0) === u"1")
     test(u"1".move(0, 0, 1) === u"1")
     test(u"0123456789abcd".move(0, 0, 0) === u"0123456789abcd")
     test(u"0123456789abcd".move(14, 14, 0) === u"0123456789abcd")
     test(u"0123456789abcd".move(0, 0, 14) === u"0123456789abcd")
     test(u"0123456789abcd".move(0, 10, 1) === u"123456789a0bcd")
     test(u"0123456789abcd".move(10, 0, 1) === u"a0123456789bcd")
     test(u"0123456789abcd".move(0, 10, 2) === u"23456789ab01cd")
     test(u"0123456789abcd".move(10, 0, 2) === u"ab0123456789cd")
     test(u"0123456789abcd".move(0, 9, 5) === u"56789abcd01234")
     test(u"0123456789abcd".move(9, 0, 5) === u"9abcd012345678")
     test(u"0123456789abcd".move(0, 1, 13) === u"d0123456789abc")
     test(u"0123456789abcd".move(1, 0, 13) === u"123456789abcd0")
     test(u"0123456789abcd".move(3, 3, 7) === u"0123456789abcd")
     test(u"0123456789abcd".move(3, 7, 3) === u"0126789345abcd")
     test(u"0123456789abcd".move(7, 3, 3) === u"0127893456abcd")

     test(u"0123456789abcdef".move(0, 0, 0) === u"0123456789abcdef")
     test(u"0123456789abcdef".move(16, 16, 0) === u"0123456789abcdef")
     test(u"0123456789abcdef".move(0, 0, 16) === u"0123456789abcdef")
     test(u"0123456789abcdef".move(0, 10, 1) === u"123456789a0bcdef")
     test(u"0123456789abcdef".move(10, 0, 1) === u"a0123456789bcdef")
     test(u"0123456789abcdef".move(0, 10, 2) === u"23456789ab01cdef")
     test(u"0123456789abcdef".move(10, 0, 2) === u"ab0123456789cdef")
     test(u"0123456789abcdef".move(0, 10, 5) === u"56789abcde01234f")
     test(u"0123456789abcdef".move(10, 0, 5) === u"abcde0123456789f")
     test(u"0123456789abcdef".move(0, 10, 6) === u"6789abcdef012345")
     test(u"0123456789abcdef".move(10, 0, 6) === u"abcdef0123456789")
     test(u"0123456789abcdef".move(0, 1, 15) === u"f0123456789abcde")
     test(u"0123456789abcdef".move(1, 0, 15) === u"123456789abcdef0")
     test(u"0123456789abcdef".move(3, 3, 7) === u"0123456789abcdef")
     test(u"0123456789abcdef".move(3, 7, 3) === u"0126789345abcdef")
     test(u"0123456789abcdef".move(7, 3, 3) === u"0127893456abcdef")

     let array = u"0123456789abcde" ++ u"f"
     test(array.move(0, 0, 0) === u"0123456789abcdef")
     test(array.move(16, 16, 0) === u"0123456789abcdef")
     test(array.move(0, 0, 16) === u"0123456789abcdef")
     test(array.move(0, 10, 1) === u"123456789a0bcdef")
     test(array.move(10, 0, 1) === u"a0123456789bcdef")
     test(array.move(0, 10, 2) === u"23456789ab01cdef")
     test(array.move(10, 0, 2) === u"ab0123456789cdef")
     test(array.move(0, 10, 5) === u"56789abcde01234f")
     test(array.move(10, 0, 5) === u"abcde0123456789f")
     test(array.move(0, 10, 6) === u"6789abcdef012345")
     test(array.move(10, 0, 6) === u"abcdef0123456789")
     test(array.move(0, 1, 15) === u"f0123456789abcde")
     test(array.move(1, 0, 15) === u"123456789abcdef0")
     test(array.move(3, 3, 7) === u"0123456789abcdef")
     test(array.move(3, 7, 3) === u"0126789345abcdef")
     test(array.move(7, 3, 3) === u"0127893456abcdef")
     array.ignore()

     let array = (u"00123456789abcde" ++ u"f0")[1, 17]
     test(array.move(0, 0, 0) === u"0123456789abcdef")
     test(array.move(16, 16, 0) === u"0123456789abcdef")
     test(array.move(0, 0, 16) === u"0123456789abcdef")
     test(array.move(0, 10, 1) === u"123456789a0bcdef")
     test(array.move(10, 0, 1) === u"a0123456789bcdef")
     test(array.move(0, 10, 2) === u"23456789ab01cdef")
     test(array.move(10, 0, 2) === u"ab0123456789cdef")
     test(array.move(0, 10, 5) === u"56789abcde01234f")
     test(array.move(10, 0, 5) === u"abcde0123456789f")
     test(array.move(0, 10, 6) === u"6789abcdef012345")
     test(array.move(10, 0, 6) === u"abcdef0123456789")
     test(array.move(0, 1, 15) === u"f0123456789abcde")
     test(array.move(1, 0, 15) === u"123456789abcdef0")
     test(array.move(3, 3, 7) === u"0123456789abcdef")
     test(array.move(3, 7, 3) === u"0126789345abcdef")
     test(array.move(7, 3, 3) === u"0127893456abcdef")
     array.ignore()

     test((u"0123456789abcde" ++ u"f").move(0, 0, 0) === u"0123456789abcdef")
     test((u"0123456789abcde" ++ u"f").move(16, 16, 0) === u"0123456789abcdef")
     test((u"0123456789abcde" ++ u"f").move(0, 0, 16) === u"0123456789abcdef")
     test((u"0123456789abcde" ++ u"f").move(0, 10, 1) === u"123456789a0bcdef")
     test((u"0123456789abcde" ++ u"f").move(10, 0, 1) === u"a0123456789bcdef")
     test((u"0123456789abcde" ++ u"f").move(0, 10, 2) === u"23456789ab01cdef")
     test((u"0123456789abcde" ++ u"f").move(10, 0, 2) === u"ab0123456789cdef")
     test((u"0123456789abcde" ++ u"f").move(0, 10, 5) === u"56789abcde01234f")
     test((u"0123456789abcde" ++ u"f").move(10, 0, 5) === u"abcde0123456789f")
     test((u"0123456789abcde" ++ u"f").move(0, 10, 6) === u"6789abcdef012345")
     test((u"0123456789abcde" ++ u"f").move(10, 0, 6) === u"abcdef0123456789")
     test((u"0123456789abcde" ++ u"f").move(0, 1, 15) === u"f0123456789abcde")
     test((u"0123456789abcde" ++ u"f").move(1, 0, 15) === u"123456789abcdef0")
     test((u"0123456789abcde" ++ u"f").move(3, 3, 7) === u"0123456789abcdef")
