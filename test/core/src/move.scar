     let len            = (rnd() & 0xffff'ffff) % (len(array_1) - max(from, to))
     let expected_array = array_1[from, from + len].insert_part_to(array_1.delete(from, from + len), to)
     test(expected_array === array_1.move(from, to, len))
     array_2.ignore()

