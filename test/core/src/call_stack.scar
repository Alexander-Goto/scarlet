fn fn_1() fn_2()
fn fn_2() fn_3()
fn fn_3() call_stack()

let g_1 = call_stack()
let g_2 = fn_1()

`noinline`
fn test__call_stack() {
     test(call_stack() === [array "function - main.main", "function - main.test__call_stack"])
     test(fn_1() === [array "function - main.main", "function - main.test__call_stack", "function - main.fn_1", "function - main.fn_2", "function - main.fn_3"])
     test(@main.g_1 === [array "constant - main.g_1"])
     test(@main.g_2 === [array "constant - main.g_2", "function - main.fn_1", "function - main.fn_2", "function - main.fn_3"])
}