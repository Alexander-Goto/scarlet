let num__add = [obj
     :value = 0

     :_ = [obj
          :core___add__   = fn (num_1, num_2) to_num__add(num_1:value + num_2:value)
          :core___equal__ = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__add(arg) new (@main.num__add):value <= arg

fn to_custom_num__add(arg) custom__create(
     arg
     [obj
          :core___add__   = fn (num_1, num_2) to_custom_num__add(num_1.custom__get_data() + num_2.custom__get_data())
          :core___equal__ = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__add = [obj
     :value = 0

     :_ = [obj
          :core___add__ = fn (_, _) heap_string()
     ]
]

fn to_broken_num__add(arg) new (@main.broken_num__add):value <= arg

fn to_broken_custom_num__add(arg) custom__create(
     arg
     [obj
          :core___add__ = fn (_, _) heap_string()
     ]
)

let error_num__add = [obj
     :value = 0

     :_ = [obj
          :core___add__ = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__add(arg) new (@main.error_num__add):value <= arg

fn to_error_custom_num__add(arg) custom__create(
     arg
     [obj
          :core___add__ = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test____add__() {
     test((0b00 + 0b00) === 0b00)
     test((0b00 + 0b01) === 0b01)
     test((0b01 + 0b00) === 0b01)
     test((0b01 + 0b01) === 0b02)
     test((0bf0 + 0b01) === 0bf1)
     test((0b01 + 0bf0) === 0bf1)
     test((0b0f + 0b0f) === 0b1e)
     test((0bff + 0b00) === 0bff)
     test((0b00 + 0bff) === 0bff)
     test((0bff + 0b01) === 0b00)
     test((0b01 + 0bff) === 0b00)
     test((0bff + 0b25) === 0b24)
     test((0b25 + 0bff) === 0b24)
     test((0bff + 0bff) === 0bfe)

     test((0 + 0) === 0)
     test((0 + 1) === 1)
     test((1 + 0) === 1)
     test((1 + 1) === 2)
     test((0 + -1) === -1)
     test((-1 + 0) === -1)
     test((-1 + -1) === -2)
     test((-1 + 1) === 0)
     test((-708044971986000615 + 8401028929648066925) === 7692983957662066310)
     test((-1964724193136850828 + -708044971986000615) === -2672769165122851443)
     test((-9223372036854775808 + 0) === -9223372036854775808)
     test((0 + -9223372036854775808) === -9223372036854775808)
     test((1 + -9223372036854775808) === -9223372036854775807)
     test((-1 + -9223372036854775808) === 9223372036854775807)
     test((-9223372036854775808 + -9223372036854775808) === 0)
     test((9223372036854775807 + 0) === 9223372036854775807)
     test((0 + 9223372036854775807) === 9223372036854775807)
     test((1 + 9223372036854775807) === -9223372036854775808)
     test((-1 + 9223372036854775807) === 9223372036854775806)
     test((9223372036854775807 + 9223372036854775807) === -2)

     test((0x0 + 0x0) === 0x0)
     test((0x0 + 0x1) === 0x1)
     test((0x1 + 0x0) === 0x1)
     test((0x1 + 0x1) === 0x2)
     test((0x0 + 0xffffffffffffffff) === 0xffffffffffffffff)
     test((0xffffffffffffffff + 0) === 0xffffffffffffffff)
     test((0xffffffffffffffff + 0xffffffffffffffff) === 0xfffffffffffffffe)
     test((0xffffffffffffffff + 0x1) === 0x0)
     test((0xf62c84d96fc5e519 + 0x7496734d0b74016d) === 0x6ac2f8267b39e686)
     test((0xe4bbe5c182764874 + 0xf62c84d96fc5e519) === 0xdae86a9af23c2d8d)
     test((0x0 + 0x8000000000000000) === 0x8000000000000000)
     test((0x8000000000000000 + 0x0) === 0x8000000000000000)
     test((0x8000000000000000 + 0x1) === 0x8000000000000001)
     test((0x8000000000000000 + 0xffffffffffffffff) === 0x7fffffffffffffff)
     test((0x8000000000000000 + 0x8000000000000000) === 0x0)
     test((0x7fffffffffffffff + 0x0) === 0x7fffffffffffffff)
     test((0x0 + 0x7fffffffffffffff) === 0x7fffffffffffffff)
     test((0x1 + 0x7fffffffffffffff) === 0x8000000000000000)
     test((0xffffffffffffffff + 0x7fffffffffffffff) === 0x7ffffffffffffffe)
     test((0x7fffffffffffffff + 0x7fffffffffffffff) === 0xfffffffffffffffe)

     test((0.0 + 0.0).in_range?(-0.01, 0.01))
     test((-0.0 + -0.0).in_range?(-0.01, 0.01))
     test((-0.0 + 0.0).in_range?(-0.01, 0.01))
     test((0.0 + -0.0).in_range?(-0.01, 0.01))
     test((0.0 + 0.1).in_range?(0.09, 0.11))
     test((0.1 + 0.0).in_range?(0.09, 0.11))
     test((0.0 + -0.1).in_range?(-0.11, -0.09))
     test((-0.1 + 0.0).in_range?(-0.11, -0.09))
     test((0.1 + 0.2).in_range?(0.29, 0.31))
     test((0.2 + 0.1).in_range?(0.29, 0.31))
     test((-0.1 + 0.2).in_range?(0.09, 0.11))
     test((-0.2 + 0.1).in_range?(-0.11, -0.09))
     test((11122.3 + 4879.111002).in_range?(16001.39, 16001.42))
     test((nan() + 1.0).nan?())
     test((1.0 + nan()).nan?())
     test((nan() + nan()).nan?())
     test((nan() + inf()).nan?())
     test((inf() + nan()).nan?())
     test((nan() + neg_inf()).nan?())
     test((neg_inf() + nan()).nan?())
     test((inf() + neg_inf()).nan?())
     test((neg_inf() + inf()).nan?())
     test((inf() + 1.0).inf?())
     test((1.0 + inf()).inf?())
     test((inf() + inf()).inf?())
     test((neg_inf() + 1.0).neg_inf?())
     test((1.0 + neg_inf()).neg_inf?())
     test((neg_inf() + neg_inf()).neg_inf?())

     test((to_num__add(0) + to_num__add(0)) === to_num__add(0))
     test((to_num__add(-708044971986000615) + to_num__add(8401028929648066925)) === to_num__add(7692983957662066310))

     test((to_custom_num__add(0) + to_custom_num__add(0)) === to_custom_num__add(0))
     test((to_custom_num__add(-708044971986000615) + to_custom_num__add(8401028929648066925)) === to_custom_num__add(7692983957662066310))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let string  = heap_string()
     test((error_1 + 1).get_error_id() === :1)
     test((1 + error_1).get_error_id() === :1)
     test((error_1 + error_2).get_error_id() === :1)
     test((error_2 + error_1).get_error_id() === :2)
     test((error_1 + string).get_error_id() === :1)
     test((string + error_1).get_error_id() === :1)

     test((string + string).get_error_id() === :invalid_type)
     test((string + 1).get_error_id() === :invalid_type)
     test((1 + string).get_error_id() === :invalid_type)
     test((1 + 1.0.scarlet__erase_info()).get_error_id() === :invalid_type)
     test((1.0.scarlet__erase_info() + 1).get_error_id() === :invalid_type)

     test((to_num__add(1) + error_1).get_error_id() === :1)
     test((error_1 + to_num__add(1)).get_error_id() === :1)
     test((to_num__add(1) + string).get_error_id() === :invalid_type)
     test((string + to_num__add(1)).get_error_id() === :invalid_type)
     test((to_num__add(1) + 1).get_error_id() === :invalid_type)
     test((1 + to_num__add(1)).get_error_id() === :invalid_type)
     test((to_num__add(1) + to_num__add(1.0)).get_error_id() === :invalid_type)

     test((to_custom_num__add(1) + error_1).get_error_id() === :1)
     test((error_1 + to_custom_num__add(1)).get_error_id() === :1)
     test((to_custom_num__add(1) + string).get_error_id() === :invalid_type)
     test((string + to_custom_num__add(1)).get_error_id() === :invalid_type)
     test((to_custom_num__add(1) + 1).get_error_id() === :invalid_type)
     test((1 + to_custom_num__add(1)).get_error_id() === :invalid_type)
     test((to_custom_num__add(1) + to_custom_num__add(1.0)).get_error_id() === :invalid_type)

     test((to_broken_num__add(1) + to_broken_num__add(0)).get_error_id() === :invalid_type)
     test((to_broken_custom_num__add(1) + to_broken_custom_num__add(0)).get_error_id() === :invalid_type)
     test((to_error_num__add(1) + to_error_num__add(0)).get_error_id() === :3)
     test((to_error_custom_num__add(1) + to_error_custom_num__add(0)).get_error_id() === :4)
}