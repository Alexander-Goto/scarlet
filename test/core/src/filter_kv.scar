let container__filter_kv = [obj
     :value = [array]

     :_ = [obj
          :core_filter_kv = fn (container, func) to_container__filter_kv(container:value.filter_kv(func))
          :core___equal__ = fn (container_1, container_2) container_1:value === container_2:value
     ]
]

fn to_container__filter_kv(arg) new (@main.container__filter_kv):value <= arg

fn to_custom_container__filter_kv(arg) custom__create(
     arg
     [obj
          :core_filter_kv = fn (container, func) to_custom_container__filter_kv(custom__get_data(container).filter_kv(func))
          :core___equal__ = fn (container_1, container_2) container_1.custom__get_data() === container_2.custom__get_data()
     ]
)

let broken_container__filter_kv = [obj
     :value = [array]

     :_ = [obj
          :core_filter_kv = fn (_, _) heap_table()
     ]
]

fn to_broken_container__filter_kv(arg) new (@main.broken_container__filter_kv):value <= arg

fn to_broken_custom_container__filter_kv(arg) custom__create(
     arg
     [obj
          :core_filter_kv = fn (_, _) heap_table()
     ]
)

let error_container__filter_kv = [obj
     :value = [array]

     :_ = [obj
          :core_filter_kv = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_container__filter_kv(arg) new (@main.error_container__filter_kv):value <= arg

fn to_error_custom_container__filter_kv(arg) custom__create(
     arg
     [obj
          :core_filter_kv = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__filter_kv() {
     let items = "0123456".to_array()
     test("".filter_kv(fn (idx, char) idx === 0 && char === items[0]) === "")
     test("1".filter_kv(fn (idx, char) idx === 0 && char === items[1]) === "1")
     test("1".filter_kv(fn (idx, char) idx =/= 0 && char === items[1]) === "")
     test("1".filter_kv(fn (idx, char) idx === 0 && char =/= items[1]) === "")
     test("012233344445555".filter_kv(fn (idx, char) idx.even?() && char =/= items[0]) === "2334455")
     test("012233344445555".filter_kv(fn (idx, char) idx.even?() && char =/= items[1]) === "02334455")
     test("012233344445555".filter_kv(fn (idx, char) idx.even?() && char =/= items[2]) === "0334455")
     test("012233344445555".filter_kv(fn (idx, char) idx.even?() && char =/= items[3]) === "024455")
     test("012233344445555".filter_kv(fn (idx, char) idx.even?() && char =/= items[4]) === "023355")
     test("012233344445555".filter_kv(fn (idx, char) idx.even?() && char =/= items[5]) === "023344")
     test("012233344445555".filter_kv(fn (idx, char) idx.even?() && char =/= items[6]) === "02334455")

     let items = "\000091\0000b3\0000ab!\0000a4\0000a7\0000b5f".to_array()
     test("\000091".filter_kv(fn (idx, char) idx === 0 && char === items[0]) === "\000091")
     test("\000091".filter_kv(fn (idx, char) idx =/= 0 && char === items[0]) === "")
     test("\000091".filter_kv(fn (idx, char) idx === 0 && char =/= items[0]) === "")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter_kv(fn (idx, char) idx.even?() && char =/= items[0]) === "\0000ab!\0000a4\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter_kv(fn (idx, char) idx.even?() && char =/= items[1]) === "\000091\0000ab!\0000a4\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter_kv(fn (idx, char) idx.even?() && char =/= items[2]) === "\000091!\0000a4\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter_kv(fn (idx, char) idx.even?() && char =/= items[3]) === "\000091\0000ab\0000a4\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter_kv(fn (idx, char) idx.even?() && char =/= items[4]) === "\000091\0000ab!\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter_kv(fn (idx, char) idx.even?() && char =/= items[5]) === "\000091\0000ab!\0000a4\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter_kv(fn (idx, char) idx.even?() && char =/= items[6]) === "\000091\0000ab!\0000a4")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter_kv(fn (idx, char) idx.even?() && char =/= items[7]) === "\000091\0000ab!\0000a4\0000b5")

     let items  = "01234567fg".to_array()
     let string = ("0011012375611135f" ++ "g0")[1, 18]
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[0]) === "1135115g")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[1]) === "0355g")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[2]) === "01135115g")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[3]) === "0115115g")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[4]) === "01135115g")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[5]) === "011311g")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[6]) === "01135115g")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[7]) === "01135115g")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[8]) === "01135115g")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[9]) === "01135115")
     string.ignore()

     let items = "01234567fg".to_array()
     test(("0011012375611135f" ++ "g0")[1, 18].filter_kv(fn (idx, char) idx.even?() && char =/= items[0]) === "1135115g")
     test(("0011012375611135f" ++ "g0")[1, 18].filter_kv(fn (idx, char) idx.even?() && char =/= items[1]) === "0355g")
