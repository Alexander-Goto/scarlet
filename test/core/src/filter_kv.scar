     test([obj].filter_kv(fn (_, _, _) string_1) === [obj])
     test([obj :_ = [obj]].filter_kv(fn (_, _, _) string_1) === [obj])
     test([obj :_ = [obj]].filter_kv(fn (_, _, _) string_1):_ === [obj])

     test("".filter_kv(fn (_, _) string_1) === "")
     test(u"".filter_kv(fn (_, _) string_1) === u"")
     test([array].filter_kv(fn (_, _) string_1) === [array])
     test([table].filter_kv(fn (_, _) string_1) === [table])
     test([obj].filter_kv(fn (_, _) string_1) === [obj])
     test([obj :_ = [obj]].filter_kv(fn (_, _) string_1) === [obj])
     test([obj :_ = [obj]].filter_kv(fn (_, _) string_1):_ === [obj])

     test("1".filter_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().filter_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"1".filter_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().filter_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([array heap_string()].filter_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([table heap_string() = heap_string()].filter_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([obj :1 = heap_string()].filter_kv(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)

     test("1".filter_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
     test(heap_string().filter_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
     test(u"1".filter_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
     test(heap_byte_array().filter_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
     test([array heap_string()].filter_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
     test([table heap_string() = heap_string()].filter_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
     test([obj :1 = heap_string()].filter_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
}
