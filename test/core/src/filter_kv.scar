     test(("0011012375611135f" ++ "g0")[1, 18].filter_kv(fn (idx, char) idx.even?() && char =/= items[3]) === "0115115g")
     test(("0011012375611135f" ++ "g0")[1, 18].filter_kv(fn (idx, char) idx.even?() && char =/= items[4]) === "01135115g")
     test(("0011012375611135f" ++ "g0")[1, 18].filter_kv(fn (idx, char) idx.even?() && char =/= items[5]) === "011311g")
     test(("0011012375611135f" ++ "g0")[1, 18].filter_kv(fn (idx, char) idx.even?() && char =/= items[6]) === "01135115g")
     test(("0011012375611135f" ++ "g0")[1, 18].filter_kv(fn (idx, char) idx.even?() && char =/= items[7]) === "01135115g")
     test(("0011012375611135f" ++ "g0")[1, 18].filter_kv(fn (idx, char) idx.even?() && char =/= items[8]) === "01135115g")
     test(("0011012375611135f" ++ "g0")[1, 18].filter_kv(fn (idx, char) idx.even?() && char =/= items[9]) === "01135115")

     let items = "01234567fg".to_array()
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[0]) === "1135115g")
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[1]) === "0355g")
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[2]) === "01135115g")
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[3]) === "0115115g")
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[4]) === "01135115g")
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[5]) === "011311g")
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[6]) === "01135115g")
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[7]) === "01135115g")
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[8]) === "01135115g")
     test(("011012375611135f" ++ "g").filter_kv(fn (idx, char) idx.even?() && char =/= items[9]) === "01135115")

     let items  = "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7g".to_array()
     let string = ("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11]
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[0]) === "\0000ab\0000a7 \0000ae")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[1]) === "\000091\0000ab\0000a7 \0000ae")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[2]) === "\000091\0000a7 \0000ae")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[3]) === "\000091\0000ab\0000a7 \0000ae")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[4]) === "\000091\0000ab \0000ae")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[5]) === "\000091\0000ab\0000a7 \0000ae")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[6]) === "\000091\0000ab\0000a7\0000ae")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[7]) === "\000091\0000ab\0000a7 \0000ae")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[8]) === "\000091\0000ab\0000a7 ")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[9]) === "\000091\0000ab\0000a7 \0000ae")
     test(string.filter_kv(fn (idx, char) idx.even?() && char =/= items[10]) === "\000091\0000ab\0000a7 \0000ae")
     string.ignore()

     let items = "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7g".to_array()
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[0]) === "\0000ab\0000a7 \0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[1]) === "\000091\0000ab\0000a7 \0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[2]) === "\000091\0000a7 \0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[3]) === "\000091\0000ab\0000a7 \0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[4]) === "\000091\0000ab \0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[5]) === "\000091\0000ab\0000a7 \0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[6]) === "\000091\0000ab\0000a7\0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[7]) === "\000091\0000ab\0000a7 \0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[8]) === "\000091\0000ab\0000a7 ")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[9]) === "\000091\0000ab\0000a7 \0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter_kv(fn (idx, char) idx.even?() && char =/= items[10]) === "\000091\0000ab\0000a7 \0000ae")

     let items = "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7g".to_array()
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[0]) === "\0000ab\0000a7 \0000ae")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[1]) === "\000091\0000ab\0000a7 \0000ae")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[2]) === "\000091\0000a7 \0000ae")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[3]) === "\000091\0000ab\0000a7 \0000ae")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[4]) === "\000091\0000ab \0000ae")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[5]) === "\000091\0000ab\0000a7 \0000ae")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[6]) === "\000091\0000ab\0000a7\0000ae")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[7]) === "\000091\0000ab\0000a7 \0000ae")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[8]) === "\000091\0000ab\0000a7 ")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[9]) === "\000091\0000ab\0000a7 \0000ae")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter_kv(fn (idx, char) idx.even?() && char =/= items[10]) === "\000091\0000ab\0000a7 \0000ae")

     let items  = "01".to_array()
     let string = ("0101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 65]
     test(string.filter_kv(fn (_, char) char === items[0]) === "00000000000000000000000000000000")
     test(string.filter_kv(fn (idx, _) idx.odd?()) === "00000000000000000000000000000000")
     test(string.filter_kv(fn (_, char) char === items[1]) === "11111111111111111111111111111111")
     test(string.filter_kv(fn (idx, _) idx.even?()) === "11111111111111111111111111111111")
     string.ignore()

     let items = "01".to_array()
     test(("0101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 65].filter_kv(fn (_, char) char === items[0]) === "00000000000000000000000000000000")
     test(("0101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 65].filter_kv(fn (idx, _) idx.odd?()) === "00000000000000000000000000000000")
     test(("0101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 65].filter_kv(fn (_, char) char === items[1]) === "11111111111111111111111111111111")
     test(("0101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 65].filter_kv(fn (idx, _) idx.even?()) === "11111111111111111111111111111111")

     let items = "01".to_array()
     test(("101010101010101010101010101010101010101010101010101010101010101" ++ "0").filter_kv(fn (_, char) char === items[0]) === "00000000000000000000000000000000")
