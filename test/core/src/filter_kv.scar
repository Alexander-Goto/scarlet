     test(("000000000000000000000000" ++ "0").filter_kv(fn (_, char) char === items[0]) === "0000000000000000000000000")
     test(("000000000000000000000000" ++ "0").filter_kv(fn (_, char) char =/= items[0]) === "")
     test(("100000000000000000000000" ++ "0").filter_kv(fn (_, char) char =/= items[0]) === "1")
     test(("100000000000000000000000" ++ "0").filter_kv(fn (_, char) char === items[0]) === "000000000000000000000000")
     test(("00000000012345600000000000000" ++ "0").filter_kv(fn (_, char) char =/= items[0]) === "123456")
     test(("000000000123456789abcdefg00000000000000" ++ "0").filter_kv(fn (_, char) char =/= items[0]) === "123456789abcdefg")

     let [box string_1, string_2] = if (rnd() & 1) === 0 {
          let string_1 = rnd_string()
          let string_2 = if (rnd() & 1) === 0; string_1 else null
          [box string_1, string_2]
     } else [box "Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let expected_string = string_1.foldl_kv("", fn (expected_string, idx, char) if char.lower?() && idx.even?(); expected_string.append(char) else expected_string)
     test(string_1.filter_kv(fn (idx, char) char.lower?() && idx.even?()) === expected_string)
     string_2.ignore()

     let [box string_1, string_2] = if (rnd() & 1) === 0 {
