fn to_custom_const__time_limit_pop(arg) custom__create(
     arg
     [obj]
)

`noinline`
fn test__time_limit_pop() {
     let [box in, out] = make_channel()
     let string        = heap_string()

     test(push(in, "Hello!!!").null?())
     test(time_limit_pop(out, 0) === "Hello!!!")
     test(push(in, string).null?())
     test(time_limit_pop(out, 0) === string)
     test(push(in, [box]).null?())
     test(time_limit_pop(out, 0) === [box])
     test(push(in, [box 1, 2, 3]).null?())
     test(time_limit_pop(out, 0) === [box 1, 2, 3])
     test(push(in, [box string]).null?())
     test(time_limit_pop(out, 0) === [box string])
     test(push(in, [obj :1 = string]).null?())
     test(time_limit_pop(out, 0) === [obj :1 = string])
     test(push(in, [table :1 = string]).null?())
     test(time_limit_pop(out, 0) === [table :1 = string])
     test(push(in, [set string]).null?())
     test(time_limit_pop(out, 0) === [set string])
     test(push(in, u"Hello world" ++ u"!!!").null?())
     test(time_limit_pop(out, 0) === u"Hello world!!!")
     test(push(in, [array string]).null?())
     test(time_limit_pop(out, 0) === [array string])
     test(push(in, _ ++ string).null?())
     test(time_limit_pop(out, 0)(string) === string ++ string)
     test(push(in, (fn (a, b) a.null?() && b === 12)(null, _)).null?())
     test(time_limit_pop(out, 0)(12))
     test(push(in, 12.to_custom_const__time_limit_pop()).null?())
     test(time_limit_pop(out, 0).custom__get_data() === 12)

     test(push(in, "Hello!!!").null?())
     test(push(in, string).null?())
     test(push(in, [box]).null?())
     test(push(in, [box 1, 2, 3]).null?())
     test(push(in, [box string]).null?())
     test(push(in, [obj :1 = string]).null?())
     test(push(in, [table :1 = string]).null?())
     test(push(in, [set string]).null?())
     test(push(in, u"Hello world" ++ u"!!!").null?())
     test(push(in, [array string]).null?())
     test(push(in, _ ++ string).null?())
     test(push(in, (fn (a, b) a.null?() && b === 12)(null, _)).null?())
     test(push(in, 12.to_custom_const__time_limit_pop()).null?())
     test(time_limit_pop(out, 0) === "Hello!!!")
     test(time_limit_pop(out, 0) === string)
     test(time_limit_pop(out, 0) === [box])
     test(time_limit_pop(out, 0) === [box 1, 2, 3])
     test(time_limit_pop(out, 0) === [box string])
     test(time_limit_pop(out, 0) === [obj :1 = string])
     test(time_limit_pop(out, 0) === [table :1 = string])
     test(time_limit_pop(out, 0) === [set string])
     test(time_limit_pop(out, 0) === u"Hello world!!!")
     test(time_limit_pop(out, 0) === [array string])
     test(time_limit_pop(out, 0)(string) === string ++ string)
     test(time_limit_pop(out, 0)(12))
     test(time_limit_pop(out, 0).custom__get_data() === 12)

     test(push(in, "Hello!!!").null?())
     test(push(in, string).null?())
     test(push(in, [box]).null?())
     test(push(in, [box 1, 2, 3]).null?())
     test(push(in, [box string]).null?())
     test(push(in, [obj :1 = string]).null?())
     test(time_limit_pop(out, 0) === "Hello!!!")
     test(time_limit_pop(out, 0) === string)
     test(time_limit_pop(out, 0) === [box])
     test(time_limit_pop(out, 0) === [box 1, 2, 3])
     test(time_limit_pop(out, 0) === [box string])
     test(time_limit_pop(out, 0) === [obj :1 = string])
     test(push(in, [table :1 = string]).null?())
     test(push(in, [set string]).null?())
     test(push(in, u"Hello world" ++ u"!!!").null?())
     test(push(in, [array string]).null?())
     test(push(in, _ ++ string).null?())
     test(push(in, (fn (a, b) a.null?() && b === 12)(null, _)).null?())
     test(push(in, 12.to_custom_const__time_limit_pop()).null?())
     test(time_limit_pop(out, 0) === [table :1 = string])
     test(time_limit_pop(out, 0) === [set string])
     test(time_limit_pop(out, 0) === u"Hello world!!!")
     test(time_limit_pop(out, 0) === [array string])
     test(time_limit_pop(out, 0)(string) === string ++ string)
     test(time_limit_pop(out, 0)(12))
     test(time_limit_pop(out, 0).custom__get_data() === 12)

     thread(fn () {
          sleep(1'000'000'000)
          push(in, string)
     })
     test(time_limit_pop(out, 0).null?())
     test(time_limit_pop(out, 2'000'000'000) === string)

     let array = rnd_string_array()
     let len   = len(array)
     array.foldl(null, fn (_, string) push(in, string))
     let new_array = loop([array], fn (array) {
          let array = array.append(time_limit_pop(out, 0))
          break(len(array) === len, array)
     })
     test(array === new_array)

     let error_1 = expected_error(:1, string, string)
     let error_2 = expected_error(:2, string, string)
     test(time_limit_pop(error_1, rnd() >> 1).get_error_id() === :1)
     test(time_limit_pop(out, error_1).get_error_id() === :1)
     test(time_limit_pop(error_1, error_2).get_error_id() === :1)
     test(time_limit_pop(error_2, error_1).get_error_id() === :2)
     test(time_limit_pop(error_1, string).get_error_id() === :1)
     test(time_limit_pop(string, error_1).get_error_id() === :1)
     test(time_limit_pop(error_1, -1.scarlet__erase_info()).get_error_id() === :1)
     test(time_limit_pop(error_1, -9223372036854775808.scarlet__erase_info()).get_error_id() === :1)

     test(time_limit_pop(string, rnd() >> 1).get_error_id() === :invalid_type)
     test(time_limit_pop(out, string).get_error_id() === :invalid_type)
     test(time_limit_pop(string, string).get_error_id() === :invalid_type)

     test(time_limit_pop(out, -1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(time_limit_pop(out, -9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)

     test(time_limit_pop(in, rnd() >> 1).get_error_id() === :cant_read_from_channel)

     let [box _, out] = make_channel()
     test(time_limit_pop(out, 0).get_error_id() === :no_writing_channel)
     test(time_limit_pop(out, 10000).get_error_id() === :no_writing_channel)
}