     let string_1               = rnd_string()
     let string_2               = if rnd_bool(); string_1 else null
     let separator              = if rnd_bool(); string_1[rnd() & (len(string_1) - 1)] else rnd_char()
     let [box parts, last_part] = string_1.foldl([box [array].init(1), ""], fn (state, char) {
          let [box parts, current_part] = state

          if char === separator
               [box parts.append(current_part), ""]
          else [box parts, current_part.append(char)]
     })
     let parts = parts.append(last_part)
     test(parts === string_1.split(separator))
     string_2.ignore()

