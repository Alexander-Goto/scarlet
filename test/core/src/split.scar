     test("0123456789abcdef".split('3') === [array "012", "456789abcdef"])
     test("0123456789abcdef".split('4') === [array "0123", "56789abcdef"])
     test("0123456789abcdef".split('5') === [array "01234", "6789abcdef"])
     test("0123456789abcdef".split('6') === [array "012345", "789abcdef"])
     test("0123456789abcdef".split('7') === [array "0123456", "89abcdef"])
