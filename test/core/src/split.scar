let array__split = [obj
     :value = [array]

     :_ = [obj
          :core_split     = fn (array, separator) array:value.split(separator).map(to_array__split(_))
          :core___equal__ = fn (array_1, array_2) array_1:value === array_2:value
     ]
]

fn to_array__split(arg) new (@main.array__split):value <= arg

fn to_custom_array__split(arg) custom__create(
     arg
     [obj
          :core_split     = fn (array, separator) custom__get_data(array).split(separator).map(to_custom_array__split(_))
          :core___equal__ = fn (array_1, array_2) array_1.custom__get_data() === array_2.custom__get_data()
     ]
)

let broken_array__split = [obj
     :value = [array]

     :_ = [obj
          :core_split = fn (_, _) heap_string()
     ]
]

fn to_broken_array__split(arg) new (@main.broken_array__split):value <= arg

fn to_broken_custom_array__split(arg) custom__create(
     arg
     [obj
          :core_split = fn (_, _) heap_string()
     ]
)

let error_array__split = [obj
     :value = [array]

     :_ = [obj
          :core_split = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__split(arg) new (@main.error_array__split):value <= arg

fn to_error_custom_array__split(arg) custom__create(
     arg
     [obj
          :core_split = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__split() {
     test("".split('0') === [array ""])
     test("1".split('0') === [array "1"])
     test("1".split('1') === [array "", ""])
     test("11".split('1') === [array "", "", ""])
     test("12".split('1') === [array "", "2"])
     test("21".split('1') === [array "2", ""])
     test("121".split('1') === [array "", "2", ""])
     test("212".split('1') === [array "2", "2"])
     test("0123056709abcd0".split('0') === [array "", "123", "567", "9abcd", ""])
     test("0123456789abcde".split('0') === [array "", "123456789abcde"])
     test("0123456789abcde".split('1') === [array "0", "23456789abcde"])
     test("0123456789abcde".split('2') === [array "01", "3456789abcde"])
     test("0123456789abcde".split('3') === [array "012", "456789abcde"])
     test("0123456789abcde".split('4') === [array "0123", "56789abcde"])
     test("0123456789abcde".split('5') === [array "01234", "6789abcde"])
     test("0123456789abcde".split('6') === [array "012345", "789abcde"])
     test("0123456789abcde".split('7') === [array "0123456", "89abcde"])
     test("0123456789abcde".split('8') === [array "01234567", "9abcde"])
     test("0123456789abcde".split('9') === [array "012345678", "abcde"])
     test("0123456789abcde".split('a') === [array "0123456789", "bcde"])
     test("0123456789abcde".split('b') === [array "0123456789a", "cde"])
     test("0123456789abcde".split('c') === [array "0123456789ab", "de"])
     test("0123456789abcde".split('d') === [array "0123456789abc", "e"])
     test("0123456789abcde".split('e') === [array "0123456789abcd", ""])
     test("0123456789abcde".split('z') === [array "0123456789abcde"])

     test("\000091".split('0') === [array "\000091"])
     test("\000091".split('\000091') === [array "", ""])
     test("\000091\000091".split('\000091') === [array "", "", ""])
     test("\0000912".split('\000091') === [array "", "2"])
     test("2\000091".split('\000091') === [array "2", ""])
     test("\0000912\000091".split('\000091') === [array "", "2", ""])
     test("2\0000912".split('\000091') === [array "2", "2"])
     test("\00009012\00009056\0000909ad\000090".split('\000090') === [array "", "12", "56", "9ad", ""])
     test("0\00009123\000094567\0000989\00009a".split('0') === [array "", "\00009123\000094567\0000989\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('\000091') === [array "0", "23\000094567\0000989\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('2') === [array "0\000091", "3\000094567\0000989\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('3') === [array "0\0000912", "\000094567\0000989\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('\000094') === [array "0\00009123", "567\0000989\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('5') === [array "0\00009123\000094", "67\0000989\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('6') === [array "0\00009123\0000945", "7\0000989\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('7') === [array "0\00009123\00009456", "\0000989\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('\000098') === [array "0\00009123\000094567", "9\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('9') === [array "0\00009123\000094567\000098", "\00009a"])
     test("0\00009123\000094567\0000989\00009a".split('\00009a') === [array "0\00009123\000094567\0000989", ""])
     test("0\00009123\000094567\0000989\00009a".split('b') === [array "0\00009123\000094567\0000989\00009a"])

     test("0123056709abcd00".split('0') === [array "", "123", "567", "9abcd", "", ""])
     test("0123456789abcdef".split('0') === [array "", "123456789abcdef"])
     test("0123456789abcdef".split('1') === [array "0", "23456789abcdef"])
