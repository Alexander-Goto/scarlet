     test("0123456789abcdef".split('9') === [array "012345678", "abcdef"])
     test("0123456789abcdef".split('a') === [array "0123456789", "bcdef"])
     test("0123456789abcdef".split('b') === [array "0123456789a", "cdef"])
     test("0123456789abcdef".split('c') === [array "0123456789ab", "def"])
     test("0123456789abcdef".split('d') === [array "0123456789abc", "ef"])
     test("0123456789abcdef".split('e') === [array "0123456789abcd", "f"])
     test("0123456789abcdef".split('f') === [array "0123456789abcde", ""])
     test("0123456789abcdef".split('z') === [array "0123456789abcdef"])
     test("0123456789abcdefz0123456789abcdef".split('z') === [array "0123456789abcdef", "0123456789abcdef"])

     test("\000090\00009123\000090567\0000909\00009abcd\000090\000090".split('\000090') === [array "", "\00009123", "567", "9\00009abcd", "", ""])
     test("0\00009123\000094567\0000989\00009abcdef".split('0') === [array "", "\00009123\000094567\0000989\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('\000091') === [array "0", "23\000094567\0000989\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('2') === [array "0\000091", "3\000094567\0000989\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('3') === [array "0\0000912", "\000094567\0000989\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('\000094') === [array "0\00009123", "567\0000989\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('5') === [array "0\00009123\000094", "67\0000989\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('6') === [array "0\00009123\0000945", "7\0000989\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('7') === [array "0\00009123\00009456", "\0000989\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('\000098') === [array "0\00009123\000094567", "9\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('9') === [array "0\00009123\000094567\000098", "\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('\00009a') === [array "0\00009123\000094567\0000989", "bcdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('b') === [array "0\00009123\000094567\0000989\00009a", "cdef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('c') === [array "0\00009123\000094567\0000989\00009ab", "def"])
     test("0\00009123\000094567\0000989\00009abcdef".split('d') === [array "0\00009123\000094567\0000989\00009abc", "ef"])
     test("0\00009123\000094567\0000989\00009abcdef".split('e') === [array "0\00009123\000094567\0000989\00009abcd", "f"])
     test("0\00009123\000094567\0000989\00009abcdef".split('f') === [array "0\00009123\000094567\0000989\00009abcde", ""])
     test("0\00009123\000094567\0000989\00009abcdef".split('z') === [array "0\00009123\000094567\0000989\00009abcdef"])
     test("0\00009123\000094567\0000989\00009abcdefz0\00009123\000094567\0000989\00009abcdef".split('z') === [array "0\00009123\000094567\0000989\00009abcdef", "0\00009123\000094567\0000989\00009abcdef"])

     let string = ("00123056709abcd00" ++ "0")[1, 17]
     test(string.split('0') === [array "", "123", "567", "9abcd", "", ""])
