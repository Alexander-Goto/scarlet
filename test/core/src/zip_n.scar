     ])
     test(zip_n([box u"0123456789abcde", u"edcba9876543210g"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array
          [array u"0"[0], u"e"[0], heap_string()]
          [array u"1"[0], u"d"[0], heap_string()]
          [array u"2"[0], u"c"[0], heap_string()]
          [array u"3"[0], u"b"[0], heap_string()]
          [array u"4"[0], u"a"[0], heap_string()]
