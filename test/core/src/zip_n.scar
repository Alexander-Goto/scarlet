let array__zip_n = [obj
     :value = [array]

     :_ = [obj
          :core_zip_n = fn (arrays, func) {
               let [box array_1, array_2] = arrays
               zip_n([box array_1:value, array_2:value], func)
          }
     ]
]

fn to_array__zip_n(arg) new (@main.array__zip_n):value <= arg

fn to_custom_array__zip_n(arg) custom__create(
     arg
     [obj
          :core_zip_n = fn (arrays, func) {
               let [box array_1, array_2] = arrays
               zip_n([box custom__get_data(array_1), array_2.custom__get_data()], func)
          }
     ]
)

let error_array__zip_n = [obj
     :value = [array]

     :_ = [obj
          :core_zip_n = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__zip_n(arg) new (@main.error_array__zip_n):value <= arg

fn to_error_custom_array__zip_n(arg) custom__create(
     arg
     [obj
          :core_zip_n = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__zip_n() {
     let items        = [array heap_string()]
     let string_array = rnd_string_array()
     let len          = (rnd() & 1023) + 1
     let token_array  = loop([array].init(len), fn (array) {
          let array = array.append(loop(rnd_token(), fn (key) if key =/= :_; [breaker key] else rnd_token()))
          break(len(array) === len, array)
     })

     test(zip_n([box "", ""], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box "0", ""], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box "", "1"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box heap_string(), ""], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box "", heap_string()], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box "0", "1"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array '0', '1', heap_string()]])
     test(zip_n([box "1", "0"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array '1', '0', heap_string()]])
     test(zip_n([box "1", "02"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array '1', '0', heap_string()]])
     test(zip_n([box "13", "0"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array '1', '0', heap_string()]])
     test(zip_n([box "13", "02"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array '1', '0', heap_string()], [array '3', '2', heap_string()]])
     test(zip_n([box "0123456789abcde", "edcba9876543210"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array
          [array '0', 'e', heap_string()]
          [array '1', 'd', heap_string()]
          [array '2', 'c', heap_string()]
          [array '3', 'b', heap_string()]
          [array '4', 'a', heap_string()]
          [array '5', '9', heap_string()]
          [array '6', '8', heap_string()]
          [array '7', '7', heap_string()]
          [array '8', '6', heap_string()]
          [array '9', '5', heap_string()]
          [array 'a', '4', heap_string()]
          [array 'b', '3', heap_string()]
          [array 'c', '2', heap_string()]
          [array 'd', '1', heap_string()]
          [array 'e', '0', heap_string()]
     ])
     test(zip_n([box "0123456789abcdef", "edcba9876543210"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array
          [array '0', 'e', heap_string()]
          [array '1', 'd', heap_string()]
          [array '2', 'c', heap_string()]
          [array '3', 'b', heap_string()]
          [array '4', 'a', heap_string()]
          [array '5', '9', heap_string()]
          [array '6', '8', heap_string()]
          [array '7', '7', heap_string()]
          [array '8', '6', heap_string()]
          [array '9', '5', heap_string()]
          [array 'a', '4', heap_string()]
          [array 'b', '3', heap_string()]
          [array 'c', '2', heap_string()]
          [array 'd', '1', heap_string()]
          [array 'e', '0', heap_string()]
     ])
     test(zip_n([box "0123456789abcde", "edcba9876543210g"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array
          [array '0', 'e', heap_string()]
          [array '1', 'd', heap_string()]
          [array '2', 'c', heap_string()]
          [array '3', 'b', heap_string()]
          [array '4', 'a', heap_string()]
          [array '5', '9', heap_string()]
          [array '6', '8', heap_string()]
          [array '7', '7', heap_string()]
          [array '8', '6', heap_string()]
          [array '9', '5', heap_string()]
          [array 'a', '4', heap_string()]
          [array 'b', '3', heap_string()]
          [array 'c', '2', heap_string()]
          [array 'd', '1', heap_string()]
          [array 'e', '0', heap_string()]
     ])
     test(zip_n([box "0123456789abcdef", "edcba9876543210g"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array
          [array '0', 'e', heap_string()]
          [array '1', 'd', heap_string()]
          [array '2', 'c', heap_string()]
          [array '3', 'b', heap_string()]
          [array '4', 'a', heap_string()]
          [array '5', '9', heap_string()]
          [array '6', '8', heap_string()]
          [array '7', '7', heap_string()]
          [array '8', '6', heap_string()]
          [array '9', '5', heap_string()]
          [array 'a', '4', heap_string()]
          [array 'b', '3', heap_string()]
          [array 'c', '2', heap_string()]
          [array 'd', '1', heap_string()]
          [array 'e', '0', heap_string()]
          [array 'f', 'g', heap_string()]
     ])

     let string_1  = rnd_string()
     let string_2  = if rnd_bool(); string_1 else null
     let string_3  = rnd_string()
     let string_4  = if rnd_bool(); string_3 else null
     let small_len = if len(string_1) < len(string_3); len(string_1) else len(string_3)
     let expected  = string_1.take(small_len).foldl_kv([array].init(small_len), fn (result, idx, char) result.append([array char, string_3[idx], items[0]]))
     test(expected === zip_n([box string_1, string_3], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     string_2.ignore()
     string_4.ignore()

     let string_1 = rnd_string()
     let string_2 = if rnd_bool(); string_1 else null
     let expected = string_1.foldl([array].init(len(string_1)), fn (result, char) result.append([array char, char, items[0]]))
     test(expected === zip_n([box string_1, string_1], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     string_2.ignore()

     test(zip_n([box u"", u""], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box u"0", u""], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box u"", u"1"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box heap_byte_array(), u""], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box u"", heap_byte_array()], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box u"0", u"1"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array u"0"[0], u"1"[0], heap_string()]])
     test(zip_n([box u"1", u"0"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array u"1"[0], u"0"[0], heap_string()]])
     test(zip_n([box u"1", u"02"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array u"1"[0], u"0"[0], heap_string()]])
     test(zip_n([box u"13", u"0"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array u"1"[0], u"0"[0], heap_string()]])
     test(zip_n([box u"13", u"02"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array u"1"[0], u"0"[0], heap_string()], [array u"3"[0], u"2"[0], heap_string()]])
     test(zip_n([box u"0123456789abcd", u"dcba9876543210"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array
          [array u"0"[0], u"d"[0], heap_string()]
          [array u"1"[0], u"c"[0], heap_string()]
          [array u"2"[0], u"b"[0], heap_string()]
          [array u"3"[0], u"a"[0], heap_string()]
          [array u"4"[0], u"9"[0], heap_string()]
          [array u"5"[0], u"8"[0], heap_string()]
          [array u"6"[0], u"7"[0], heap_string()]
          [array u"7"[0], u"6"[0], heap_string()]
          [array u"8"[0], u"5"[0], heap_string()]
          [array u"9"[0], u"4"[0], heap_string()]
          [array u"a"[0], u"3"[0], heap_string()]
          [array u"b"[0], u"2"[0], heap_string()]
          [array u"c"[0], u"1"[0], heap_string()]
          [array u"d"[0], u"0"[0], heap_string()]
     ])
     test(zip_n([box u"0123456789abcdef", u"edcba9876543210"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array
          [array u"0"[0], u"e"[0], heap_string()]
