     let arrays = loop([array].init(16), fn (arrays) {
          let arrays = arrays.append(
               (switch (rnd() >> 1) % 3
               case 0: rnd_string()
               case 1: rnd_byte_array()
               case 2: rnd_string_array()
               default: unreachable()).drop(1)
          )
          break(len(arrays) === 16, arrays)
     })
     let borrowed_arrays = arrays.foldl([array].init(16), fn (borrowed_arrays, array) if rnd_bool(); borrowed_arrays.append(array) else borrowed_arrays)
     let small_len       = arrays.foldl(0.max_val(), fn (small_len, array) min(small_len, len(array)))
     let expected        = arrays[0].take(small_len).foldl_kv([array].init(small_len), fn (result, idx, item_1) result.append([array
          item_1
          arrays[1][idx]
          arrays[2][idx]
          arrays[3][idx]
          arrays[4][idx]
          arrays[5][idx]
          arrays[6][idx]
          arrays[7][idx]
