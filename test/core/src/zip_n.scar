     test(zip_n([box [obj], [obj]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [obj])
     test(zip_n([box [obj :_ = [obj]], [obj :_ = [obj]]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [obj])
     test(zip_n([box [obj :_ = [obj]], [obj :_ = [obj]]], fn (item_1, item_2) [array item_1, item_2, items[0]]):_.null?())
     test(zip_n([box [obj :0 = 10], [obj]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [obj])
     test(zip_n([box [obj :0 = 10, :_ = [obj]], [obj :_ = [obj]]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [obj])
     test(zip_n([box [obj :0 = 10, :_ = [obj]], [obj :_ = [obj]]], fn (item_1, item_2) [array item_1, item_2, items[0]]):_.null?())
