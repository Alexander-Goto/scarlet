     test(zip_n([box [obj :0 = 10], [obj :1 = 11]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [obj])
     test(zip_n([box [obj :1 = 11], [obj :0 = 10]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [obj])
     test(zip_n([box [obj :1 = 11], [obj :1 = 111, :2 = 12]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [obj :1 = [array 11, 111, heap_string()]])
     test(zip_n([box [obj :1 = 11, :2 = 12], [obj :1 = 111]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [obj :1 = [array 11, 111, heap_string()]])
