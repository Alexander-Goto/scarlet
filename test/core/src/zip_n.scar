          item_5
          item_6
          item_7
          item_8
          item_9
          item_10
          item_11
          item_12
          item_13
          item_14
          item_15
          item_16
     ]))
     borrowed_containers.ignore()

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(zip_n(error_1, _ ++ heap_string()).get_error_id() === :1)
     test(zip_n([box heap_string(), heap_string()], error_1).get_error_id() === :1)
     test(zip_n(error_1, error_2).get_error_id() === :1)
     test(zip_n(error_2, error_1).get_error_id() === :2)
     test(zip_n(error_1, heap_string()).get_error_id() === :1)
     test(zip_n(heap_string(), error_1).get_error_id() === :1)

     test(zip_n(heap_string(), _ ++ heap_string()).get_error_id() === :invalid_type)
     test(zip_n([box heap_string(), heap_string()], heap_string()).get_error_id() === :invalid_type)
     test(zip_n(heap_string(), heap_string()).get_error_id() === :invalid_type)

     test(zip_n([box heap_string()], _ ++ heap_string()).get_error_id() === :out_of_bounds)
     test(zip_n([box], _ ++ heap_string()).get_error_id() === :out_of_bounds)

     test(zip_n([box heap_string(), heap_byte_array()], fn (_, _) expected_error(:11, heap_string(), heap_string())).get_error_id() === :11)
     test(zip_n([box heap_string(), heap_byte_array()], fn (item_1, item_2, item_3) [array item_1, item_2, item_3]).get_error_id() === :wrong_num_fn_args)

     test([box to_error_array__zip_n([array].init(10)), to_error_array__zip_n([array].init(10))].zip_n(fn (_, _) string_1).get_error_id() == :3)
     test([box to_error_custom_array__zip_n([array].init(10)), to_error_custom_array__zip_n([array].init(10))].zip_n(fn (_, _) string_1).get_error_id() == :4)
