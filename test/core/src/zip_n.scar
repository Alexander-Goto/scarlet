          [array u"d"[0], u"1"[0], heap_string()]
          [array u"e"[0], u"0"[0], heap_string()]
     ])
     test(zip_n([box u"0123456789abcdef", u"edcba9876543210g"], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array
          [array u"0"[0], u"e"[0], heap_string()]
          [array u"1"[0], u"d"[0], heap_string()]
          [array u"2"[0], u"c"[0], heap_string()]
          [array u"3"[0], u"b"[0], heap_string()]
          [array u"4"[0], u"a"[0], heap_string()]
          [array u"5"[0], u"9"[0], heap_string()]
          [array u"6"[0], u"8"[0], heap_string()]
          [array u"7"[0], u"7"[0], heap_string()]
          [array u"8"[0], u"6"[0], heap_string()]
          [array u"9"[0], u"5"[0], heap_string()]
          [array u"a"[0], u"4"[0], heap_string()]
          [array u"b"[0], u"3"[0], heap_string()]
          [array u"c"[0], u"2"[0], heap_string()]
          [array u"d"[0], u"1"[0], heap_string()]
          [array u"e"[0], u"0"[0], heap_string()]
          [array u"f"[0], u"g"[0], heap_string()]
     ])

     let array_1   = rnd_byte_array()
     let array_2   = if rnd_bool(); array_1 else null
     let array_3   = rnd_byte_array()
     let array_4   = if rnd_bool(); array_3 else null
     let small_len = if len(array_1) < len(array_3); len(array_1) else len(array_3)
     let expected  = array_1.take(small_len).foldl_kv([array].init(small_len), fn (result, idx, byte) result.append([array byte, array_3[idx], items[0]]))
     test(expected === zip_n([box array_1, array_3], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     array_2.ignore()
     array_4.ignore()

     let array_1  = rnd_byte_array()
     let array_2  = if rnd_bool(); array_1 else null
     let expected = array_1.foldl([array].init(len(array_1)), fn (result, byte) result.append([array byte, byte, items[0]]))
     test(expected === zip_n([box array_1, array_1], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     array_2.ignore()

     test(zip_n([box [array], [array]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box [array 0], [array]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box [array], [array 1]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box [array].init(10), [array].init(10)], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box [array 0], [array].init(10)], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box [array].init(10), [array 1]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array])
     test(zip_n([box [array 0], [array 1]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array 0, 1, heap_string()]])
     test(zip_n([box [array 1], [array 0]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array 1, 0, heap_string()]])
     test(zip_n([box [array 1], [array 0, 2]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array 1, 0, heap_string()]])
     test(zip_n([box [array 1, 3], [array 0]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array 1, 0, heap_string()]])
     test(zip_n([box [array 1, 3], [array 0, 2]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [array [array 1, 0, heap_string()], [array 3, 2, heap_string()]])

     let array_1   = rnd_string_array()
     let array_2   = if rnd_bool(); array_1 else null
     let array_3   = rnd_string_array()
     let array_4   = if rnd_bool(); array_3 else null
     let small_len = if len(array_1) < len(array_3); len(array_1) else len(array_3)
     let expected  = array_1.take(small_len).foldl_kv([array].init(small_len), fn (result, idx, string) result.append([array string, array_3[idx], items[0]]))
     test(expected === zip_n([box array_1, array_3], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     array_2.ignore()
     array_4.ignore()

     let array_1  = rnd_string_array()
     let array_2  = if rnd_bool(); array_1 else null
     let expected = array_1.foldl([array].init(len(array_1)), fn (result, string) result.append([array string, string, items[0]]))
     test(expected === zip_n([box array_1, array_1], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     array_2.ignore()

     let array_1   = (switch (rnd() >> 1) % 3
          case 0: rnd_string()
          case 1: rnd_byte_array()
          case 2: rnd_string_array()
          default: unreachable()).drop(1)
     let array_2   = if rnd_bool(); array_1 else null
     let array_3   = (switch (rnd() >> 1) % 3
          case 0: rnd_string()
          case 1: rnd_byte_array()
          case 2: rnd_string_array()
          default: unreachable()).drop(1)
     let array_4   = if rnd_bool(); array_3 else null
     let small_len = if len(array_1) < len(array_3); len(array_1) else len(array_3)
     let expected  = array_1.take(small_len).foldl_kv([array].init(small_len), fn (result, idx, item) result.append([array item, array_3[idx], items[0]]))
     test(expected === zip_n([box array_1, array_3], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     array_2.ignore()
     array_4.ignore()

     test(zip_n([box [set], [set]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [set 0], [set]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [set], [set 1]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [set].init(10), [set].init(10)], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [set 0], [set].init(10)], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [set].init(10), [set 1]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [set 0], [set 1]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [set 1], [set 0]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [set 1], [set 1, 2]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table 1 = [array 1, 1, heap_string()]])
     test(zip_n([box [set 1, 2], [set 1]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table 1 = [array 1, 1, heap_string()]])
     test(zip_n([box [set 1, 3], [set 3, 2]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table 3 = [array 3, 3, heap_string()]])

     let set_1    = loop([set], fn (set) {
          if (rnd() & 511) === 511
               [breaker set]
          else if (rnd() & 7) === 7
               set.append(rnd_string())
          else set.append(string_array[(rnd() >> 1) % len(string_array)])
     })
     let set_2    = if rnd_bool(); set_1 else null
     let set_3    = loop([set], fn (set) {
          if (rnd() & 511) === 511
               [breaker set]
          else if (rnd() & 7) === 7
               set.append(rnd_string())
          else set.append(string_array[(rnd() >> 1) % len(string_array)])
     })
     let set_4    = if rnd_bool(); set_3 else null
     let expected = set_1.foldl([table], fn (table, item) if set_3[item].null?(); table else new (table)[item] <= [array item, item, items[0]])
     test(expected === zip_n([box set_1, set_3], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     set_2.ignore()
     set_4.ignore()

     let set_1    = loop([set], fn (set) {
          if (rnd() & 511) === 511
               [breaker set]
          else if (rnd() & 7) === 7
               set.append(rnd_string())
          else set.append(string_array[(rnd() >> 1) % len(string_array)])
     })
     let set_2    = if rnd_bool(); set_1 else null
     let expected = set_1.foldl([table], fn (table, item) new (table)[item] <= [array item, item, items[0]])
     test(expected === zip_n([box set_1, set_1], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     set_2.ignore()

     test(zip_n([box [table], [table]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [table 0 = 10], [table]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [table], [table 1 = 11]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [table].init(10), [table].init(10)], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [table 0 = 10], [table].init(10)], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [table].init(10), [table 1 = 11]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [table 0 = 10], [table 1 = 11]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [table 1 = 11], [table 0 = 10]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table])
     test(zip_n([box [table 1 = 11], [table 1 = 111, 2 = 12]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table 1 = [array 11, 111, heap_string()]])
     test(zip_n([box [table 1 = 11, 2 = 12], [table 1 = 111]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table 1 = [array 11, 111, heap_string()]])
     test(zip_n([box [table 1 = 11, 2 = 12], [table 1 = 111, 2 = 112]], fn (item_1, item_2) [array item_1, item_2, items[0]]) === [table 1 = [array 11, 111, heap_string()], 2 = [array 12, 112, heap_string()]])

     let table_1  = loop([table], fn (table) {
          if (rnd() & 511) === 511
               [breaker table]
          else if (rnd() & 7) === 7
               new (table)[rnd_string()] <= rnd_string()
          else new (table)[string_array[(rnd() >> 1) % len(string_array)]] <= rnd_string()
     })
     let table_2  = if rnd_bool(); table_1 else null
     let table_3  = loop([table], fn (table) {
          if (rnd() & 511) === 511
               [breaker table]
          else if (rnd() & 7) === 7
               new (table)[rnd_string()] <= rnd_string()
          else new (table)[string_array[(rnd() >> 1) % len(string_array)]] <= rnd_string()
     })
     let table_4  = if rnd_bool(); table_3 else null
     let expected = table_1.foldl_kv([table], fn (table, key, item_1) {
          let item_2 = table_3[key]
          if item_2.null?()
               table
          else new (table)[key] <= [array item_1, item_2, items[0]]
     })
     test(expected === zip_n([box table_1, table_3], fn (item_1, item_2) [array item_1, item_2, items[0]]))
     table_2.ignore()
     table_4.ignore()

     let table_1  = loop([table], fn (table) {
