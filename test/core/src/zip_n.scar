          item_10
          item_11
          item_12
          item_13
          item_14
          item_15
          item_16
     ]))
     borrowed_arrays.ignore()

     let containers = loop([array].init(16), fn (containers) {
          let containers = containers.append(
               switch (rnd() >> 1) % 3
               case 0: loop([set], fn (set) {
                    if (rnd() & 511) === 511
                         [breaker set]
                    else set.append(
                         switch rnd() & 3
                         case 0: rnd_string()
                         case 1: loop(rnd_token(), fn (key) if key =/= :_; [breaker key] else rnd_token())
                         case 2: string_array[(rnd() >> 1) % len(string_array)]
                         case 3: token_array[(rnd() >> 1) % len(token_array)]
                         default: unreachable()
                    )
               })
               case 1: loop([table], fn (table) {
                    if (rnd() & 511) === 511
                         [breaker table]
                    else new (table) [
                         switch rnd() & 3
                         case 0: rnd_string()
                         case 1: loop(rnd_token(), fn (key) if key =/= :_; [breaker key] else rnd_token())
                         case 2: string_array[(rnd() >> 1) % len(string_array)]
                         case 3: token_array[(rnd() >> 1) % len(token_array)]
                         default: unreachable()
                    ] <= rnd_string()
               })
               case 2: loop([obj], fn (obj) {
                    if (rnd() & 511) === 511
                         [breaker obj]
                    else if (rnd() & 7) === 7
                         new (obj)[loop(rnd_token(), fn (key) if key =/= :_; [breaker key] else rnd_token())] <= rnd_string()
                    else new (obj)[token_array[(rnd() >> 1) % len(token_array)]] <= rnd_string()
               })
               default: unreachable()
          )
          break(len(containers) === 16, containers)
     })
     let borrowed_containers = containers.foldl([array].init(16), fn (borrowed_containers, container) if rnd_bool(); borrowed_containers.append(container) else borrowed_containers)
     let expected_type       = containers.foldl([obj], fn (result, container) if container.type() === "core.obj"; result else [table])
     let expected            = if containers[0].type() === "core.set"
          containers[0].foldl([table], fn (result, item_1) {
               let items = loop([array].init(16).append(item_1), fn (items) {
                    let current_container = containers[len(items)]

                    let item = if current_container.type() === "core.obj" && item_1.type() =/= "core.token"
                         null
                    else current_container[item_1]

                    if item.null?()
                         [breaker null]
                    else break(len(items) === 15, items.append(item))
               })

               if items.null?()
                    result
               else new (result)[item_1] <= items
          })
     else containers[0].foldl_kv(expected_type, fn (result, key, item_1) {
          let items = loop([array].init(16).append(item_1), fn (items) {
               let current_container = containers[len(items)]

               let item = if current_container.type() === "core.obj" && key.type() =/= "core.token"
                    null
               else current_container[key]

               if item.null?()
                    [breaker null]
               else break(len(items) === 15, items.append(item))
          })

          if items.null?()
               result
          else new (result)[key] <= items
     })
     test(expected === zip_n(containers.to_box(), fn (
          item_1
          item_2
          item_3
          item_4
          item_5
          item_6
          item_7
          item_8
          item_9
          item_10
          item_11
          item_12
          item_13
          item_14
          item_15
          item_16
