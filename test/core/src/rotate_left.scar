let num__rotate_left = [obj
     :value = 0

     :_ = [obj
          :core_rotate_left = fn (num, shifts) to_num__rotate_left(rotate_left(num:value, shifts))
          :core___equal__   = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__rotate_left(arg) new (@main.num__rotate_left):value <= arg

fn to_custom_num__rotate_left(arg) custom__create(
     arg
     [obj
          :core_rotate_left = fn (num, shifts) to_custom_num__rotate_left(rotate_left(num.custom__get_data(), shifts))
          :core___equal__   = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__rotate_left = [obj
     :value = 0

     :_ = [obj
          :core_rotate_left = fn (_, _) heap_string()
     ]
]

fn to_broken_num__rotate_left(arg) new (@main.broken_num__rotate_left):value <= arg

fn to_broken_custom_num__rotate_left(arg) custom__create(
     arg
     [obj
          :core_rotate_left = fn (_, _) heap_string()
     ]
)

let error_num__rotate_left = [obj
     :value = 0

     :_ = [obj
          :core_rotate_left = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__rotate_left(arg) new (@main.error_num__rotate_left):value <= arg

fn to_error_custom_num__rotate_left(arg) custom__create(
     arg
     [obj
          :core_rotate_left = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__rotate_left() {
     test(rotate_left(0, 0) === 0)
     test(rotate_left(0, 1) === 0)
     test(rotate_left(1, 0) === 1)
     test(rotate_left(1, 1) === 2)
     test(rotate_left(-1, 0) === -1)
     test(rotate_left(-1, 1) === -1)
     test(rotate_left(-708044971986000615, 3) === -5664359775888004913)
     test(rotate_left(-708044971986000615, 58) === 7482926577257224084)
     test(rotate_left(-708044971986000615, 59) === -3480890919195103448)
     test(rotate_left(-708044971986000615, 60) === -6961781838390206895)
     test(rotate_left(-708044971986000615, 61) === 4523180396929137827)
     test(rotate_left(-708044971986000615, 62) === 9046360793858275654)
     test(rotate_left(-708044971986000615, 63) === -354022485993000308)
     test(rotate_left(-708044971986000615, 64) === -708044971986000615)
     test(rotate_left(-9223372036854775808, 0) === -9223372036854775808)
     test(rotate_left(-9223372036854775808, 1) === 1)
     test(rotate_left(-9223372036854775808, 62) === 2305843009213693952)
     test(rotate_left(-9223372036854775808, 63) === 4611686018427387904)
     test(rotate_left(-9223372036854775808, 64) === -9223372036854775808)
     test(rotate_left(9223372036854775807, 0) === 9223372036854775807)
     test(rotate_left(9223372036854775807, 1) === -2)
     test(rotate_left(9223372036854775807, 17) === -65537)
     test(rotate_left(9223372036854775807, 62) === -2305843009213693953)
     test(rotate_left(9223372036854775807, 63) === -4611686018427387905)
     test(rotate_left(9223372036854775807, 64) === 9223372036854775807)

     test(rotate_left(0, 0b00) === 0)
     test(rotate_left(0, 0b01) === 0)
     test(rotate_left(1, 0b00) === 1)
     test(rotate_left(1, 0b01) === 2)
     test(rotate_left(-1, 0b00) === -1)
     test(rotate_left(-1, 0b01) === -1)
     test(rotate_left(-708044971986000615, 0b03) === -5664359775888004913)
     test(rotate_left(-708044971986000615, 0b3a) === 7482926577257224084)
     test(rotate_left(-708044971986000615, 0b3b) === -3480890919195103448)
     test(rotate_left(-708044971986000615, 0b3c) === -6961781838390206895)
     test(rotate_left(-708044971986000615, 0b3d) === 4523180396929137827)
     test(rotate_left(-708044971986000615, 0b3e) === 9046360793858275654)
     test(rotate_left(-708044971986000615, 0b3f) === -354022485993000308)
     test(rotate_left(-708044971986000615, 0b40) === -708044971986000615)
     test(rotate_left(-9223372036854775808, 0b00) === -9223372036854775808)
     test(rotate_left(-9223372036854775808, 0b01) === 1)
     test(rotate_left(-9223372036854775808, 0b3e) === 2305843009213693952)
     test(rotate_left(-9223372036854775808, 0b3f) === 4611686018427387904)
     test(rotate_left(-9223372036854775808, 0b40) === -9223372036854775808)
     test(rotate_left(9223372036854775807, 0b00) === 9223372036854775807)
     test(rotate_left(9223372036854775807, 0b01) === -2)
     test(rotate_left(9223372036854775807, 0b11) === -65537)
     test(rotate_left(9223372036854775807, 0b3e) === -2305843009213693953)
     test(rotate_left(9223372036854775807, 0b3f) === -4611686018427387905)
     test(rotate_left(9223372036854775807, 0b40) === 9223372036854775807)

     let int      = rnd()
     let shifts   = rnd() & 63
     let expected = (int << shifts) | (int >> (64 - shifts))
     test(rotate_left(int, shifts) === expected)

     test(rotate_left(0b00, 0) === 0b00)
     test(rotate_left(0b00, 1) === 0b00)
     test(rotate_left(0b01, 0) === 0b01)
     test(rotate_left(0b01, 1) === 0b02)
     test(rotate_left(0bff, 0) === 0bff)
     test(rotate_left(0bff, 1) === 0bff)
     test(rotate_left(0bff, 2) === 0bff)
     test(rotate_left(0bff, 3) === 0bff)
     test(rotate_left(0bff, 4) === 0bff)
     test(rotate_left(0bff, 5) === 0bff)
     test(rotate_left(0bff, 6) === 0bff)
     test(rotate_left(0bff, 7) === 0bff)
     test(rotate_left(0bff, 8) === 0bff)
     test(rotate_left(0b78, 0) === 0b78)
     test(rotate_left(0b78, 1) === 0bf0)
     test(rotate_left(0b78, 2) === 0be1)
     test(rotate_left(0b78, 3) === 0bc3)
     test(rotate_left(0b78, 4) === 0b87)
     test(rotate_left(0b78, 5) === 0b0f)
     test(rotate_left(0b78, 6) === 0b1e)
     test(rotate_left(0b78, 7) === 0b3c)
     test(rotate_left(0b78, 8) === 0b78)

     test(rotate_left(0b00, 0b00) === 0b00)
     test(rotate_left(0b00, 0b01) === 0b00)
     test(rotate_left(0b01, 0b00) === 0b01)
     test(rotate_left(0b01, 0b01) === 0b02)
     test(rotate_left(0bff, 0b00) === 0bff)
     test(rotate_left(0bff, 0b01) === 0bff)
     test(rotate_left(0bff, 0b02) === 0bff)
     test(rotate_left(0bff, 0b03) === 0bff)
     test(rotate_left(0bff, 0b04) === 0bff)
     test(rotate_left(0bff, 0b05) === 0bff)
     test(rotate_left(0bff, 0b06) === 0bff)
     test(rotate_left(0bff, 0b07) === 0bff)
     test(rotate_left(0bff, 0b08) === 0bff)
     test(rotate_left(0b78, 0b00) === 0b78)
     test(rotate_left(0b78, 0b01) === 0bf0)
     test(rotate_left(0b78, 0b02) === 0be1)
     test(rotate_left(0b78, 0b03) === 0bc3)
     test(rotate_left(0b78, 0b04) === 0b87)
     test(rotate_left(0b78, 0b05) === 0b0f)
     test(rotate_left(0b78, 0b06) === 0b1e)
     test(rotate_left(0b78, 0b07) === 0b3c)
     test(rotate_left(0b78, 0b08) === 0b78)

     let byte     = rnd_byte()
     let shifts   = rnd() & 7
     let expected = (byte << shifts) | (byte >> (8 - shifts))
     test(rotate_left(byte, shifts) === expected)

     test(rotate_left(to_num__rotate_left(0), 0) === to_num__rotate_left(0))
     test(rotate_left(to_num__rotate_left(-708044971986000615), 3) === to_num__rotate_left(-5664359775888004913))

     test(rotate_left(to_custom_num__rotate_left(0), 0) === to_custom_num__rotate_left(0))
     test(rotate_left(to_custom_num__rotate_left(-708044971986000615), 3) === to_custom_num__rotate_left(-5664359775888004913))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(rotate_left(error_1, 1).get_error_id() === :1)
     test(rotate_left(1, error_1).get_error_id() === :1)
     test(rotate_left(error_1, error_2).get_error_id() === :1)
     test(rotate_left(error_2, error_1).get_error_id() === :2)
     test(rotate_left(error_1, heap_string()).get_error_id() === :1)
     test(rotate_left(heap_string(), error_1).get_error_id() === :1)

     test(rotate_left(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(rotate_left(heap_string(), 1).get_error_id() === :invalid_type)
     test(rotate_left(1, heap_string()).get_error_id() === :invalid_type)

     test(rotate_left(to_broken_num__rotate_left(1), 0).get_error_id() === :invalid_type)
     test(rotate_left(to_broken_custom_num__rotate_left(1), 0).get_error_id() === :invalid_type)
     test(rotate_left(to_error_num__rotate_left(1), 0).get_error_id() === :3)
     test(rotate_left(to_error_custom_num__rotate_left(1), 0).get_error_id() === :4)

     test(rotate_left(0, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(1, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(1, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(1, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(1, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(1, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(1, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(9223372036854775807, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(9223372036854775807, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(9223372036854775807, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(9223372036854775807, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(9223372036854775807, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(9223372036854775807, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-1, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-1, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-1, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-1, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-1, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-1, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-9223372036854775808, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-9223372036854775808, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-9223372036854775808, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-9223372036854775808, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-9223372036854775808, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-9223372036854775808, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)

     test(rotate_left(0, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(1, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(1, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(9223372036854775807, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(9223372036854775807, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-1, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-1, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-9223372036854775808, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(-9223372036854775808, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)

     test(rotate_left(0b00, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b00, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b00, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b00, 9.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b00, 10.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b00, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b01, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b01, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b01, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b01, 9.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b01, 10.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b01, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bf0, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bf0, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bf0, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bf0, 9.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bf0, 10.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bf0, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bff, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bff, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bff, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bff, 9.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bff, 10.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bff, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)

     test(rotate_left(0b00, 0b09.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b00, 0ba0.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b00, 0bff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b09, 0b09.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b09, 0ba0.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0b09, 0bff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0ba0, 0b09.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0ba0, 0ba0.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0ba0, 0bff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bff, 0b09.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bff, 0ba0.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_left(0bff, 0bff.scarlet__erase_info()).get_error_id() === :bits_shift)
