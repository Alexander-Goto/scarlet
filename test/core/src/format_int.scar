     let int    = rnd()
     let base   = (rnd() & 31) + (rnd() & 3) + 2
     let signed = rnd_bool()
     test(parse_int(format_int(int, base, signed), base) === int)

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let error_3 = expected_error(:3, heap_string(), heap_string())
     test(format_int(error_1, 2, false).get_error_id() === :1)
     test(format_int(0, error_1, false).get_error_id() === :1)
     test(format_int(0, 2, error_1).get_error_id() === :1)
     test(format_int(error_2, error_1, false).get_error_id() === :2)
     test(format_int(0, error_2, error_1).get_error_id() === :2)
     test(format_int(error_2, 2, error_1).get_error_id() === :2)
     test(format_int(error_3, error_2, error_1).get_error_id() === :3)
     test(format_int(error_1, -100.scarlet__erase_info(), heap_string()).get_error_id() === :1)
     test(format_int(0, error_1, heap_string()).get_error_id() === :1)
     test(format_int(0, heap_string(), error_1).get_error_id() === :1)
     test(format_int(0, -6.scarlet__erase_info(), false).get_error_id() === :out_of_bounds)
     test(format_int(0, 1.scarlet__erase_info(), false).get_error_id() === :out_of_bounds)
     test(format_int(0, 37.scarlet__erase_info(), false).get_error_id() === :out_of_bounds)
     test(format_int(heap_string(), 37.scarlet__erase_info(), heap_string()).error?())
     test(format_int(heap_string(), heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(format_int(heap_string(), 2, false).get_error_id() === :invalid_type)
     test(format_int(0, 2, heap_string()).get_error_id() === :invalid_type)
     test(format_int(0, heap_string(), false).get_error_id() === :invalid_type)
}