     let array = [array 0].repeat((rnd() & 1023) + 1).map(fn (_) (rnd() >> 2).int_to_time())
     let bytes = array.foldl(u"", fn (bytes, time) time.serialize(bytes))
     test(bytes.type() === "core.byte_array")
     test(bytes.len() >= array.len() * 5)
     let expected = loop([box [array].init(len(array)), bytes], fn (state) {
          let [box expected, bytes] = state

          let [box time, bytes] = bytes.deserialize()
          let expected          = expected.append(time)

          if len(expected) === len(array) {
               test(bytes.empty?())

               [breaker expected]
          } else [box expected, bytes]
     })
     test(expected === array)

     test(0.0.serialize([byte_array]) === [byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00])
     test(-0.0.serialize([byte_array]) === [byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b80])
     test(1.5.serialize([byte_array]) === [byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf8, 0b3f])
     test(-1.5.serialize([byte_array]) === [byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf8, 0bbf])
     test(inf().serialize([byte_array]) === [byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf0, 0b7f])
     test(neg_inf().serialize([byte_array]) === [byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf0, 0bff])
     test(nan().serialize([byte_array])[0] === 0b1a)
     test(nan().serialize([byte_array]).len() === 9)
     test((nan().serialize([byte_array]).drop(1).scarlet__split!!!()[0] & 0xf'ffff'ffff'ffff) =/= 0)
     test(((nan().serialize([byte_array]).drop(1).scarlet__split!!!()[0] >> 52) & 0x7ff) === 0x7ff)

     test([byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00].deserialize() === [box 0.0, [byte_array]])
     test([byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b80].deserialize() === [box -0.0, [byte_array]])
     test([byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf8, 0b3f].deserialize() === [box 1.5, [byte_array]])
     test([byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf8, 0bbf].deserialize() === [box -1.5, [byte_array]])
     test([byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf0, 0b7f].deserialize() === [box inf(), [byte_array]])
     test([byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf0, 0bff].deserialize() === [box neg_inf(), [byte_array]])
     let nan_bytes = [byte_array 0b1a] ++ scarlet__join!!!(nan().scarlet__split!!!()[0], u"01234567".scarlet__split!!!()[1])
     test(nan_bytes.deserialize()[0].nan?())
     test(nan_bytes.deserialize()[1] === [byte_array])

     test(0.0.serialize([byte_array 0bff]) === [byte_array 0bff, 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00])
     test(-0.0.serialize([byte_array 0bff]) === [byte_array 0bff, 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b80])
     test(1.5.serialize([byte_array 0bff]) === [byte_array 0bff, 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf8, 0b3f])
     test(-1.5.serialize([byte_array 0bff]) === [byte_array 0bff, 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf8, 0bbf])
     test(inf().serialize([byte_array 0bff]) === [byte_array 0bff, 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf0, 0b7f])
     test(neg_inf().serialize([byte_array 0bff]) === [byte_array 0bff, 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bf0, 0bff])
     test(nan().serialize([byte_array 0bff]).take(2) === [byte_array 0bff, 0b1a])
     test(nan().serialize([byte_array 0bff]).len() === 10)
     test((nan().serialize([byte_array 0bff]).drop(2).scarlet__split!!!()[0] & 0xf'ffff'ffff'ffff) =/= 0)
     test(((nan().serialize([byte_array 0bff]).drop(2).scarlet__split!!!()[0] >> 52) & 0x7ff) === 0x7ff)

     test([byte_array 0b1a, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0b00, 0bff].deserialize() === [box 0.0, [byte_array 0bff]])
