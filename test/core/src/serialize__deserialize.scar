fn serialize_tkn(token) {
     let array = token.to_string().str_to_ustr()
     new (array)[array.len() - 1] => _ | 0b80
}

`noinline`
fn test__serialize__deserialize() {
     test(0.serialize([byte_array]) === [byte_array 0b00, 0b00])
     test(1.serialize([byte_array]) === [byte_array 0b00, 0b01])
     test(10.serialize([byte_array]) === [byte_array 0b00, 0b0a])
     test(0xff.serialize([byte_array]) === [byte_array 0b00, 0bff])

     test([byte_array 0b00, 0b00].deserialize() === [box 0, [byte_array]])
     test([byte_array 0b00, 0b01].deserialize() === [box 1, [byte_array]])
     test([byte_array 0b00, 0b0a].deserialize() === [box 10, [byte_array]])
     test([byte_array 0b00, 0bff].deserialize() === [box 0xff, [byte_array]])

     test(0.serialize([byte_array 0bff]) === [byte_array 0bff, 0b00, 0b00])
     test(1.serialize([byte_array 0bff]) === [byte_array 0bff, 0b00, 0b01])
     test(10.serialize([byte_array 0bff]) === [byte_array 0bff, 0b00, 0b0a])
     test(0xff.serialize([byte_array 0bff]) === [byte_array 0bff, 0b00, 0bff])

     test([byte_array 0b00, 0b00, 0bff].deserialize() === [box 0, [byte_array 0bff]])
     test([byte_array 0b00, 0b01, 0bff].deserialize() === [box 1, [byte_array 0bff]])
     test([byte_array 0b00, 0b0a, 0bff].deserialize() === [box 10, [byte_array 0bff]])
     test([byte_array 0b00, 0bff, 0bff].deserialize() === [box 0xff, [byte_array 0bff]])

     test(0x100.serialize([byte_array]) === [byte_array 0b01, 0b00, 0b00])
     test(0x101.serialize([byte_array]) === [byte_array 0b01, 0b01, 0b00])
     test(0x200.serialize([byte_array]) === [byte_array 0b01, 0b00, 0b01])
     test(0x1'00ff.serialize([byte_array]) === [byte_array 0b01, 0bff, 0bff])

     test([byte_array 0b01, 0b00, 0b00].deserialize() === [box 0x100, [byte_array]])
     test([byte_array 0b01, 0b01, 0b00].deserialize() === [box 0x101, [byte_array]])
