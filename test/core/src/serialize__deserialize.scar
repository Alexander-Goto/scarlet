     let array = [array 0].repeat((rnd() & 1023) + 1).map(fn (_) rnd())
     let bytes = array.foldl(u"", fn (bytes, int) int.serialize(bytes))
     test(bytes.type() === "core.byte_array")
     test(bytes.len() >= array.len() * 2)
     let expected = loop([box [array].init(len(array)), bytes], fn (state) {
          let [box expected, bytes] = state

          let [box int, bytes] = bytes.deserialize()
          let expected         = expected.append(int)
          if len(expected) === len(array) {
               test(bytes.empty?())

               [breaker expected]
          } else [box expected, bytes]
     })
     test(expected === array)

