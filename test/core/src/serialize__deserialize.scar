     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.serialize(heap_byte_array()).get_error_id() === :1)
     test(heap_byte_array().serialize(error_1).get_error_id() === :1)
     test(error_1.serialize(error_2).get_error_id() === :1)
     test(error_2.serialize(error_1).get_error_id() === :2)
