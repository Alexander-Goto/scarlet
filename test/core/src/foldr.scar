let container__foldr = [obj
     :value = [array]

     :_ = [obj
          :core_foldr = fn (container, state, func) container:value.foldr(state, func)
     ]
]

fn to_container__foldr(arg) new (@main.container__foldr):value <= arg

fn to_custom_container__foldr(arg) custom__create(
     arg
     [obj
          :core_foldr = fn (container, state, func) custom__get_data(container).foldr(state, func)
     ]
)

let error_container__foldr = [obj
     :value = [array]

     :_ = [obj
          :core_foldr = fn (_, _, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_container__foldr(arg) new (@main.error_container__foldr):value <= arg

fn to_error_custom_container__foldr(arg) custom__create(
     arg
     [obj
          :core_foldr = fn (_, _, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__foldr() {
     let items = ",".to_array()
     let state = heap_string()
     test("".foldr(state, fn (state, char) state.append(char).append(items[0])) === state)
     test("1".foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "1,")
     test("0123456789abcde".foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "e,d,c,b,a,9,8,7,6,5,4,3,2,1,0,")

     test("\000091".foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "\000091,")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "\0000b5,\0000a7,\0000a4,!,!,!,\0000ab,\0000b3,\000091,")

     let string = ("0011012375611135f" ++ "g0")[1, 18]
     test(string.foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "g,f,5,3,1,1,1,6,5,7,3,2,1,0,1,1,0,")
     string.ignore()

     test(("0011012375611135f" ++ "g0")[1, 18].foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "g,f,5,3,1,1,1,6,5,7,3,2,1,0,1,1,0,")
     test(("011012375611135f" ++ "g").foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "g,f,5,3,1,1,1,6,5,7,3,2,1,0,1,1,0,")

     let string = ("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11]
     test(string.foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "\0000b7,\0000ae,\0000af, ,\0000b5,\0000a7,\0000a4,\0000ab,\0000b3,\000091,")
     string.ignore()

     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "\0000b7,\0000ae,\0000af, ,\0000b5,\0000a7,\0000a4,\0000ab,\0000b3,\000091,")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").foldr(state, fn (state, char) state.append(char).append(items[0])) === state ++ "\0000b7,\0000ae,\0000af, ,\0000b5,\0000a7,\0000a4,\0000ab,\0000b3,\000091,")

     test("0123456789abcde".foldr(null, fn (_, char) if char < 'a'; [breaker char] else null) === '9')
     test("0123456789abcdef".foldr(null, fn (_, char) if char < 'a'; [breaker char] else null) === '9')

     let string_1        = rnd_string()
     let string_2        = if rnd_bool(); string_1 else null
     let expected_string = loop("", fn (expected_string)
          if len(expected_string) === len(string_1)
               [breaker expected_string]
          else expected_string.append(string_1[len(string_1) - len(expected_string) - 1].ascii_to_lower())
     )
     test(string_1.foldr("", fn (string, char) string.append(char.ascii_to_lower())) === expected_string)
     string_2.ignore()

     let items = u",".to_array()
     let state = heap_byte_array()
     test(u"".foldr(state, fn (state, byte) state.append(byte).append(items[0])) === state)
     test(u"1".foldr(state, fn (state, byte) state.append(byte).append(items[0])) === state ++ u"1,")
     test(u"0123456789abcd".foldr(state, fn (state, byte) state.append(byte).append(items[0])) === state ++ u"d,c,b,a,9,8,7,6,5,4,3,2,1,0,")

     let string = (u"0011012375611135f" ++ u"g0")[1, 18]
     test(string.foldr(state, fn (state, byte) state.append(byte).append(items[0])) === state ++ u"g,f,5,3,1,1,1,6,5,7,3,2,1,0,1,1,0,")
     string.ignore()

     test((u"0011012375611135f" ++ u"g0")[1, 18].foldr(state, fn (state, byte) state.append(byte).append(items[0])) === state ++ u"g,f,5,3,1,1,1,6,5,7,3,2,1,0,1,1,0,")
     test((u"011012375611135f" ++ u"g").foldr(state, fn (state, byte) state.append(byte).append(items[0])) === state ++ u"g,f,5,3,1,1,1,6,5,7,3,2,1,0,1,1,0,")

     test(u"0123456789abcd".foldr(null, fn (_, byte) if byte < u"a"[0]; [breaker byte] else null) === u"9"[0])
     test(u"0123456789abcde".foldr(null, fn (_, byte) if byte < u"a"[0]; [breaker byte] else null) === u"9"[0])

     let array_1        = rnd_byte_array()
     let array_2        = if rnd_bool(); array_1 else null
     let expected_array = array_1.map(_ - 0b01).reverse()
     test(array_1.foldr(u"", fn (array, byte) array.append(byte - 0b01)) === expected_array)
     array_2.ignore()

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     let string_3 = string_0 ++ "3"
     let string_4 = string_0 ++ "4"
     let string_5 = string_0 ++ "5"
     test([array].foldr([array], fn (state, item) state.append(item).append(string_0)) === [array])
     test([array].init(10).foldr([array].init(10), fn (state, item) state.append(item).append(string_0)) === [array])
     let array = [array].init(10)
     test(array.foldr([array].init(10), fn (state, item) state.append(item).append(string_0)) === [array])
     test(array.foldr(array, fn (state, item) state.append(item).append(string_0)) === [array])
     test(array.foldr(array, fn (state, item) state.append(item).append(string_0)) === [array])

     let array = [array string_0, string_1, string_0][1, 2]
     test(array.foldr([array].init(10), fn (state, item) state.append(item).append(string_0)) === [array string_1, string_0])
     test(array.foldr(array, fn (state, item) state.append(item).append(string_0)) === [array string_1, string_1, string_0])
     test(array.foldr(array, fn (state, item) state.append(item).append(string_0)) === [array string_1, string_1, string_0])
     test([array string_0, string_1, string_0][1, 2].foldr([array].init(10), fn (state, item) state.append(item).append(string_0)) === [array string_1, string_0])
     test([array string_1].foldr([array].init(10), fn (state, item) state.append(item).append(string_0)) === [array string_1, string_0])

     let array = [array string_0, string_0, string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_5, string_5, string_0][1, 11]
     test(array.foldr([array], fn (state, item) state.append(item).append(string_0)) === [array string_5, string_0, string_5, string_0, string_4, string_0, string_3, string_0, string_3, string_0, string_3, string_0, string_2, string_0, string_2, string_0, string_1, string_0, string_0, string_0])
     test(array.foldr(array, fn (state, item) state.append(item).append(string_0)) === [array string_0, string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_5, string_5, string_5, string_0, string_5, string_0, string_4, string_0, string_3, string_0, string_3, string_0, string_3, string_0, string_2, string_0, string_2, string_0, string_1, string_0, string_0, string_0])
     test(array.foldr(array, fn (state, item) state.append(item).append(string_0)) === [array string_0, string_1, string_2, string_2, string_3, string_3, string_3, string_4, string_5, string_5, string_5, string_0, string_5, string_0, string_4, string_0, string_3, string_0, string_3, string_0, string_3, string_0, string_2, string_0, string_2, string_0, string_1, string_0, string_0, string_0])

     test([array 0, 1, 2, 3, 4].foldr(null, fn (_, item) if item =/= 2; [breaker item] else null) === 4)

     let array_1 = rnd_string_array()
     let array_2 = if (rnd() & 1) === 0; array_1 else null
     test(array_1.foldr([array], fn (array, string) array.append(string.to_lower())) === array_1.map(_.to_lower()).reverse())
     array_2.ignore()

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     let string_3 = string_0 ++ "3"
     let string_4 = string_0 ++ "4"
     let string_5 = string_0 ++ "5"
     test([set].foldr([set], fn (state, item) state.append(item.to_upper() ++ string_0)) === [set])
     test([set].init(10).foldr([set].init(10), fn (state, item) state.append(item.to_upper() ++ string_0)) === [set])
     let set = [set].init(10)
     test(set.foldr([set].init(10), fn (state, item) state.append(item.to_upper() ++ string_0)) === [set])
     test(set.foldr(set, fn (state, item) state.append(item.to_upper() ++ string_0)) === [set])
     test(set.foldr(set, fn (state, item) state.append(item.to_upper() ++ string_0)) === [set])

     let set = [set string_1]
     test(set.foldr([set].init(10), fn (state, item) state.append(item.to_upper() ++ string_0)) === [set string_1.to_upper() ++ string_0])
     test(set.foldr(set, fn (state, item) state.append(item.to_upper() ++ string_0)) === [set string_1, string_1.to_upper() ++ string_0])
     test(set.foldr(set, fn (state, item) state.append(item.to_upper() ++ string_0)) === [set string_1, string_1.to_upper() ++ string_0])
     test([set string_1].foldr([set].init(10), fn (state, item) state.append(item.to_upper() ++ string_0)) === [set string_1.to_upper() ++ string_0])

     let set = [set string_0, string_1, string_2, string_3, string_4, string_5]
     test(set.foldr([set], fn (state, item) state.append(item.to_upper() ++ string_0)) === [set string_0.to_upper() ++ string_0, string_1.to_upper() ++ string_0, string_2.to_upper() ++ string_0, string_3.to_upper() ++ string_0, string_4.to_upper() ++ string_0, string_5.to_upper() ++ string_0])
     test(set.foldr(set, fn (state, item) state.append(item.to_upper() ++ string_0)) === [set string_0, string_1, string_2, string_3, string_4, string_5, string_0.to_upper() ++ string_0, string_1.to_upper() ++ string_0, string_2.to_upper() ++ string_0, string_3.to_upper() ++ string_0, string_4.to_upper() ++ string_0, string_5.to_upper() ++ string_0])
     test(set.foldr(set, fn (state, item) state.append(item.to_upper() ++ string_0)) === [set string_0, string_1, string_2, string_3, string_4, string_5, string_0.to_upper() ++ string_0, string_1.to_upper() ++ string_0, string_2.to_upper() ++ string_0, string_3.to_upper() ++ string_0, string_4.to_upper() ++ string_0, string_5.to_upper() ++ string_0])

     test([set 0, 1, 2, 3, 4].foldr(null, fn (_, item) if item =/= 2; [breaker item] else null).in?([set 0, 1, 3, 4]))

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     let string_3 = string_0 ++ "3"
     let string_4 = string_0 ++ "4"
     let string_5 = string_0 ++ "5"
     test([table].foldr([table], fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table])
     test([table].init(10).foldr([table].init(10), fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table])

     let table = [table].init(10)
     test(table.foldr([table].init(10), fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table])
     test(table.foldr(table, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table])
     test(table.foldr(table, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table])

     let table = [table string_1 = string_2]
     test(table.foldr([table].init(10), fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table string_2 = string_2.to_upper() ++ string_0])
     test(table.foldr(table, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table string_1 = string_2, string_2 = string_2.to_upper() ++ string_0])
     test(table.foldr(table, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table string_1 = string_2, string_2 = string_2.to_upper() ++ string_0])
     test([table string_1 = string_2].foldr([table].init(10), fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table string_2 = string_2.to_upper() ++ string_0])

     let table = [table string_0 = string_1, string_2 = string_3, string_4 = string_5]
     test(table.foldr([table], fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table string_1 = string_1.to_upper() ++ string_0, string_3 = string_3.to_upper() ++ string_0, string_5 = string_5.to_upper() ++ string_0])
     test(table.foldr(table, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table string_0 = string_1, string_2 = string_3, string_4 = string_5, string_1 = string_1.to_upper() ++ string_0, string_3 = string_3.to_upper() ++ string_0, string_5 = string_5.to_upper() ++ string_0])
     test(table.foldr(table, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table string_0 = string_1, string_2 = string_3, string_4 = string_5, string_1 = string_1.to_upper() ++ string_0, string_3 = string_3.to_upper() ++ string_0, string_5 = string_5.to_upper() ++ string_0])
     test([table string_0 = string_1, string_2 = string_3, string_4 = string_5].foldr([table], fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [table string_1 = string_1.to_upper() ++ string_0, string_3 = string_3.to_upper() ++ string_0, string_5 = string_5.to_upper() ++ string_0])

     test([table 0 = 1, 1 = 1, 2 = 0, 3 = 0].foldr(null, fn (_, item) if item =/= 1; [breaker item] else null) === 0)

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     let string_3 = string_0 ++ "3"
     let string_5 = string_0 ++ "5"
     test([obj].foldr([obj], fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [obj])
     test([obj].init(10).foldr([obj].init(10), fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [obj])
     test([obj :_ = [obj :1 = string_0]].foldr([obj], fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [obj])

     let obj = [obj :_ = [obj :1 = string_0]].init(10)
     test(obj.foldr([obj].init(10), fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [obj])
     test(obj.foldr(obj, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [obj])
     test(obj.foldr(obj, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [obj])

     let obj = [obj].init(10)
     test(obj.foldr([obj].init(10), fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [obj])
     test(obj.foldr(obj, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [obj])
     test(obj.foldr(obj, fn (state, item) new (state)[item] <= item.to_upper() ++ string_0) === [obj])

     let obj = [obj :1 = string_2, :_ = [obj :1 = string_0]]
     test(obj.foldr([obj].init(10), fn (state, item) new (state)[item.str_to_tkn()] <= item.to_upper() ++ string_0) === [obj string_2.str_to_tkn() = string_2.to_upper() ++ string_0])
     test(obj.foldr(obj, fn (state, item) new (state)[item.str_to_tkn()] <= item.to_upper() ++ string_0) === [obj :1 = string_2, string_2.str_to_tkn() = string_2.to_upper() ++ string_0])
     test(obj.foldr(obj, fn (state, item) new (state)[item.str_to_tkn()] <= item.to_upper() ++ string_0) === [obj :1 = string_2, string_2.str_to_tkn() = string_2.to_upper() ++ string_0])
     test([obj :1 = string_2].foldr([obj].init(10), fn (state, item) new (state)[item.str_to_tkn()] <= item.to_upper() ++ string_0) === [obj string_2.str_to_tkn() = string_2.to_upper() ++ string_0])

     let obj = [obj :0 = string_1, :2 = string_3, :4 = string_5, :_ = [obj :1 = string_0]]
     test(obj.foldr([obj], fn (state, item) new (state)[item.str_to_tkn()] <= item.to_upper() ++ string_0) === [obj string_1.str_to_tkn() = string_1.to_upper() ++ string_0, string_3.str_to_tkn() = string_3.to_upper() ++ string_0, string_5.str_to_tkn() = string_5.to_upper() ++ string_0])
     test(obj.foldr(obj, fn (state, item) new (state)[item.str_to_tkn()] <= item.to_upper() ++ string_0) === [obj :0 = string_1, :2 = string_3, :4 = string_5, string_1.str_to_tkn() = string_1.to_upper() ++ string_0, string_3.str_to_tkn() = string_3.to_upper() ++ string_0, string_5.str_to_tkn() = string_5.to_upper() ++ string_0])
     test(obj.foldr(obj, fn (state, item) new (state)[item.str_to_tkn()] <= item.to_upper() ++ string_0) === [obj :0 = string_1, :2 = string_3, :4 = string_5, string_1.str_to_tkn() = string_1.to_upper() ++ string_0, string_3.str_to_tkn() = string_3.to_upper() ++ string_0, string_5.str_to_tkn() = string_5.to_upper() ++ string_0])
     test([obj :0 = string_1, :2 = string_3, :4 = string_5, :_ = [obj :1 = string_0]].foldr([obj], fn (state, item) new (state)[item.str_to_tkn()] <= item.to_upper() ++ string_0) === [obj string_1.str_to_tkn() = string_1.to_upper() ++ string_0, string_3.str_to_tkn() = string_3.to_upper() ++ string_0, string_5.str_to_tkn() = string_5.to_upper() ++ string_0])

     test([obj :0 = 1, :1 = 1, :2 = 0, :3 = 0].foldr(null, fn (_, item) if item =/= 1; [breaker item] else null) === 0)

     test(to_container__foldr("AbCd").foldr("", fn (string, char) string.append(char.ascii_to_lower())) === "dcba")
     test(to_container__foldr("AbCd").foldr("", fn (string, char) string.append(char.ascii_to_upper())) === "DCBA")
     test(to_custom_container__foldr("AbCd").foldr("", fn (string, char) string.append(char.ascii_to_lower())) === "dcba")
     test(to_custom_container__foldr("AbCd").foldr("", fn (string, char) string.append(char.ascii_to_upper())) === "DCBA")

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let error_3 = expected_error(:3, heap_string(), heap_string())
     test(error_1.foldr(heap_string(), _ === heap_string()).get_error_id() === :1)
     test(heap_string().foldr(error_1, _ === heap_string()).get_error_id() === :1)
     test(heap_string().foldr(heap_string(), error_1).get_error_id() === :1)
     test(error_1.foldr(heap_string(), error_2).get_error_id() === :1)
     test(error_2.foldr(heap_string(), error_1).get_error_id() === :2)
     test(error_1.foldr(error_2, error_3).get_error_id() === :1)
     test(error_3.foldr(error_2, error_1).get_error_id() === :3)

     test((_ === heap_string()).scarlet__erase_info().foldr(heap_string(), _ === heap_string()).get_error_id() === :invalid_type)
     test(heap_string().foldr(heap_string(), heap_string()).get_error_id() === :invalid_type)

     test("".foldr("", fn (_, _, _) string_1) === "")
     test(u"".foldr(u"", fn (_, _, _) string_1) === u"")
     test([array].foldr([array], fn (_, _, _) string_1) === [array])
     test([table].foldr([table], fn (_, _, _) string_1) === [table])
     test([obj].foldr([obj], fn (_, _, _) string_1) === [obj])
     test([set].foldr([set], fn (_, _, _) string_1) === [set])

     test("".foldr("", fn (_) string_1) === "")
     test(u"".foldr(u"", fn (_) string_1) === u"")
     test([array].foldr([array], fn (_) string_1) === [array])
     test([table].foldr([table], fn (_) string_1) === [table])
     test([obj].foldr([obj], fn (_) string_1) === [obj])
     test([set].foldr([set], fn (_) string_1) === [set])

     test("1".foldr(heap_string(), fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().foldr(heap_string(), fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"1".foldr(heap_string(), fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().foldr(heap_string(), fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([array heap_string()].foldr(heap_string(), fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([table heap_string() = heap_string()].foldr(heap_string(), fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([obj :1 = heap_string()].foldr(heap_string(), fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([set heap_string()].foldr(heap_string(), fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)

     test("1".foldr(heap_string(), fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().foldr(heap_string(), fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"1".foldr(heap_string(), fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().foldr(heap_string(), fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([array heap_string()].foldr(heap_string(), fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([table heap_string() = heap_string()].foldr(heap_string(), fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([obj :1 = heap_string()].foldr(heap_string(), fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([set heap_string()].foldr(heap_string(), fn (_) string_1).get_error_id() === :wrong_num_fn_args)

     test(to_error_container__foldr([array].init(10)).foldr(string_0, fn (_, _) string_1).get_error_id() == :3)
     test(to_error_custom_container__foldr([array].init(10)).foldr(string_0, fn (_, _) string_1).get_error_id() == :4)
}