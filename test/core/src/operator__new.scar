     let array_1  = rnd_byte_array()
     let array_2  = if rnd_bool(); array_1 else null
     let expected = array_1.map(_ + 0b01)
     let have     = loop([box 0, array_1], fn (state) {
          let [box idx, have] = state

          let byte     = have[idx]
          let new_byte = byte + 0b01
          let have     = new (have)[idx] <= new_byte
          let idx      = idx + 1

          if idx === len(have)
               [breaker have]
          else [box idx, have]
     })

     test(expected === have)
     array_2.ignore()

