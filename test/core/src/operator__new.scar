     let array_1  = rnd_string_array()
     let array_2  = if rnd_bool(); array_1 else null
     let expected = array_1.map(_.to_lower())
     let have     = loop([box 0, array_1], fn (state) {
          let [box idx, have] = state

          let string     = have[idx]
          let new_string = string.to_lower()
          let have       = new (have)[idx] <= new_string
          let idx        = idx + 1

          if idx === len(have)
               [breaker have]
          else [box idx, have]
     })

     test(expected === have)
     array_2.ignore()

     let array_1  = rnd_string_array()
     let array_2  = if rnd_bool(); array_1 else null
     let expected = array_1.map(_.to_lower())
     let have     = loop([box 0, array_1], fn (state) {
          let [box idx, have] = state

          let string     = have[idx]
          let new_string = string.to_lower()
          let have       = new (have)[idx] => fn (_) new_string
          let idx        = idx + 1

          if idx === len(have)
               [breaker have]
          else [box idx, have]
     })

     test(expected === have)
     array_2.ignore()

     let array_1                     = rnd_string_array()
     let array_2                     = if rnd_bool(); array_1 else null
     let expected                    = array_1.map(_.to_lower())
     let [box have, strings_correct] = loop([box 0, array_1, true], fn (state) {
          let [box idx, have, strings_correct] = state

          let string                 = have[idx]
          let new_string             = string.to_lower()
          let [box have, old_string] = new (have)[idx] <<= new_string
          let strings_correct        = strings_correct && string === old_string
          let idx                    = idx + 1

          if idx === len(have)
               [breaker [box have, strings_correct]]
          else [box idx, have, strings_correct]
     })

     test(expected === have)
     test(strings_correct)
     array_2.ignore()

     let array_1                     = rnd_string_array()
     let array_2                     = if rnd_bool(); array_1 else null
     let expected                    = array_1.map(_.to_lower())
     let [box have, strings_correct] = loop([box 0, array_1, true], fn (state) {
          let [box idx, have, strings_correct] = state

          let string                 = have[idx]
          let new_string             = string.to_lower()
          let [box have, old_string] = new (have)[idx] =>> fn (_) new_string
          let strings_correct        = strings_correct && string === old_string
          let idx                    = idx + 1

          if idx === len(have)
               [breaker [box have, strings_correct]]
          else [box idx, have, strings_correct]
     })

     test(expected === have)
     test(strings_correct)
     array_2.ignore()

