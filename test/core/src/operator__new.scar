     let string_1 = rnd_string()
     let string_2 = if rnd_bool(); string_1 else null
     let expected = string_1.map(fn (char) if char === @main.last_corsar_code.to_char(); 1.to_char() else (char.to_int() + 1).to_char())
     let have     = loop([box 0, string_1], fn (state) {
          let [box idx, have] = state

          let char     = have[idx]
          let new_char = if char === @main.last_corsar_code.to_char(); 1.to_char() else (char.to_int() + 1).to_char()
          let have     = new (have)[idx] <= new_char
          let idx      = idx + 1

          if idx === len(have)
               [breaker have]
          else [box idx, have]
     })

     test(expected === have)
     string_2.ignore()

