     let [box string_1, string_2] = if (rnd() & 1) === 0 {
          let string_1 = rnd_string()
          let string_2 = if (rnd() & 1) === 0; string_1 else null
          [box string_1, string_2]
     } else [box "Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let len             = len(string_1)
     let from            = (rnd() >> 1) % (len + 1)
     let to              = from + (rnd() >> 1) % (len - from + 1)
     let expected_string = string_1.foldl_kv("", fn (expected_string, idx, char) if idx < from || idx >= to; expected_string.append(char) else expected_string)
     test(string_1.delete(from, to) === expected_string)
     string_2.ignore()

