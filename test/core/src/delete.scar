let array__delete = [obj
     :value = [array]

     :_ = [obj
          :core_delete    = fn (arr, from, to) to_array__delete(arr:value.delete(from, to))
          :core___equal__ = fn (array_1, array_2) array_1:value === array_2:value
     ]
]

fn to_array__delete(arg) new (@main.array__delete):value <= arg

fn to_custom_array__delete(arg) custom__create(
     arg
     [obj
          :core_delete    = fn (arr, from, to) to_custom_array__delete(custom__get_data(arr).delete(from, to))
          :core___equal__ = fn (array_1, array_2) array_1.custom__get_data() === array_2.custom__get_data()
     ]
)

let broken_array__delete = [obj
     :value = [array]

     :_ = [obj
          :core_delete    = fn (_, _, _) heap_table()
     ]
]

fn to_broken_array__delete(arg) new (@main.broken_array__delete):value <= arg

fn to_broken_custom_array__delete(arg) custom__create(
     arg
     [obj
          :core_delete    = fn (_, _, _) heap_table()
     ]
)

let error_array__delete = [obj
     :value = [array]

     :_ = [obj
          :core_delete    = fn (_, _, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__delete(arg) new (@main.error_array__delete):value <= arg

fn to_error_custom_array__delete(arg) custom__create(
     arg
     [obj
          :core_delete    = fn (_, _, _) expected_error(:4, heap_string(), null)
     ]
)

