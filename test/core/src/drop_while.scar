     let items = u"0123456789abcdef".to_array()
     test(u"0123456789abcde".drop_while(fn (byte) byte =/= items[0]) === u"0123456789abcde")
     test(u"0123456789abcde".drop_while(fn (byte) byte =/= items[1]) === u"123456789abcde")
