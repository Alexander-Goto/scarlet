     test([array 1].drop_while(fn (item) item =/= items[0]) === [array 1])
     test([array 1].drop_while(fn (item) item === items[0]) === [array])
     test([array 1, 2, 3, 4, 5].drop_while(fn (item) item =/= items[0]) === [array 1, 2, 3, 4, 5])
     test([array 1, 2, 3, 4, 5].drop_while(fn (item) item =/= items[1]) === [array 2, 3, 4, 5])
     test([array 1, 2, 3, 4, 5].drop_while(fn (item) item =/= items[2]) === [array 3, 4, 5])
     test([array 1, 2, 3, 4, 5].drop_while(fn (item) item =/= items[3]) === [array 4, 5])
     test([array 1, 2, 3, 4, 5].drop_while(fn (item) item =/= items[4]) === [array 5])
     test([array 1, 2, 3, 4, 5].drop_while(fn (item) item =/= items[5]) === [array])

