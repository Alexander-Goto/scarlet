     test(u"0123456789abcde".drop_while(fn (byte) byte =/= items[9]) === u"9abcde")
     test(u"0123456789abcde".drop_while(fn (byte) byte =/= items[10]) === u"abcde")
     test(u"0123456789abcde".drop_while(fn (byte) byte =/= items[11]) === u"bcde")
     test(u"0123456789abcde".drop_while(fn (byte) byte =/= items[12]) === u"cde")
     test(u"0123456789abcde".drop_while(fn (byte) byte =/= items[13]) === u"de")
     test(u"0123456789abcde".drop_while(fn (byte) byte =/= items[14]) === u"e")
     test(u"0123456789abcde".drop_while(fn (byte) byte =/= items[15]) === u"")

     test(u"11000000000000".drop_while(_ === u"0"[0]) === u"11000000000000")
     test(u"01100000000000".drop_while(_ === u"0"[0]) === u"1100000000000")
