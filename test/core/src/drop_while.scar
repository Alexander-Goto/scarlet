     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.drop_while(_ ++ heap_string()).get_error_id() === :1)
     test(heap_string().drop_while(error_1).get_error_id() === :1)
     test(error_1.drop_while(error_2).get_error_id() === :1)
     test(error_2.drop_while(error_1).get_error_id() === :2)
     test(error_1.drop_while(heap_string()).get_error_id() === :1)
     test(heap_table().drop_while(error_1).get_error_id() === :1)

     test(heap_table().drop_while(_ ++ heap_string()).get_error_id() === :invalid_type)
     test(heap_string().drop_while(heap_table()).get_error_id() === :invalid_type)
     test(heap_table().drop_while(heap_table()).get_error_id() === :invalid_type)

     test(to_broken_array__drop_while("").drop_while(_ ++ heap_string()).get_error_id() === :invalid_type)
     test(to_broken_custom_array__drop_while("").drop_while(_ ++ heap_string()).get_error_id() === :invalid_type)
     test(to_error_array__drop_while("").drop_while(_ ++ heap_string()).get_error_id() === :3)
     test(to_error_custom_array__drop_while("").drop_while(_ ++ heap_string()).get_error_id() === :4)

     test("".drop_while(fn (_, _) string_1) === "")
     test(u"".drop_while(fn (_, _) string_1) === u"")
     test([array].drop_while(fn (_, _) string_1) === [array])

     test("".drop_while(fn (_) string_1) === "")
     test(u"".drop_while(fn (_) string_1) === u"")
     test([array].drop_while(fn (_) string_1) === [array])

     test("1".drop_while(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().drop_while(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"1".drop_while(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().drop_while(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)

     test("1".drop_while(fn (_) string_1).get_error_id() === :invalid_type)
     test(heap_string().drop_while(fn (_) string_1).get_error_id() === :invalid_type)
     test(u"1".drop_while(fn (_) string_1).get_error_id() === :invalid_type)
     test(heap_byte_array().drop_while(fn (_) string_1).get_error_id() === :invalid_type)
}
