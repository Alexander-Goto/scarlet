let array__drop_while = [obj
     :value = [array]

     :_ = [obj
          :core_drop_while = fn (arr, func) to_array__drop_while(arr:value.drop_while(func))
          :core___equal__  = fn (array_1, array_2) array_1:value === array_2:value
     ]
]

fn to_array__drop_while(arg) new (@main.array__drop_while):value <= arg

fn to_custom_array__drop_while(arg) custom__create(
     arg
     [obj
          :core_drop_while = fn (arr, func) to_custom_array__drop_while(custom__get_data(arr).drop_while(func))
          :core___equal__  = fn (array_1, array_2) array_1.custom__get_data() === array_2.custom__get_data()
     ]
)

let broken_array__drop_while = [obj
     :value = [array]

     :_ = [obj
          :core_drop_while = fn (_, _) heap_table()
     ]
]

fn to_broken_array__drop_while(arg) new (@main.broken_array__drop_while):value <= arg

fn to_broken_custom_array__drop_while(arg) custom__create(
     arg
     [obj
          :core_drop_while = fn (_, _) heap_table()
     ]
)

let error_array__drop_while = [obj
     :value = [array]

     :_ = [obj
          :core_drop_while = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__drop_while(arg) new (@main.error_array__drop_while):value <= arg

fn to_error_custom_array__drop_while(arg) custom__create(
     arg
     [obj
          :core_drop_while = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__drop_while() {
     let items = "0123456789abcdef".to_array()
     test("".drop_while(fn (char) char =/= items[0]) === "")
     test("1".drop_while(fn (char) char =/= items[1]) === "1")
     test("1".drop_while(fn (char) char === items[1]) === "")
     test("0123456789abcde".drop_while(fn (char) char =/= items[0]) === "0123456789abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[1]) === "123456789abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[2]) === "23456789abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[3]) === "3456789abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[4]) === "456789abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[5]) === "56789abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[6]) === "6789abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[7]) === "789abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[8]) === "89abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[9]) === "9abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[10]) === "abcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[11]) === "bcde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[12]) === "cde")
     test("0123456789abcde".drop_while(fn (char) char =/= items[13]) === "de")
     test("0123456789abcde".drop_while(fn (char) char =/= items[14]) === "e")
     test("0123456789abcde".drop_while(fn (char) char =/= items[15]) === "")

     let items = "\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5f".to_array()
     test("\000091".drop_while(fn (char) char =/= items[0]) === "\000091")
     test("\000091".drop_while(fn (char) char === items[0]) === "")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".drop_while(fn (char) char =/= items[0]) === "\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".drop_while(fn (char) char =/= items[1]) === "\0000b3\0000ab!!!\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".drop_while(fn (char) char =/= items[2]) === "\0000ab!!!\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".drop_while(fn (char) char =/= items[3]) === "!!!\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".drop_while(fn (char) char =/= items[6]) === "\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".drop_while(fn (char) char =/= items[7]) === "\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".drop_while(fn (char) char =/= items[8]) === "\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".drop_while(fn (char) char =/= items[9]) === "")

     let items = "0123456789abcdefg".to_array()
     test("0123456789abcdef".drop_while(fn (char) char =/= items[0]) === "0123456789abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[1]) === "123456789abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[2]) === "23456789abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[3]) === "3456789abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[4]) === "456789abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[5]) === "56789abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[6]) === "6789abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[7]) === "789abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[8]) === "89abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[9]) === "9abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[10]) === "abcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[11]) === "bcdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[12]) === "cdef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[13]) === "def")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[14]) === "ef")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[15]) === "f")
     test("0123456789abcdef".drop_while(fn (char) char =/= items[16]) === "")

     let items = "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7g".to_array()
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[0]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[1]) === "\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[2]) === "\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[3]) === "\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[4]) === "\0000a7\0000b5 \0000af\0000ae\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[5]) === "\0000b5 \0000af\0000ae\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[6]) === " \0000af\0000ae\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[7]) === "\0000af\0000ae\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[8]) === "\0000ae\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[9]) === "\0000b7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".drop_while(fn (char) char =/= items[10]) === "")

     test("110000000000000".drop_while(_ === '0') === "110000000000000")
     test("011000000000000".drop_while(_ === '0') === "11000000000000")
     test("000000000000011".drop_while(_ === '0') === "11")
     test("1100000000000000".drop_while(_ === '0') === "1100000000000000")
     test("0110000000000000".drop_while(_ === '0') === "110000000000000")
     test("0000000000000011".drop_while(_ === '0') === "11")

     let [box string_1, string_2] = if (rnd() & 1) === 0 {
          let string_1 = rnd_string()
          let string_2 = if (rnd() & 1) === 0; string_1 else null
          [box string_1, string_2]
     } else [box "Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let len             = len(string_1)
     let n               = (rnd() >> 1) % len
     let n_char          = string_1[n]
     let expected_string = string_1[n_char.look_in(string_1), len].unslice()
     test(string_1.drop_while(_ =/= n_char) === expected_string)
     string_2.ignore()

     let [box string_1, string_2] = if (rnd() & 1) === 0 {
          let string_1 = rnd_string()
          let string_2 = if (rnd() & 1) === 0; string_1 else null
          [box string_1, string_2]
     } else [box "Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let len             = len(string_1)
     let n               = (rnd() >> 1) % len
     let n_char          = string_1[n]
     let expected_string = string_1[n_char.look_in(string_1), len].unslice()
     test(string_1.drop_while(fn (char) string_1 === 17 || char =/= n_char) === expected_string)
     string_2.ignore()

     let items = u"0123456789abcde".to_array()
     test(u"".drop_while(fn (byte) byte =/= items[0]) === u"")
     test(u"1".drop_while(fn (byte) byte =/= items[1]) === u"1")
     test(u"1".drop_while(fn (byte) byte === items[1]) === u"")
     test(u"0123456789abcd".drop_while(fn (byte) byte =/= items[0]) === u"0123456789abcd")
