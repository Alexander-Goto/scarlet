     test([array string_1].drop_while(fn (item) item =/= items[0]) === [array string_1])
     test([array string_1].drop_while(fn (item) item === items[0]) === [array])
     test([array string_1, string_2, string_3, string_4, string_5].drop_while(fn (item) item =/= items[0]) === [array string_1, string_2, string_3, string_4, string_5])
     test([array string_1, string_2, string_3, string_4, string_5].drop_while(fn (item) item =/= items[1]) === [array string_2, string_3, string_4, string_5])
     test([array string_1, string_2, string_3, string_4, string_5].drop_while(fn (item) item =/= items[2]) === [array string_3, string_4, string_5])
     test([array string_1, string_2, string_3, string_4, string_5].drop_while(fn (item) item =/= items[3]) === [array string_4, string_5])
     test([array string_1, string_2, string_3, string_4, string_5].drop_while(fn (item) item =/= items[4]) === [array string_5])
     test([array string_1, string_2, string_3, string_4, string_5].drop_while(fn (item) item =/= items[5]) === [array])

     let [box array_1, array_2] = if (rnd() & 1) === 0 {
