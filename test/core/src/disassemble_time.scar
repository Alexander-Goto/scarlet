`noinline`
fn test__disassemble_time() {
     test(disassemble_time(0.int_to_time(), 0) == [box 1970, 1, 1, 0, 0, 0])
     test(disassemble_time(11002.int_to_time(), 0) == [box 1970, 1, 1, 3, 3, 22])
     test(disassemble_time(63072000.int_to_time(), 0) == [box 1972, 1, 1, 0, 0, 0])
     test(disassemble_time(63079789.int_to_time(), 0) == [box 1972, 1, 1, 2, 9, 49])
     test(disassemble_time(946684800.int_to_time(), 0) == [box 2000, 1, 1, 0, 0, 0])
     test(disassemble_time(946685978.int_to_time(), 0) == [box 2000, 1, 1, 0, 19, 38])
     test(disassemble_time(3071675727.int_to_time(), 0) == [box 2067, 5, 3, 19, 15, 27])
     test(disassemble_time(2982223890.int_to_time(), 0) == [box 2064, 7, 2, 11, 31, 30])
     test(disassemble_time(1056498668.int_to_time(), 0) == [box 2003, 6, 24, 23, 51, 8])
     test(disassemble_time(549784052.int_to_time(), 0) == [box 1987, 6, 4, 5, 47, 32])
     test(disassemble_time(2953582074.int_to_time(), 0) == [box 2063, 8, 5, 23, 27, 54])
     test(disassemble_time(8689046.int_to_time(), 0) == [box 1970, 4, 11, 13, 37, 26])
     test(disassemble_time(1376809701.int_to_time(), 0) == [box 2013, 8, 18, 7, 8, 21])
     test(disassemble_time(3824707036.int_to_time(), 0) == [box 2091, 3, 14, 10, 37, 16])
     test(disassemble_time(1158132353.int_to_time(), 0) == [box 2006, 9, 13, 7, 25, 53])
     test(disassemble_time(949624230.int_to_time(), 0) == [box 2000, 2, 4, 0, 30, 30])
     test(disassemble_time(1281717032.int_to_time(), 0) == [box 2010, 8, 13, 16, 30, 32])
     test(disassemble_time(781467978.int_to_time(), 0) == [box 1994, 10, 6, 18, 26, 18])
     test(disassemble_time(1662330597.int_to_time(), 0) == [box 2022, 9, 4, 22, 29, 57])
     test(disassemble_time(3641724393.int_to_time(), 0) == [box 2085, 5, 26, 14, 6, 33])
     test(disassemble_time(2074699765.int_to_time(), 0) == [box 2035, 9, 29, 17, 29, 25])
     test(disassemble_time(2666241882.int_to_time(), 0) == [box 2054, 6, 28, 6, 44, 42])
     test(disassemble_time(2639079008.int_to_time(), 0) == [box 2053, 8, 17, 21, 30, 8])
     test(disassemble_time(3248551025.int_to_time(), 0) == [box 2072, 12, 9, 23, 17, 5])
     test(disassemble_time(2715062736.int_to_time(), 0) == [box 2056, 1, 14, 8, 5, 36])
     test(disassemble_time(1228890761.int_to_time(), 0) == [box 2008, 12, 10, 6, 32, 41])

     test(disassemble_time(9223372036825516799.int_to_time(), 0) == [box 292277026595, 12, 31, 23, 59, 59])
     test(disassemble_time(9223372036825516799.int_to_time(), 86400) == [box 292277026596, 1, 1, 23, 59, 59])
     test(disassemble_time(9223372036825516799.int_to_time(), -86400) == [box 292277026595, 12, 30, 23, 59, 59])
     test(disassemble_time(0.int_to_time(), 86400) == [box 1970, 1, 2, 0, 0, 0])
     test(disassemble_time(0.int_to_time(), -86400) == [box 1969, 12, 31, 0, 0, 0])

     test(disassemble_time(5011200.int_to_time(), 0) == [box 1970, 2, 28, 0, 0, 0])
     test(disassemble_time(5097600.int_to_time(), 0) == [box 1970, 3, 1, 0, 0, 0])
     test(disassemble_time(68169600.int_to_time(), 0) == [box 1972, 2, 29, 0, 0, 0])
     test(disassemble_time(951782400.int_to_time(), 0) == [box 2000, 2, 29, 0, 0, 0])
     test(disassemble_time(1078012800.int_to_time(), 0) == [box 2004, 2, 29, 0, 0, 0])
     test(disassemble_time(4107456000.int_to_time(), 0) == [box 2100, 2, 28, 0, 0, 0])
     test(disassemble_time(4107542400.int_to_time(), 0) == [box 2100, 3, 1, 0, 0, 0])

     test(disassemble_time(0.int_to_time(), 86401.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(disassemble_time(0.int_to_time(), -86401.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(disassemble_time(0.int_to_time(), 9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(disassemble_time(0.int_to_time(), -9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(disassemble_time(error_1, 0).get_error_id() === :1)
     test(disassemble_time(0.int_to_time(), error_1).get_error_id() === :1)
     test(disassemble_time(error_1, error_2).get_error_id() === :1)
     test(disassemble_time(error_2, error_1).get_error_id() === :2)
     test(disassemble_time(error_1, -9223372036825516800.scarlet__erase_info()).get_error_id() === :1)

     test(disassemble_time(0.int_to_time(), heap_string()).get_error_id() === :invalid_type)
     test(disassemble_time(heap_string(), 0).get_error_id() === :invalid_type)
     test(disassemble_time(heap_string(), heap_string()).get_error_id() === :invalid_type)
}