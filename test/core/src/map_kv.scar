let container__map_kv = [obj
     :value = [array]

     :_ = [obj
          :core_map_kv    = fn (container, func) to_container__map_kv(container:value.map_kv(func))
          :core___equal__ = fn (container_1, container_2) container_1:value === container_2:value
     ]
]

fn to_container__map_kv(arg) new (@main.container__map_kv):value <= arg

fn to_custom_container__map_kv(arg) custom__create(
     arg
     [obj
          :core_map_kv    = fn (container, func) to_custom_container__map_kv(custom__get_data(container).map_kv(func))
          :core___equal__ = fn (container_1, container_2) container_1.custom__get_data() === container_2.custom__get_data()
     ]
)

let broken_container__map_kv = [obj
     :value = [array]

     :_ = [obj
          :core_map_kv = fn (_, _) _ ++ heap_table()
     ]
]

fn to_broken_container__map_kv(arg) new (@main.broken_container__map_kv):value <= arg

fn to_broken_custom_container__map_kv(arg) custom__create(
     arg
     [obj
          :core_map_kv = fn (_, _) _ ++ heap_table()
     ]
)

let error_container__map_kv = [obj
     :value = [array]

     :_ = [obj
          :core_map_kv = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_container__map_kv(arg) new (@main.error_container__map_kv):value <= arg

fn to_error_custom_container__map_kv(arg) custom__create(
     arg
     [obj
          :core_map_kv = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__map_kv() {
     let items = "3".to_array()
     test("".map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "")
     test("1".map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "2")
     test("122333444455555".map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "2/3040737384848")

     let items = "\000093".to_array()
     test("\000091".map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "\000092")
     test("\0000912\000092\000093\000093\000093\000094\000094".map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "\000092/\000093\000090\000094\000090\000097\000093")

     let items  = "3".to_array()
     let string = "011012375611135" ++ "f"
     test("011012375611135f".map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "1.2-2/46852.208e")
     test(string.map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "1.2-2/46852.208e")
     test(string.map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "1.2-2/46852.208e")

     let items  = "\000093".to_array()
     let string = "\000090\000091\000091\000090\000091\000092\000093\000097\000095\000096\000091\000091\000091\000093\000095" ++ "\00009f"
     test("\000090\000091\000091\000090\000091\000092\000093\000097\000095\000096\000091\000091\000091\000093\000095\00009f".map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "\000091\00008e\000092\00008d\000092\00008f\000094\000096\000098\000095\000092\00008e\000092\000090\000098\00009e")
     test(string.map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "\000091\00008e\000092\00008d\000092\00008f\000094\000096\000098\000095\000092\00008e\000092\000090\000098\00009e")
     test(string.map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "\000091\00008e\000092\00008d\000092\00008f\000094\000096\000098\000095\000092\00008e\000092\000090\000098\00009e")

     let items  = "3".to_array()
     let string = ("0011012375611135f" ++ "0")[1, 17]
     test("0011012375611135f0"[1, 17].map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "1.2-2/46852.208e")
     test(string.map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "1.2-2/46852.208e")
     test(string.map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "1.2-2/46852.208e")

     let items  = "\000093".to_array()
     let string = ("0\000090\000091\000091\000090\000091\000092\000093\000097\000095\000096\000091\000091\000091\000093\000095\00009f" ++ "0")[1, 17]
     test("0\000090\000091\000091\000090\000091\000092\000093\000097\000095\000096\000091\000091\000091\000093\000095\00009f0"[1, 17].map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "\000091\00008e\000092\00008d\000092\00008f\000094\000096\000098\000095\000092\00008e\000092\000090\000098\00009e")
     test(string.map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "\000091\00008e\000092\00008d\000092\00008f\000094\000096\000098\000095\000092\00008e\000092\000090\000098\00009e")
     test(string.map_kv(fn (idx, char) (char.to_int() + (if char > items[0]; 1 else -1) + if idx.even?(); 2 else -2).to_char()) === "\000091\00008e\000092\00008d\000092\00008f\000094\000096\000098\000095\000092\00008e\000092\000090\000098\00009e")

     let string_1        = rnd_string()
     let string_2        = if rnd_bool(); string_1 else null
     let expected_string = string_1.foldl_kv("", fn (string, idx, char)
          if not char.in_range?('\000004', (@main.last_corsar_code - 2).to_char())
               string.append(char)
          else string.append((char.to_int() + if idx.even?(); 1 else -1).to_char())
     )
     let have_string = string_1.map_kv(fn (idx, char)
          if not char.in_range?('\000004', (@main.last_corsar_code - 2).to_char())
               char
          else (char.to_int() + if idx.even?(); 1 else -1).to_char()
     )
     test(expected_string === have_string)
     string_2.ignore()

     let items = u"3".to_array()
     test(u"".map_kv(fn (idx, byte) byte + (if byte > items[0]; 0b01 else 0bff) + if idx.even?(); 0b02 else 0bfe) === u"")
     test(u"1".map_kv(fn (idx, byte) byte + (if byte > items[0]; 0b01 else 0bff) + if idx.even?(); 0b02 else 0bfe) === u"2")
     test(u"12233344445555".map_kv(fn (idx, byte) byte + (if byte > items[0]; 0b01 else 0bff) + if idx.even?(); 0b02 else 0bfe) === u"2/304073738484")

     let items  = u"3".to_array()
     let array = u"011012375611135" ++ u"f"
     test(u"011012375611135f".map_kv(fn (idx, byte) byte + (if byte > items[0]; 0b01 else 0bff) + if idx.even?(); 0b02 else 0bfe) === u"1.2-2/46852.208e")
     test(array.map_kv(fn (idx, byte) byte + (if byte > items[0]; 0b01 else 0bff) + if idx.even?(); 0b02 else 0bfe) === u"1.2-2/46852.208e")
     test(array.map_kv(fn (idx, byte) byte + (if byte > items[0]; 0b01 else 0bff) + if idx.even?(); 0b02 else 0bfe) === u"1.2-2/46852.208e")

     let items  = u"3".to_array()
     let array = (u"0011012375611135f" ++ u"0")[1, 17]
     test(u"0011012375611135f0"[1, 17].map_kv(fn (idx, byte) byte + (if byte > items[0]; 0b01 else 0bff) + if idx.even?(); 0b02 else 0bfe) === u"1.2-2/46852.208e")
     test(array.map_kv(fn (idx, byte) byte + (if byte > items[0]; 0b01 else 0bff) + if idx.even?(); 0b02 else 0bfe) === u"1.2-2/46852.208e")
     test(array.map_kv(fn (idx, byte) byte + (if byte > items[0]; 0b01 else 0bff) + if idx.even?(); 0b02 else 0bfe) === u"1.2-2/46852.208e")

     let array_1        = rnd_byte_array()
     let array_2        = if rnd_bool(); array_1 else null
     let expected_array = array_1.foldl_kv(u"", fn (array, idx, byte) array.append(byte + if idx.even?(); 0b01 else 0bff))
     let have_array = array_1.map_kv(fn (idx, byte) byte + if idx.even?(); 0b01 else 0bff)
     test(expected_array === have_array)
     array_2.ignore()

     let string_1 = heap_string()
     let string_2 = string_1 ++ "2"
     let string_3 = string_1 ++ "3"
     test([array].map_kv(fn (idx, string) string ++ idx.to_string()) === [array])
     test([array].init(10).map_kv(fn (idx, string) string ++ idx.to_string()) === [array])
     test([array string_1].map_kv(fn (idx, string) string ++ idx.to_string()) === [array string_1 ++ "0"])
     test([array "1", "2", "3"].map_kv(fn (idx, string) string ++ idx.to_string()) === [array "10", "21", "32"])
     test([array "0", "1", "2", "3", "0"][1, 4].map_kv(fn (idx, string) string ++ idx.to_string()) === [array "10", "21", "32"])

     let array = [array string_1, string_2, string_3]
     test(array.map_kv(fn (idx, string) string ++ idx.to_string()) === [array string_1 ++ "0", string_2 ++ "1", string_3 ++ "2"])
     test(array.map_kv(fn (idx, string) string ++ idx.to_string()) === [array string_1 ++ "0", string_2 ++ "1", string_3 ++ "2"])

     let array = [array string_3, string_1, string_2, string_3, string_1][1, 4]
     test(array.map_kv(fn (idx, string) string ++ idx.to_string()) === [array string_1 ++ "0", string_2 ++ "1", string_3 ++ "2"])
     test(array.map_kv(fn (idx, string) string ++ idx.to_string()) === [array string_1 ++ "0", string_2 ++ "1", string_3 ++ "2"])

     test([array 1, 2, 3, 4].map_kv(fn (idx, num) (idx + num).to_string()) === [array "1", "3", "5", "7"])

     let array_1        = rnd_string_array()
     let array_2        = if rnd_bool(); array_1 else null
     let expected_array = array_1.foldl_kv([array], fn (array, idx, string) array.append(string ++ idx.to_string()))
     let have_array     = array_1.map_kv(fn (idx, string) string ++ idx.to_string())
     test(expected_array === have_array)
     array_2.ignore()

     let string_1 = heap_string()
     let string_2 = string_1 ++ "2"
     let string_3 = string_1 ++ "3"
     test([table].map_kv(fn (key, value) value ++ key) === [table])
     test([table].init(10).map_kv(fn (key, value) value ++ key) === [table])
     test([table string_3 = string_1].map_kv(fn (key, value) value ++ key) === [table string_3 = string_1 ++ string_3])
     test([table "0" = "1", "1" = "2", "2" = "3"].map_kv(fn (key, value) value ++ key) === [table "0" = "10", "1" = "21", "2" = "32"])

     let table = [table string_3 = string_1, string_1 = string_2, string_2 = string_3]
     test(table.map_kv(fn (key, value) value ++ key) === [table string_3 = string_1 ++ string_3, string_1 = string_2 ++ string_1, string_2 = string_3 ++ string_2])
     test(table.map_kv(fn (key, value) value ++ key) === [table string_3 = string_1 ++ string_3, string_1 = string_2 ++ string_1, string_2 = string_3 ++ string_2])

     test([table 0 = 1, 1 = 2, 2 = 3, 3 = 4].map_kv(fn (key, value) (key + value).to_string()) === [table 0 = "1", 1 = "3", 2 = "5", 3 = "7"])

     let table_1        = rnd_string_table()
     let table_2        = if rnd_bool(); table_1 else null
     let expected_table = table_1.foldl_kv([table], fn (table, key, value) new (table)[key] <= value ++ key)
     let have_table     = table_1.map_kv(fn (key, value) value ++ key)
     test(expected_table === have_table)
     table_2.ignore()

     let string_1 = heap_string()
     let string_2 = string_1 ++ "2"
     let string_3 = string_1 ++ "3"
     test([obj].map_kv(fn (key, value) value ++ key.to_string()) === [obj])
     test([obj :_ = [obj :1 = 2]].map_kv(fn (key, value) value ++ key.to_string()) === [obj])
     test([obj :_ = [obj :1 = 2]].map_kv(fn (key, value) value ++ key.to_string()):_ === [obj :1 = 2])
     test([obj].init(10).map_kv(fn (key, value) value ++ key.to_string()) === [obj])
     test([obj :3 = string_1].map_kv(fn (key, value) value ++ key.to_string()) === [obj :3 = string_1 ++ "3"])
     test([obj :3 = string_1, :_ = [obj :1 = 2]].map_kv(fn (key, value) value ++ key.to_string()) === [obj :3 = string_1 ++ "3"])
     test([obj :3 = string_1, :_ = [obj :1 = 2]].map_kv(fn (key, value) value ++ key.to_string()):_ === [obj :1 = 2])
     test([obj :0 = "1", :1 = "2", :2 = "3"].map_kv(fn (key, value) value ++ key.to_string()) === [obj :0 = "10", :1 = "21", :2 = "32"])
     test([obj :0 = "1", :1 = "2", :2 = "3", :_ = [obj :1 = 2]].map_kv(fn (key, value) value ++ key.to_string()) === [obj :0 = "10", :1 = "21", :2 = "32"])
     test([obj :0 = "1", :1 = "2", :2 = "3", :_ = [obj :1 = 2]].map_kv(fn (key, value) value ++ key.to_string()):_ === [obj :1 = 2])

     let obj = [obj :3 = string_1, :1 = string_2, :2 = string_3]
     test(obj.map_kv(fn (key, value) value ++ key.to_string()) === [obj :3 = string_1 ++ "3", :1 = string_2 ++ "1", :2 = string_3 ++ "2"])
     test(obj.map_kv(fn (key, value) value ++ key.to_string()) === [obj :3 = string_1 ++ "3", :1 = string_2 ++ "1", :2 = string_3 ++ "2"])

     let obj = [obj :3 = string_1, :1 = string_2, :2 = string_3, :_ = [obj :1 = 2]]
     test(obj.map_kv(fn (key, value) value ++ key.to_string()) === [obj :3 = string_1 ++ "3", :1 = string_2 ++ "1", :2 = string_3 ++ "2"])
     test(obj.map_kv(fn (key, value) value ++ key.to_string()) === [obj :3 = string_1 ++ "3", :1 = string_2 ++ "1", :2 = string_3 ++ "2"])

     let obj = [obj :3 = string_1, :1 = string_2, :2 = string_3, :_ = [obj :1 = 2]]
     test(obj.map_kv(fn (key, value) value ++ key.to_string()):_ === [obj :1 = 2])
     test(obj.map_kv(fn (key, value) value ++ key.to_string()):_ === [obj :1 = 2])

     test([obj :0 = 1, :1 = 2, :2 = 3, :3 = 4].map_kv(fn (key, value) key.to_string() ++ value.to_string()) === [obj :0 = "01", :1 = "12", :2 = "23", :3 = "34"])

     let obj_1        = rnd_string_obj()
     let obj_2        = if rnd_bool(); obj_1 else null
     let expected_obj = obj_1.foldl_kv([obj], fn (obj, key, value) new (obj)[key] <= value ++ key.to_string())
     let have_obj     = obj_1.map_kv(fn (key, value) value ++ key.to_string())
     test(expected_obj === have_obj)
     obj_2.ignore()

     test(to_container__map_kv("abCD").map_kv(fn (idx, char) if idx.even?(); char.ascii_to_lower() else char) === to_container__map_kv("abcD"))
     test(to_container__map_kv("abCD").map_kv(fn (idx, char) if idx.even?(); char.ascii_to_upper() else char) === to_container__map_kv("AbCD"))
     test(to_custom_container__map_kv("abCD").map_kv(fn (idx, char) if idx.even?(); char.ascii_to_lower() else char) === to_custom_container__map_kv("abcD"))
     test(to_custom_container__map_kv("abCD").map_kv(fn (idx, char) if idx.even?(); char.ascii_to_upper() else char) === to_custom_container__map_kv("AbCD"))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.map_kv(heap_string().insert_to(_, _)).get_error_id() === :1)
     test(heap_string().map_kv(error_1).get_error_id() === :1)
     test(error_1.map_kv(error_2).get_error_id() === :1)
     test(error_2.map_kv(error_1).get_error_id() === :2)
     test(error_1.map_kv(heap_string()).get_error_id() === :1)
     test((_ === heap_string()).scarlet__erase_info().map_kv(error_1).get_error_id() === :1)

     test((_ === heap_string()).scarlet__erase_info().map_kv(heap_string().insert_to(_, _)).get_error_id() === :invalid_type)
     test(heap_string().map_kv(heap_table()).get_error_id() === :invalid_type)
     test((_ === heap_string()).scarlet__erase_info().map_kv(heap_table()).get_error_id() === :invalid_type)

     test(to_broken_container__map_kv("").map_kv(_ === heap_string()).get_error_id() === :invalid_type)
     test(to_broken_custom_container__map_kv("").map_kv(_ === heap_string()).get_error_id() === :invalid_type)
     test(to_error_container__map_kv("").map_kv(_ === heap_string()).get_error_id() === :3)
     test(to_error_custom_container__map_kv("").map_kv(_ === heap_string()).get_error_id() === :4)

     test("".map_kv(fn (_) string_1) === "")
     test(u"".map_kv(fn (_) string_1) === u"")
     test([array].map_kv(fn (_) string_1) === [array])
     test([table].map_kv(fn (_) string_1) === [table])
     test([obj].map_kv(fn (_) string_1) === [obj])
     test([obj :_ = [obj]].map_kv(fn (_) string_1) === [obj])
     test([obj :_ = [obj]].map_kv(fn (_) string_1):_ === [obj])

     test("1".map_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().map_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"1".map_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().map_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([array heap_string()].map_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([table heap_string() = heap_string()].map_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([obj :1 = heap_string()].map_kv(fn (_) string_1).get_error_id() === :wrong_num_fn_args)

     test("1".map_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
     test(heap_string().map_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
     test(u"1".map_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
     test(heap_byte_array().map_kv(fn (_, _) string_1).get_error_id() === :invalid_type)
}