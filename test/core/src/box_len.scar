`noinline`
fn test__box_len() {
     let string_1  = rnd_string()
     let string_2  = rnd_string()
     let string_3  = rnd_string()
     let string_4  = rnd_string()
     let string_5  = rnd_string()
     let string_6  = rnd_string()
     let string_7  = rnd_string()
     let string_8  = rnd_string()
     let string_9  = rnd_string()
     let string_10 = rnd_string()
     let string_11 = rnd_string()
     let string_12 = rnd_string()
     let string_13 = rnd_string()
     let string_14 = rnd_string()
     let string_15 = rnd_string()
     let string_16 = rnd_string()
     test([box].box_len() === [box 0, [box]])
     test([box string_1].box_len() === [box 1, [box string_1]])
     test([box string_1, string_2].box_len() === [box 2, [box string_1, string_2]])
     test([box string_1, string_2, string_3].box_len() === [box 3, [box string_1, string_2, string_3]])
     test([box string_1, string_2, string_3, string_4].box_len() === [box 4, [box string_1, string_2, string_3, string_4]])
     test([box string_1, string_2, string_3, string_4, string_5].box_len() === [box 5, [box string_1, string_2, string_3, string_4, string_5]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6].box_len() === [box 6, [box string_1, string_2, string_3, string_4, string_5, string_6]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7].box_len() === [box 7, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8].box_len() === [box 8, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9].box_len() === [box 9, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10].box_len() === [box 10, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11].box_len() === [box 11, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12].box_len() === [box 12, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13].box_len() === [box 13, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_14].box_len() === [box 14, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_14]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_14, string_15].box_len() === [box 15, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_14, string_15]])
     test([box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_14, string_15, string_16].box_len() === [box 16, [box string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_14, string_15, string_16]])

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.box_len().get_error_id() === :1)
     test(heap_string().box_len().get_error_id() === :invalid_type)
}