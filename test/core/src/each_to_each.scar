     test([obj :1 = string_3, :2 = string_2, :3 = string_1].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]) === [obj :1 = string_3, :2 = string_1, :3 = string_2])
     test([obj :1 = string_3, :2 = string_2, :3 = string_1, :_ = [obj :1 = 2]].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]) === [obj :1 = string_3, :2 = string_1, :3 = string_2])
     test([obj :1 = string_3, :2 = string_2, :3 = string_1, :_ = [obj :1 = 2]].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]):_ === [obj :1 = 2])
     test([obj :1 = string_1, :2 = string_2, :3 = string_3].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]) === [obj :1 = string_2, :2 = string_1, :3 = string_3])
     test([obj :1 = string_1, :2 = string_2, :3 = string_3, :_ = [obj :1 = 2]].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]) === [obj :1 = string_2, :2 = string_1, :3 = string_3])
     test([obj :1 = string_1, :2 = string_2, :3 = string_3, :_ = [obj :1 = 2]].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]):_ === [obj :1 = 2])
     test([obj :1 = string_2, :2 = string_1, :3 = string_3].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]) === [obj :1 = string_1, :2 = string_2, :3 = string_3])
     test([obj :1 = string_2, :2 = string_1, :3 = string_3, :_ = [obj :1 = 2]].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]) === [obj :1 = string_1, :2 = string_2, :3 = string_3])
     test([obj :1 = string_2, :2 = string_1, :3 = string_3, :_ = [obj :1 = 2]].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]):_ === [obj :1 = 2])

     test([obj].each_to_each(fn (item_1, item_2) [box item_1, item_2]) === [obj])
     test([obj].init(10).each_to_each(fn (item_1, item_2) [box item_1, item_2]) === [obj])
     test([obj :1 = string_2].each_to_each(fn (item_1, item_2) [box item_1, item_2]) === [obj :1 = string_2])
     test([obj :1 = string_2, :2 = string_1].each_to_each(fn (item_1, item_2) [box item_1, item_2]) === [obj :1 = string_2, :2 = string_1])
     test([obj :1 = string_3, :2 = string_1, :3 = string_2].each_to_each(fn (item_1, item_2) [box item_1, item_2]) === [obj :1 = string_3, :2 = string_1, :3 = string_2])

     let array = loop(rnd_string_array(), fn (array) {
          let uniq = array.foldl([set], _.append(_))

          if uniq.len() < 3
               rnd_string_array()
          else [breaker uniq.foldl([array].init(uniq.len()), _.append(_))]
     })
     let right_idx    = (rnd() >> 1) % array.len()
     let left_idx     = (rnd() >> 1) % (right_idx + 1)
     let left_item    = array[left_idx]
     let right_item   = array[right_idx]
     let obj_1        = array.foldl_kv([obj].init(array.len()), fn (obj, idx, item) new (obj)[idx.to_string().str_to_tkn()] <= item)
     let obj_2        = if rnd_bool(); obj_1 else null
     let expected_obj = new (obj_1) {
          [left_idx.to_string().str_to_tkn()]  <= right_item
          [right_idx.to_string().str_to_tkn()] <= left_item
     }
     let have_obj = obj_1.each_to_each(fn (item_1, item_2) if item_1 == left_item && item_2 == right_item || item_1 == right_item && item_2 == left_item; [box item_2, item_1] else [box item_1, item_2])
     test(expected_obj === have_obj)
     obj_2.ignore()

     test(to_container__each_to_each("abcd").each_to_each(fn (char_1, char_2) if char_1 == 'a' && char_2 == 'b'; [box 'f', 'g'] else [box char_1, char_2]) === to_container__each_to_each("fgcd"))
     test(to_container__each_to_each("abcd").each_to_each(fn (char_1, char_2) if char_1 == 'a' && char_2 == 'd'; [box 'f', 'g'] else [box char_1, char_2]) === to_container__each_to_each("fbcg"))
     test(to_custom_container__each_to_each("abcd").each_to_each(fn (char_1, char_2) if char_1 == 'a' && char_2 == 'b'; [box 'f', 'g'] else [box char_1, char_2]) === to_custom_container__each_to_each("fgcd"))
     test(to_custom_container__each_to_each("abcd").each_to_each(fn (char_1, char_2) if char_1 == 'a' && char_2 == 'd'; [box 'f', 'g'] else [box char_1, char_2]) === to_custom_container__each_to_each("fbcg"))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.each_to_each(heap_string().insert_to(_, _)).get_error_id() === :1)
     test(heap_string().each_to_each(error_1).get_error_id() === :1)
     test(error_1.each_to_each(error_2).get_error_id() === :1)
     test(error_2.each_to_each(error_1).get_error_id() === :2)
     test(error_1.each_to_each(heap_string()).get_error_id() === :1)
     test((_ === heap_string()).scarlet__erase_info().each_to_each(error_1).get_error_id() === :1)

     test((_ === heap_string()).scarlet__erase_info().each_to_each(heap_string().insert_to(_, _)).get_error_id() === :invalid_type)
     test(heap_string().each_to_each(heap_table()).get_error_id() === :invalid_type)
     test((_ === heap_string()).scarlet__erase_info().each_to_each(heap_table()).get_error_id() === :invalid_type)

     test(to_broken_container__each_to_each("").each_to_each(_ === heap_string()).get_error_id() === :invalid_type)
     test(to_broken_custom_container__each_to_each("").each_to_each(_ === heap_string()).get_error_id() === :invalid_type)
     test(to_error_container__each_to_each("").each_to_each(_ === heap_string()).get_error_id() === :3)
     test(to_error_custom_container__each_to_each("").each_to_each(_ === heap_string()).get_error_id() === :4)

     test("".each_to_each(fn (_) string_1) === "")
     test(u"".each_to_each(fn (_) string_1) === u"")
     test([array].each_to_each(fn (_) string_1) === [array])
     test([table].each_to_each(fn (_) string_1) === [table])
     test([obj].each_to_each(fn (_) string_1) === [obj])
     test([obj :_ = [obj]].each_to_each(fn (_) string_1) === [obj])
     test([obj :_ = [obj]].each_to_each(fn (_) string_1):_ === [obj])

     test("01".each_to_each(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().each_to_each(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"01".each_to_each(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().each_to_each(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([array 0, heap_string()].each_to_each(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([table 0 = 1, heap_string() = heap_string()].each_to_each(fn (_) string_1).get_error_id() === :wrong_num_fn_args)
     test([obj :0 = 0, :1 = heap_string()].each_to_each(fn (_) string_1).get_error_id() === :wrong_num_fn_args)

     test("01".each_to_each(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().each_to_each(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"01".each_to_each(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().each_to_each(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([array 0, heap_string()].each_to_each(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([table 0 = 1, heap_string() = heap_string()].each_to_each(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)
     test([obj :0 = 0, :1 = heap_string()].each_to_each(fn (_, _, _) string_1).get_error_id() === :wrong_num_fn_args)

     test("01".each_to_each(fn (_, _) string_1).get_error_id() === :invalid_type)
     test(heap_string().each_to_each(fn (_, _) string_1).get_error_id() === :invalid_type)
     test(u"01".each_to_each(fn (_, _) string_1).get_error_id() === :invalid_type)
     test(heap_byte_array().each_to_each(fn (_, _) string_1).get_error_id() === :invalid_type)
     test([array 0, heap_string()].each_to_each(fn (_, _) string_1).get_error_id() === :invalid_type)
     test([table 0 = 1, heap_string() = heap_string()].each_to_each(fn (_, _) string_1).get_error_id() === :invalid_type)
     test([obj :0 = 0, :1 = heap_string()].each_to_each(fn (_, _) string_1).get_error_id() === :invalid_type)

     test("01".each_to_each(fn (_, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test(heap_string().each_to_each(fn (_, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test(u"01".each_to_each(fn (_, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test(heap_byte_array().each_to_each(fn (_, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test([array 0, heap_string()].each_to_each(fn (_, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test([table 0 = 1, heap_string() = heap_string()].each_to_each(fn (_, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
     test([obj :0 = 0, :1 = heap_string()].each_to_each(fn (_, _) [box heap_string()]).get_error_id() === :unpk_not_enough_items)
}