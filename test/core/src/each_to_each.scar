     test([obj :1 = string_1, :2 = string_2, :_ = [obj :1 = 2]].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]):_ === [obj :1 = 2])
     test([obj :1 = string_3, :2 = string_1, :3 = string_2].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]) === [obj :1 = string_3, :2 = string_2, :3 = string_1])
     test([obj :1 = string_3, :2 = string_1, :3 = string_2, :_ = [obj :1 = 2]].each_to_each(fn (value_1, value_2) if value_1 == string_2 && value_2 == string_1 || value_2 == string_2 && value_1 == string_1; [box value_2, value_1] else [box value_1, value_2]) === [obj :1 = string_3, :2 = string_2, :3 = string_1])
