let container__look_in = [obj
     :value = [array]

     :_ = [obj
          :core_look_in = fn (item, container) item.look_in(container:value)
     ]
]

fn to_container__look_in(arg) new (@main.container__look_in):value <= arg

fn to_custom_container__look_in(arg) custom__create(
     arg
     [obj
          :core_look_in = fn (item, container) item.look_in(container.custom__get_data())
     ]
)

let error_container__look_in = [obj
     :value = [array]

     :_ = [obj
          :core_look_in = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_container__look_in(arg) new (@main.error_container__look_in):value <= arg

fn to_error_custom_container__look_in(arg) custom__create(
     arg
     [obj
          :core_look_in = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__look_in() {
     test('2'.look_in("").null?())
     test('1'.look_in("").null?())
     test('2'.look_in("1").null?())
     test('1'.look_in("1") === 0)
     test('0'.look_in("0123456789abcde") === 0)
     test('3'.look_in("0123456789abcde") === 3)
     test('a'.look_in("0123456789abcde") === 10)
     test('e'.look_in("0123456789abcde") === 14)
     test('f'.look_in("0123456789abcde").null?())
     test('_'.look_in("0123456789abcde").null?())

     test('_'.look_in(("_0123456789abcdef" ++ "g")[1, 17]).null?())
     test('g'.look_in(("_0123456789abcdef" ++ "g")[1, 17]).null?())
     test('0'.look_in(("_0123456789abcdef" ++ "g")[1, 17]) === 0)
     test('4'.look_in(("_0123456789abcdef" ++ "g")[1, 17]) === 4)
     test('e'.look_in(("_0123456789abcdef" ++ "g")[1, 17]) === 14)
     test('f'.look_in(("_0123456789abcdef" ++ "g")[1, 17]) === 15)

     test('0'.look_in("000000000000000") === 0)
     test('1'.look_in("000000000000000").null?())
     test('1'.look_in("000000000000001") === 14)
     test('0'.look_in(("00000000000000000" ++ "0")[1, 17]) === 0)
     test('1'.look_in(("10000000000000000" ++ "1")[1, 17]).null?())
     test('1'.look_in(("10000000000000001" ++ "1")[1, 17]) === 15)

     test('\000092'.look_in("").null?())
     test('\000091'.look_in("").null?())
     test('\000092'.look_in("\000091").null?())
     test('\000091'.look_in("\000091") === 0)
     test('\000090'.look_in("\000090\0000912\000093\000094\000095\000096\000097") === 0)
     test('\000093'.look_in("\000090\0000912\000093\000094\000095\000096\000097") === 3)
     test('\000097'.look_in("\000090\0000912\000093\000094\000095\000096\000097") === 7)

     test('\000090'.look_in(("_\000090\000091\000092\000093456\00009789a\00009bcdef" ++ "g")[1, 17]) === 0)
     test('\000094'.look_in(("_01\0000923\00009456789abcd\00009ef" ++ "g")[1, 17]) === 4)
     test('\00009e'.look_in(("_\000090123\00009456789abcd\00009e\00009f" ++ "g")[1, 17]) === 14)
     test('\00009f'.look_in(("_0123456789abcde\00009f" ++ "g")[1, 17]) === 15)

     test('\000090'.look_in("\000090\000090\000090\0000900\000090\000090\000090") === 0)
     test('\000091'.look_in("\000090\000090\000090\0000900\000090\000090\000090").null?())
     test('\000091'.look_in("\000090\000090\000090\0000900\000090\000090\000091") === 7)
     test('\000090'.look_in(("\000090\000090\0000900\000090\000090\000090\000090\000090\000090" ++ "\000090")[1, 10]) === 0)
     test('\000091'.look_in(("\000091\000090\0000900\000090\000090\000090\000090\000090\000090" ++ "\000091")[1, 10]).null?())
     test('\000091'.look_in(("\000090\000091\0000900\000090\000090\000090\000090\000090\000091" ++ "\000091")[1, 10]) === 0)

     let string = rnd_string()
     let char   = rnd_char()
     test((char.look_in(string) <? -1) === loop(0, fn (idx) {
          if idx === len(string)
               [breaker -1]
          else if string[idx] === char
               [breaker idx]
          else idx + 1
     }))

     test(u"2"[0].look_in(u"").null?())
     test(u"1"[0].look_in(u"").null?())
     test(u"2"[0].look_in(u"1").null?())
     test(u"1"[0].look_in(u"1") === 0)
     test(u"0"[0].look_in(u"0123456789abcd") === 0)
     test(u"3"[0].look_in(u"0123456789abcd") === 3)
     test(u"a"[0].look_in(u"0123456789abcd") === 10)
     test(u"d"[0].look_in(u"0123456789abcd") === 13)
     test(u"e"[0].look_in(u"0123456789abcd").null?())
     test(u"_"[0].look_in(u"0123456789abcd").null?())

     test(u"_"[0].look_in((u"_0123456789abcdef" ++ u"g")[1, 17]).null?())
     test(u"g"[0].look_in((u"_0123456789abcdef" ++ u"g")[1, 17]).null?())
     test(u"0"[0].look_in((u"_0123456789abcdef" ++ u"g")[1, 17]) === 0)
     test(u"4"[0].look_in((u"_0123456789abcdef" ++ u"g")[1, 17]) === 4)
     test(u"e"[0].look_in((u"_0123456789abcdef" ++ u"g")[1, 17]) === 14)
     test(u"f"[0].look_in((u"_0123456789abcdef" ++ u"g")[1, 17]) === 15)

     test(u"0"[0].look_in(u"000000000000000") === 0)
     test(u"1"[0].look_in(u"000000000000000").null?())
     test(u"1"[0].look_in(u"000000000000001") === 14)
     test(u"0"[0].look_in((u"00000000000000000" ++ u"0")[1, 17]) === 0)
     test(u"1"[0].look_in((u"10000000000000000" ++ u"1")[1, 17]).null?())
     test(u"1"[0].look_in((u"10000000000000001" ++ u"1")[1, 17]) === 15)

     let array = rnd_byte_array()
     let byte  = rnd_byte()
     test((byte.look_in(array) <? -1) === loop(0, fn (idx) {
          if idx === len(array)
               [breaker -1]
          else if array[idx] === byte
               [breaker idx]
          else idx + 1
     }))

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     let string_3 = string_0 ++ "3"
     let string_4 = string_0 ++ "4"
     let string_5 = string_0 ++ "5"
     test(string_0.look_in([array]).null?())
     test(string_0.look_in([array].init(10)).null?())
     test(string_0.look_in([array string_1]).null?())
     test(string_0.look_in([array string_0]) === 0)
     test(string_0.look_in([array string_0, string_0]) === 0)
     test(string_0.look_in([array string_0, string_0, string_0, string_0, string_0]) === 0)
     test(string_1.look_in([array string_0, string_0, string_0, string_0, string_0]).null?())
     test(string_0.look_in([array string_0, string_1, string_2, string_3, string_4, string_5]) === 0)
     test(string_0.look_in([array string_5, string_4, string_3, string_2, string_1, string_0]) === 5)
     test(string_0.look_in([array string_5, string_4, string_0, string_2, string_1, string_5]) === 2)

     test(string_0.look_in([array string_0, string_0, string_0][1, 2]) === 0)
     test(string_0.look_in([array string_0, string_0, string_0, string_0][1, 3]) === 0)
     test(string_0.look_in([array string_0, string_0, string_0, string_0, string_0, string_0, string_0][1, 6]) === 0)
     test(string_1.look_in([array string_1, string_0, string_0, string_0, string_0, string_0, string_1][1, 6]).null?())
     test(string_0.look_in([array string_0, string_0, string_1, string_2, string_3, string_4, string_5, string_0][1, 7]) === 0)
     test(string_0.look_in([array string_0, string_5, string_4, string_3, string_2, string_1, string_0, string_0][1, 7]) === 5)
     test(string_0.look_in([array string_0, string_5, string_4, string_0, string_2, string_1, string_5, string_0][1, 7]) === 2)

     let array  = rnd_string_array()
     let string = if rnd_bool(); array[rnd() & (len(array) - 1)] else rnd_string()
     test((string.look_in(array) <? -1) === loop(0, fn (idx) {
          if idx === len(array)
               [breaker -1]
          else if array[idx] === string
               [breaker idx]
          else idx + 1
     }))

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     let string_3 = string_0 ++ "3"
     let string_4 = string_0 ++ "4"
     let string_5 = string_0 ++ "5"
     test(string_0.look_in([table]).null?())
     test(string_0.look_in([table string_0 = string_1]).null?())
     test(string_0.look_in([table string_1 = string_0]) === string_1)
     test(string_0.look_in([table string_1 = string_0, string_2 = string_1]) === string_1)
     test(string_1.look_in([table string_0 = string_1, string_2 = string_3, string_4 = string_5]) === string_0)
     test(string_3.look_in([table string_0 = string_1, string_2 = string_3, string_4 = string_5]) === string_2)
     test(string_5.look_in([table string_0 = string_1, string_2 = string_3, string_4 = string_5]) === string_4)
     test(string_1.look_in([table string_0 = string_1, string_2 = string_1, string_4 = string_1]).in?([array string_0, string_2, string_4]))

     let array = rnd_string_array()
     let table = loop([table], fn (table) {
          let table = new (table)[rnd_string()] <= array[len(table)]
          break(len(array) === len(table), table)
     })
     let string = if rnd_bool(); array[rnd() & (len(array) - 1)] else rnd_string()
     let result = string.look_in(table)
     if result.null?()
          test(table.filter(_ === string).empty?())
     else test(table[result] === string)

     let array = rnd_string_array()
     let table = loop([table], fn (table) {
          let table = new (table)[rnd_string()] <= array[len(table)]
          break(len(array) === len(table), table)
     })
     let string = if rnd_bool(); array[rnd() & (len(array) - 1)] else rnd_string()
     let result = string.look_in(table)
     if result.null?()
          test(table.filter(_ === string).empty?())
     else test(table[result] === string)

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     test(string_0.look_in([set]).null?())
     test(string_0.look_in([set string_0]) === heap_string())
     test(string_0.look_in([set string_1, string_0]) === string_0)
     test(string_1.look_in([set string_0, string_1]) === string_1)
     test(string_1.look_in([set string_0, string_1]) === string_0 ++ "1")
     test(string_2.look_in([set string_0, string_1]).null?())

     let array = rnd_string_array()
     let set   = array.foldl([set], _.append(_))
     let string = if rnd_bool(); array[rnd() & (len(array) - 1)] else rnd_string()
     let result = string.look_in(set)
     test(if result.null?(); set[string].null?() else set[string] === string)

     test(string_0.look_in([obj]).null?())
     test(string_0.look_in([obj :_ = [obj :1 = string_0]]).null?())
     test([obj :1 = string_0].look_in([obj :_ = [obj :1 = string_0]]).null?())
     test(string_0.look_in([obj :0 = string_1]).null?())
     test(string_0.look_in([obj :1 = string_0]) === :1)
     test(string_0.look_in([obj :1 = string_0, :2 = string_1]) === :1)
     test(string_1.look_in([obj :0 = string_1, :2 = string_3, :4 = string_5]) === :0)
     test(string_3.look_in([obj :0 = string_1, :2 = string_3, :4 = string_5]) === :2)
     test(string_5.look_in([obj :0 = string_1, :2 = string_3, :4 = string_5]) === :4)
     test(string_1.look_in([obj :0 = string_1, :2 = string_1, :4 = string_1]).in?([array :0, :2, :4]))
     test(string_1.look_in([obj :0 = string_1, :2 = string_1, :4 = string_1, :_ = [obj :3 = string_1]]).in?([array :0, :2, :4]))
     test([obj :3 = string_1].look_in([obj :0 = string_1, :2 = string_1, :4 = string_1, :_ = [obj :3 = string_1]]).null?())
     test([obj :3 = string_1].look_in([obj :0 = string_1, :2 = [obj :3 = string_1], :4 = string_1, :_ = [obj :3 = string_1]]) === :2)

     let array = rnd_string_array()
     let obj = loop([obj], fn (obj) {
          let key = loop(rnd_token(), fn (key) if key =/= :_; [breaker key] else rnd_token())
          let obj = new (obj)[key] <= array[len(obj)]
          break(len(array) === len(obj), obj)
     })
     let string = if rnd_bool(); array[rnd() & (len(array) - 1)] else rnd_string()
     let result = string.look_in(obj)
     if result.null?()
          test(obj.filter(_ === string).empty?())
     else test(obj[result] === string)

     test('1'.look_in("123123".to_container__look_in()) === 0)
     test('0'.look_in("123123".to_container__look_in()).null?())
     test('1'.look_in("123123".to_custom_container__look_in()) === 0)
     test('0'.look_in("123123".to_custom_container__look_in()).null?())

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.look_in(heap_string()).get_error_id() === :1)
     test(heap_string().look_in(error_1).get_error_id() === :1)
     test(error_1.look_in(error_2).get_error_id() === :1)
     test(error_2.look_in(error_1).get_error_id() === :2)

     test([box heap_string()].scarlet__erase_info().look_in(heap_string()).get_error_id() === :invalid_type)
     test([box heap_string()].scarlet__erase_info().look_in([box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test(null.scarlet__erase_info().look_in([array].init(10)).get_error_id() === :invalid_type)
     test((_ ++ _).scarlet__erase_info().look_in([array].init(10)).get_error_id() === :invalid_type)
     test((_ ++ heap_string()).scarlet__erase_info().look_in([array].init(10)).get_error_id() === :invalid_type)
     test([breaker heap_string()].scarlet__erase_info().look_in([array].init(10)).get_error_id() === :invalid_type)
     test(thread(fn() null).scarlet__erase_info().look_in([array].init(10)).get_error_id() === :invalid_type)
     test(make_channel()[0].scarlet__erase_info().look_in([array].init(10)).get_error_id() === :invalid_type)
     test(heap_string().look_in("").get_error_id() === :invalid_type)
     test(heap_string().look_in(heap_string()).get_error_id() === :invalid_type)
     test(heap_string().look_in(u"").get_error_id() === :invalid_type)
     test(heap_string().look_in(heap_byte_array()).get_error_id() === :invalid_type)

     test(heap_string().look_in(to_error_container__look_in([array])).get_error_id() === :3)
     test(heap_string().look_in(to_error_custom_container__look_in([array])).get_error_id() === :4)
}