`noinline`
fn test__hour() {
     test(assemble_time(0, 1970, 1, 1, 3, 0, 0).hour(0) == 3)
     test(assemble_time(0, 1970, 1, 1, 6, 3, 22).hour(0) == 6)
     test(assemble_time(0, 1972, 1, 1, 3, 0, 0).hour(0) == 3)
     test(assemble_time(0, 1972, 1, 1, 5, 9, 49).hour(0) == 5)
     test(assemble_time(0, 2000, 1, 1, 2, 0, 0).hour(0) == 2)
     test(assemble_time(0, 2000, 1, 1, 2, 19, 38).hour(0) == 2)
     test(assemble_time(0, 2101, 2, 2, 2, 4, 29).hour(0) == 2)
     test(assemble_time(0, 2101, 10, 1, 6, 7, 41).hour(0) == 6)
     test(assemble_time(0, 2056, 9, 17, 6, 39, 54).hour(0) == 6)
     test(assemble_time(0, 2052, 6, 19, 16, 9, 56).hour(0) == 16)
     test(assemble_time(0, 2004, 8, 7, 20, 54, 59).hour(0) == 20)
     test(assemble_time(0, 1995, 2, 26, 11, 47, 23).hour(0) == 11)
     test(assemble_time(0, 2058, 10, 31, 20, 55, 41).hour(0) == 20)
     test(assemble_time(0, 1978, 2, 22, 12, 27, 22).hour(0) == 12)
     test(assemble_time(0, 1977, 10, 25, 0, 24, 30).hour(0) == 0)
     test(assemble_time(0, 1995, 5, 9, 1, 37, 32).hour(0) == 1)
     test(assemble_time(0, 2003, 10, 13, 10, 24, 59).hour(0) == 10)
     test(assemble_time(0, 2041, 11, 6, 12, 17, 19).hour(0) == 12)
     test(assemble_time(0, 2042, 10, 20, 8, 0, 28).hour(0) == 8)
     test(assemble_time(0, 2037, 3, 17, 21, 5, 24).hour(0) == 21)
     test(assemble_time(0, 2090, 5, 24, 17, 15, 59).hour(0) == 17)
     test(assemble_time(0, 2088, 5, 2, 16, 50, 5).hour(0) == 16)
     test(assemble_time(0, 2067, 1, 10, 15, 11, 9).hour(0) == 15)
     test(assemble_time(0, 2095, 5, 14, 1, 6, 27).hour(0) == 1)
     test(assemble_time(0, 2064, 9, 15, 12, 20, 58).hour(0) == 12)
     test(assemble_time(0, 2008, 3, 11, 20, 14, 12).hour(0) == 20)

     test(assemble_time(0, 292277026595, 12, 31, 23, 59, 59).hour(0) == 23)
     test(assemble_time(86400, 292277026596, 1, 1, 23, 59, 59).hour(86400) == 23)
     test(assemble_time(-86400, 292277026595, 12, 30, 23, 59, 59).hour(-86400) == 23)
     test(assemble_time(86400, 1970, 1, 2, 0, 0, 0).hour(86400) == 0)
     test(assemble_time(-86400, 1969, 12, 31, 0, 0, 0).hour(-86400) == 0)

     test(assemble_time(0, 1970, 2, 28, 0, 0, 0).hour(0) == 0)
     test(assemble_time(0, 1970, 3, 1, 0, 0, 0).hour(0) == 0)
     test(assemble_time(0, 1972, 2, 29, 0, 0, 0).hour(0) == 0)
     test(assemble_time(0, 2000, 2, 29, 0, 0, 0).hour(0) == 0)
     test(assemble_time(0, 2004, 2, 29, 0, 0, 0).hour(0) == 0)
     test(assemble_time(0, 2100, 2, 28, 0, 0, 0).hour(0) == 0)
     test(assemble_time(0, 2100, 3, 1, 0, 0, 0).hour(0) == 0)

     test(hour(0.int_to_time(), 86401.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(hour(0.int_to_time(), -86401.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(hour(0.int_to_time(), 9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(hour(0.int_to_time(), -9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(hour(error_1, 0).get_error_id() === :1)
     test(hour(0.int_to_time(), error_1).get_error_id() === :1)
     test(hour(error_1, error_2).get_error_id() === :1)
     test(hour(error_2, error_1).get_error_id() === :2)
     test(hour(error_1, -9223372036825516800.scarlet__erase_info()).get_error_id() === :1)

     test(hour(0.int_to_time(), heap_string()).get_error_id() === :invalid_type)
     test(hour(heap_string(), 0).get_error_id() === :invalid_type)
     test(hour(heap_string(), heap_string()).get_error_id() === :invalid_type)
}