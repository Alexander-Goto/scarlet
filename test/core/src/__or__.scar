     arg
     [obj
          :core___or__    = fn (num_1, num_2) to_custom_num__or(num_1.custom__get_data() | num_2.custom__get_data())
          :core___equal__ = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
