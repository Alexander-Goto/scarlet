let num__floor = [obj
     :value = 0.0

     :_ = [obj
          :core_floor     = fn (num) to_num__floor(num:value.floor())
          :core___equal__ = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__floor(arg) new (@main.num__floor):value <= arg

fn to_custom_num__floor(arg) custom__create(
     arg
     [obj
          :core_floor     = fn (num) to_custom_num__floor(num.custom__get_data().floor())
          :core___equal__ = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__floor = [obj
     :value = 0.0

     :_ = [obj
          :core_floor = fn (_) heap_string()
     ]
]

fn to_broken_num__floor(arg) new (@main.broken_num__floor):value <= arg

fn to_broken_custom_num__floor(arg) custom__create(
     arg
     [obj
          :core_floor = fn (_) heap_string()
     ]
)

let error_num__floor = [obj
     :value = 0.0

     :_ = [obj
          :core_floor = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__floor(arg) new (@main.error_num__floor):value <= arg

fn to_error_custom_num__floor(arg) custom__create(
     arg
     [obj
          :core_floor = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__floor() {
     let inf     = inf()
     let neg_inf = neg_inf()
     test(0.0.floor().scarlet__split!!!()[0] === 0.0.scarlet__split!!!()[0])
     test(-0.0.floor().scarlet__split!!!()[0] === -0.0.scarlet__split!!!()[0])
     test(0.1.floor().in_range?(-0.01, 0.01))
     test(-0.1.floor().in_range?(-1.01, -0.99))
     test(1.0.floor().in_range?(0.99, 1.01))
     test(-1.0.floor().in_range?(-1.01, -0.99))
     test(1.01.floor().in_range?(0.99, 1.01))
     test(-1.01.floor().in_range?(-2.01, -1.99))
     test(0.5.floor().in_range?(-0.01, 0.01))
     test(-0.5.floor().in_range?(-1.01, -0.99))
     test(0.49.floor().in_range?(-0.01, 0.01))
     test(-0.49.floor().in_range?(-1.01, -0.99))
     test(0.51.floor().in_range?(-0.01, 0.01))
     test(-0.51.floor().in_range?(-1.01, -0.99))

     test(inf.floor().scarlet__split!!!()[0] === inf.scarlet__split!!!()[0])
     test(neg_inf.floor().scarlet__split!!!()[0] === neg_inf.scarlet__split!!!()[0])
     test(nan().floor().nan?())

     test(to_num__floor(-0.49).floor():value.in_range?(-1.01, -0.99))
     test(to_num__floor(-0.51).floor():value.in_range?(-1.01, -0.99))

     test(to_custom_num__floor(-0.49).floor().custom__get_data().in_range?(-1.01, -0.99))
     test(to_custom_num__floor(-0.51).floor().custom__get_data().in_range?(-1.01, -0.99))

     let error  = expected_error(:1, heap_string(), heap_string())
     test(error.floor().get_error_id() === :1)
     test(heap_string().floor().get_error_id() === :invalid_type)

     test(to_broken_num__floor(1.0).floor().get_error_id() === :invalid_type)
     test(to_broken_custom_num__floor(1.0).floor().get_error_id() === :invalid_type)
     test(to_error_num__floor(1.0).floor().get_error_id() === :3)
     test(to_error_custom_num__floor(1.0).floor().get_error_id() === :4)
}