let num__rotate_right = [obj
     :value = 0

     :_ = [obj
          :core_rotate_right = fn (num, shifts) to_num__rotate_right(rotate_right(num:value, shifts))
          :core___equal__    = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__rotate_right(arg) new (@main.num__rotate_right):value <= arg

fn to_custom_num__rotate_right(arg) custom__create(
     arg
     [obj
          :core_rotate_right = fn (num, shifts) to_custom_num__rotate_right(rotate_right(num.custom__get_data(), shifts))
          :core___equal__    = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__rotate_right = [obj
     :value = 0

     :_ = [obj
          :core_rotate_right = fn (_, _) heap_string()
     ]
]

fn to_broken_num__rotate_right(arg) new (@main.broken_num__rotate_right):value <= arg

fn to_broken_custom_num__rotate_right(arg) custom__create(
     arg
     [obj
          :core_rotate_right = fn (_, _) heap_string()
     ]
)

let error_num__rotate_right = [obj
     :value = 0

     :_ = [obj
          :core_rotate_right = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__rotate_right(arg) new (@main.error_num__rotate_right):value <= arg

fn to_error_custom_num__rotate_right(arg) custom__create(
     arg
     [obj
          :core_rotate_right = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__rotate_right() {
     test(rotate_right(0, 0) === 0)
     test(rotate_right(0, 1) === 0)
     test(rotate_right(1, 0) === 1)
     test(rotate_right(1, 1) === -9223372036854775808)
     test(rotate_right(-1, 0) === -1)
     test(rotate_right(-1, 1) === -1)
     test(rotate_right(-708044971986000615, 3) === 4523180396929137827)
     test(rotate_right(-708044971986000615, 58) === -8421390059684936067)
     test(rotate_right(-708044971986000615, 59) === -4210695029842468034)
     test(rotate_right(-708044971986000615, 60) === 7118024521933541791)
     test(rotate_right(-708044971986000615, 61) === -5664359775888004913)
     test(rotate_right(-708044971986000615, 62) === -2832179887944002457)
     test(rotate_right(-708044971986000615, 63) === -1416089943972001229)
     test(rotate_right(-708044971986000615, 64) === -708044971986000615)
     test(rotate_right(-9223372036854775808, 0) === -9223372036854775808)
     test(rotate_right(-9223372036854775808, 1) === 4611686018427387904)
     test(rotate_right(-9223372036854775808, 62) === 2)
     test(rotate_right(-9223372036854775808, 63) === 1)
     test(rotate_right(-9223372036854775808, 64) === -9223372036854775808)
     test(rotate_right(9223372036854775807, 0) === 9223372036854775807)
     test(rotate_right(9223372036854775807, 1) === -4611686018427387905)
     test(rotate_right(9223372036854775807, 17) === -70368744177665)
     test(rotate_right(9223372036854775807, 62) === -3)
     test(rotate_right(9223372036854775807, 63) === -2)
     test(rotate_right(9223372036854775807, 64) === 9223372036854775807)

     test(rotate_right(0, 0b00) === 0)
     test(rotate_right(0, 0b01) === 0)
     test(rotate_right(1, 0b00) === 1)
     test(rotate_right(1, 0b01) === -9223372036854775808)
     test(rotate_right(-1, 0b00) === -1)
     test(rotate_right(-1, 0b01) === -1)
     test(rotate_right(-708044971986000615, 0b03) === 4523180396929137827)
     test(rotate_right(-708044971986000615, 0b3a) === -8421390059684936067)
     test(rotate_right(-708044971986000615, 0b3b) === -4210695029842468034)
     test(rotate_right(-708044971986000615, 0b3c) === 7118024521933541791)
     test(rotate_right(-708044971986000615, 0b3d) === -5664359775888004913)
     test(rotate_right(-708044971986000615, 0b3e) === -2832179887944002457)
     test(rotate_right(-708044971986000615, 0b3f) === -1416089943972001229)
     test(rotate_right(-708044971986000615, 0b40) === -708044971986000615)
     test(rotate_right(-9223372036854775808, 0b00) === -9223372036854775808)
     test(rotate_right(-9223372036854775808, 0b01) === 4611686018427387904)
     test(rotate_right(-9223372036854775808, 0b3e) === 2)
     test(rotate_right(-9223372036854775808, 0b3f) === 1)
     test(rotate_right(-9223372036854775808, 0b40) === -9223372036854775808)
     test(rotate_right(9223372036854775807, 0b00) === 9223372036854775807)
     test(rotate_right(9223372036854775807, 0b01) === -4611686018427387905)
     test(rotate_right(9223372036854775807, 0b11) === -70368744177665)
     test(rotate_right(9223372036854775807, 0b3e) === -3)
     test(rotate_right(9223372036854775807, 0b3f) === -2)
     test(rotate_right(9223372036854775807, 0b40) === 9223372036854775807)

     let int      = rnd()
     let shifts   = rnd() & 63
     let expected = (int >> shifts) | (int << (64 - shifts))
     test(rotate_right(int, shifts) === expected)

     test(rotate_right(0b00, 0) === 0b00)
     test(rotate_right(0b00, 1) === 0b00)
     test(rotate_right(0b01, 0) === 0b01)
     test(rotate_right(0b01, 1) === 0b80)
     test(rotate_right(0bff, 0) === 0bff)
     test(rotate_right(0bff, 1) === 0bff)
     test(rotate_right(0bff, 2) === 0bff)
     test(rotate_right(0bff, 3) === 0bff)
     test(rotate_right(0bff, 4) === 0bff)
     test(rotate_right(0bff, 5) === 0bff)
     test(rotate_right(0bff, 6) === 0bff)
     test(rotate_right(0bff, 7) === 0bff)
     test(rotate_right(0bff, 8) === 0bff)
     test(rotate_right(0b78, 0) === 0b78)
     test(rotate_right(0b78, 1) === 0b3c)
     test(rotate_right(0b78, 2) === 0b1e)
     test(rotate_right(0b78, 3) === 0b0f)
     test(rotate_right(0b78, 4) === 0b87)
     test(rotate_right(0b78, 5) === 0bc3)
     test(rotate_right(0b78, 6) === 0be1)
     test(rotate_right(0b78, 7) === 0bf0)
     test(rotate_right(0b78, 8) === 0b78)

     test(rotate_right(0b00, 0b00) === 0b00)
     test(rotate_right(0b00, 0b01) === 0b00)
     test(rotate_right(0b01, 0b00) === 0b01)
     test(rotate_right(0b01, 0b01) === 0b80)
     test(rotate_right(0bff, 0b00) === 0bff)
     test(rotate_right(0bff, 0b01) === 0bff)
     test(rotate_right(0bff, 0b02) === 0bff)
     test(rotate_right(0bff, 0b03) === 0bff)
     test(rotate_right(0bff, 0b04) === 0bff)
     test(rotate_right(0bff, 0b05) === 0bff)
     test(rotate_right(0bff, 0b06) === 0bff)
     test(rotate_right(0bff, 0b07) === 0bff)
     test(rotate_right(0bff, 0b08) === 0bff)
     test(rotate_right(0b78, 0b00) === 0b78)
     test(rotate_right(0b78, 0b01) === 0b3c)
     test(rotate_right(0b78, 0b02) === 0b1e)
     test(rotate_right(0b78, 0b03) === 0b0f)
     test(rotate_right(0b78, 0b04) === 0b87)
     test(rotate_right(0b78, 0b05) === 0bc3)
     test(rotate_right(0b78, 0b06) === 0be1)
     test(rotate_right(0b78, 0b07) === 0bf0)
     test(rotate_right(0b78, 0b08) === 0b78)

     let byte     = rnd_byte()
     let shifts   = rnd() & 7
     let expected = (byte >> shifts) | (byte << (8 - shifts))
     test(rotate_right(byte, shifts) === expected)

     test(rotate_right(to_num__rotate_right(0), 0) === to_num__rotate_right(0))
     test(rotate_right(to_num__rotate_right(-708044971986000615), 3) === to_num__rotate_right(4523180396929137827))

     test(rotate_right(to_custom_num__rotate_right(0), 0) === to_custom_num__rotate_right(0))
     test(rotate_right(to_custom_num__rotate_right(-708044971986000615), 3) === to_custom_num__rotate_right(4523180396929137827))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(rotate_right(error_1, 1).get_error_id() === :1)
     test(rotate_right(1, error_1).get_error_id() === :1)
     test(rotate_right(error_1, error_2).get_error_id() === :1)
     test(rotate_right(error_2, error_1).get_error_id() === :2)
     test(rotate_right(error_1, heap_string()).get_error_id() === :1)
     test(rotate_right(heap_string(), error_1).get_error_id() === :1)

     test(rotate_right(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(rotate_right(heap_string(), 1).get_error_id() === :invalid_type)
     test(rotate_right(1, heap_string()).get_error_id() === :invalid_type)

     test(rotate_right(to_broken_num__rotate_right(1), 0).get_error_id() === :invalid_type)
     test(rotate_right(to_broken_custom_num__rotate_right(1), 0).get_error_id() === :invalid_type)
     test(rotate_right(to_error_num__rotate_right(1), 0).get_error_id() === :3)
     test(rotate_right(to_error_custom_num__rotate_right(1), 0).get_error_id() === :4)

     test(rotate_right(0, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(1, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(1, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(1, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(1, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(1, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(1, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(9223372036854775807, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(9223372036854775807, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(9223372036854775807, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(9223372036854775807, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(9223372036854775807, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(9223372036854775807, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-1, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-1, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-1, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-1, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-1, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-1, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-9223372036854775808, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-9223372036854775808, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-9223372036854775808, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-9223372036854775808, 65.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-9223372036854775808, 66.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-9223372036854775808, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)

     test(rotate_right(0, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(1, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(1, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(9223372036854775807, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(9223372036854775807, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-1, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-1, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-9223372036854775808, 0x41.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(-9223372036854775808, 0xff.scarlet__erase_info()).get_error_id() === :bits_shift)

     test(rotate_right(0b00, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b00, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b00, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b00, 9.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b00, 10.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b00, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b01, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b01, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b01, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b01, 9.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b01, 10.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b01, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bf0, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bf0, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bf0, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bf0, 9.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bf0, 10.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bf0, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bff, -1.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bff, -2.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bff, -9223372036854775808.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bff, 9.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bff, 10.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bff, 9223372036854775807.scarlet__erase_info()).get_error_id() === :bits_shift)

     test(rotate_right(0b00, 0b09.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b00, 0ba0.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b00, 0bff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b09, 0b09.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b09, 0ba0.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0b09, 0bff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0ba0, 0b09.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0ba0, 0ba0.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0ba0, 0bff.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bff, 0b09.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bff, 0ba0.scarlet__erase_info()).get_error_id() === :bits_shift)
     test(rotate_right(0bff, 0bff.scarlet__erase_info()).get_error_id() === :bits_shift)
}