     let string_1 = rnd_string()
     let string_2 = if rnd_bool() {
          let from = (rnd() & 0xffff'ffff) % len(string_1)
          let to   = from + (rnd() & 0xffff'ffff) % (len(string_1) - from)
          string_1[from, to]
     } else rnd_string()
     let idx             = (rnd() & 0xffff'ffff) % len(string_1)
     let string_3        = if rnd_bool(); string_1 else null
     let string_4        = if rnd_bool(); string_2 else null
     let expected_string = string_1.take(idx) ++ string_2 ++ string_1.drop(idx)
     test(expected_string === string_2.insert_part_to(string_1, idx))
     string_3.ignore()
     string_4.ignore()

     test(u"".insert_part_to(u"", 0) === u"")
     test(u"1".insert_part_to(u"", 0) === u"1")
     test(u"".insert_part_to(u"1", 0) === u"1")
