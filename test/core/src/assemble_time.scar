`noinline`
fn test__assemble_time() {
     let time = assemble_time(0, 1970, 1, 1, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 0)
     let time = assemble_time(0, 1970, 1, 1, 3, 3, 22)
     test(time.type() == "core.time")
     test(time.to_int() == 11002)
     let time = assemble_time(0, 1972, 1, 1, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 63072000)
     let time = assemble_time(0, 1972, 1, 1, 2, 9, 49)
     test(time.type() == "core.time")
     test(time.to_int() == 63079789)
     let time = assemble_time(0, 2000, 1, 1, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 946684800)
     let time = assemble_time(0, 2000, 1, 1, 0, 19, 38)
     test(time.type() == "core.time")
     test(time.to_int() == 946685978)
     let time = assemble_time(0, 2067, 5, 3, 19, 15, 27)
     test(time.type() == "core.time")
     test(time.to_int() == 3071675727)
     let time = assemble_time(0, 2064, 7, 2, 11, 31, 30)
     test(time.type() == "core.time")
     test(time.to_int() == 2982223890)
     let time = assemble_time(0, 2003, 6, 24, 23, 51, 8)
     test(time.type() == "core.time")
     test(time.to_int() == 1056498668)
     let time = assemble_time(0, 1987, 6, 4, 5, 47, 32)
     test(time.type() == "core.time")
     test(time.to_int() == 549784052)
     let time = assemble_time(0, 2063, 8, 5, 23, 27, 54)
     test(time.type() == "core.time")
     test(time.to_int() == 2953582074)
     let time = assemble_time(0, 1970, 4, 11, 13, 37, 26)
     test(time.type() == "core.time")
     test(time.to_int() == 8689046)
     let time = assemble_time(0, 2013, 8, 18, 7, 8, 21)
     test(time.type() == "core.time")
     test(time.to_int() == 1376809701)
     let time = assemble_time(0, 2091, 3, 14, 10, 37, 16)
     test(time.type() == "core.time")
     test(time.to_int() == 3824707036)
     let time = assemble_time(0, 2006, 9, 13, 7, 25, 53)
     test(time.type() == "core.time")
     test(time.to_int() == 1158132353)
     let time = assemble_time(0, 2000, 2, 4, 0, 30, 30)
     test(time.type() == "core.time")
     test(time.to_int() == 949624230)
     let time = assemble_time(0, 2010, 8, 13, 16, 30, 32)
     test(time.type() == "core.time")
     test(time.to_int() == 1281717032)
     let time = assemble_time(0, 1994, 10, 6, 18, 26, 18)
     test(time.type() == "core.time")
     test(time.to_int() == 781467978)
     let time = assemble_time(0, 2022, 9, 4, 22, 29, 57)
     test(time.type() == "core.time")
     test(time.to_int() == 1662330597)
     let time = assemble_time(0, 2085, 5, 26, 14, 6, 33)
     test(time.type() == "core.time")
     test(time.to_int() == 3641724393)
     let time = assemble_time(0, 2035, 9, 29, 17, 29, 25)
     test(time.type() == "core.time")
     test(time.to_int() == 2074699765)
     let time = assemble_time(0, 2054, 6, 28, 6, 44, 42)
     test(time.type() == "core.time")
     test(time.to_int() == 2666241882)
     let time = assemble_time(0, 2053, 8, 17, 21, 30, 8)
     test(time.type() == "core.time")
     test(time.to_int() == 2639079008)
     let time = assemble_time(0, 2072, 12, 9, 23, 17, 5)
     test(time.type() == "core.time")
     test(time.to_int() == 3248551025)
     let time = assemble_time(0, 2056, 1, 14, 8, 5, 36)
     test(time.type() == "core.time")
     test(time.to_int() == 2715062736)
     let time = assemble_time(0, 2008, 12, 10, 6, 32, 41)
     test(time.type() == "core.time")
     test(time.to_int() == 1228890761)

     let time = assemble_time(0, 292277026595, 12, 31, 23, 59, 59)
     test(time.type() == "core.time")
     test(time.to_int() == 9223372036825516799)
     let time = assemble_time(86400, 292277026596, 1, 1, 23, 59, 59)
     test(time.type() == "core.time")
     test(time.to_int() == 9223372036825516799)
     let time = assemble_time(-86400, 292277026595, 12, 30, 23, 59, 59)
     test(time.type() == "core.time")
     test(time.to_int() == 9223372036825516799)
     let time = assemble_time(86400, 1970, 1, 2, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 0)
     let time = assemble_time(-86400, 1969, 12, 31, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 0)

     let time = assemble_time(0, 1970, 2, 28, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 5011200)
     let time = assemble_time(0, 1970, 3, 1, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 5097600)
     let time = assemble_time(0, 1972, 2, 29, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 68169600)
     let time = assemble_time(0, 2000, 2, 29, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 951782400)
     let time = assemble_time(0, 2004, 2, 29, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 1078012800)
     let time = assemble_time(0, 2100, 2, 28, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 4107456000)
     let time = assemble_time(0, 2100, 3, 1, 0, 0, 0)
     test(time.type() == "core.time")
     test(time.to_int() == 4107542400)

     test(assemble_time(-86401.scarlet__erase_info(), 2000, 1, 1, 1, 1, 1).get_error_id() == :out_of_bounds)
     test(assemble_time(86401.scarlet__erase_info(), 2000, 1, 1, 1, 1, 1).get_error_id() == :out_of_bounds)
     test(assemble_time(-9223372036854775808.scarlet__erase_info(), 2000, 1, 1, 1, 1, 1).get_error_id() == :out_of_bounds)
     test(assemble_time(9223372036854775807.scarlet__erase_info(), 2000, 1, 1, 1, 1, 1).get_error_id() == :out_of_bounds)

     test(assemble_time(0, 292277026596, 1, 1, 0, 0, 0).null?())
     test(assemble_time(0, 1969, 12, 31, 23, 59, 59).null?())
     test(assemble_time(86400, 292277026596, 1, 2, 0, 0, 09).null?())
     test(assemble_time(-86400, 292277026595, 12, 31, 0, 0, 0).null?())
     test(assemble_time(86400, 1970, 1, 1, 23, 59, 59).null?())
     test(assemble_time(86400, 292277026596, 1, 2, 0, 0, 0).null?())
     test(assemble_time(-86400, 292277026595, 12, 31, 0, 0, 0).null?())
     test(assemble_time(86400, 1970, 1, 1, 23, 59, 59).null?())
     test(assemble_time(-86400, 1969, 12, 30, 23, 59, 59).null?())

     test(assemble_time(0, 1969, 1, 1, 1, 1, 1).null?())
     test(assemble_time(0, 292277026596, 1, 1, 1, 1, 1).null?())
     test(assemble_time(0, -9223372036854775808, 1, 1, 1, 1, 1).null?())
     test(assemble_time(0, 9223372036854775807, 1, 1, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 13, 1, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 0, 1, 1, 1, 1).null?())
     test(assemble_time(0, 2000, -9223372036854775808, 1, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 9223372036854775807, 1, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 32, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 0, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 32, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 0, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 1, -9223372036854775808, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 9223372036854775807, 1, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 1, 24, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 1, -1, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 1, -9223372036854775808, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 1, 9223372036854775807, 1, 1).null?())
     test(assemble_time(0, 2000, 1, 1, 1, 60, 1).null?())
     test(assemble_time(0, 2000, 1, 1, 1, -1, 1).null?())
     test(assemble_time(0, 2000, 1, 1, 1, -9223372036854775808, 1).null?())
     test(assemble_time(0, 2000, 1, 1, 1, 9223372036854775807, 1).null?())
     test(assemble_time(0, 2000, 1, 1, 1, 1, 60).null?())
     test(assemble_time(0, 2000, 1, 1, 1, 1, -1).null?())
     test(assemble_time(0, 2000, 1, 1, 1, 1, -9223372036854775808).null?())
     test(assemble_time(0, 2000, 1, 1, 1, 1, 9223372036854775807).null?())

     test(assemble_time(heap_string(), 2000, 1, 1, 1, 1, 1).get_error_id() === :invalid_type)
     test(assemble_time(1, heap_string(), 1, 1, 1, 1, 1).get_error_id() === :invalid_type)
     test(assemble_time(1, 2000, heap_string(), 1, 1, 1, 1).get_error_id() === :invalid_type)
     test(assemble_time(1, 2000, 1, heap_string(), 1, 1, 1).get_error_id() === :invalid_type)
     test(assemble_time(1, 2000, 1, 1, heap_string(), 1, 1).get_error_id() === :invalid_type)
     test(assemble_time(1, 2000, 1, 1, 1, heap_string(), 1).get_error_id() === :invalid_type)
     test(assemble_time(1, 2000, 1, 1, 1, 1, heap_string()).get_error_id() === :invalid_type)
     test(assemble_time(heap_string(), heap_string(), heap_string(), heap_string(), heap_string(), heap_string(), heap_string()).get_error_id() === :invalid_type)

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let error_3 = expected_error(:3, heap_string(), heap_string())
     let error_4 = expected_error(:4, heap_string(), heap_string())
     let error_5 = expected_error(:5, heap_string(), heap_string())
     let error_6 = expected_error(:6, heap_string(), heap_string())
     let error_7 = expected_error(:7, heap_string(), heap_string())
     test(assemble_time(error_1, 2000, 1, 1, 0, 0, 0).get_error_id() === :1)
     test(assemble_time(0, error_1, 1, 1, 0, 0, 0).get_error_id() === :1)
     test(assemble_time(0, 2000, error_1, 1, 0, 0, 0).get_error_id() === :1)
     test(assemble_time(0, 2000, 1, error_1, 0, 0, 0).get_error_id() === :1)
     test(assemble_time(0, 2000, 1, 1, error_1, 0, 0).get_error_id() === :1)
     test(assemble_time(0, 2000, 1, 1, 0, error_1, 0).get_error_id() === :1)
     test(assemble_time(0, 2000, 1, 1, 0, 0, error_1).get_error_id() === :1)
     test(assemble_time(error_1, -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info()).get_error_id() === :1)
     test(assemble_time(-1.scarlet__erase_info(), error_1, -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info()).get_error_id() === :1)
     test(assemble_time(-1.scarlet__erase_info(), -1.scarlet__erase_info(), error_1, -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info()).get_error_id() === :1)
     test(assemble_time(-1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), error_1, -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info()).get_error_id() === :1)
     test(assemble_time(-1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), error_1, -1.scarlet__erase_info(), -1.scarlet__erase_info()).get_error_id() === :1)
     test(assemble_time(-1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), error_1, -1.scarlet__erase_info()).get_error_id() === :1)
     test(assemble_time(-1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), -1.scarlet__erase_info(), error_1).get_error_id() === :1)
     test(assemble_time(error_1, heap_string(), heap_string(), heap_string(), heap_string(), heap_string(), heap_string()).get_error_id() === :1)
     test(assemble_time(heap_string(), error_1, heap_string(), heap_string(), heap_string(), heap_string(), heap_string()).get_error_id() === :1)
     test(assemble_time(heap_string(), heap_string(), error_1, heap_string(), heap_string(), heap_string(), heap_string()).get_error_id() === :1)
     test(assemble_time(heap_string(), heap_string(), heap_string(), error_1, heap_string(), heap_string(), heap_string()).get_error_id() === :1)
     test(assemble_time(heap_string(), heap_string(), heap_string(), heap_string(), error_1, heap_string(), heap_string()).get_error_id() === :1)
     test(assemble_time(heap_string(), heap_string(), heap_string(), heap_string(), heap_string(), error_1, heap_string()).get_error_id() === :1)
     test(assemble_time(heap_string(), heap_string(), heap_string(), heap_string(), heap_string(), heap_string(), error_1).get_error_id() === :1)
     test(assemble_time(error_1, error_2, error_3, error_4, error_5, error_6, error_7).get_error_id() === :1)
     test(assemble_time(error_7, error_6, error_5, error_4, error_3, error_2, error_1).get_error_id() === :7)
}