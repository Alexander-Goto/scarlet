          "0123456789abcde6"
          "0123456789abcde7"
          "0123456789abcde10"
          "0123456789abcde1"
          "0123456789abcde2"
          "0123456789abcde8"
     ]))
     test((big_set /= big_set.remove("0123456789abcde0")))

     let big_array = loop([array], fn (array) {
          let len           = len(array)
          let len_as_string = len.to_string()
          let array         = array.append("0123456789abcde" ++ len_as_string)
          break(len == 10, array)
     })
     test(not ([array] /= [array]))
     test(not ([array 10] /= [array 10]))
     test(not ([array 1, 2] /= [array 1, 2]))
     test(([array 1] /= [array]))
     test(([array 1] /= [array 1, 2]))
     test(([array 1, 2] /= [array 1]))
     test(([array 2, 1] /= [array 1, 2]))
     test(not (big_array /= big_array))
     test(not (big_array /= [array
          "0123456789abcde0"
          "0123456789abcde1"
          "0123456789abcde2"
          "0123456789abcde3"
          "0123456789abcde4"
          "0123456789abcde5"
          "0123456789abcde6"
          "0123456789abcde7"
          "0123456789abcde8"
          "0123456789abcde9"
          "0123456789abcde10"
     ]))
