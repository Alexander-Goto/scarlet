let const__strong_not_equal = [obj
     :value = 0

     :_ = [obj
          :core___strong_equal__ = fn (const_1, const_2) const_1:value == const_2:value
     ]
]

fn to_const__strong_not_equal(arg) new (@main.const__strong_not_equal):value <= arg

fn to_custom_const__strong_not_equal(arg) custom__create(
     arg
     [obj
          :core___strong_equal__ = fn (const_1, const_2) const_1.custom__get_data() == const_2.custom__get_data()
     ]
)

