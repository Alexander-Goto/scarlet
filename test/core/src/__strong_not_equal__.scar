     let big_set = loop([set], fn (set) {
          let len           = len(set)
          let len_as_string = len.to_string()
          let set           = set.append("0123456789abcde" ++ len_as_string)
          break(len == 10, set)
     })
     test(not ([set] /= [set]))
     test(not ([set 10] /= [set 10]))
     test(not ([set 1, 2] /= [set 1, 2]))
     test(([set 1] /= [set]))
     test(([set 1] /= [set 1, 2]))
     test(([set 1, 2] /= [set 1]))
