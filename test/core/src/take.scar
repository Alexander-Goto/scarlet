let array__take = [obj
     :value = [array]

     :_ = [obj
          :core_take      = fn (arr, n) to_array__take(arr:value.take(n))
          :core___equal__ = fn (array_1, array_2) array_1:value === array_2:value
     ]
]

fn to_array__take(arg) new (@main.array__take):value <= arg

fn to_custom_array__take(arg) custom__create(
     arg
     [obj
          :core_take      = fn (arr, n) to_custom_array__take(custom__get_data(arr).take(n))
          :core___equal__ = fn (array_1, array_2) array_1.custom__get_data() === array_2.custom__get_data()
     ]
)

let broken_array__take = [obj
     :value = [array]

     :_ = [obj
          :core_take = fn (_, _) heap_table()
     ]
]

fn to_broken_array__take(arg) new (@main.broken_array__take):value <= arg

fn to_broken_custom_array__take(arg) custom__create(
     arg
     [obj
          :core_take = fn (_, _) heap_table()
     ]
)

let error_array__take = [obj
     :value = [array]

     :_ = [obj
          :core_take = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__take(arg) new (@main.error_array__take):value <= arg

fn to_error_custom_array__take(arg) custom__create(
     arg
     [obj
          :core_take = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__take() {
     test("".take(0) === "")
     test("1".take(0) === "")
     test("1".take(1) === "1")
     test("0123456789abcde".take(0) === "")
     test("0123456789abcde".take(1) === "0")
     test("0123456789abcde".take(2) === "01")
     test("0123456789abcde".take(3) === "012")
     test("0123456789abcde".take(4) === "0123")
     test("0123456789abcde".take(5) === "01234")
     test("0123456789abcde".take(6) === "012345")
     test("0123456789abcde".take(7) === "0123456")
     test("0123456789abcde".take(8) === "01234567")
     test("0123456789abcde".take(9) === "012345678")
     test("0123456789abcde".take(10) === "0123456789")
     test("0123456789abcde".take(11) === "0123456789a")
     test("0123456789abcde".take(12) === "0123456789ab")
     test("0123456789abcde".take(13) === "0123456789abc")
     test("0123456789abcde".take(14) === "0123456789abcd")
     test("0123456789abcde".take(15) === "0123456789abcde")

     test("\0000ac".take(0) === "")
     test("\0000ac".take(1) === "\0000ac")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(0) === "")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(1) === "\000091")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(2) === "\000091\0000b3")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(3) === "\000091\0000b3\0000ab")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(4) === "\000091\0000b3\0000ab!")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(5) === "\000091\0000b3\0000ab!!")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(6) === "\000091\0000b3\0000ab!!!")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(7) === "\000091\0000b3\0000ab!!!\0000a4")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(8) === "\000091\0000b3\0000ab!!!\0000a4\0000a7")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take(9) === "\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5")

     test("0123456789abcdef".take(0) === "")
     test("0123456789abcdef".take(1) === "0")
     test("0123456789abcdef".take(2) === "01")
     test("0123456789abcdef".take(3) === "012")
     test("0123456789abcdef".take(4) === "0123")
     test("0123456789abcdef".take(5) === "01234")
     test("0123456789abcdef".take(6) === "012345")
     test("0123456789abcdef".take(7) === "0123456")
     test("0123456789abcdef".take(8) === "01234567")
     test("0123456789abcdef".take(9) === "012345678")
     test("0123456789abcdef".take(10) === "0123456789")
     test("0123456789abcdef".take(11) === "0123456789a")
     test("0123456789abcdef".take(12) === "0123456789ab")
     test("0123456789abcdef".take(13) === "0123456789abc")
     test("0123456789abcdef".take(14) === "0123456789abcd")
     test("0123456789abcdef".take(15) === "0123456789abcde")
     test("0123456789abcdef".take(16) === "0123456789abcdef")

     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(0) === "")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(1) === "\000091")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(2) === "\000091\0000b3")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(3) === "\000091\0000b3\0000ab")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(4) === "\000091\0000b3\0000ab\0000a4")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(5) === "\000091\0000b3\0000ab\0000a4\0000a7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(6) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(7) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 ")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(8) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(9) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3".take(10) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3")

     let [box string_1, string_2] = if (rnd() & 1) === 0 {
          let string_1 = rnd_string()
          let string_2 = if (rnd() & 1) === 0; string_1 else null
          [box string_1, string_2]
     } else [box "Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let len             = len(string_1)
     let n               = (rnd() >> 1) % (len + 1)
     let expected_string = string_1[0, n].unslice()
     test(string_1.take(n) === expected_string)
     string_2.ignore()

     test(u"".take(0) === u"")
     test(u"1".take(0) === u"")
     test(u"1".take(1) === u"1")
     test(u"0123456789abcd".take(0) === u"")
     test(u"0123456789abcd".take(1) === u"0")
     test(u"0123456789abcd".take(2) === u"01")
     test(u"0123456789abcd".take(3) === u"012")
     test(u"0123456789abcd".take(4) === u"0123")
     test(u"0123456789abcd".take(5) === u"01234")
     test(u"0123456789abcd".take(6) === u"012345")
     test(u"0123456789abcd".take(7) === u"0123456")
     test(u"0123456789abcd".take(8) === u"01234567")
     test(u"0123456789abcd".take(9) === u"012345678")
     test(u"0123456789abcd".take(10) === u"0123456789")
     test(u"0123456789abcd".take(11) === u"0123456789a")
     test(u"0123456789abcd".take(12) === u"0123456789ab")
     test(u"0123456789abcd".take(13) === u"0123456789abc")
     test(u"0123456789abcd".take(14) === u"0123456789abcd")

     test(u"0123456789abcdef".take(0) === u"")
     test(u"0123456789abcdef".take(1) === u"0")
     test(u"0123456789abcdef".take(2) === u"01")
     test(u"0123456789abcdef".take(3) === u"012")
     test(u"0123456789abcdef".take(4) === u"0123")
     test(u"0123456789abcdef".take(5) === u"01234")
     test(u"0123456789abcdef".take(6) === u"012345")
     test(u"0123456789abcdef".take(7) === u"0123456")
     test(u"0123456789abcdef".take(8) === u"01234567")
     test(u"0123456789abcdef".take(9) === u"012345678")
     test(u"0123456789abcdef".take(10) === u"0123456789")
     test(u"0123456789abcdef".take(11) === u"0123456789a")
     test(u"0123456789abcdef".take(12) === u"0123456789ab")
     test(u"0123456789abcdef".take(13) === u"0123456789abc")
     test(u"0123456789abcdef".take(14) === u"0123456789abcd")
     test(u"0123456789abcdef".take(15) === u"0123456789abcde")
     test(u"0123456789abcdef".take(16) === u"0123456789abcdef")

     let [box array_1, array_2] = if (rnd() & 1) === 0 {
          let array_1 = rnd_byte_array()
          let array_2 = if (rnd() & 1) === 0; array_1 else null
          [box array_1, array_2]
     } else [box u"Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let len            = len(array_1)
     let n              = (rnd() >> 1) % (len + 1)
     let expected_array = array_1[0, n].unslice()
     test(array_1.take(n) === expected_array)
     array_2.ignore()

     test([array].take(0) === [array])
     test([array].init(10).take(0) === [array])
     test([array 1].take(0) === [array])
     test([array 1].take(1) === [array 1])
     test([array 1, 2, 3, 4, 5].take(0) === [array])
     test([array 1, 2, 3, 4, 5].take(1) === [array 1])
     test([array 1, 2, 3, 4, 5].take(2) === [array 1, 2])
     test([array 1, 2, 3, 4, 5].take(3) === [array 1, 2, 3])
     test([array 1, 2, 3, 4, 5].take(4) === [array 1, 2, 3, 4])
     test([array 1, 2, 3, 4, 5].take(5) === [array 1, 2, 3, 4, 5])

     let string_1  = heap_string()
     let string_2  = string_1 ++ "2"
     let string_3  = string_1 ++ "3"
     let string_4  = string_1 ++ "4"
     let string_5  = string_1 ++ "5"
     test([array string_1].take(0) === [array])
     test([array string_1].take(1) === [array string_1])
     test([array string_1, string_2, string_3, string_4, string_5].take(0) === [array])
     test([array string_1, string_2, string_3, string_4, string_5].take(1) === [array string_1])
     test([array string_1, string_2, string_3, string_4, string_5].take(2) === [array string_1, string_2])
     test([array string_1, string_2, string_3, string_4, string_5].take(3) === [array string_1, string_2, string_3])
     test([array string_1, string_2, string_3, string_4, string_5].take(4) === [array string_1, string_2, string_3, string_4])
     test([array string_1, string_2, string_3, string_4, string_5].take(5) === [array string_1, string_2, string_3, string_4, string_5])

     let [box array_1, array_2] = if (rnd() & 1) === 0 {
          let array_1 = rnd_string_array()
          let array_2 = if (rnd() & 1) === 0; array_1 else null
          [box array_1, array_2]
     } else [box [array 7, 2, 4, 1, "dfsdf", 0, -14, [table]], null]
     let len            = len(array_1)
     let n              = (rnd() >> 1) % (len + 1)
     let expected_array = array_1[0, n].unslice()
     test(array_1.take(n) === expected_array)
     array_2.ignore()

     test([array].to_array__take().take(0) === [array].to_array__take())
     test([array].init(10).to_array__take().take(0) === [array].to_array__take())
     test([array 1].to_array__take().take(0) === [array].to_array__take())
     test([array 1].to_array__take().take(1) === [array 1].to_array__take())
     test([array 1, 2, 3, 4, 5].to_array__take().take(1) === [array 1].to_array__take())
     test([array 1, 2, 3, 4, 5].to_array__take().take(2) === [array 1, 2].to_array__take())
     test([array 1, 2, 3, 4, 5].to_array__take().take(3) === [array 1, 2, 3].to_array__take())
     test([array 1, 2, 3, 4, 5].to_array__take().take(4) === [array 1, 2, 3, 4].to_array__take())
     test([array 1, 2, 3, 4, 5].to_array__take().take(5) === [array 1, 2, 3, 4, 5].to_array__take())

     test([array].to_custom_array__take().take(0) === [array].to_custom_array__take())
     test([array].init(10).to_custom_array__take().take(0) === [array].to_custom_array__take())
     test([array 1].to_custom_array__take().take(0) === [array].to_custom_array__take())
     test([array 1].to_custom_array__take().take(1) === [array 1].to_custom_array__take())
     test([array 1, 2, 3, 4, 5].to_custom_array__take().take(1) === [array 1].to_custom_array__take())
     test([array 1, 2, 3, 4, 5].to_custom_array__take().take(2) === [array 1, 2].to_custom_array__take())
     test([array 1, 2, 3, 4, 5].to_custom_array__take().take(3) === [array 1, 2, 3].to_custom_array__take())
     test([array 1, 2, 3, 4, 5].to_custom_array__take().take(4) === [array 1, 2, 3, 4].to_custom_array__take())
     test([array 1, 2, 3, 4, 5].to_custom_array__take().take(5) === [array 1, 2, 3, 4, 5].to_custom_array__take())

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.take(0).get_error_id() === :1)
     test("".take(error_1).get_error_id() === :1)
     test(error_1.take(error_2).get_error_id() === :1)
     test(error_2.take(error_1).get_error_id() === :2)
     test(error_1.take(heap_string()).get_error_id() === :1)
     test(heap_table().take(error_1).get_error_id() === :1)

     test(heap_table().take(0).get_error_id() === :invalid_type)
     test(heap_string().take(heap_table()).get_error_id() === :invalid_type)
     test(heap_table().take(heap_table()).get_error_id() === :invalid_type)

     test("".take(1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("".take(9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("".take(-1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("".take(-9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".take(16.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".take(17.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".take(9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".take(-1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".take(-9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".append('f').take(17.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".append('f').take(18.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".append('f').take(9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".append('f').take(-1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test("0123456789abcde".append('f').take(-9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"".take(1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"".take(9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"".take(-1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"".take(-9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".take(15.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".take(16.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".take(9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".take(-1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".take(-9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".append(u"f"[0]).take(16.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".append(u"f"[0]).take(17.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".append(u"f"[0]).take(9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".append(u"f"[0]).take(-1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(u"0123456789abcd".append(u"f"[0]).take(-9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array].take(1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array].take(9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array].take(-1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array].take(-9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].take(2.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].take(9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].take(-1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string()].take(-9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_string()].take(3.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_string()].take(4.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_string()].take(9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_string()].take(-1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_string()].take(-9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)

     test(to_broken_array__take("").take(0).get_error_id() === :invalid_type)
     test(to_broken_custom_array__take("").take(0).get_error_id() === :invalid_type)
     test(to_error_array__take("").take(0).get_error_id() === :3)
     test(to_error_custom_array__take("").take(0).get_error_id() === :4)
}