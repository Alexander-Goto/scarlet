     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(parse_int(error_1, 2).get_error_id() === :1)
     test(parse_int(error_1, 0.scarlet__erase_info()).get_error_id() === :1)
     test(parse_int("0", error_1).get_error_id() === :1)
     test(parse_int(error_1, error_2).get_error_id() === :1)
     test(parse_int(error_2, error_1).get_error_id() === :2)
     test(parse_int(error_1, heap_string()).get_error_id() === :1)
     test(parse_int(heap_table(), error_1).get_error_id() === :1)
     test(parse_int("1", heap_string()).get_error_id() === :invalid_type)
     test(parse_int(heap_table(), 2).get_error_id() === :invalid_type)
     test(parse_int(heap_table(), heap_string()).get_error_id() === :invalid_type)

     test(parse_int("0", 0.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(parse_int("0", 1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(parse_int("0", -1.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(parse_int("0", -9223372036854775808.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(parse_int("0", 37.scarlet__erase_info()).get_error_id() === :out_of_bounds)
     test(parse_int("0", 9223372036854775807.scarlet__erase_info()).get_error_id() === :out_of_bounds)

     test(parse_int("", 2) == :invalid_str_fmt)
     test(parse_int("", 36) == :invalid_str_fmt)
     let base = (rnd() & 63) % 34 + 2
     let [box max_digit_1, max_digit_2, max_digit_3] = if base < 10
          [box ('0'.to_int() + base - 1).to_char(), '0', '0']
     else {
          let char = ('A'.to_int() + base - 11).to_char()
          [box '9', char, ascii_to_lower(char)]
     }
     let string = loop(null, fn (_) {
          let string   = rnd_string()
          break(not string.filter(fn (char) not (char >= '0' && char <= max_digit_1 || char >= 'A' && char <= max_digit_2 || char >= 'a' && char <= max_digit_3)).empty?(), string)
     })
     test(parse_int(string, base) == :invalid_str_fmt)

     test(parse_int("54125341235412354123541651243651243651243651243", 10) == :64_bits_is_not_enough)
     test(parse_int("54125341235412354123541651243651243651243651243", 8) == :64_bits_is_not_enough)
