let char__ascii_letter = [obj
     :value = 0

     :_ = [obj
          :core_ascii_letter? = fn (char) char:value.ascii_letter?()
     ]
]

fn to_char__ascii_letter?(arg) new (@main.char__ascii_letter):value <= arg

fn to_custom_char__ascii_letter?(arg) custom__create(
     arg
     [obj
          :core_ascii_letter? = fn (char) char.custom__get_data().ascii_letter?()
     ]
)

let broken_char__ascii_letter = [obj
     :value = 0

     :_ = [obj
          :core_ascii_letter? = fn (_) heap_string()
     ]
]

fn to_broken_char__ascii_letter?(arg) new (@main.broken_char__ascii_letter):value <= arg

fn to_broken_custom_char__ascii_letter?(arg) custom__create(
     arg
     [obj
          :core_ascii_letter? = fn (_) heap_string()
     ]
)

let error_char__ascii_letter = [obj
     :value = 0

     :_ = [obj
          :core_ascii_letter? = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_char__ascii_letter?(arg) new (@main.error_char__ascii_letter):value <= arg

fn to_error_custom_char__ascii_letter?(arg) custom__create(
     arg
     [obj
          :core_ascii_letter? = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__ascii_letter?() {
     test(not '\000001'.ascii_letter?())
     test(not '\000008'.ascii_letter?())
     test(not '\00000a'.ascii_letter?())
     test(not '\00001f'.ascii_letter?())
     test(not '\00007f'.ascii_letter?())
     test(not '\000009'.ascii_letter?())
     test(not '\t'.ascii_letter?())
     test(not '\000020'.ascii_letter?())
     test(not '\00007e'.ascii_letter?())
     test(not ' '.ascii_letter?())
     test('a'.ascii_letter?())
     test('z'.ascii_letter?())
     test('A'.ascii_letter?())
     test('Z'.ascii_letter?())
     test(not '\00008b'.ascii_letter?())
     test(not '0'.ascii_letter?())
     test(not '9'.ascii_letter?())

     let string = rnd_string()
     test(string.filter(fn (char) char.in_range?('a', '{') || char.in_range?('A', '[')) === string.filter(ascii_letter?(_)))

     test(to_char__ascii_letter?('a').ascii_letter?())
     test(to_char__ascii_letter?('A').ascii_letter?())
     test(not to_char__ascii_letter?('0').ascii_letter?())

     test(to_custom_char__ascii_letter?('a').ascii_letter?())
     test(to_custom_char__ascii_letter?('A').ascii_letter?())
     test(not to_custom_char__ascii_letter?('0').ascii_letter?())

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.ascii_letter?().get_error_id() === :1)
     test(heap_table().ascii_letter?().get_error_id() === :invalid_type)

     test(to_broken_char__ascii_letter?('a').ascii_letter?().get_error_id() === :invalid_type)
     test(to_broken_custom_char__ascii_letter?('a').ascii_letter?().get_error_id() === :invalid_type)
     test(to_error_char__ascii_letter?('a').ascii_letter?().get_error_id() === :3)
     test(to_error_custom_char__ascii_letter?('a').ascii_letter?().get_error_id() === :4)
}