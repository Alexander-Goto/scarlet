let const__great_or_eq = [obj
     :value = 0

     :_ = [obj
          :core_cmp = fn (const_1, const_2) cmp(const_1:value, const_2:value)
     ]
]

fn to_const__great_or_eq(arg) new (@main.const__great_or_eq):value <= arg

fn to_custom_const__great_or_eq(arg) custom__create(
     arg
     [obj
          :core_cmp = fn (const_1, const_2) cmp(const_1.custom__get_data(), const_2.custom__get_data())
     ]
)

`noinline`
fn test____great_or_eq__() {
     test(("" >= ""))
     test(("0" >= ""))
     test(not ("" >= "0"))
     test(("1" >= "1"))
     test(not ("0" >= "1"))
     test(("1" >= "0"))
     test(("11" >= "11"))
     test(("11" >= "1"))
     test(not ("1" >= "11"))
     test(("0123456789abcde" >= "0123456789abcde"))
     test(("1123456789abcde" >= "0123456789abcde"))
     test(not ("0123456789abcde" >= "1123456789abcde"))
     test(not ("0123456789abcdd" >= "0123456789abcde"))
     test(("0123456789abcde" >= "0123456789abcdd"))
     test(not ("0123456789abcd" >= "0123456789abcde"))
     test(("0123456789abcde" >= "0123456789abcd"))
     test(not ("" >= "0123456789abcde"))
     test(("0123456789abcde" >= ""))
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5" >= "\000091\0000b3\0000ab\0000a4\0000a7\0000b5"))
     test(("\0000b2\0000b3\0000ab\0000a4\0000a7\0000b5" >= "\000091\0000b3\0000ab\0000a4\0000a7\0000b5"))
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5" >= "\000091\0000b3\0000ab\0000a4\0000a7"))
     test(not ("\000091\0000b3\0000ab\0000a4\0000a7\0000b5" >= "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 "))
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 " >= "\000091\0000b3\0000ab\0000a4\0000a7\0000b5"))
     test(("0123456789abcdef" >= "0123456789abcdef"))
     test(("0123456789abcdef" >= "0123456789abcde"))
     test(not ("0123456789abcde" >= "0123456789abcdef"))
     test(not ("0123456789abcdef" >= "0123456789abcdefg"))
     test(("0123456789abcdefg" >= "0123456789abcdef"))
     test(not ("" >= "0123456789abcdef"))
     test(("0123456789abcdef" >= ""))
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3" >= "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3"))
     test(("\0000b2\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3" >= "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3"))
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3" >= "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\000092"))
     test(not ("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3" >= "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3 "))
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3 " >= "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ab\0000b3"))
     test(("0123456789abcde" ++ "f") >= "0123456789abcdef")
     test(("0123456789abcde" ++ "f") >= "0123456789abcde")
     test("0123456789abcdef" >= ("0123456789abcde" ++ "f"))
     test(not ("0123456789abcde" >= ("0123456789abcde" ++ "f")))
     test(("0123456789abcde" ++ "f") >= ("0123456789abcde" ++ "f"))
     test(("0123456789abcde" ++ "ff") >= ("0123456789abcde" ++ "f"))
     let string_1  = rnd_string()
     let string_2  = rnd_string()
     let short_len = if len(string_1) < len(string_2); len(string_1) else len(string_2)
     let is_great_or_eq  = loop(0, fn (idx) {
          if idx === short_len
               [breaker len(string_1) >= len(string_2)]
          else {
               let char_1 = string_1[idx]
               let char_2 = string_2[idx]
               if char_1 =/= char_2
                    [breaker char_1 >= char_2]
               else idx + 1
          }
     })
     test((string_1 >= string_2) === is_great_or_eq)

     test((:_ >= :_))
     test(not (:0 >= :_))
     test((:_ >= :0))
     test((:1 >= :1))
     test(not (:0 >= :1))
     test((:1 >= :0))
     test((:11 >= :11))
     test((:11 >= :1))
     test(not (:1 >= :11))
     test((:0123456789abcdefghijkl >= :0123456789abcdefghijkl))
     test((:1123456789abcdefghijkl >= :0123456789abcdefghijkl))
     test(not (:0123456789abcdefghijkl >= :1123456789abcdefghijkl))
     test(not (:0123456789abcdefghijkl >= :0123456789abcdefghijkm))
     test((:0123456789abcdefghijkm >= :0123456789abcdefghijkl))
     test((:1! >= :1!))
     test((:1! >= :1))
     test(not (:1! >= :1!!!))
     test(not (:1! >= :1?))
     test((:1!!! >= :1!!!))
     test((:1!!! >= :1))
     test((:1!!! >= :1!))
     test(not (:1!!! >= :1?))
     test((:1? >= :1?))
     test((:1? >= :1))
     test((:1? >= :1!))
     test((:1? >= :1!!!))
     test((:0000000000000000000000 >= :0000000000000000000000))
     test(not (:0000000000000000000000 >= :0000000000000000000000!))
     test((:0000000000000000000000! >= :0000000000000000000000))
     test((:zzzzzzzzzzzzzzzzzzzzzz >= :zzzzzzzzzzzzzzzzzzzzzz))
     test(not (:zzzzzzzzzzzzzzzzzzzzzz >= :zzzzzzzzzzzzzzzzzzzzzz!))
     test((:zzzzzzzzzzzzzzzzzzzzzz! >= :zzzzzzzzzzzzzzzzzzzzzz))
     test(not (:0000000000000000000000 >= :zzzzzzzzzzzzzzzzzzzzzz))
     test((:zzzzzzzzzzzzzzzzzzzzzz >= :0000000000000000000000))

     test((0b00 >= 0b00))
     test((0bff >= 0bff))
     test((0bf0 >= 0bf0))
     test((0b0f >= 0b0f))
     test(not (0b00 >= 0b01))
     test((0b01 >= 0b00))
     test((0b10 >= 0b01))
     test(not (0b01 >= 0b10))
     test(not (0b00 >= 0bff))
     test((0bff >= 0b00))

     test(('a' >= 'a'))
     test(('z' >= 'z'))
     test(('0' >= '0'))
     test(('\00008b' >= '\00008b'))
     test(('\00009b' >= '\00009b'))
     test(not ('a' >= 'z'))
     test(('z' >= 'a'))
     test(('a' >= '0'))
     test(not ('0' >= 'a'))
     test(not ('a' >= '\0000ac'))
     test(('\0000ac' >= 'a'))
     test(not ('\00008b' >= '\0000ac'))
     test(('\0000ac' >= '\00008b'))
     test(not ('A' >= 'a'))
     test(('a' >= 'A'))

     test((0 >= 0))
     test((1 >= 1))
     test((1654654 >= 1654654))
     test((9223372036854775807 >= 9223372036854775807))
     test((-1 >= -1))
     test((-664654 >= -664654))
     test((-9223372036854775808 >= -9223372036854775808))
     test(not (0 >= 1))
     test(not (0 >= 1654654))
     test(not (0 >= 9223372036854775807))
     test((0 >= -1))
     test((0 >= -664654))
     test((0 >= -9223372036854775808))
     test(not (1 >= 1654654))
     test(not (1 >= 9223372036854775807))
     test((1 >= -1))
     test((1 >= -664654))
     test((1 >= -9223372036854775808))
     test(not (1654654 >= 9223372036854775807))
     test((1654654 >= -1))
     test((1654654 >= -664654))
     test((1654654 >= -9223372036854775808))
     test((9223372036854775807 >= -1))
     test((9223372036854775807 >= -664654))
     test((9223372036854775807 >= -9223372036854775808))
     test((-1 >= -664654))
     test((-1 >= -9223372036854775808))
     test((-664654 >= -9223372036854775808))
     test(not (-9223372036854775808 >= -664654))
     test(not (8 >= 9))
     test((8 >= 4))

     test((0.int_to_time() >= 0.int_to_time()))
     test((1.int_to_time() >= 1.int_to_time()))
     test((1654654.int_to_time() >= 1654654.int_to_time()))
     test((9223372036825516799.int_to_time() >= 9223372036825516799.int_to_time()))
     test(not (0.int_to_time() >= 1.int_to_time()))
     test(not (0.int_to_time() >= 1654654.int_to_time()))
     test(not (0.int_to_time() >= 9223372036825516799.int_to_time()))
     test(not (1.int_to_time() >= 1654654.int_to_time()))
     test(not (1.int_to_time() >= 9223372036825516799.int_to_time()))
     test(not (1654654.int_to_time() >= 9223372036825516799.int_to_time()))
     test(not (8.int_to_time() >= 9.int_to_time()))
     test((8.int_to_time() >= 4.int_to_time()))

     let float_1 = 0.0
     let float_2 = 1.0
     let float_3 = 654659.333
     let float_4 = inf()
     let float_5 = -0.0
     let float_6 = -1.0
     let float_7 = -654659.33
     let float_8 = neg_inf()
     let nan     = nan()
     test((float_1 >= float_1))
     test((float_2 >= float_2))
     test((float_3 >= float_3))
     test((float_4 >= float_4))
     test((float_5 >= float_5))
     test((float_6 >= float_6))
     test((float_7 >= float_7))
     test((float_8 >= float_8))
     test(not (float_1 >= float_2))
     test(not (float_1 >= float_3))
     test(not (float_1 >= float_4))
     test((float_1 >= float_5))
     test((float_1 >= float_6))
     test((float_1 >= float_7))
     test((float_1 >= float_8))
     test(not (float_2 >= float_3))
     test(not (float_2 >= float_4))
     test((float_2 >= float_5))
     test((float_2 >= float_6))
     test((float_2 >= float_7))
     test((float_2 >= float_8))
     test(not (float_3 >= float_4))
     test((float_3 >= float_5))
     test((float_3 >= float_6))
     test((float_3 >= float_7))
     test((float_3 >= float_8))
     test((float_4 >= float_5))
     test((float_4 >= float_6))
     test((float_4 >= float_7))
     test((float_4 >= float_8))
     test((float_5 >= float_6))
     test((float_5 >= float_7))
     test((float_5 >= float_8))
     test((float_6 >= float_7))
     test((float_6 >= float_8))
     test((float_7 >= float_8))
     test(not (float_8 >= float_7))
     test((nan >= nan).get_error_id() === :nan_cmp)
     test((float_1 >= nan).get_error_id() === :nan_cmp)
     test((nan >= float_1).get_error_id() === :nan_cmp)

     test((u"" >= u""))
     test((u"0" >= u""))
     test(not (u"" >= u"0"))
     test((u"1" >= u"1"))
     test(not (u"0" >= u"1"))
     test((u"1" >= u"0"))
     test((u"11" >= u"11"))
     test((u"11" >= u"1"))
     test(not (u"1" >= u"11"))
     test((u"0123456789abcd" >= u"0123456789abcd"))
     test((u"1123456789abcd" >= u"0123456789abcd"))
     test(not (u"0123456789abcd" >= u"1123456789abcd"))
     test(not (u"0123456789abcc" >= u"0123456789abcd"))
     test((u"0123456789abcd" >= u"0123456789abcc"))
     test(not (u"0123456789abc" >= u"0123456789abcd"))
     test((u"0123456789abcd" >= u"0123456789abc"))
     test(not (u"" >= u"0123456789abcd"))
     test((u"0123456789abcd" >= u""))
     test((u"0123456789abcdef" >= u"0123456789abcdef"))
     test((u"0123456789abcdef" >= u"0123456789abcde"))
     test(not (u"0123456789abcde" >= u"0123456789abcdef"))
     test(not (u"0123456789abcdef" >= u"0123456789abcdefg"))
     test((u"0123456789abcdefg" >= u"0123456789abcdef"))
     test(not (u"" >= u"0123456789abcdef"))
     test((u"0123456789abcde" >= u""))
     test((u"0123456789abcd" ++ u"e") >= u"0123456789abcde")
     test((u"0123456789abcd" ++ u"e") >= u"0123456789abcd")
     test(u"0123456789abcde" >= (u"0123456789abcd" ++ u"e"))
     test(not (u"0123456789abcd" >= (u"0123456789abcd" ++ u"e")))
     test((u"0123456789abcd" ++ u"e") >= (u"0123456789abcd" ++ u"e"))
     test((u"0123456789abcde" ++ u"ff") >= (u"0123456789abcde" ++ u"f"))
     let array_1  = rnd_byte_array()
     let array_2  = rnd_byte_array()
     let short_len = if len(array_1) < len(array_2); len(array_1) else len(array_2)
     let is_great_or_eq  = loop(0, fn (idx) {
          if idx === short_len
               [breaker len(array_1) >= len(array_2)]
          else {
               let byte_1 = array_1[idx]
               let byte_2 = array_2[idx]
               if byte_1 =/= byte_2
                    [breaker byte_1 >= byte_2]
               else idx + 1
          }
     })
     test((array_1 >= array_2) === is_great_or_eq)

     test(([array] >= [array]))
     test(([array 10] >= [array 10]))
     test(([array 1, 2] >= [array 1, 2]))
     test(([array 1] >= [array]))
     test(not ([array 1] >= [array 1, 2]))
     test(([array 1, 2] >= [array 1]))
     test(([array 2, 1] >= [array 1, 2]))

     let array_1  = rnd_string_array()
     let array_2  = rnd_string_array()
     let short_len = if len(array_1) < len(array_2); len(array_1) else len(array_2)
     let is_great_or_eq  = loop(0, fn (idx) {
          if idx === short_len
               [breaker len(array_1) >= len(array_2)]
          else {
               let string_1 = array_1[idx]
               let string_2 = array_2[idx]
               if string_1 =/= string_2
                    [breaker string_1 >= string_2]
               else idx + 1
          }
     })
     test((array_1 >= array_2) === is_great_or_eq)

     test(([array].to_const__great_or_eq() >= [array].to_const__great_or_eq()))
     test(([array 10.scarlet__erase_info()].to_const__great_or_eq() >= [array 10.scarlet__erase_info()].to_const__great_or_eq()))
     test(([array 1.scarlet__erase_info(), 2].to_const__great_or_eq() >= [array 1, 2.scarlet__erase_info()].to_const__great_or_eq()))
     test(([array 1.scarlet__erase_info()].to_const__great_or_eq() >= [array].to_const__great_or_eq()))
     test(not ([array 1.scarlet__erase_info()].to_const__great_or_eq() >= [array 1.scarlet__erase_info(), 2].to_const__great_or_eq()))
     test(([array 1.scarlet__erase_info(), 2].to_const__great_or_eq() >= [array 1.scarlet__erase_info()].to_const__great_or_eq()))
     test(([array 2.scarlet__erase_info(), 1].to_const__great_or_eq() >= [array 1.scarlet__erase_info(), 2].to_const__great_or_eq()))

     test(([array].to_custom_const__great_or_eq() >= [array].to_custom_const__great_or_eq()))
     test(([array 10.scarlet__erase_info()].to_custom_const__great_or_eq() >= [array 10.scarlet__erase_info()].to_custom_const__great_or_eq()))
     test(([array 1.scarlet__erase_info(), 2].to_custom_const__great_or_eq() >= [array 1, 2.scarlet__erase_info()].to_custom_const__great_or_eq()))
     test(([array 1.scarlet__erase_info()].to_custom_const__great_or_eq() >= [array].to_custom_const__great_or_eq()))
     test(not ([array 1.scarlet__erase_info()].to_custom_const__great_or_eq() >= [array 1.scarlet__erase_info(), 2].to_custom_const__great_or_eq()))
     test(([array 1.scarlet__erase_info(), 2].to_custom_const__great_or_eq() >= [array 1.scarlet__erase_info()].to_custom_const__great_or_eq()))
     test(([array 2.scarlet__erase_info(), 1].to_custom_const__great_or_eq() >= [array 1.scarlet__erase_info(), 2].to_custom_const__great_or_eq()))

     test(([array nan()].to_const__great_or_eq() <= [array 12.0].to_const__great_or_eq()).get_error_id() === :nan_cmp)
     test(([array nan()].to_custom_const__great_or_eq() <= [array 12.0].to_custom_const__great_or_eq()).get_error_id() === :nan_cmp)

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let string  = heap_string()
     let table   = heap_table()
     test((error_1 >= error_2).get_error_id() === :1)
     test((error_2 >= error_1).get_error_id() === :2)
     test((error_1 >= string).get_error_id() === :1)
     test((string >= error_1).get_error_id() === :1)
     test((error_1 >= table).get_error_id() === :1)
     test((table >= error_1).get_error_id() === :1)

     test((1.scarlet__erase_info() >= 1.0).get_error_id() === :invalid_type)
     test((1.0.scarlet__erase_info() >= 1).get_error_id() === :invalid_type)
     test(("".scarlet__erase_info() >= u"").get_error_id() === :invalid_type)
     test((u"" >= string).get_error_id() === :invalid_type)
     test((table >= string).get_error_id() === :invalid_type)
     test((string >= table).get_error_id() === :invalid_type)
     test((table >= 1).get_error_id() === :invalid_type)
     test((1 >= table).get_error_id() === :invalid_type)
     test((1 >= string).get_error_id() === :invalid_type)
     test((string >= 1).get_error_id() === :invalid_type)
     test(([array 1].scarlet__erase_info() >= [array 1.0]).get_error_id() === :invalid_type)
     test(([array 1.0].scarlet__erase_info() >= [array 1]).get_error_id() === :invalid_type)
     test(([array ""].scarlet__erase_info() >= [array u""]).get_error_id() === :invalid_type)
     test(([array u""] >= [array string]).get_error_id() === :invalid_type)
     test(([array table] >= [array string]).get_error_id() === :invalid_type)
     test(([array string] >= [array table]).get_error_id() === :invalid_type)
     test(([array table] >= [array 1]).get_error_id() === :invalid_type)
     test(([array 1] >= [array table]).get_error_id() === :invalid_type)
     test(([array 1] >= [array string]).get_error_id() === :invalid_type)
     test(([array string] >= [array 1]).get_error_id() === :invalid_type)
}