fn to_custom_const__pop__push(arg) custom__create(
     arg
     [obj]
)

`noinline`
fn test__pop__push() {
     let [box in, out] = make_channel()
     let string        = heap_string()

     test(push(in, "Hello!!!").null?())
     test(pop(out) === "Hello!!!")
     test(push(in, string).null?())
     test(pop(out) === string)
     test(push(in, [box]).null?())
     test(pop(out) === [box])
     test(push(in, [box 1, 2, 3]).null?())
     test(pop(out) === [box 1, 2, 3])
     test(push(in, [box string]).null?())
     test(pop(out) === [box string])
     test(push(in, [obj :1 = string]).null?())
     test(pop(out) === [obj :1 = string])
     test(push(in, [table :1 = string]).null?())
     test(pop(out) === [table :1 = string])
     test(push(in, [set string]).null?())
     test(pop(out) === [set string])
     test(push(in, u"Hello world" ++ u"!!!").null?())
     test(pop(out) === u"Hello world!!!")
     test(push(in, [array string]).null?())
     test(pop(out) === [array string])
     test(push(in, _ ++ string).null?())
     test(pop(out)(string) === string ++ string)
     test(push(in, (fn (a, b) a.null?() && b === 12)(null, _)).null?())
     test(pop(out)(12))
     test(push(in, 12.to_custom_const__pop__push()).null?())
     test(pop(out).custom__get_data() === 12)

     test(push(in, "Hello!!!").null?())
     test(push(in, string).null?())
     test(push(in, [box]).null?())
     test(push(in, [box 1, 2, 3]).null?())
     test(push(in, [box string]).null?())
     test(push(in, [obj :1 = string]).null?())
     test(push(in, [table :1 = string]).null?())
     test(push(in, [set string]).null?())
     test(push(in, u"Hello world" ++ u"!!!").null?())
     test(push(in, [array string]).null?())
     test(push(in, _ ++ string).null?())
     test(push(in, (fn (a, b) a.null?() && b === 12)(null, _)).null?())
     test(push(in, 12.to_custom_const__pop__push()).null?())
     test(pop(out) === "Hello!!!")
     test(pop(out) === string)
     test(pop(out) === [box])
     test(pop(out) === [box 1, 2, 3])
     test(pop(out) === [box string])
     test(pop(out) === [obj :1 = string])
     test(pop(out) === [table :1 = string])
     test(pop(out) === [set string])
     test(pop(out) === u"Hello world!!!")
     test(pop(out) === [array string])
     test(pop(out)(string) === string ++ string)
     test(pop(out)(12))
     test(pop(out).custom__get_data() === 12)

     test(push(in, "Hello!!!").null?())
     test(push(in, string).null?())
     test(push(in, [box]).null?())
     test(push(in, [box 1, 2, 3]).null?())
     test(push(in, [box string]).null?())
     test(push(in, [obj :1 = string]).null?())
     test(pop(out) === "Hello!!!")
     test(pop(out) === string)
     test(pop(out) === [box])
     test(pop(out) === [box 1, 2, 3])
     test(pop(out) === [box string])
     test(pop(out) === [obj :1 = string])
     test(push(in, [table :1 = string]).null?())
     test(push(in, [set string]).null?())
     test(push(in, u"Hello world" ++ u"!!!").null?())
     test(push(in, [array string]).null?())
     test(push(in, _ ++ string).null?())
     test(push(in, (fn (a, b) a.null?() && b === 12)(null, _)).null?())
     test(push(in, 12.to_custom_const__pop__push()).null?())
     test(pop(out) === [table :1 = string])
     test(pop(out) === [set string])
     test(pop(out) === u"Hello world!!!")
     test(pop(out) === [array string])
     test(pop(out)(string) === string ++ string)
     test(pop(out)(12))
     test(pop(out).custom__get_data() === 12)

     let array     = rnd_string_array()
     let len       = len(array)
     array.foldl(null, fn (_, string) push(in, string))
     let new_array = loop([array], fn (array) {
          let array = array.append(pop(out))
          break(len(array) === len, array)
     })
     test(array === new_array)

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(push(error_1, in).get_error_id() === :1)
     test(push(heap_string(), error_1).get_error_id() === :1)
     test(push(error_1, error_2).get_error_id() === :1)
     test(push(error_2, error_1).get_error_id() === :2)
     test(push(error_1, heap_string()).get_error_id() === :1)
     test(push(in, error_1).get_error_id() === :1)
     test(push(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(pop(error_1).get_error_id() === :1)
     test(pop(heap_string()).get_error_id() === :invalid_type)

     test(push(out, heap_string()).get_error_id() === :cant_write_to_channel)
     test(pop(in).get_error_id() === :cant_read_from_channel)
     test(push(in, null.scarlet__erase_info()).get_error_id() === :share_invalid_type)
     test(push(in, thread(fn () 1 + 1).scarlet__erase_info()).get_error_id() === :share_invalid_type)
     test(push(in, out.scarlet__erase_info()).get_error_id() === :share_invalid_type)
     test(push(in, heap_string()).get_error_id() === :no_reading_channel)

     let [box _, out] = make_channel()
     test(pop(out).get_error_id() === :no_writing_channel)
}