     set_2.ignore()

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     test([table].any(true, fn (_) string_1))
     test(not [table].any(false, fn (_) string_1))
     test(not [table "0123456789abcdef1" = "1"].any(true, fn (item) string_1 === item))
     test([table "0" = "0123456789abcdef1"].any(true, fn (item) string_1 === item))
     test([table "2" = "0123456789abcdef", "0" = "1123456789abcdef1", "1" = "0123456789abcdef1"].any(true, fn (item) string_1 === item))
     test(not [table "0123456789abcdef1" = "0123456789abcdef", "0" = "1123456789abcdef1", "1" = "0"].any(true, fn (item) string_1 === item))

     let table = [table].init(10)
     test(table.any(true, fn (item) string_1 === item))
     table.ignore()

     let table = [table string_0 = string_1]
     test(table.any(true, fn (item) string_1 === item))
     table.ignore()

     let table = [table string_1 = string_0]
     test(not table.any(true, fn (item) string_1 === item))
     table.ignore()

     let table = [table string_0 = string_1, string_2 = string_0]
     test(table.any(true, fn (item) string_1 === item))
     table.ignore()

     let table = [table string_1 = string_0, string_0 = string_2]
     test(not table.any(true, fn (item) string_1 === item))
     table.ignore()

     test([table].init(10).any(true, fn (item) string_1 === item))
     test(not [table].init(10).any(false, fn (item) string_1 === item))
     test([table string_0 = string_1].any(true, fn (item) string_1 === item))
     test(not [table string_1 = string_0].any(true, fn (item) string_1 === item))
     test([table string_0 = string_1, string_2 = string_0].any(true, fn (item) string_1 === item))
     test(not [table string_1 = string_0, string_0 = string_2].any(true, fn (item) string_1 === item))

     let table_1  = rnd_string_table()
     let table_2  = if rnd_bool(); table_1 else null
     let expected = not table_1.all(true, fn (string) string[0] =/= '3')
     let have     = table_1.any(true, fn (string) string[0] === '3')
     test(expected === have)
     table_2.ignore()

     let table_1  = rnd_string_table()
     let table_2  = if rnd_bool(); table_1 else null
     let expected = not table_1.all(true, fn (string) string[0] =/= '3')
     let have     = table_1.any(true, fn (string) table_1 === 17 || string[0] === '3')
     test(expected === have)
     table_2.ignore()

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     test([obj].any(true, fn (_) string_1))
     test(not [obj].any(false, fn (_) string_1))
     test(not [obj :0 = "1"].any(true, fn (item) string_1 === item))
     test([obj :0 = "0123456789abcdef1"].any(true, fn (item) string_1 === item))
     test([obj :0 = "0123456789abcdef1", :1 = "1123456789abcdef1", :2 = "0"].any(true, fn (item) string_1 === item))
     test(not [obj :_ = [obj :0 = "0123456789abcdef1"], :0 = "0123456789abcdef", :1 = "1123456789abcdef1", :2 = "0"].any(true, fn (item) string_1 === item))
     test(not [obj :0 = "0123456789abcdef", :1 = "1123456789abcdef1", :2 = "0123456789abcdef0"].any(true, fn (item) string_1 === item))

     let obj = [obj].init(10)
     test(obj.any(true, fn (item) string_1 === item))
     obj.ignore()

     let obj = [obj :0 = string_1]
     test(obj.any(true, fn (item) string_1 === item))
     obj.ignore()

     let obj = [obj :1 = string_0]
     test(not obj.any(true, fn (item) string_1 === item))
     obj.ignore()

     let obj = [obj :0 = string_1, :2 = string_0]
     test(obj.any(true, fn (item) string_1 === item))
     obj.ignore()

     let obj = [obj :1 = string_0, :0 = string_2]
     test(not obj.any(true, fn (item) string_1 === item))
     obj.ignore()

     let obj = [obj :_ = [obj :0 = string_1],  :1 = string_0, :0 = string_2]
     test(not obj.any(true, fn (item) string_1 === item))
     obj.ignore()

     test([obj].init(10).any(true, fn (item) string_1 === item))
     test(not [obj].init(10).any(false, fn (item) string_1 === item))
     test([obj :0 = string_1].any(true, fn (item) string_1 === item))
     test(not [obj :1 = string_0].any(true, fn (item) string_1 === item))
     test([obj :0 = string_1, :2 = string_0].any(true, fn (item) string_1 === item))
     test(not [obj :1 = string_0, :0 = string_2].any(true, fn (item) string_1 === item))
     test(not [obj :_ = [obj :0 = string_1],  :1 = string_0, :0 = string_2].any(true, fn (item) string_1 === item))

     let obj_1    = rnd_string_obj()
     let obj_2    = if rnd_bool(); obj_1 else null
     let expected = not obj_1.all(true, fn (string) string[0] =/= '3')
     let have     = obj_1.any(true, fn (string) string[0] === '3')
     test(expected === have)
     obj_2.ignore()

     let obj_1    = rnd_string_obj()
     let obj_2    = if rnd_bool(); obj_1 else null
     let expected = not obj_1.all(true, fn (string) string[0] =/= '3')
     let have     = obj_1.any(true, fn (string) obj_1 === 17 || string[0] === '3')
     test(expected === have)
     obj_2.ignore()

     test(to_container__any("abc").any(true, _.ascii_lower?()))
     test(to_container__any("aBc").any(true, _.ascii_lower?()))
     test(not to_container__any("ABC").any(true, _.ascii_lower?()))
     test(to_custom_container__any("abc").any(true, _.ascii_lower?()))
     test(to_custom_container__any("aBc").any(true, _.ascii_lower?()))
     test(not to_custom_container__any("ABC").any(true, _.ascii_lower?()))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let error_3 = expected_error(:3, heap_string(), heap_string())
     test(error_1.any(true, _ === heap_string()).get_error_id() === :1)
     test(heap_string().any(error_1, _ === heap_string()).get_error_id() === :1)
     test(heap_string().any(true, error_1).get_error_id() === :1)
     test(error_1.any(error_2, error_3).get_error_id() === :1)
     test(error_3.any(error_2, error_1).get_error_id() === :3)

     test((_ === heap_string()).scarlet__erase_info().any(true, _ === heap_string()).get_error_id() === :invalid_type)
     test(heap_string().any(heap_string(), _ === heap_string()).get_error_id() === :invalid_type)
     test(heap_string().any(true, heap_table()).get_error_id() === :invalid_type)
     test((_ === heap_string()).scarlet__erase_info().any(heap_string(), heap_table()).get_error_id() === :invalid_type)

     test(to_broken_container__any("").any(true, _ === heap_string()).get_error_id() === :invalid_type)
     test(to_broken_custom_container__any("").any(true, _ === heap_string()).get_error_id() === :invalid_type)
     test(to_error_container__any("").any(true, _ === heap_string()).get_error_id() === :3)
     test(to_error_custom_container__any("").any(true, _ === heap_string()).get_error_id() === :4)

     test([array heap_string()].any(true, fn (_) expected_error(:5, heap_string(), heap_string())).get_error_id() === :5)
}