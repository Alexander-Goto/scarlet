let container__any = [obj
     :value = [array]

     :_ = [obj
          :core_any = fn (container, default_result, func) container:value.any(default_result, func)
     ]
]

fn to_container__any(arg) new (@main.container__any):value <= arg

fn to_custom_container__any(arg) custom__create(
     arg
     [obj
          :core_any = fn (container, default_result, func) custom__get_data(container).any(default_result, func)
     ]
)

let broken_container__any = [obj
     :value = [array]

     :_ = [obj
          :core_any = fn (_, _, _) heap_string()
     ]
]

fn to_broken_container__any(arg) new (@main.broken_container__any):value <= arg

fn to_broken_custom_container__any(arg) custom__create(
     arg
     [obj
          :core_any = fn (_, _, _) heap_string()
     ]
)

let error_container__any = [obj
     :value = [array]

     :_ = [obj
          :core_any = fn (_, _, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_container__any(arg) new (@main.error_container__any):value <= arg

fn to_error_custom_container__any(arg) custom__create(
     arg
     [obj
          :core_any = fn (_, _, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__any() {
     let items = "3".to_array()
     test("".any(true, fn (_) items))
     test(not "".any(false, fn (_) items))
     test(not "1".any(true, fn (char) items[0] === char))
     test("3".any(true, fn (char) items[0] === char))
     test("333333333333333".any(true, fn (char) items[0] === char))
     test("233333333333333".any(true, fn (char) items[0] === char))
     test("333333333333332".any(true, fn (char) items[0] === char))
     test("322222222222222".any(true, fn (char) items[0] === char))
     test("222222222222223".any(true, fn (char) items[0] === char))
     test(not "222222222222222".any(true, fn (char) items[0] === char))
     test("0123456789abcde".any(true, fn (char) items[0] === char))

     let items = "\000093".to_array()
     test(not "\000091".any(true, fn (char) items[0] === char))
     test("\000093".any(true, fn (char) items[0] === char))
     test("\000093\000093\000093\000093\000093\000093\000093".any(true, fn (char) items[0] === char))
     test("\000092\000093\000093\000093\000093\000093\000093".any(true, fn (char) items[0] === char))
     test("2\000093\000093\000093\000093\000093\000093\000093".any(true, fn (char) items[0] === char))
     test("\000093\000093\000093\000093\000093\000093\0000933".any(true, fn (char) items[0] === char))
     test("\000093\000092\000092\000092\000092\000092\000092".any(true, fn (char) items[0] === char))
     test("\000092\000092\000092\000092\000092\000092\000093".any(true, fn (char) items[0] === char))
     test(not "\000092\000092\000092\000092\0000923\000092\000092".any(true, fn (char) items[0] === char))
     test(not "\000092\000092\000092\000092\000092\000092\0000923".any(true, fn (char) items[0] === char))
     test(not "\000092\000092\000092\000092\000092\000092\0000923".any(true, fn (char) items[0] === char))
     test("012\000093456789abcd".any(true, fn (char) items[0] === char))

     let items = "3".to_array()
     test("3333333333333333".any(true, fn (char) items[0] === char))
     test("2333333333333333".any(true, fn (char) items[0] === char))
     test("3333333333333332".any(true, fn (char) items[0] === char))
     test("3222222222222222".any(true, fn (char) items[0] === char))
     test("2222222222222223".any(true, fn (char) items[0] === char))
     test(not "2222222222222222".any(true, fn (char) items[0] === char))
     test("0123456789abcdef".any(true, fn (char) items[0] === char))

     let string = ("033333333333333" ++ "330")[1, 17]
     test(string.any(true, fn (char) items[0] === char))
     string.ignore()

     let string = ("023333333333333" ++ "330")[1, 17]
     test(string.any(true, fn (char) items[0] === char))
     string.ignore()

     let string = ("033333333333333" ++ "320")[1, 17]
     test(string.any(true, fn (char) items[0] === char))
     string.ignore()

     let string = ("022222222222222" ++ "220")[1, 17]
     test(not string.any(true, fn (char) items[0] === char))
     string.ignore()

     let string = ("032222222222222" ++ "220")[1, 17]
     test(string.any(true, fn (char) items[0] === char))
     string.ignore()

     let string = ("022222222222222" ++ "230")[1, 17]
     test(string.any(true, fn (char) items[0] === char))
     string.ignore()

     let string = ("00123456789abcd" ++ "ef0")[1, 17]
     test(string.any(true, fn (char) items[0] === char))
     string.ignore()

     test(("033333333333333" ++ "330")[1, 17].any(true, fn (char) items[0] === char))
     test(("023333333333333" ++ "330")[1, 17].any(true, fn (char) items[0] === char))
     test(("033333333333333" ++ "320")[1, 17].any(true, fn (char) items[0] === char))
     test(("032222222222222" ++ "220")[1, 17].any(true, fn (char) items[0] === char))
     test(("022222222222222" ++ "230")[1, 17].any(true, fn (char) items[0] === char))
     test(not ("022222222222222" ++ "220")[1, 17].any(true, fn (char) items[0] === char))
     test(("00123456789abcd" ++ "ef0")[1, 17].any(true, fn (char) items[0] === char))

     let items = "\000093".to_array()
