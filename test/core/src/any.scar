     test(not string.any(true, fn (char) items[0] === char))
     string.ignore()

     let string = ("0\000090\000091\000092\000093\000094\000095\000096\000097\000098\000099\00009a\00009b\00009c\00009d" ++ "\00009e\00009f0")[1, 17]
     test(string.any(true, fn (char) items[0] === char))
     string.ignore()

     test(("0\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093" ++ "\000093\0000930")[1, 17].any(true, fn (char) items[0] === char))
     test(("0\000092\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093" ++ "\000093\0000930")[1, 17].any(true, fn (char) items[0] === char))
     test(("0\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093\000093" ++ "\000093\0000920")[1, 17].any(true, fn (char) items[0] === char))
     test(("0\000093\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092" ++ "\000092\0000920")[1, 17].any(true, fn (char) items[0] === char))
     test(("0\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092" ++ "\000092\0000930")[1, 17].any(true, fn (char) items[0] === char))
     test(not ("0\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092\000092" ++ "\000092\0000920")[1, 17].any(true, fn (char) items[0] === char))
     test(("0\000090\000091\000092\000093\000094\000095\000096\000097\000098\000099\00009a\00009b\00009c\00009d" ++ "\00009e\00009f0")[1, 17].any(true, fn (char) items[0] === char))

     test("01".any(true, fn (char) if char === '0'; true else expected_error(:5, "", "")))
     test(heap_string().any(true, fn (char) if char === '0'; true else expected_error(:5, "", "")))

     let string_1 = rnd_string()
     let string_2 = if rnd_bool(); string_1 else null
     let expected = not string_1.all(true, _ =/= '3')
     let have     = string_1.any(true, _ === '3')
     test(expected === have)
     string_2.ignore()

     let string_1 = rnd_string()
     let string_2 = if rnd_bool(); string_1 else null
     let expected = not string_1.all(true, _ =/= '3')
     let have     = string_1.any(true, fn (char) string_1 === 17 || char === '3')
     test(expected === have)
     string_2.ignore()

     let items = u"3".to_array()
     test(u"".any(true, fn (_) items))
     test(not u"".any(false, fn (_) items))
