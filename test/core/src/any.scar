     test((u"033333333333333" ++ u"320")[1, 17].any(true, fn (byte) items[0] === byte))
     test((u"032222222222222" ++ u"220")[1, 17].any(true, fn (byte) items[0] === byte))
     test((u"022222222222222" ++ u"230")[1, 17].any(true, fn (byte) items[0] === byte))
     test(not (u"022222222222222" ++ u"220")[1, 17].any(true, fn (byte) items[0] === byte))
     test((u"00123456789abcd" ++ u"ef0")[1, 17].any(true, fn (byte) items[0] === byte))

     test(u"01".any(true, fn (byte) if byte === u"0"[0]; true else expected_error(:5, "", u"")))
     test(heap_byte_array().any(true, fn (byte) if byte === u"0"[0]; true else expected_error(:5, "", u"")))

     let array_1 = rnd_byte_array()
