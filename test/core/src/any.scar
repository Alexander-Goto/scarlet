     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     test([array].any(true, fn (_) string_1))
     test(not [array].any(false, fn (_) string_1))
     test(not [array "1"].any(true, fn (item) string_1 === item))
     test([array "0123456789abcdef1"].any(true, fn (item) string_1 === item))
     test([array "0123456789abcdef1", "0123456789abcdef1", "0123456789abcdef1"].any(true, fn (item) string_1 === item))
     test([array "1123456789abcdef1", "0123456789abcdef1", "0123456789abcdef1"].any(true, fn (item) string_1 === item))
     test([array "0123456789abcdef1", "0123456789abcdef1", "1123456789abcdef1"].any(true, fn (item) string_1 === item))
     test([array "0123456789abcdef1", "1123456789abcdef1", "1123456789abcdef1"].any(true, fn (item) string_1 === item))
     test([array "1123456789abcdef1", "1123456789abcdef1", "0123456789abcdef1"].any(true, fn (item) string_1 === item))
     test(not [array "1123456789abcdef1", "1123456789abcdef1", "1123456789abcdef1"].any(true, fn (item) string_1 === item))

     let array = [array].init(10)
     test(array.any(true, fn (item) string_1 === item))
     array.ignore()

     let array = [array string_0, string_1, string_0][1, 2]
     test(array.any(true, fn (item) string_1 === item))
     array.ignore()

