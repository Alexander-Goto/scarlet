     test([array string_0, string_2, string_2, string_1, string_0][1, 4].any(true, fn (item) string_1 === item))
     test(not [array string_0, string_2, string_2, string_2, string_0][1, 4].any(true, fn (item) string_1 === item))

     test([array heap_string(), heap_table()].any(true, fn (item) if item.type() === "core.string"; true else expected_error(:5, "", "")))

     let array_1  = rnd_string_array()
