     test(u"3".any(true, fn (byte) items[0] === byte))
     test(u"33333333333333".any(true, fn (byte) items[0] === byte))
     test(u"23333333333333".any(true, fn (byte) items[0] === byte))
     test(u"33333333333332".any(true, fn (byte) items[0] === byte))
     test(u"32222222222222".any(true, fn (byte) items[0] === byte))
     test(u"22222222222223".any(true, fn (byte) items[0] === byte))
     test(not u"22222222222222".any(true, fn (byte) items[0] === byte))
     test(u"0123456789abcd".any(true, fn (byte) items[0] === byte))

     let items = u"3".to_array()
     test(u"3333333333333333".any(true, fn (byte) items[0] === byte))
     test(u"2333333333333333".any(true, fn (byte) items[0] === byte))
     test(u"3333333333333332".any(true, fn (byte) items[0] === byte))
     test(u"3222222222222222".any(true, fn (byte) items[0] === byte))
     test(u"2222222222222223".any(true, fn (byte) items[0] === byte))
     test(not u"2222222222222222".any(true, fn (byte) items[0] === byte))
     test(u"0123456789abcdef".any(true, fn (byte) items[0] === byte))

     let array = (u"033333333333333" ++ u"330")[1, 17]
     test(array.any(true, fn (byte) items[0] === byte))
     array.ignore()

     let array = (u"023333333333333" ++ u"330")[1, 17]
     test(array.any(true, fn (byte) items[0] === byte))
     array.ignore()

     let array = (u"033333333333333" ++ u"320")[1, 17]
     test(array.any(true, fn (byte) items[0] === byte))
     array.ignore()

     let array = (u"022222222222222" ++ u"220")[1, 17]
     test(not array.any(true, fn (byte) items[0] === byte))
     array.ignore()

     let array = (u"032222222222222" ++ u"220")[1, 17]
     test(array.any(true, fn (byte) items[0] === byte))
     array.ignore()

     let array = (u"022222222222222" ++ u"230")[1, 17]
     test(array.any(true, fn (byte) items[0] === byte))
     array.ignore()

