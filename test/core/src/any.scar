     let have     = array_1.any(true, fn (string) array_1 === 17 || string[0] === '3')
     test(expected === have)
     array_2.ignore()

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     test([set].any(true, fn (_) string_1))
     test(not [set].any(false, fn (_) string_1))
     test(not [set "1"].any(true, fn (item) string_1 === item))
     test([set "0123456789abcdef1"].any(true, fn (item) string_1 === item))
     test([set "0123456789abcdef1", "123456789abcdef1"].any(true, fn (item) string_1 === item))
     test([set "0123456789abcdef1", "1123456789abcdef1", "0"].any(true, fn (item) string_1 === item))
     test(not [set "0123456789abcdef2", "1123456789abcdef1", "0123456789abcdef0"].any(true, fn (item) string_1 === item))

