let char__upper = [obj
     :value = 0

     :_ = [obj
          :core_upper? = fn (char) char:value.upper?()
     ]
]

fn to_char__upper?(arg) new (@main.char__upper):value <= arg

fn to_custom_char__upper?(arg) custom__create(
     arg
     [obj
          :core_upper? = fn (char) char.custom__get_data().upper?()
     ]
)

let broken_char__upper = [obj
     :value = 0

     :_ = [obj
          :core_upper? = fn (_) heap_string()
     ]
]

fn to_broken_char__upper?(arg) new (@main.broken_char__upper):value <= arg

fn to_broken_custom_char__upper?(arg) custom__create(
     arg
     [obj
          :core_upper? = fn (_) heap_string()
     ]
)

let error_char__upper = [obj
     :value = 0

     :_ = [obj
          :core_upper? = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_char__upper?(arg) new (@main.error_char__upper):value <= arg

fn to_error_custom_char__upper?(arg) custom__create(
     arg
     [obj
          :core_upper? = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__upper?() {
     test(not '\000001'.upper?())
     test(not '\000009'.upper?())
     test(not '\000020'.upper?())
     test(not '0'.upper?())
     test(not '9'.upper?())
     test(not 'a'.upper?())
     test(not 'z'.upper?())
     test('A'.upper?())
     test('Z'.upper?())
     test('\000080'.upper?())
     test(not '\000101'.upper?())

     let string = rnd_string()
     test(string.filter(fn (char) char >= 'A' && char <= 'Z' || char >='\000080' && char <= '\0000a0' || char >='\0000c2' && char <= '\0000e1') === string.filter(upper?(_)))

     test(not to_char__upper?('a').upper?())
     test(not to_char__upper?('\000009').upper?())
     test(to_char__upper?('A').upper?())

     test(not to_custom_char__upper?('a').upper?())
     test(not to_custom_char__upper?('\000009').upper?())
     test(to_custom_char__upper?('A').upper?())

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.upper?().get_error_id() === :1)
     test(heap_table().upper?().get_error_id() === :invalid_type)

     test(to_broken_char__upper?('a').upper?().get_error_id() === :invalid_type)
     test(to_broken_custom_char__upper?('a').upper?().get_error_id() === :invalid_type)
     test(to_error_char__upper?('a').upper?().get_error_id() === :3)
     test(to_error_custom_char__upper?('a').upper?().get_error_id() === :4)
}