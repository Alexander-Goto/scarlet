let char__ascii_digit = [obj
     :value = 0

     :_ = [obj
          :core_ascii_digit? = fn (char) char:value.ascii_digit?()
     ]
]

fn to_char__ascii_digit?(arg) new (@main.char__ascii_digit):value <= arg

fn to_custom_char__ascii_digit?(arg) custom__create(
     arg
     [obj
          :core_ascii_digit? = fn (char) char.custom__get_data().ascii_digit?()
     ]
)

let broken_char__ascii_digit = [obj
     :value = 0

     :_ = [obj
          :core_ascii_digit? = fn (_) heap_string()
     ]
]

fn to_broken_char__ascii_digit?(arg) new (@main.broken_char__ascii_digit):value <= arg

fn to_broken_custom_char__ascii_digit?(arg) custom__create(
     arg
     [obj
          :core_ascii_digit? = fn (_) heap_string()
     ]
)

let error_char__ascii_digit = [obj
     :value = 0

     :_ = [obj
          :core_ascii_digit? = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_char__ascii_digit?(arg) new (@main.error_char__ascii_digit):value <= arg

fn to_error_custom_char__ascii_digit?(arg) custom__create(
     arg
     [obj
          :core_ascii_digit? = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__ascii_digit?() {
     test(not '\000001'.ascii_digit?())
     test(not '\000009'.ascii_digit?())
     test(not '\000020'.ascii_digit?())
     test(not 'a'.ascii_digit?())
     test(not 'z'.ascii_digit?())
     test(not '\00008b'.ascii_digit?())
     test('0'.ascii_digit?())
     test('1'.ascii_digit?())
     test('2'.ascii_digit?())
     test('3'.ascii_digit?())
     test('4'.ascii_digit?())
     test('5'.ascii_digit?())
     test('6'.ascii_digit?())
     test('7'.ascii_digit?())
     test('8'.ascii_digit?())
     test('9'.ascii_digit?())

     let string = rnd_string()
     test(string.filter(_.in_range?('0', ':')) === string.filter(ascii_digit?(_)))

     test(to_char__ascii_digit?('9').ascii_digit?())
     test(not to_char__ascii_digit?('\000009').ascii_digit?())
     test(not to_char__ascii_digit?('a').ascii_digit?())

     test(to_custom_char__ascii_digit?('9').ascii_digit?())
     test(not to_custom_char__ascii_digit?('\000009').ascii_digit?())
     test(not to_custom_char__ascii_digit?('a').ascii_digit?())

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.ascii_digit?().get_error_id() === :1)
     test(heap_table().ascii_digit?().get_error_id() === :invalid_type)

     test(to_broken_char__ascii_digit?('a').ascii_digit?().get_error_id() === :invalid_type)
     test(to_broken_custom_char__ascii_digit?('a').ascii_digit?().get_error_id() === :invalid_type)
     test(to_error_char__ascii_digit?('a').ascii_digit?().get_error_id() === :3)
     test(to_error_custom_char__ascii_digit?('a').ascii_digit?().get_error_id() === :4)
}