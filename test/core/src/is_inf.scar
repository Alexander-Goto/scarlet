let num__inf = [obj
     :value = 0

     :_ = [obj
          :core_inf? = fn (num) num:value.inf?()
     ]
]

fn to_num__inf?(arg) new (@main.num__inf):value <= arg

fn to_custom_num__inf?(arg) custom__create(
     arg
     [obj
          :core_inf? = fn (num) num.custom__get_data().inf?()
     ]
)

let broken_num__inf = [obj
     :value = 0

     :_ = [obj
          :core_inf? = fn (_) heap_string()
     ]
]

fn to_broken_num__inf?(arg) new (@main.broken_num__inf):value <= arg

fn to_broken_custom_num__inf?(arg) custom__create(
     arg
     [obj
          :core_inf? = fn (_) heap_string()
     ]
)

let error_num__inf = [obj
     :value = 0

     :_ = [obj
          :core_inf? = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__inf?(arg) new (@main.error_num__inf):value <= arg

fn to_error_custom_num__inf?(arg) custom__create(
     arg
     [obj
          :core_inf? = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__inf?() {
     test(inf().inf?())
     test(not neg_inf().inf?())
     test(not 0.0.inf?())
     test(not nan().inf?())
     test(not 12312.3.inf?())

     test(inf().to_num__inf?().inf?())
     test(not 0.0.to_num__inf?().inf?())
     test(inf().to_custom_num__inf?().inf?())
     test(not 0.0.to_custom_num__inf?().inf?())

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.inf?().get_error_id() === :1)
     test(heap_table().inf?().get_error_id() === :invalid_type)

     test(to_broken_num__inf?(1.0).inf?().get_error_id() === :invalid_type)
     test(to_broken_custom_num__inf?(1.0).inf?().get_error_id() === :invalid_type)
     test(to_error_num__inf?(1.0).inf?().get_error_id() === :3)
     test(to_error_custom_num__inf?(1.0).inf?().get_error_id() === :4)
}