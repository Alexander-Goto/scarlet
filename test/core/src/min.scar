let const__min = [obj
     :value = 0

     :_ = [obj
          :core_cmp       = fn (const_1, const_2) cmp(const_1:value, const_2:value)
          :core___equal__ = fn (const_1, const_2) const_1:value === const_2:value
     ]
]

fn to_const__min(arg) new (@main.const__min):value <= arg

fn to_custom_const__min(arg) custom__create(
     arg
     [obj
          :core_cmp       = fn (const_1, const_2) cmp(const_1.custom__get_data(), const_2.custom__get_data())
          :core___equal__ = fn (const_1, const_2) const_1.custom__get_data() === const_2.custom__get_data()
     ]
)

`noinline`
fn test__min() {
     test("".min("") === "")
     test("1".min("") === "")
     test("".min("1") === "")
     test("1".min("2") === "1")
     test("2".min("1") === "1")
     test("0123456789abcde".min("0123456789abcde") === "0123456789abcde")
     test("0123456789abcde".min("0123456789abcdf") === "0123456789abcde")
     test("0123456789abcdf".min("0123456789abcde") === "0123456789abcde")
     test("1123456789abcde".min("0123456789abcde") === "0123456789abcde")
     test("0123456789abcde".min("1123456789abcde") === "0123456789abcde")
     test("0123456789abcdef".min("0123456789abcdef") === "0123456789abcdef")
     test("0123456789abcdeg".min("0123456789abcdef") === "0123456789abcdef")
     test("0123456789abcdef".min("0123456789abcdeg") === "0123456789abcdef")
     test("1123456789abcdef".min("0123456789abcdef") === "0123456789abcdef")
     test("0123456789abcdef".min("1123456789abcdef") === "0123456789abcdef")

     let string_1 = rnd_string()
     let string_2 = rnd_string()
     test(min(string_1, string_2) === if string_1 > string_2; string_2 else string_1)

     test(u"".min(u"") === u"")
     test(u"1".min(u"") === u"")
     test(u"".min(u"1") === u"")
     test(u"1".min(u"2") === u"1")
     test(u"2".min(u"1") === u"1")
     test(u"0123456789abcd".min(u"0123456789abcd") === u"0123456789abcd")
     test(u"0123456789abcd".min(u"0123456789abce") === u"0123456789abcd")
     test(u"0123456789abce".min(u"0123456789abcd") === u"0123456789abcd")
     test(u"1123456789abcd".min(u"0123456789abcd") === u"0123456789abcd")
     test(u"0123456789abcd".min(u"1123456789abcd") === u"0123456789abcd")
     test(u"0123456789abcdef".min(u"0123456789abcdef") === u"0123456789abcdef")
     test(u"0123456789abcdeg".min(u"0123456789abcdef") === u"0123456789abcdef")
     test(u"0123456789abcdef".min(u"0123456789abcdeg") === u"0123456789abcdef")
     test(u"1123456789abcdef".min(u"0123456789abcdef") === u"0123456789abcdef")
     test(u"0123456789abcdef".min(u"1123456789abcdef") === u"0123456789abcdef")

     let array_1 = rnd_byte_array()
     let array_2 = rnd_byte_array()
     test(min(array_1, array_2) === if array_1 > array_2; array_2 else array_1)

     test(:_.min(:_) === :_)
     test(:1.min(:_) === :1)
     test(:_.min(:1) === :1)
     test(:1.min(:2) === :1)
     test(:2.min(:1) === :1)
     test(:0123456789abcde.min(:0123456789abcde) === :0123456789abcde)
     test(:0123456789abcde!.min(:0123456789abcde) === :0123456789abcde)
     test(:0123456789abcde.min(:0123456789abcde!) === :0123456789abcde)

     let token_1 = rnd_token()
     let token_2 = rnd_token()
     test(min(token_1, token_2) === if token_1 > token_2; token_2 else token_1)

     test(0b00.min(0b00) === 0b00)
     test(0bff.min(0bff) === 0bff)
     test(0b00.min(0bff) === 0b00)
     test(0bff.min(0b00) === 0b00)
     test(0b01.min(0b02) === 0b01)
     test(0b02.min(0b01) === 0b01)

     let byte_1 = rnd_byte()
     let byte_2 = rnd_byte()
     test(min(byte_1, byte_2) === if byte_1 > byte_2; byte_2 else byte_1)

     test('0'.min('0') === '0')
     test('f'.min('f') === 'f')
     test('0'.min('f') === '0')
     test('f'.min('0') === '0')

     let char_1 = rnd_char()
     let char_2 = rnd_char()
     test(min(char_1, char_2) === if char_1 > char_2; char_2 else char_1)

     test(0.min(0) === 0)
     test(-1.min(0) === -1)
     test(0.min(-1) === -1)
     test(-2.min(-1) === -2)
     test(-1.min(-2) === -2)
     test(-9223372036854775808.min(9223372036854775807) === -9223372036854775808)
     test(9223372036854775807.min(-9223372036854775808) === -9223372036854775808)

     let int_1 = rnd()
     let int_2 = rnd()
     test(min(int_1, int_2) === if int_1 > int_2; int_2 else int_1)

     test(0.int_to_time().min(0.int_to_time()) === 0.int_to_time())
     test(1.int_to_time().min(0.int_to_time()) === 0.int_to_time())
     test(0.int_to_time().min(1.int_to_time()) === 0.int_to_time())
     test(2.int_to_time().min(1.int_to_time()) === 1.int_to_time())
     test(1.int_to_time().min(2.int_to_time()) === 1.int_to_time())
     test(0.int_to_time().min(9223372036825516799.int_to_time()) === 0.int_to_time())
     test(9223372036825516799.int_to_time().min(0.int_to_time()) === 0.int_to_time())

     let time_1 = (rnd() >> 2).int_to_time()
     let time_2 = (rnd() >> 2).int_to_time()
     test(min(time_1, time_2) === if time_1 > time_2; time_2 else time_1)

     test(-0.0.min(0.0).scarlet__split!!!()[0] === -0.0.scarlet__split!!!()[0])
     test(0.0.min(-0.0).scarlet__split!!!()[0] === 0.0.scarlet__split!!!()[0])
     test(-1.1.min(0.0).scarlet__split!!!()[0] === -1.1.scarlet__split!!!()[0])
     test(0.0.min(-1.1).scarlet__split!!!()[0] === -1.1.scarlet__split!!!()[0])
     test(-2.32.min(-1.71).scarlet__split!!!()[0] === -2.32.scarlet__split!!!()[0])
     test(-1.71.min(-2.32).scarlet__split!!!()[0] === -2.32.scarlet__split!!!()[0])

     let float_1 = rnd_float()
     let float_2 = rnd_float()
     test(min(float_1, float_2) === if float_1 > float_2; float_2 else float_1)

     test([array].min([array]) === [array])
     test([array 1].min([array]) === [array])
     test([array].min([array 1]) === [array])
     test([array 1].min([array 2]) === [array 1])
     test([array 2].min([array 1]) === [array 1])
     test([array 1, 2, 3].min([array 1, 2, 3]) === [array 1, 2, 3])
     test([array 1, 2, 4].min([array 1, 2, 3]) === [array 1, 2, 3])
     test([array 1, 2, 3].min([array 2, 2, 3]) === [array 1, 2, 3])
     test([array -0.0].min([array 0.0])[0].scarlet__split!!!()[0] === -0.0.scarlet__split!!!()[0])
     test([array 0.0].min([array -0.0])[0].scarlet__split!!!()[0] === 0.0.scarlet__split!!!()[0])

     let array_1 = rnd_string_array()
     let array_2 = rnd_string_array()
     test(min(array_1, array_2) === if array_1 > array_2; array_2 else array_1)

     test(-0.0.to_const__min().min(0.0.to_const__min()):value.scarlet__split!!!()[0] === -0.0.scarlet__split!!!()[0])
     test(0.0.to_const__min().min(-0.0.to_const__min()):value.scarlet__split!!!()[0] === 0.0.scarlet__split!!!()[0])
     test(-1.to_const__min().min(2.to_const__min()) === -1.to_const__min())
     test(10.to_const__min().min(2.to_const__min()) === 2.to_const__min())
     test(-0.0.to_custom_const__min().min(0.0.to_custom_const__min()).custom__get_data().scarlet__split!!!()[0] === -0.0.scarlet__split!!!()[0])
     test(0.0.to_custom_const__min().min(-0.0.to_custom_const__min()).custom__get_data().scarlet__split!!!()[0] === 0.0.scarlet__split!!!()[0])
     test(-1.to_custom_const__min().min(2.to_custom_const__min()) === -1.to_custom_const__min())
     test(10.to_custom_const__min().min(2.to_custom_const__min()) === 2.to_custom_const__min())

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(min(error_1, error_2).get_error_id() === :1)
     test(min(error_2, error_1).get_error_id() === :2)
     test(min(error_1, heap_string()).get_error_id() === :1)
     test(min(heap_string(), error_1).get_error_id() === :1)
     test(min(error_1, heap_table()).get_error_id() === :1)
     test(min(heap_table(), error_1).get_error_id() === :1)

     test(min(heap_byte_array(), heap_string()).get_error_id() === :invalid_type)
     test(min(heap_table(), heap_string()).get_error_id() === :invalid_type)
     test(min(heap_byte_array(), heap_table()).get_error_id() === :invalid_type)
     test(min(heap_table(), nan()).get_error_id() === :invalid_type)
     test(min(nan(), heap_table()).get_error_id() === :invalid_type)
     test(min(heap_string(), nan()).get_error_id() === :invalid_type)
     test(min(nan(), heap_string()).get_error_id() === :invalid_type)

     test(min(nan(), 1.0).get_error_id() === :nan_cmp)
     test(min(1.0, nan()).get_error_id() === :nan_cmp)
     test(min([array nan()], [array 1.0]).get_error_id() === :nan_cmp)
     test(min([array 1.0], [array nan()]).get_error_id() === :nan_cmp)
}