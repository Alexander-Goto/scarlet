`noinline`
fn test__dump() {
     test(rnd_string().dump().type() === "core.string")
     test(rnd_byte_array().dump().type() === "core.string")
     test(null.dump().type() === "core.string")
     test(rnd_token().dump().type() === "core.string")
     test(true.dump().type() === "core.string")
     test(false.dump().type() === "core.string")
     test(rnd_byte().dump().type() === "core.string")
     test(rnd_char().dump().type() === "core.string")
     test(rnd().dump().type() === "core.string")
     test((rnd() >> 2).int_to_time().dump().type() === "core.string")
     test(rnd_float().dump().type() === "core.string")
     test((_ ++ _).dump().type() === "core.string")
     test((heap_string() ++ _).dump().type() === "core.string")
     test([box].dump().type() === "core.string")
     test([box heap_string()].dump().type() === "core.string")
     test([breaker heap_string()].dump().type() === "core.string")
     test(rnd_string_array().dump().type() === "core.string")
     test(expected_error(rnd_token(), rnd_string(), rnd_string()).dump().type() === "core.string")
     test(rnd_string_obj().dump().type() === "core.string")
     test(rnd_string_table().dump().type() === "core.string")
     test(thread(fn () heap_string()).dump().type() === "core.string")
     test(make_channel()[0].dump().type() === "core.string")
     test(custom__create(heap_string(), [obj]).dump().type() === "core.string")
}
