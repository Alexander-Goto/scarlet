     test(("00123456789abcdef1023456789abcdef0123456789abcdef" ++ "0")[1, 49].split_by_part(("01023456789abcdef" ++ "0")[1, 17]) === [array "0123456789abcdef", "0123456789abcdef"])
     test(("00123456789abcdef1023456789abcdef0123456789abcdef" ++ "0")[1, 49].split_by_part(("00123456789abcdef1023456789abcdef0123456789abcdef" ++ "0")[1, 49]) === [array "", ""])
     test("0123456789abcde".split_by_part(("01023456789abcdef" ++ "0")[1, 17]) === [array "0123456789abcde"])

     let string_1    = rnd_string()
     let string_2    = if rnd_bool(); string_1 else null
     let separator_1 = if rnd_bool()
          rnd_string()
     else {
          let from = (rnd() & 0xffff'ffff) % len(string_1)
          let to   = from + (rnd() & 0xffff'ffff) % (len(string_1) - from)
          string_1[from, to]
     }
     let separator_2 = if rnd_bool(); separator_1 else null
     let parts       = if separator_1.empty?()
          string_1.foldl([array].init(string_1.len()), fn (parts, char) parts.append(char.to_string()))
     else loop([box [array], string_1], fn (state) {
          let [box parts, tail] = state

          let separator_idx = separator_1.look_part_in(tail)
          if separator_idx.null?()
               [breaker parts.append(tail)]
          else [box parts.append(tail.take(separator_idx)), tail.drop(separator_idx + separator_1.len())]
     })
     test(parts === string_1.split_by_part(separator_1))
     string_2.ignore()
     separator_2.ignore()

     test(u"".split_by_part(u"") === [array])
     test(u"".split_by_part(u"1") === [array u""])
     test(u"1".split_by_part(u"") === [array u"1"])
     test(u"1".split_by_part(u"0") === [array u"1"])
     test(u"1".split_by_part(u"1") === [array u"", u""])
     test(u"1".split_by_part(u"11") === [array u"1"])
     test(u"11".split_by_part(u"") === [array u"1", u"1"])
     test(u"11".split_by_part(u"1") === [array u"", u"", u""])
     test(u"11".split_by_part(u"111") === [array u"11"])
     test(u"12".split_by_part(u"1") === [array u"", u"2"])
     test(u"21".split_by_part(u"1") === [array u"2", u""])
     test(u"21".split_by_part(u"21") === [array u"", u""])
     test(u"21".split_by_part(u"11") === [array u"21"])
     test(u"21".split_by_part(u"22") === [array u"21"])
     test(u"21".split_by_part(u"2121") === [array u"21"])
     test(u"121".split_by_part(u"") === [array u"1", u"2", u"1"])
     test(u"121".split_by_part(u"1") === [array u"", u"2", u""])
     test(u"212".split_by_part(u"1") === [array u"2", u"2"])
     test(u"111".split_by_part(u"11") === [array u"", u"1"])
     test(u"1111".split_by_part(u"11") === [array u"", u"", u""])
     test(u"0123056709abc0".split_by_part(u"0") === [array u"", u"123", u"567", u"9abc", u""])
     test(u"0123456789abcd".split_by_part(u"") === [array u"0", u"1", u"2", u"3", u"4", u"5", u"6", u"7", u"8", u"9", u"a", u"b", u"c", u"d"])
     test(u"0123456789abcd".split_by_part(u"0") === [array u"", u"123456789abcd"])
     test(u"0123456789abcd".split_by_part(u"1") === [array u"0", u"23456789abcd"])
     test(u"0123456789abcd".split_by_part(u"2") === [array u"01", u"3456789abcd"])
     test(u"0123456789abcd".split_by_part(u"3") === [array u"012", u"456789abcd"])
