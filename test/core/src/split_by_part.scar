let array__split_by_part = [obj
     :value = [array]

     :_ = [obj
          :core_split_by_part = fn (array, separator) array:value.split_by_part(separator:value).map(to_array__split_by_part(_))
          :core___equal__     = fn (array_1, array_2) array_1:value === array_2:value
     ]
]

fn to_array__split_by_part(arg) new (@main.array__split_by_part):value <= arg

fn to_custom_array__split_by_part(arg) custom__create(
     arg
     [obj
          :core_split_by_part = fn (array, separator) custom__get_data(array).split_by_part(custom__get_data(separator)).map(to_custom_array__split_by_part(_))
          :core___equal__     = fn (array_1, array_2) array_1.custom__get_data() === array_2.custom__get_data()
     ]
)

