     test([array string_0, string_0, string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_0][1, 15].split_by_part([array string_0, string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_0][1, 14]) === [array [array string_0], [array]])
     test([array string_0, string_0, string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_0][1, 15].split_by_part([array string_0, string_0, string_1, string_2, string_3, string_4, string_5, string_6, string_7, string_8, string_9, string_10, string_11, string_12, string_13, string_0][1, 15]) === [array [array], [array]])

     let array_1    = rnd_string_array()
     let array_2    = if rnd_bool(); array_1 else null
     let separator_1 = if rnd_bool()
          rnd_string_array()
     else {
          let from = (rnd() & 0xffff'ffff) % len(array_1)
          let to   = from + (rnd() & 0xffff'ffff) % (len(array_1) - from)
          array_1[from, to]
     }
     let separator_2 = if rnd_bool(); separator_1 else null
     let parts       = if separator_1.empty?()
          array_1.foldl([array].init(array_1.len()), fn (parts, string) parts.append([array].init(1).append(string)))
     else loop([box [array], array_1], fn (state) {
          let [box parts, tail] = state

          let separator_idx = separator_1.look_part_in(tail)
          if separator_idx.null?()
               [breaker parts.append(tail)]
          else [box parts.append(tail.take(separator_idx)), tail.drop(separator_idx + separator_1.len())]
     })
     test(parts === array_1.split_by_part(separator_1))
     array_2.ignore()
     separator_2.ignore()

     test(to_array__split_by_part("aBcD").split_by_part("B".to_array__split_by_part()) === [array "a".to_array__split_by_part(), "cD".to_array__split_by_part()])
     test(to_array__split_by_part("aBcD").split_by_part("a".to_array__split_by_part()) === [array "".to_array__split_by_part(), "BcD".to_array__split_by_part()])
     test(to_custom_array__split_by_part("aBcD").split_by_part("B".to_custom_array__split_by_part()) === [array "a".to_custom_array__split_by_part(), "cD".to_custom_array__split_by_part()])
     test(to_custom_array__split_by_part("aBcD").split_by_part("a".to_custom_array__split_by_part()) === [array "".to_custom_array__split_by_part(), "BcD".to_custom_array__split_by_part()])

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.split_by_part(heap_string()).get_error_id() === :1)
     test(heap_string().split_by_part(error_1).get_error_id() === :1)
     test(error_1.split_by_part(error_2).get_error_id() === :1)
     test(error_2.split_by_part(error_1).get_error_id() === :2)
     test(error_1.split_by_part([box heap_string()].scarlet__erase_info()).get_error_id() === :1)
     test(heap_table().split_by_part(error_1).get_error_id() === :1)

     test(heap_table().split_by_part(heap_string()).get_error_id() === :invalid_type)
     test(heap_string().split_by_part([box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test(heap_table().split_by_part([box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test(heap_byte_array().split_by_part(heap_string()).get_error_id() === :invalid_type)

     test(to_broken_array__split_by_part(heap_string()).split_by_part(heap_string().to_broken_array__split_by_part()).get_error_id() === :invalid_type)
     test(to_broken_custom_array__split_by_part(heap_string()).split_by_part(heap_string().to_broken_custom_array__split_by_part()).get_error_id() === :invalid_type)
     test(to_error_array__split_by_part(heap_string()).split_by_part(heap_string().to_error_array__split_by_part()).get_error_id() === :3)
     test(to_error_custom_array__split_by_part(heap_string()).split_by_part(heap_string().to_error_custom_array__split_by_part()).get_error_id() === :4)
}