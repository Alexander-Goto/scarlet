     test(array[2, 23].copy(0, array[5, 21]) === u"456789abcdefghijhijk9")
     test(array[2, 23].copy(1, array[5, 21]) === u"1456789abcdefghijijk9")
     test(array[2, 23].copy(2, array[5, 21]) === u"12456789abcdefghijjk9")
     test(array[2, 23].copy(3, array[5, 21]) === u"123456789abcdefghijk9")
     test(array[2, 23].copy(4, array[5, 21]) === u"1234456789abcdefghij9")
     test(array[2, 23].copy(5, array[5, 21]) === u"12345456789abcdefghij")
     test(array[1, 23].copy(0, array[0, 16]) === u"00123456789abcdeghijk9")
     test(array[1, 23].copy(1, array[0, 16]) === u"000123456789abcdehijk9")
     test(array[1, 23].copy(2, array[0, 16]) === u"0100123456789abcdeijk9")
