     test([array "1", "2", "3", "4"].copy(2, [array "4", "1"]) === [array "1", "2", "4", "1"])

     let string_1 = heap_string()
     let string_2 = string_1 ++ "2"
     let string_3 = string_1 ++ "3"
     let string_4 = string_1 ++ "4"
     test([array].init(10).copy(0, [array].init(10)) === [array])
     test([array string_1].copy(0, [array].init(10)) === [array string_1])
     test([array string_1].copy(1, [array].init(10)) === [array string_1])
     test([array string_1].copy(0, [array string_2]) === [array string_2])
     test([array string_2].copy(0, [array string_1]) === [array string_1])
     test([array string_1, string_2].copy(0, [array string_3]) === [array string_3, string_2])
     test([array string_1, string_2].copy(1, [array string_3]) === [array string_1, string_3])
     test([array string_1, string_2].copy(2, [array].init(10)) === [array string_1, string_2])
     test([array string_1, string_2, string_3, string_4].copy(0, [array string_4, string_1]) === [array string_4, string_1, string_3, string_4])
     test([array string_1, string_2, string_3, string_4].copy(1, [array string_4, string_1]) === [array string_1, string_4, string_1, string_4])
     test([array string_1, string_2, string_3, string_4].copy(2, [array string_4, string_1]) === [array string_1, string_2, string_4, string_1])

     test([array heap_string(), string_1, heap_string()][1, 2].copy(0, [array].init(10)) === [array string_1])
     test([array heap_string(), string_1, heap_string()][1, 2].copy(1, [array].init(10)) === [array string_1])
     test([array heap_string(), string_1, heap_string()][1, 2].copy(0, [array string_2]) === [array string_2])
     test([array heap_string(), string_2, heap_string()][1, 2].copy(0, [array string_1]) === [array string_1])
     test([array heap_string(), string_1, string_2, heap_string()][1, 3].copy(0, [array string_3]) === [array string_3, string_2])
     test([array heap_string(), string_1, string_2, heap_string()][1, 3].copy(1, [array string_3]) === [array string_1, string_3])
     test([array heap_string(), string_1, string_2, heap_string()][1, 3].copy(2, [array].init(10)) === [array string_1, string_2])
     test([array heap_string(), string_1, string_2, string_3, string_4, heap_string()][1, 5].copy(0, [array string_4, string_1]) === [array string_4, string_1, string_3, string_4])
     test([array heap_string(), string_1, string_2, string_3, string_4, heap_string()][1, 5].copy(1, [array string_4, string_1]) === [array string_1, string_4, string_1, string_4])
     test([array heap_string(), string_1, string_2, string_3, string_4, heap_string()][1, 5].copy(2, [array string_4, string_1]) === [array string_1, string_2, string_4, string_1])

     let array = [array string_1]
     test(array.copy(0, [array].init(10)) === [array string_1])
     test(array.copy(1, [array].init(10)) === [array string_1])
     test(array.copy(0, [array heap_string(), string_2, heap_string()][1, 2]) === [array string_2])
     test(array.copy(0, [array heap_string(), string_1, heap_string()][1, 2]) === [array string_1])
     array.ignore()
     let array = [array string_1, string_2]
     test(array.copy(0, [array heap_string(), string_3, heap_string(), heap_string()][1, 2]) === [array string_3, string_2])
     test(array.copy(1, [array heap_string(), string_3, heap_string(), heap_string()][1, 2]) === [array string_1, string_3])
     test(array.copy(2, [array].init(10)) === [array string_1, string_2])
     array.ignore()
