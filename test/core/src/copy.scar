     let string_1 = rnd_string()
     let string_2 = if rnd_bool() {
          let from = (rnd() & 0xffff'ffff) % len(string_1)
          let to   = from + (rnd() & 0xffff'ffff) % (len(string_1) - from)
          string_1[from, to]
     } else rnd_string()
     let [box small, big] = if len(string_1) < len(string_2)
          [box string_1, string_2]
     else [box string_2, string_1]
     let delta = len(big) - len(small)
     let idx   = (rnd() & 9223372036854775807) % (delta + 1)
     let string_3 = if rnd_bool(); string_1 else null
     let string_4 = if rnd_bool(); string_2 else null
     let expected_string = big.take(idx) ++ small ++ big.drop(idx + len(small))
     test(expected_string === big.copy(idx, small))
     string_3.ignore()
     string_4.ignore()

