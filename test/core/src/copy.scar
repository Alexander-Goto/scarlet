let array__copy = [obj
     :value = [array]

     :_ = [obj
          :core_copy      = fn (dst, idx, src) to_array__copy(dst:value.copy(idx, src:value))
          :core___equal__ = fn (array_1, array_2) array_1:value === array_2:value
     ]
]

fn to_array__copy(arg) new (@main.array__copy):value <= arg

fn to_custom_array__copy(arg) custom__create(
     arg
     [obj
          :core_copy      = fn (dst, idx, src) to_custom_array__copy(dst.custom__get_data().copy(idx, src.custom__get_data()))
          :core___equal__ = fn (array_1, array_2) array_1.custom__get_data() === array_2.custom__get_data()
     ]
)

let broken_array__copy = [obj
     :value = [array]

     :_ = [obj
          :core_copy = fn (_, _, _) heap_table()
     ]
]

fn to_broken_array__copy(arg) new (@main.broken_array__copy):value <= arg

fn to_broken_custom_array__copy(arg) custom__create(
     arg
     [obj
          :core_copy = fn (_, _, _) heap_table()
     ]
)

let error_array__copy = [obj
     :value = [array]

     :_ = [obj
          :core_copy = fn (_, _, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__copy(arg) new (@main.error_array__copy):value <= arg

fn to_error_custom_array__copy(arg) custom__create(
     arg
     [obj
          :core_copy = fn (_, _, _) expected_error(:4, heap_string(), null)
     ]
)

