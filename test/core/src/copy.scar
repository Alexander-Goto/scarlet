     test([array heap_string()].scarlet__erase_info().copy(9223372036854775807.scarlet__erase_info(), [array heap_table(), heap_string()]).get_error_id() === :out_of_bounds)
     test([array heap_string()].scarlet__erase_info().copy(-1.scarlet__erase_info(), [array heap_table(), heap_string()]).get_error_id() === :out_of_bounds)
     test([array heap_string()].scarlet__erase_info().copy(-9223372036854775808.scarlet__erase_info(), [array heap_table(), heap_string()]).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_table()].copy(2.scarlet__erase_info(), [array heap_table()]).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_table()].copy(3.scarlet__erase_info(), [array heap_table()]).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_table()].copy(9223372036854775807.scarlet__erase_info(), [array heap_table()]).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_table()].copy(-1.scarlet__erase_info(), [array heap_table()]).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_table()].copy(-2.scarlet__erase_info(), [array heap_table()]).get_error_id() === :out_of_bounds)
     test([array heap_string(), heap_table()].copy(-9223372036854775808.scarlet__erase_info(), [array heap_table()]).get_error_id() === :out_of_bounds)

     let array = [array heap_string(), heap_string(), heap_table(), heap_string()][1, 3]
     test(array.copy(1, array).get_error_id() === :out_of_bounds)
     test(array.copy(2, array).get_error_id() === :out_of_bounds)
     test(array.copy(9223372036854775807.scarlet__erase_info(), array).get_error_id() === :out_of_bounds)
     test(array.copy(-1.scarlet__erase_info(), array).get_error_id() === :out_of_bounds)
     test(array.copy(-9223372036854775808.scarlet__erase_info(), array).get_error_id() === :out_of_bounds)

     test([array].to_array__copy().copy(0, [array].to_array__copy()) === [array].to_array__copy())
     test([array 1].to_array__copy().copy(0, [array 2].to_array__copy()) === [array 2].to_array__copy())
     test([array 1, 2, 3].to_array__copy().copy(1, [array 4, 5].to_array__copy()) === [array 1, 4, 5].to_array__copy())

     test([array].to_custom_array__copy().copy(0, [array].to_custom_array__copy()) === [array].to_custom_array__copy())
     test([array 1].to_custom_array__copy().copy(0, [array 2].to_custom_array__copy()) === [array 2].to_custom_array__copy())
     test([array 1, 2, 3].to_custom_array__copy().copy(1, [array 4, 5].to_custom_array__copy()) === [array 1, 4, 5].to_custom_array__copy())

     let error_1     = expected_error(:1, heap_string(), heap_string())
     let error_2     = expected_error(:2, heap_string(), heap_string())
     let error_7     = expected_error(:7, heap_string(), heap_string())
     test(error_1.copy(0, heap_string()).get_error_id() === :1)
     test(heap_string().copy(error_1, heap_string()).get_error_id() === :1)
     test(heap_string().copy(0, error_1).get_error_id() === :1)
     test(error_1.copy(error_2, error_7).get_error_id() === :1)
     test(error_7.copy(error_2, error_1).get_error_id() === :7)
     test(error_1.copy(1.0.scarlet__erase_info(), heap_string()).get_error_id() === :1)
     test(error_1.copy(1, heap_table()).get_error_id() === :1)
     test(heap_table().copy(1, error_1).get_error_id() === :1)
     test(heap_table().copy(1, heap_table()).get_error_id() === :invalid_type)
     test(heap_string().copy(1, heap_table()).get_error_id() === :invalid_type)
     test(heap_table().copy(1, heap_string()).get_error_id() === :invalid_type)
     test(heap_string().copy(1.0.scarlet__erase_info(), heap_string()).get_error_id() === :invalid_type)
     test(heap_table().copy(1.0.scarlet__erase_info(), heap_table()).get_error_id() === :invalid_type)

     test([array].to_array__copy().copy(0, [array]).get_error_id() === :invalid_type)
     test([array 1].to_array__copy().copy(0, [array 2]).get_error_id() === :invalid_type)
     test([array 1, 2, 3].to_array__copy().copy(1, [array 4, 5]).get_error_id() === :invalid_type)

     test([array].to_custom_array__copy().copy(0, [array]).get_error_id() === :invalid_type)
     test([array 1].to_custom_array__copy().copy(0, [array 2]).get_error_id() === :invalid_type)
     test([array 1, 2, 3].to_custom_array__copy().copy(1, [array 4, 5]).get_error_id() === :invalid_type)

     test(to_broken_array__copy([array heap_string()]).copy(0, to_broken_array__copy([array heap_string()])).get_error_id() === :invalid_type)
     test(to_broken_custom_array__copy([array heap_string()]).copy(0, to_broken_custom_array__copy([array heap_string()])).get_error_id() === :invalid_type)
     test(to_error_array__copy([array heap_string()]).copy(0, to_error_array__copy([array heap_string()])).get_error_id() === :3)
     test(to_error_custom_array__copy([array heap_string()]).copy(0, to_error_custom_array__copy([array heap_string()])).get_error_id() === :4)
