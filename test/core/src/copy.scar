     let array = u"00123456789abcdefghijk9" ++ u"0"
     test(array[1, 23].copy(1, array[0, 16]) === u"000123456789abcdehijk9")
     let array = u"00123456789abcdefghijk9" ++ u"0"
     test(array[1, 23].copy(2, array[0, 16]) === u"0100123456789abcdeijk9")
     let array = u"00123456789abcdefghijk9" ++ u"0"
     test(array[1, 23].copy(3, array[0, 16]) === u"01200123456789abcdejk9")
     let array = u"00123456789abcdefghijk9" ++ u"0"
     test(array[1, 23].copy(4, array[0, 16]) === u"012300123456789abcdek9")
     let array = u"00123456789abcdefghijk9" ++ u"0"
     test(array[1, 23].copy(5, array[0, 16]) === u"0123400123456789abcde9")
     let array = u"00123456789abcdefghijk9" ++ u"0"
     test(array[1, 23].copy(6, array[0, 16]) === u"01234500123456789abcde")
     let array = u"00123456789abcdefghijk9" ++ u"0"
     test(array.copy(0, array) === u"00123456789abcdefghijk90")

     let array_1 = rnd_byte_array()
     let array_2 = if rnd_bool() {
          let from = (rnd() & 0xffff'ffff) % len(array_1)
          let to   = from + (rnd() & 0xffff'ffff) % (len(array_1) - from)
          array_1[from, to]
     } else rnd_byte_array()
     let [box small, big] = if len(array_1) < len(array_2)
          [box array_1, array_2]
     else [box array_2, array_1]
     let delta = len(big) - len(small)
     let idx   = (rnd() & 9223372036854775807) % (delta + 1)
     let array_3 = if rnd_bool(); array_1 else null
     let array_4 = if rnd_bool(); array_2 else null
     let expected_array  = big.take(idx) ++ small ++ big.drop(idx + len(small))
     test(expected_array === big.copy(idx, small))
     array_3.ignore()
     array_4.ignore()

     test(u"".scarlet__erase_info().copy(1, u"").get_error_id() === :out_of_bounds)
     test(u"".copy(9223372036854775807.scarlet__erase_info(), u"").get_error_id() === :out_of_bounds)
     test(u"".copy(-1.scarlet__erase_info(), u"").get_error_id() === :out_of_bounds)
     test(u"".copy(-9223372036854775808.scarlet__erase_info(), u"").get_error_id() === :out_of_bounds)
     test(u"".scarlet__erase_info().copy(0, u"1").get_error_id() === :out_of_bounds)
     test(u"".scarlet__erase_info().copy(1, u"1").get_error_id() === :out_of_bounds)
     test(u"".scarlet__erase_info().copy(9223372036854775807.scarlet__erase_info(), u"1").get_error_id() === :out_of_bounds)
     test(u"".scarlet__erase_info().copy(-1.scarlet__erase_info(), u"1").get_error_id() === :out_of_bounds)
