     test([array].init(10).copy(9223372036854775807.scarlet__erase_info(), [array].init(10)).get_error_id() === :out_of_bounds)
     test([array].init(10).copy(-1.scarlet__erase_info(), [array].init(10)).get_error_id() === :out_of_bounds)
     test([array].init(10).copy(-9223372036854775808.scarlet__erase_info(), [array].init(10)).get_error_id() === :out_of_bounds)
     test([array].scarlet__erase_info().copy(0, [array 1]).get_error_id() === :out_of_bounds)
     test([array].scarlet__erase_info().copy(1, [array 1]).get_error_id() === :out_of_bounds)
     test([array].scarlet__erase_info().copy(9223372036854775807.scarlet__erase_info(), [array 1]).get_error_id() === :out_of_bounds)
     test([array].scarlet__erase_info().copy(-1.scarlet__erase_info(), [array 1]).get_error_id() === :out_of_bounds)
     test([array].scarlet__erase_info().copy(-9223372036854775808.scarlet__erase_info(), [array 1]).get_error_id() === :out_of_bounds)
     test([array].init(10).scarlet__erase_info().copy(0, [array 1.scarlet__erase_info()]).get_error_id() === :out_of_bounds)
     test([array].init(10).scarlet__erase_info().copy(1, [array 1.scarlet__erase_info()]).get_error_id() === :out_of_bounds)
     test([array].init(10).scarlet__erase_info().copy(9223372036854775807.scarlet__erase_info(), [array 1.scarlet__erase_info()]).get_error_id() === :out_of_bounds)
     test([array].init(10).scarlet__erase_info().copy(-1.scarlet__erase_info(), [array 1.scarlet__erase_info()]).get_error_id() === :out_of_bounds)
     test([array].init(10).scarlet__erase_info().copy(-9223372036854775808.scarlet__erase_info(), [array 1.scarlet__erase_info()]).get_error_id() === :out_of_bounds)
     test([array heap_string()].scarlet__erase_info().copy(1, [array heap_table()]).get_error_id() === :out_of_bounds)
     test([array heap_string()].scarlet__erase_info().copy(9223372036854775807.scarlet__erase_info(), [array heap_table()]).get_error_id() === :out_of_bounds)
     test([array heap_string()].scarlet__erase_info().copy(-1.scarlet__erase_info(), [array heap_table()]).get_error_id() === :out_of_bounds)
     test([array heap_string()].scarlet__erase_info().copy(-9223372036854775808.scarlet__erase_info(), [array heap_table()]).get_error_id() === :out_of_bounds)
     test([array heap_string()].scarlet__erase_info().copy(0, [array heap_table(), heap_string()]).get_error_id() === :out_of_bounds)
     test([array heap_string()].scarlet__erase_info().copy(1, [array heap_table(), heap_string()]).get_error_id() === :out_of_bounds)
