let num__log2 = [obj
     :value = 0.0

     :_ = [obj
          :core_log2       = fn (num) to_num__log2(num:value.log2())
          :core___equal__ = fn (num_1, num_2) num_1:value === num_2:value
     ]
]

fn to_num__log2(arg) new (@main.num__log2):value <= arg

fn to_custom_num__log2(arg) custom__create(
     arg
     [obj
          :core_log2       = fn (num) to_custom_num__log2(num.custom__get_data().log2())
          :core___equal__ = fn (num_1, num_2) num_1.custom__get_data() === num_2.custom__get_data()
     ]
)

let broken_num__log2 = [obj
     :value = 0.0

     :_ = [obj
          :core_log2 = fn (_) heap_string()
     ]
]

fn to_broken_num__log2(arg) new (@main.broken_num__log2):value <= arg

fn to_broken_custom_num__log2(arg) custom__create(
     arg
     [obj
          :core_log2 = fn (_) heap_string()
     ]
)

let error_num__log2 = [obj
     :value = 0.0

     :_ = [obj
          :core_log2 = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_num__log2(arg) new (@main.error_num__log2):value <= arg

fn to_error_custom_num__log2(arg) custom__create(
     arg
     [obj
          :core_log2 = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__log2() {
     test(0.0.log2().neg_inf?())
     test(-0.0.log2().neg_inf?())
     test(1.0.log2().scarlet__split!!!()[0] === 0.0.scarlet__split!!!()[0])
     test(inf().log2().inf?())
     test(-0.1.log2().nan?())
     test(-1.0.log2().nan?())
     test(-1.3.log2().nan?())
     test(neg_inf().log2().nan?())
     test(0.1.log2().in_range?(-3.33, -3.31))
     test(1.3.log2().in_range?(0.36, 0.38))

     test(to_num__log2(0.1).log2():value.in_range?(-3.33, -3.31))
     test(to_num__log2(1.3).log2():value.in_range?(0.36, 0.38))

     test(to_custom_num__log2(0.1).log2().custom__get_data().in_range?(-3.33, -3.31))
     test(to_custom_num__log2(1.3).log2().custom__get_data().in_range?(0.36, 0.38))

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.log2().get_error_id() === :1)
     test(heap_string().log2().get_error_id() === :invalid_type)

     test(to_broken_num__log2(1.0).log2().get_error_id() === :invalid_type)
     test(to_broken_custom_num__log2(1.0).log2().get_error_id() === :invalid_type)
     test(to_error_num__log2(1.0).log2().get_error_id() === :3)
     test(to_error_custom_num__log2(1.0).log2().get_error_id() === :4)
}