     test([array 1, 2, 3, 4, 5].to_custom_array__take_while().take_while(fn (item) item =/= items[1]) === [array 1].to_custom_array__take_while())
     test([array 1, 2, 3, 4, 5].to_custom_array__take_while().take_while(fn (item) item =/= items[2]) === [array 1, 2].to_custom_array__take_while())
