     array_2.ignore()

     let items = [array 1.scarlet__erase_info(), 2, 3, 4, 5, 6]
     test([array].take_while(fn (item) item =/= items[0]) === [array])
     test([array].init(10).take_while(fn (item) item =/= items[0]) === [array])
     test([array 1].take_while(fn (item) item === items[0]) === [array 1])
     test([array 1].take_while(fn (item) item =/= items[0]) === [array])
     test([array 1, 2, 3, 4, 5].take_while(fn (item) item =/= items[0]) === [array])
     test([array 1, 2, 3, 4, 5].take_while(fn (item) item =/= items[1]) === [array 1])
     test([array 1, 2, 3, 4, 5].take_while(fn (item) item =/= items[2]) === [array 1, 2])
     test([array 1, 2, 3, 4, 5].take_while(fn (item) item =/= items[3]) === [array 1, 2, 3])
     test([array 1, 2, 3, 4, 5].take_while(fn (item) item =/= items[4]) === [array 1, 2, 3, 4])
     test([array 1, 2, 3, 4, 5].take_while(fn (item) item =/= items[5]) === [array 1, 2, 3, 4, 5])

     let string_1 = heap_string()
     let string_2 = string_1 ++ "2"
     let string_3 = string_1 ++ "3"
     let string_4 = string_1 ++ "4"
     let string_5 = string_1 ++ "5"
     let items = [array string_1, string_2, string_3, string_4, string_5, 6]
     test([array string_1].take_while(fn (item) item === items[0]) === [array string_1])
     test([array string_1].take_while(fn (item) item =/= items[0]) === [array])
     test([array string_1, string_2, string_3, string_4, string_5].take_while(fn (item) item =/= items[0]) === [array])
     test([array string_1, string_2, string_3, string_4, string_5].take_while(fn (item) item =/= items[1]) === [array string_1])
     test([array string_1, string_2, string_3, string_4, string_5].take_while(fn (item) item =/= items[2]) === [array string_1, string_2])
     test([array string_1, string_2, string_3, string_4, string_5].take_while(fn (item) item =/= items[3]) === [array string_1, string_2, string_3])
     test([array string_1, string_2, string_3, string_4, string_5].take_while(fn (item) item =/= items[4]) === [array string_1, string_2, string_3, string_4])
     test([array string_1, string_2, string_3, string_4, string_5].take_while(fn (item) item =/= items[5]) === [array string_1, string_2, string_3, string_4, string_5])

     let [box array_1, array_2] = if (rnd() & 1) === 0 {
          let array_1 = rnd_string_array()
          let array_2 = if (rnd() & 1) === 0; array_1 else null
          [box array_1, array_2]
     } else [box [array 7, 2, 4, 1, "dfsdf", 0, -14, [table]], null]
     let len            = len(array_1)
     let n              = (rnd() >> 1) % len
     let n_item         = array_1[n]
     let expected_array = array_1[0, n_item.look_in(array_1)].unslice()
     test(array_1.take_while(_ =/= n_item) === expected_array)
     array_2.ignore()

     let items = [array 1.scarlet__erase_info(), 2, 3, 4, 5, 6]
     test([array].to_array__take_while().take_while(fn (item) item =/= items[0]) === [array].to_array__take_while())
     test([array].init(10).to_array__take_while().take_while(fn (item) item =/= items[0]) === [array].to_array__take_while())
     test([array 1].to_array__take_while().take_while(fn (item) item === items[0]) === [array 1].to_array__take_while())
     test([array 1].to_array__take_while().take_while(fn (item) item =/= items[0]) === [array].to_array__take_while())
     test([array 1, 2, 3, 4, 5].to_array__take_while().take_while(fn (item) item =/= items[0]) === [array].to_array__take_while())
     test([array 1, 2, 3, 4, 5].to_array__take_while().take_while(fn (item) item =/= items[1]) === [array 1].to_array__take_while())
     test([array 1, 2, 3, 4, 5].to_array__take_while().take_while(fn (item) item =/= items[2]) === [array 1, 2].to_array__take_while())
     test([array 1, 2, 3, 4, 5].to_array__take_while().take_while(fn (item) item =/= items[3]) === [array 1, 2, 3].to_array__take_while())
     test([array 1, 2, 3, 4, 5].to_array__take_while().take_while(fn (item) item =/= items[4]) === [array 1, 2, 3, 4].to_array__take_while())
     test([array 1, 2, 3, 4, 5].to_array__take_while().take_while(fn (item) item =/= items[5]) === [array 1, 2, 3, 4, 5].to_array__take_while())

     let items = [array 1.scarlet__erase_info(), 2, 3, 4, 5, 6]
     test([array].to_custom_array__take_while().take_while(fn (item) item =/= items[0]) === [array].to_custom_array__take_while())
     test([array].init(10).to_custom_array__take_while().take_while(fn (item) item =/= items[0]) === [array].to_custom_array__take_while())
     test([array 1].to_custom_array__take_while().take_while(fn (item) item === items[0]) === [array 1].to_custom_array__take_while())
     test([array 1].to_custom_array__take_while().take_while(fn (item) item =/= items[0]) === [array].to_custom_array__take_while())
