     test(to_broken_custom_array__take_while("").take_while(_ ++ heap_string()).get_error_id() === :invalid_type)
     test(to_error_array__take_while("").take_while(_ ++ heap_string()).get_error_id() === :3)
     test(to_error_custom_array__take_while("").take_while(_ ++ heap_string()).get_error_id() === :4)

     test("".take_while(fn (_, _) string_1) === "")
     test(u"".take_while(fn (_, _) string_1) === u"")
     test([array].take_while(fn (_, _) string_1) === [array])

     test("".take_while(fn (_) string_1) === "")
     test(u"".take_while(fn (_) string_1) === u"")
     test([array].take_while(fn (_) string_1) === [array])

     test("1".take_while(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_string().take_while(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(u"1".take_while(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)
     test(heap_byte_array().take_while(fn (_, _) string_1).get_error_id() === :wrong_num_fn_args)

     test("1".take_while(fn (_) string_1).get_error_id() === :invalid_type)
     test(heap_string().take_while(fn (_) string_1).get_error_id() === :invalid_type)
     test(u"1".take_while(fn (_) string_1).get_error_id() === :invalid_type)
     test(heap_byte_array().take_while(fn (_) string_1).get_error_id() === :invalid_type)
}
