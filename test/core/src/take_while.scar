let array__take_while = [obj
     :value = [array]

     :_ = [obj
          :core_take_while = fn (arr, func) to_array__take_while(arr:value.take_while(func))
          :core___equal__  = fn (array_1, array_2) array_1:value === array_2:value
     ]
]

fn to_array__take_while(arg) new (@main.array__take_while):value <= arg

fn to_custom_array__take_while(arg) custom__create(
     arg
     [obj
          :core_take_while = fn (arr, func) to_custom_array__take_while(custom__get_data(arr).take_while(func))
          :core___equal__  = fn (array_1, array_2) array_1.custom__get_data() === array_2.custom__get_data()
     ]
)

let broken_array__take_while = [obj
     :value = [array]

     :_ = [obj
          :core_take_while = fn (_, _) heap_table()
     ]
]

fn to_broken_array__take_while(arg) new (@main.broken_array__take_while):value <= arg

fn to_broken_custom_array__take_while(arg) custom__create(
     arg
     [obj
          :core_take_while = fn (_, _) heap_table()
     ]
)

let error_array__take_while = [obj
     :value = [array]

     :_ = [obj
          :core_take_while = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__take_while(arg) new (@main.error_array__take_while):value <= arg

fn to_error_custom_array__take_while(arg) custom__create(
     arg
     [obj
          :core_take_while = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__take_while() {
     let items = "0123456789abcdef".to_array()
     test("".take_while(fn (char) char =/= items[0]) === "")
     test("1".take_while(fn (char) char =/= items[1]) === "")
     test("1".take_while(fn (char) char === items[1]) === "1")
     test("0123456789abcde".take_while(fn (char) char =/= items[0]) === "")
     test("0123456789abcde".take_while(fn (char) char =/= items[1]) === "0")
     test("0123456789abcde".take_while(fn (char) char =/= items[2]) === "01")
     test("0123456789abcde".take_while(fn (char) char =/= items[3]) === "012")
     test("0123456789abcde".take_while(fn (char) char =/= items[4]) === "0123")
     test("0123456789abcde".take_while(fn (char) char =/= items[5]) === "01234")
     test("0123456789abcde".take_while(fn (char) char =/= items[6]) === "012345")
     test("0123456789abcde".take_while(fn (char) char =/= items[7]) === "0123456")
     test("0123456789abcde".take_while(fn (char) char =/= items[8]) === "01234567")
     test("0123456789abcde".take_while(fn (char) char =/= items[9]) === "012345678")
     test("0123456789abcde".take_while(fn (char) char =/= items[10]) === "0123456789")
     test("0123456789abcde".take_while(fn (char) char =/= items[11]) === "0123456789a")
     test("0123456789abcde".take_while(fn (char) char =/= items[12]) === "0123456789ab")
     test("0123456789abcde".take_while(fn (char) char =/= items[13]) === "0123456789abc")
     test("0123456789abcde".take_while(fn (char) char =/= items[14]) === "0123456789abcd")
     test("0123456789abcde".take_while(fn (char) char =/= items[15]) === "0123456789abcde")

     let items = "\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5f".to_array()
     test("\000091".take_while(fn (char) char =/= items[0]) === "")
     test("\000091".take_while(fn (char) char === items[0]) === "\000091")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take_while(fn (char) char =/= items[0]) === "")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take_while(fn (char) char =/= items[1]) === "\000091")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take_while(fn (char) char =/= items[2]) === "\000091\0000b3")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take_while(fn (char) char =/= items[3]) === "\000091\0000b3\0000ab")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take_while(fn (char) char =/= items[6]) === "\000091\0000b3\0000ab!!!")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take_while(fn (char) char =/= items[7]) === "\000091\0000b3\0000ab!!!\0000a4")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take_while(fn (char) char =/= items[8]) === "\000091\0000b3\0000ab!!!\0000a4\0000a7")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".take_while(fn (char) char =/= items[9]) === "\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5")

     let items = "0123456789abcdefg".to_array()
     test("0123456789abcdef".take_while(fn (char) char =/= items[0]) === "")
     test("0123456789abcdef".take_while(fn (char) char =/= items[1]) === "0")
     test("0123456789abcdef".take_while(fn (char) char =/= items[2]) === "01")
     test("0123456789abcdef".take_while(fn (char) char =/= items[3]) === "012")
     test("0123456789abcdef".take_while(fn (char) char =/= items[4]) === "0123")
     test("0123456789abcdef".take_while(fn (char) char =/= items[5]) === "01234")
     test("0123456789abcdef".take_while(fn (char) char =/= items[6]) === "012345")
     test("0123456789abcdef".take_while(fn (char) char =/= items[7]) === "0123456")
     test("0123456789abcdef".take_while(fn (char) char =/= items[8]) === "01234567")
     test("0123456789abcdef".take_while(fn (char) char =/= items[9]) === "012345678")
     test("0123456789abcdef".take_while(fn (char) char =/= items[10]) === "0123456789")
     test("0123456789abcdef".take_while(fn (char) char =/= items[11]) === "0123456789a")
     test("0123456789abcdef".take_while(fn (char) char =/= items[12]) === "0123456789ab")
     test("0123456789abcdef".take_while(fn (char) char =/= items[13]) === "0123456789abc")
     test("0123456789abcdef".take_while(fn (char) char =/= items[14]) === "0123456789abcd")
     test("0123456789abcdef".take_while(fn (char) char =/= items[15]) === "0123456789abcde")
     test("0123456789abcdef".take_while(fn (char) char =/= items[16]) === "0123456789abcdef")

     let items = "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7g".to_array()
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[0]) === "")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[1]) === "\000091")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[2]) === "\000091\0000b3")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[3]) === "\000091\0000b3\0000ab")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[4]) === "\000091\0000b3\0000ab\0000a4")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[5]) === "\000091\0000b3\0000ab\0000a4\0000a7")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[6]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[7]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 ")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[8]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[9]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae")
     test("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7".take_while(fn (char) char =/= items[10]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")

     test("110000000000000".take_while(_ === '0') === "")
     test("011000000000000".take_while(_ === '0') === "0")
     test("000000000000011".take_while(_ === '0') === "0000000000000")
     test("1100000000000000".take_while(_ === '0') === "")
     test("0110000000000000".take_while(_ === '0') === "0")
     test("0000000000000011".take_while(_ === '0') === "00000000000000")

     test("110000000000000".take_while(_ === '1') === "11")
     test("011000000000000".take_while(_ === '1') === "")
     test("000000000000011".take_while(_ === '1') === "")
     test("1100000000000000".take_while(_ === '1') === "11")
     test("0110000000000000".take_while(_ === '1') === "")
     test("0000000000000011".take_while(_ === '1') === "")

     let [box string_1, string_2] = if (rnd() & 1) === 0 {
          let string_1 = rnd_string()
          let string_2 = if (rnd() & 1) === 0; string_1 else null
          [box string_1, string_2]
     } else [box "Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let len             = len(string_1)
     let n               = (rnd() >> 1) % len
     let n_char          = string_1[n]
     let expected_string = string_1[0, n_char.look_in(string_1)]
     test(string_1.take_while(_ =/= n_char) === expected_string)
     string_2.ignore()

     let items = u"0123456789abcde".to_array()
     test(u"".take_while(fn (byte) byte =/= items[0]) === u"")
     test(u"1".take_while(fn (byte) byte =/= items[1]) === u"")
     test(u"1".take_while(fn (byte) byte === items[1]) === u"1")
