     test([array 1, 2, 3, 4, 5].to_custom_array__take_while().take_while(fn (item) item =/= items[4]) === [array 1, 2, 3, 4].to_custom_array__take_while())
     test([array 1, 2, 3, 4, 5].to_custom_array__take_while().take_while(fn (item) item =/= items[5]) === [array 1, 2, 3, 4, 5].to_custom_array__take_while())

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.take_while(_ ++ heap_string()).get_error_id() === :1)
     test(heap_string().take_while(error_1).get_error_id() === :1)
     test(error_1.take_while(error_2).get_error_id() === :1)
     test(error_2.take_while(error_1).get_error_id() === :2)
     test(error_1.take_while(heap_string()).get_error_id() === :1)
     test(heap_table().take_while(error_1).get_error_id() === :1)

     test(heap_table().take_while(_ ++ heap_string()).get_error_id() === :invalid_type)
     test(heap_string().take_while(heap_table()).get_error_id() === :invalid_type)
     test(heap_table().take_while(heap_table()).get_error_id() === :invalid_type)

