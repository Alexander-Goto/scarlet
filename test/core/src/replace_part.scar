`noinline`
fn test__replace_part() {
     test("".replace_part("a", "c") === "")
     test("".replace_part("", "c") === "c")
     test("".replace_part("a", "") === "")
     test("".replace_part("", "") === "")
     test("1".replace_part("2", "3") === "1")
     test("2".replace_part("2", "3") === "3")
     test("2".replace_part("", "3") === "323")
     test("2".replace_part("2", "") === "")
     test("2".replace_part("", "") === "2")
     test("0123456789abcde".replace_part("g", "0") === "0123456789abcde")
     test("0123456789abcde".replace_part("0", "g") === "g123456789abcde")
     test("0123456789abcde".replace_part("1", "g") === "0g23456789abcde")
     test("0123456789abcde".replace_part("2", "g") === "01g3456789abcde")
     test("0123456789abcde".replace_part("3", "g") === "012g456789abcde")
     test("0123456789abcde".replace_part("4", "g") === "0123g56789abcde")
     test("0123456789abcde".replace_part("5", "g") === "01234g6789abcde")
     test("0123456789abcde".replace_part("6", "g") === "012345g789abcde")
     test("0123456789abcde".replace_part("7", "g") === "0123456g89abcde")
     test("0123456789abcde".replace_part("8", "g") === "01234567g9abcde")
     test("0123456789abcde".replace_part("9", "g") === "012345678gabcde")
     test("0123456789abcde".replace_part("a", "g") === "0123456789gbcde")
     test("0123456789abcde".replace_part("b", "g") === "0123456789agcde")
     test("0123456789abcde".replace_part("c", "g") === "0123456789abgde")
     test("0123456789abcde".replace_part("d", "g") === "0123456789abcge")
     test("0123456789abcde".replace_part("e", "g") === "0123456789abcdg")
     test("000111220111220".replace_part("0", "g") === "ggg11122g11122g")
     test("0123456789abcde".replace_part("", "g") === "g0g1g2g3g4g5g6g7g8g9gagbgcgdgeg")
     test("0123456789abcde".replace_part("0123", "") === "456789abcde")
     test("0123456789abcde".replace_part("0123", "0") === "0456789abcde")
     test("0123456789abcde".replace_part("0123", "0123456") === "0123456456789abcde")
     test("0123456789abcde".replace_part("abcde", "") === "0123456789")
     test("0123456789abcde".replace_part("abcde", "1") === "01234567891")
     test("0123456789abcde".replace_part("abcde", "abcdefg") === "0123456789abcdefg")
     test("mama".replace_part("ma", "mama") === "mamamama")
     test("mamama".replace_part("mama", "papa") === "papama")
     test("mamama".replace_part("mam", "pam") === "pamama")

     test("0\00009000\000090\00009002".replace_part("0", "\000091") === "\000091\000090\000091\000091\000090\000090\0000912")
     test("0\00009000\000090\00009002".replace_part("\000090", "1") === "01001102")
     test("0\00009000\000090\00009002".replace_part("2", "\000089") === "0\00009000\000090\0000900\000089")
     test("0\00009000\000090\0000900200".replace_part("0", "\000091") === "\000091\000090\000091\000091\000090\000090\0000912\000091\000091")

     test("0123456789abcdef".replace_part("g", "0") === "0123456789abcdef")
     test("0123456789abcdef".replace_part("0", "g") === "g123456789abcdef")
     test("0123456789abcdef".replace_part("1", "g") === "0g23456789abcdef")
     test("0123456789abcdef".replace_part("2", "g") === "01g3456789abcdef")
     test("0123456789abcdef".replace_part("3", "g") === "012g456789abcdef")
     test("0123456789abcdef".replace_part("4", "g") === "0123g56789abcdef")
     test("0123456789abcdef".replace_part("5", "g") === "01234g6789abcdef")
     test("0123456789abcdef".replace_part("6", "g") === "012345g789abcdef")
     test("0123456789abcdef".replace_part("7", "g") === "0123456g89abcdef")
     test("0123456789abcdef".replace_part("8", "g") === "01234567g9abcdef")
     test("0123456789abcdef".replace_part("9", "g") === "012345678gabcdef")
     test("0123456789abcdef".replace_part("a", "g") === "0123456789gbcdef")
     test("0123456789abcdef".replace_part("b", "g") === "0123456789agcdef")
     test("0123456789abcdef".replace_part("c", "g") === "0123456789abgdef")
     test("0123456789abcdef".replace_part("d", "g") === "0123456789abcgef")
     test("0123456789abcdef".replace_part("e", "g") === "0123456789abcdgf")
     test("0123456789abcdef".replace_part("f", "g") === "0123456789abcdeg")
     test("0001112201112200".replace_part("0", "g") === "ggg11122g11122gg")

     test("0\00009000\000090\00009000002\00009000\000090\000090".replace_part("0", "\000091") === "\000091\000090\000091\000091\000090\000090\000091\000091\000091\0000912\000090\000091\000091\000090\000090")
     test("0\00009000\000090\00009000002\00009000\000090\000090".replace_part("\000090", "1") === "0100110000210011")
     test("0\00009000\000090\00009000002\00009000\000090\000090".replace_part("2", "\000089") === "0\00009000\000090\0000900000\000089\00009000\000090\000090")

     let string = ("00123456789abcdef" ++ "0")[1, 17]
     test(string.replace_part("g", "0") === "0123456789abcdef")
     test(string.replace_part("0", "g") === "g123456789abcdef")
     test(string.replace_part("1", "g") === "0g23456789abcdef")
     test(string.replace_part("2", "g") === "01g3456789abcdef")
     test(string.replace_part("3", "g") === "012g456789abcdef")
     test(string.replace_part("4", "g") === "0123g56789abcdef")
     test(string.replace_part("5", "g") === "01234g6789abcdef")
     test(string.replace_part("6", "g") === "012345g789abcdef")
     test(string.replace_part("7", "g") === "0123456g89abcdef")
     test(string.replace_part("8", "g") === "01234567g9abcdef")
     test(string.replace_part("9", "g") === "012345678gabcdef")
     test(string.replace_part("a", "g") === "0123456789gbcdef")
     test(string.replace_part("b", "g") === "0123456789agcdef")
     test(string.replace_part("c", "g") === "0123456789abgdef")
     test(string.replace_part("d", "g") === "0123456789abcgef")
     test(string.replace_part("e", "g") === "0123456789abcdgf")
     test(string.replace_part("f", "g") === "0123456789abcdeg")
     test(string.replace_part(string, string) === "0123456789abcdef")
     test(string.replace_part(string, string) === "0123456789abcdef")

     let string = ("00\00009000\000090\00009000002\00009000\000090\000090" ++ "0")[1, 17]
     test(string.replace_part("0", "\000091") === "\000091\000090\000091\000091\000090\000090\000091\000091\000091\0000912\000090\000091\000091\000090\000090")
     test(string.replace_part("\000090", "1") === "0100110000210011")
     test(string.replace_part("2", "\000089") === "0\00009000\000090\0000900000\000089\00009000\000090\000090")
     test(string.replace_part(string, string) === "0\00009000\000090\00009000002\00009000\000090\000090")
     test(string.replace_part(string, string) === "0\00009000\000090\00009000002\00009000\000090\000090")

     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("g", "0") === "0123456789abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("0", "g") === "g123456789abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("1", "g") === "0g23456789abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("2", "g") === "01g3456789abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("3", "g") === "012g456789abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("4", "g") === "0123g56789abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("5", "g") === "01234g6789abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("6", "g") === "012345g789abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("7", "g") === "0123456g89abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("8", "g") === "01234567g9abcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("9", "g") === "012345678gabcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("a", "g") === "0123456789gbcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("b", "g") === "0123456789agcdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("c", "g") === "0123456789abgdef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("d", "g") === "0123456789abcgef")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("e", "g") === "0123456789abcdgf")
     test(("00123456789abcdef" ++ "0")[1, 17].replace_part("f", "g") === "0123456789abcdeg")

     test(("00\00009000\000090\00009000002\00009000\000090\000090" ++ "0")[1, 17].replace_part("0", "\000091") === "\000091\000090\000091\000091\000090\000090\000091\000091\000091\0000912\000090\000091\000091\000090\000090")
     test(("00\00009000\000090\00009000002\00009000\000090\000090" ++ "0")[1, 17].replace_part("\000090", "1") === "0100110000210011")
     test(("00\00009000\000090\00009000002\00009000\000090\000090" ++ "0")[1, 17].replace_part("2", "\000089") === "0\00009000\000090\0000900000\000089\00009000\000090\000090")

     let string   = rnd_string()
     let old_part = if rnd_bool() {
          let from = (rnd() & 0xffff'ffff) % len(string)
          let to   = from + (rnd() & 0xffff'ffff) % (len(string) - from)
          string[from, to]
     } else rnd_string()
     let old_part  = if rnd_bool(); old_part.unslice() else old_part
     let new_part  = if rnd_bool() {
          let from = (rnd() & 0xffff'ffff) % len(string)
          let to   = from + (rnd() & 0xffff'ffff) % (len(string) - from)
          string[from, to]
     } else rnd_string()
     let new_part  = if rnd_bool(); new_part.unslice() else new_part
     let expected  = if old_part.empty?(); string.foldl("", fn (result, char) result ++ new_part.append(char)) ++ new_part else loop([box "", 0], fn (state) {
          let [box result, idx] = state

          let part_idx = old_part.look_part_in(string.drop(idx))
          if part_idx.null?()
               [breaker result ++ string.drop(idx)]
          else [box result ++ string[idx, idx + part_idx] ++ new_part, idx + part_idx + old_part.len()]
     })
     test(string.replace_part(old_part, new_part) === expected)

     test(u"".replace_part(u"a", u"c") === u"")
