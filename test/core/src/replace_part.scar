     test(array.replace_part([array string_4], [array string_5]) === [array string_1, string_2, string_3, string_5])
     test(array.replace_part([array string_1, string_2], [array]) === [array string_3, string_4])
     test(array.replace_part([array string_2, string_3], [array]) === [array string_1, string_4])
     test(array.replace_part([array string_3, string_4], [array]) === [array string_1, string_2])
     test(array.replace_part([array string_1, string_2], [array string_5]) === [array string_5, string_3, string_4])
