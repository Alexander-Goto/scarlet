     test([array].replace_part([array 1], [array]) === [array])
     test([array].replace_part([array], [array]) === [array])
     test([array 1].replace_part([array 2], [array 3]) === [array 1])
     test([array 2].replace_part([array 2], [array 3]) === [array 3])
     test([array 2].replace_part([array], [array 3]) === [array 3, 2, 3])
     test([array 2].replace_part([array 2], [array]) === [array])
     test([array 2].replace_part([array], [array]) === [array 2])
     test([array 1, 2, 3, 4].replace_part([array 5], [array 1]) === [array 1, 2, 3, 4])
     test([array 1, 2, 3, 4].replace_part([array 1], [array 5]) === [array 5, 2, 3, 4])
     test([array 1, 2, 3, 4].replace_part([array 2], [array 5]) === [array 1, 5, 3, 4])
     test([array 1, 2, 3, 4].replace_part([array 3], [array 5]) === [array 1, 2, 5, 4])
     test([array 1, 2, 3, 4].replace_part([array 4], [array 5]) === [array 1, 2, 3, 5])
     test([array 1, 2, 1, 2].replace_part([array 1], [array 5]) === [array 5, 2, 5, 2])
     test([array 1, 2, 1, 2].replace_part([array 2], [array 5]) === [array 1, 5, 1, 5])
     test([array 1, 2, 3, 4].replace_part([array 1, 2], [array]) === [array 3, 4])
     test([array 1, 2, 3, 4].replace_part([array 2, 3], [array]) === [array 1, 4])
     test([array 1, 2, 3, 4].replace_part([array 3, 4], [array]) === [array 1, 2])
     test([array 1, 2, 3, 4].replace_part([array 1, 2], [array 5]) === [array 5, 3, 4])
     test([array 1, 2, 3, 4].replace_part([array 2, 3], [array 5]) === [array 1, 5, 4])
     test([array 1, 2, 3, 4].replace_part([array 3, 4], [array 5]) === [array 1, 2, 5])
     test([array 1, 2, 3, 4].replace_part([array 1, 2], [array 5, 1, 5]) === [array 5, 1, 5, 3, 4])
     test([array 1, 2, 3, 4].replace_part([array 2, 3], [array 5, 1, 5]) === [array 1, 5, 1, 5, 4])
     test([array 1, 2, 3, 4].replace_part([array 3, 4], [array 5, 1, 5]) === [array 1, 2, 5, 1, 5])
     test([array 1, 2, 1, 2].replace_part([array 1, 2], [array 1, 2, 1, 2]) === [array 1, 2, 1, 2, 1, 2, 1, 2])
     test([array 1, 2, 1, 2, 1, 2].replace_part([array 1, 2, 1, 2], [array 3, 2, 3, 2]) === [array 3, 2, 3, 2, 1, 2])
     test([array 1, 2, 1, 2, 1, 2].replace_part([array 1, 2, 1], [array 3, 2, 1]) === [array 3, 2, 1, 2, 1, 2])

     let array = [array].init(10)
