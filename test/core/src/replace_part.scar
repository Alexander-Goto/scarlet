     test([array string_1, string_1, string_2, string_1, string_2, string_1, string_2, string_1][1, 7].replace_part([array string_1, string_2, string_1], [array string_3, string_2, string_1]) === [array string_3, string_2, string_1, string_2, string_1, string_2])

     let array    = rnd_string_array()
     let old_part = if rnd_bool() {
          let from = (rnd() & 0xffff'ffff) % len(array)
          let to   = from + (rnd() & 0xffff'ffff) % (len(array) - from)
          array[from, to]
     } else rnd_string_array()
     let old_part  = if rnd_bool(); old_part.unslice() else old_part
     let new_part  = if rnd_bool() {
          let from = (rnd() & 0xffff'ffff) % len(array)
          let to   = from + (rnd() & 0xffff'ffff) % (len(array) - from)
          array[from, to]
     } else rnd_string_array()
     let new_part  = if rnd_bool(); new_part.unslice() else new_part
     let expected  = if old_part.empty?(); array.foldl([array].init((len(new_part) + 1) * len(array)), fn (result, string) (result ++ new_part).append(string)) ++ new_part else loop([box [array].init(len(array)), 0], fn (state) {
          let [box result, idx] = state

          let part_idx = old_part.look_part_in(array.drop(idx))
          if part_idx.null?()
               [breaker result ++ array.drop(idx)]
          else [box result ++ array[idx, idx + part_idx] ++ new_part, idx + part_idx + old_part.len()]
     })
     test(array.replace_part(old_part, new_part) === expected)

     test(to_container__replace_part("mamama").replace_part("mama".to_container__replace_part(), "papa".to_container__replace_part()) === to_container__replace_part("papama"))
     test(to_container__replace_part("mamama").replace_part("mam".to_container__replace_part(), "pam".to_container__replace_part()) === to_container__replace_part("pamama"))
     test(to_custom_container__replace_part("mamama").replace_part("mama".to_custom_container__replace_part(), "papa".to_custom_container__replace_part()) === to_custom_container__replace_part("papama"))
     test(to_custom_container__replace_part("mamama").replace_part("mam".to_custom_container__replace_part(), "pam".to_custom_container__replace_part()) === to_custom_container__replace_part("pamama"))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let error_3 = expected_error(:3, heap_string(), heap_string())
     test(error_1.replace_part(heap_string(), heap_string()).get_error_id() === :1)
     test([array heap_string()].replace_part(error_1, [array heap_string()]).get_error_id() === :1)
     test([array heap_string()].replace_part([array heap_string()], error_1).get_error_id() === :1)
     test(error_1.replace_part(error_2, error_3).get_error_id() === :1)
     test(error_3.replace_part(error_2, error_1).get_error_id() === :3)
     test(error_1.replace_part([box heap_string()].scarlet__erase_info(), [box heap_string()].scarlet__erase_info()).get_error_id() === :1)
     test(heap_string().replace_part(error_1, heap_string()).get_error_id() === :1)
     test(heap_string().replace_part(heap_string(), error_1).get_error_id() === :1)

     test(heap_string().replace_part(heap_string(), heap_byte_array()).get_error_id() === :invalid_type)
     test(heap_string().replace_part(heap_byte_array(), heap_string()).get_error_id() === :invalid_type)
     test(heap_string().replace_part(heap_byte_array(), heap_byte_array()).get_error_id() === :invalid_type)
     test(heap_byte_array().replace_part(heap_byte_array(), heap_string()).get_error_id() === :invalid_type)
     test(heap_byte_array().replace_part(heap_string(), heap_byte_array()).get_error_id() === :invalid_type)
     test(heap_byte_array().replace_part(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test([array heap_string()].replace_part([box heap_string()].scarlet__erase_info(), [array heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace_part([array heap_string()], [box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace_part([box heap_string()].scarlet__erase_info(), [box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test([box heap_string()].scarlet__erase_info().replace_part([box heap_string()].scarlet__erase_info(), [box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)

     test(to_broken_container__replace_part(heap_string()).replace_part(heap_string().to_broken_container__replace_part(), heap_string().to_broken_container__replace_part()).get_error_id() === :invalid_type)
     test(to_broken_custom_container__replace_part(heap_string()).replace_part(heap_string().to_broken_custom_container__replace_part(), heap_string().to_broken_custom_container__replace_part()).get_error_id() === :invalid_type)
     test(to_error_container__replace_part(heap_string()).replace_part(heap_string().to_error_container__replace_part(), heap_string().to_error_container__replace_part()).get_error_id() === :3)
     test(to_error_custom_container__replace_part(heap_string()).replace_part(heap_string().to_error_custom_container__replace_part(), heap_string().to_error_custom_container__replace_part()).get_error_id() === :4)
