     :value = [array]

     :_ = [obj
          :core_replace_part = fn (container, old_part, new_part) to_container__replace_part(container:value.replace_part(old_part:value, new_part:value))
          :core___equal__    = fn (container_1, container_2) container_1:value === container_2:value
     ]
]

fn to_container__replace_part(arg) new (@main.container__replace_part):value <= arg

