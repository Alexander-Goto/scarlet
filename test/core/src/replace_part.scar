     test(array.replace_part([array string_3, string_4], [array string_5]) === [array string_1, string_2, string_5])
     test(array.replace_part([array string_1, string_2], [array string_5, string_1, string_5]) === [array string_5, string_1, string_5, string_3, string_4])
     test(array.replace_part([array string_2, string_3], [array string_5, string_1, string_5]) === [array string_1, string_5, string_1, string_5, string_4])
     test(array.replace_part([array string_3, string_4], [array string_5, string_1, string_5]) === [array string_1, string_2, string_5, string_1, string_5])
     array.ignore()

     let array = [array string_1, string_1, string_2, string_1, string_2, string_1][1, 5]
     test(array.replace_part([array string_1], [array string_5]) === [array string_5, string_2, string_5, string_2])
     test(array.replace_part([array string_2], [array string_5]) === [array string_1, string_5, string_1, string_5])
     test(array.replace_part([array string_1, string_2], [array string_1, string_2, string_1, string_2]) === [array string_1, string_2, string_1, string_2, string_1, string_2, string_1, string_2])

