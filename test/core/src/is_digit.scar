let char__digit = [obj
     :value = 0

     :_ = [obj
          :core_digit? = fn (char) char:value.digit?()
     ]
]

fn to_char__digit?(arg) new (@main.char__digit):value <= arg

fn to_custom_char__digit?(arg) custom__create(
     arg
     [obj
          :core_digit? = fn (char) char.custom__get_data().digit?()
     ]
)

let broken_char__digit = [obj
     :value = 0

     :_ = [obj
          :core_digit? = fn (_) heap_string()
     ]
]

fn to_broken_char__digit?(arg) new (@main.broken_char__digit):value <= arg

fn to_broken_custom_char__digit?(arg) custom__create(
     arg
     [obj
          :core_digit? = fn (_) heap_string()
     ]
)

let error_char__digit = [obj
     :value = 0

     :_ = [obj
          :core_digit? = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_char__digit?(arg) new (@main.error_char__digit):value <= arg

fn to_error_custom_char__digit?(arg) custom__create(
     arg
     [obj
          :core_digit? = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__digit?() {
     test(not '\000001'.digit?())
     test(not '\000009'.digit?())
     test(not '\000020'.digit?())
     test(not 'a'.digit?())
     test(not 'z'.digit?())
     test(not '\00008b'.digit?())
     test('0'.digit?())
     test('1'.digit?())
     test('2'.digit?())
     test('3'.digit?())
     test('4'.digit?())
     test('5'.digit?())
     test('6'.digit?())
     test('7'.digit?())
     test('8'.digit?())
     test('9'.digit?())

     let string = rnd_string()
     test(string.filter(_.in_range?('0', ':')) === string.filter(digit?(_)))

     test(to_char__digit?('9').digit?())
     test(not to_char__digit?('\000009').digit?())
     test(not to_char__digit?('a').digit?())

     test(to_custom_char__digit?('9').digit?())
     test(not to_custom_char__digit?('\000009').digit?())
     test(not to_custom_char__digit?('a').digit?())

     let error = expected_error(:1, heap_string(), heap_string())
     test(error.digit?().get_error_id() === :1)
     test(heap_table().digit?().get_error_id() === :invalid_type)

     test(to_broken_char__digit?('a').digit?().get_error_id() === :invalid_type)
     test(to_broken_custom_char__digit?('a').digit?().get_error_id() === :invalid_type)
     test(to_error_char__digit?('a').digit?().get_error_id() === :3)
     test(to_error_custom_char__digit?('a').digit?().get_error_id() === :4)
}