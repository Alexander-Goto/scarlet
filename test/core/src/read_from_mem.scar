`noinline`
fn test__read_from_mem!!!() {
     let string = u"Hello World!!! Hello World!!!"
     test(read_from_mem!!!(string, 16, 5) == u"Hello")
     test(read_from_mem!!!(string, 17, 5) == u"ello ")
     test(read_from_mem!!!(string, 0, 0) == u"")
     test(read_from_mem!!!(string, 17, 16) == u"ello World!!! He")

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let error_3 = expected_error(:3, heap_string(), heap_string())
     test(read_from_mem!!!(error_1, 0, 0) == u"")
     test(read_from_mem!!!(error_1, error_2, 16).get_error_id() == :2)
     test(read_from_mem!!!(error_1, 16, error_2).get_error_id() == :2)
     test(read_from_mem!!!(error_1, error_2, -1.scarlet__erase_info()).get_error_id() == :2)
     test(read_from_mem!!!(error_1, error_2, -9223372036854775808.scarlet__erase_info()).get_error_id() == :2)
     test(read_from_mem!!!(error_1, error_2, -9223372036854775807.scarlet__erase_info()).get_error_id() == :2)
     test(read_from_mem!!!(error_1, error_2, 9223372036854775807.scarlet__erase_info()).get_error_id() == :2)
     test(read_from_mem!!!(error_1, error_2, heap_string()).get_error_id() == :2)
     test(read_from_mem!!!(error_1, heap_string(), error_2).get_error_id() == :2)
     test(read_from_mem!!!(error_1, error_2, error_3).get_error_id() == :2)
     test(read_from_mem!!!(error_1, error_3, error_2).get_error_id() == :3)

     test(read_from_mem!!!(error_1, 0, -1.scarlet__erase_info()).get_error_id() == :out_of_bounds)
     test(read_from_mem!!!(error_1, 0, -9223372036854775808.scarlet__erase_info()).get_error_id() == :out_of_bounds)
     test(read_from_mem!!!(error_1, 0, -9223372036854775807.scarlet__erase_info()).get_error_id() == :out_of_bounds)
     test(read_from_mem!!!(error_1, 0, 9223372036854775807.scarlet__erase_info()).get_error_id() == :out_of_bounds)

     test(read_from_mem!!!(error_1, 0, heap_string()).get_error_id() == :invalid_type)
     test(read_from_mem!!!(error_1, heap_string(), 0).get_error_id() == :invalid_type)
     test(read_from_mem!!!(error_1, heap_string(), heap_string()).get_error_id() == :invalid_type)

     test(read_from_mem!!!(heap_string(), heap_string(), -1.scarlet__erase_info()).error?())
}
