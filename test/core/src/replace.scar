     test([obj].init(10).replace(1, 4) === [obj])
     test([obj :1 = 2, :2 = 3, :3 = 4].replace(2, 5) === [obj :1 = 5, :2 = 3, :3 = 4])
     test([obj :1 = 2, :2 = 3, :3 = 4].replace(3, 5) === [obj :1 = 2, :2 = 5, :3 = 4])
     test([obj :1 = 2, :2 = 3, :3 = 4].replace(4, 5) === [obj :1 = 2, :2 = 3, :3 = 5])
     test([obj :1 = 2, :2 = 3, :3 = 4].replace(4, "Hello") === [obj :1 = 2, :2 = 3, :3 = "Hello"])
     test([obj :1 = 2, :2 = 2, :3 = 2].replace(2, "Hello") === [obj :1 = "Hello", :2 = "Hello", :3 = "Hello"])
     test([obj :1 = 2, :2 = 3, :3 = 4, :_ = [obj :1 = 2]].replace(2, 5) === [obj :1 = 5, :2 = 3, :3 = 4])
     test([obj :1 = 2, :2 = 3, :3 = 4, :_ = [obj :1 = 2]].replace(2, 5):_ === [obj :1 = 2])
     test([obj :1 = 2, :2 = 3, :3 = 4, :_ = [obj :1 = 2]].replace(3, 5) === [obj :1 = 2, :2 = 5, :3 = 4])
     test([obj :1 = 2, :2 = 3, :3 = 4, :_ = [obj :1 = 2]].replace(3, 5):_ === [obj :1 = 2])
     test([obj :1 = 2, :2 = 3, :3 = 4, :_ = [obj :1 = 2]].replace(4, 5) === [obj :1 = 2, :2 = 3, :3 = 5])
     test([obj :1 = 2, :2 = 3, :3 = 4, :_ = [obj :1 = 2]].replace(4, 5):_ === [obj :1 = 2])
     test([obj :1 = 2, :2 = 3, :3 = 4, :_ = [obj :1 = 2]].replace(4, "Hello") === [obj :1 = 2, :2 = 3, :3 = "Hello"])
     test([obj :1 = 2, :2 = 3, :3 = 4, :_ = [obj :1 = 2]].replace(4, "Hello"):_ === [obj :1 = 2])
     test([obj :1 = 2, :2 = 2, :3 = 2, :_ = [obj :1 = 2]].replace(2, "Hello") === [obj :1 = "Hello", :2 = "Hello", :3 = "Hello"])
     test([obj :1 = 2, :2 = 2, :3 = 2, :_ = [obj :1 = 2]].replace(2, "Hello"):_ === [obj :1 = 2])

     let obj = [obj :1 = string_2, :2 = string_3, :3 = string_4]
     test(obj.replace(string_2, string_5) === [obj :1 = string_5, :2 = string_3, :3 = string_4])
     test(obj.replace(string_3, string_5) === [obj :1 = string_2, :2 = string_5, :3 = string_4])
     test(obj.replace(string_4, string_5) === [obj :1 = string_2, :2 = string_3, :3 = string_5])
     obj.ignore()

     let obj = [obj :1 = string_2, :2 = string_3, :3 = string_4, :_ = [obj :1 = 2]]
     test(obj.replace(string_2, string_5) === [obj :1 = string_5, :2 = string_3, :3 = string_4])
     test(obj.replace(string_2, string_5):_ === [obj :1 = 2])
     test(obj.replace(string_3, string_5) === [obj :1 = string_2, :2 = string_5, :3 = string_4])
     test(obj.replace(string_3, string_5):_ === [obj :1 = 2])
     test(obj.replace(string_4, string_5) === [obj :1 = string_2, :2 = string_3, :3 = string_5])
     test(obj.replace(string_4, string_5):_ === [obj :1 = 2])
     obj.ignore()

     let obj = [obj :1 = string_2, :2 = string_2, :3 = string_2]
     test(obj.replace(string_2, string_5) === [obj :1 = string_5, :2 = string_5, :3 = string_5])
     obj.ignore()

     let obj = [obj :1 = string_2, :2 = string_2, :3 = string_2, :_ = [obj :1 = 2]]
     test(obj.replace(string_2, string_5) === [obj :1 = string_5, :2 = string_5, :3 = string_5])
     test(obj.replace(string_2, string_5):_ === [obj :1 = 2])
     obj.ignore()

     test([obj :1 = string_2, :2 = string_3, :3 = string_4].replace(string_2, string_5) === [obj :1 = string_5, :2 = string_3, :3 = string_4])
     test([obj :1 = string_2, :2 = string_3, :3 = string_4].replace(string_3, string_5) === [obj :1 = string_2, :2 = string_5, :3 = string_4])
     test([obj :1 = string_2, :2 = string_3, :3 = string_4].replace(string_4, string_5) === [obj :1 = string_2, :2 = string_3, :3 = string_5])
     test([obj :1 = string_2, :2 = string_2, :3 = string_2].replace(string_2, string_5) === [obj :1 = string_5, :2 = string_5, :3 = string_5])
     test([obj :1 = string_2, :2 = string_3, :3 = string_4, :_ = [obj :1 = 2]].replace(string_2, string_5) === [obj :1 = string_5, :2 = string_3, :3 = string_4])
     test([obj :1 = string_2, :2 = string_3, :3 = string_4, :_ = [obj :1 = 2]].replace(string_3, string_5) === [obj :1 = string_2, :2 = string_5, :3 = string_4])
     test([obj :1 = string_2, :2 = string_3, :3 = string_4, :_ = [obj :1 = 2]].replace(string_4, string_5) === [obj :1 = string_2, :2 = string_3, :3 = string_5])
     test([obj :1 = string_2, :2 = string_2, :3 = string_2, :_ = [obj :1 = 2]].replace(string_2, string_5) === [obj :1 = string_5, :2 = string_5, :3 = string_5])
     test([obj :1 = string_2, :2 = string_3, :3 = string_4, :_ = [obj :1 = 2]].replace(string_2, string_5):_ === [obj :1 = 2])
     test([obj :1 = string_2, :2 = string_3, :3 = string_4, :_ = [obj :1 = 2]].replace(string_3, string_5):_ === [obj :1 = 2])
     test([obj :1 = string_2, :2 = string_3, :3 = string_4, :_ = [obj :1 = 2]].replace(string_4, string_5):_ === [obj :1 = 2])
     test([obj :1 = string_2, :2 = string_2, :3 = string_2, :_ = [obj :1 = 2]].replace(string_2, string_5):_ === [obj :1 = 2])

     let array    = rnd_string_array()
     let obj      = loop([obj], fn (obj) {
          let key = loop(rnd_token(), fn (key) if key =/= :_; [breaker key] else rnd_token())
          let obj = new (obj)[key] <= array[len(obj)]
          break(len(array) === len(obj), obj)
     })
     let old_string = if rnd_bool(); array[(rnd() & 0xffff'ffff) % len(array)] else rnd_string()
     let new_string = rnd_string()
     test(obj.replace(old_string, new_string) === obj.map(fn (string) if string === old_string; new_string else string))

     test(to_container__replace("aBcD").replace('a', 'C') === to_container__replace("CBcD"))
     test(to_container__replace("aBcD").replace('D', 'a') === to_container__replace("aBca"))
     test(to_custom_container__replace("aBcD").replace('a', 'C') === to_custom_container__replace("CBcD"))
     test(to_custom_container__replace("aBcD").replace('D', 'a') === to_custom_container__replace("aBca"))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let error_3 = expected_error(:3, heap_string(), heap_string())
     test(error_1.replace(heap_string(), heap_string()).get_error_id() === :1)
     test([array heap_string()].replace(error_1, heap_string()).get_error_id() === :1)
     test([array heap_string()].replace(heap_string(), error_1).get_error_id() === :1)
     test(error_1.replace(error_2, error_3).get_error_id() === :1)
     test(error_3.replace(error_2, error_1).get_error_id() === :3)
     test(error_1.replace([box heap_string()].scarlet__erase_info(), [box heap_string()].scarlet__erase_info()).get_error_id() === :1)
     test(heap_string().replace(error_1, heap_string()).get_error_id() === :1)
     test(heap_string().replace(heap_string(), error_1).get_error_id() === :1)

     test(heap_string().replace(heap_string(), 'a').get_error_id() === :invalid_type)
     test(heap_string().replace('a', heap_string()).get_error_id() === :invalid_type)
     test(heap_string().replace(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test("".replace(heap_string(), 'a').get_error_id() === :invalid_type)
     test("".replace('a', heap_string()).get_error_id() === :invalid_type)
     test("".replace(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(heap_byte_array().replace(heap_string(), 0b00).get_error_id() === :invalid_type)
     test(heap_byte_array().replace(0b00, heap_string()).get_error_id() === :invalid_type)
     test(heap_byte_array().replace(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(u"".replace(heap_string(), 0b00).get_error_id() === :invalid_type)
     test(u"".replace(0b00, heap_string()).get_error_id() === :invalid_type)
     test(u"".replace(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test([array heap_string()].replace([box heap_string()].scarlet__erase_info(), heap_string()).get_error_id() === :invalid_type)
     test([array heap_string()].replace(heap_string(), [box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace([box heap_string()].scarlet__erase_info(), [box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace(null.scarlet__erase_info(), heap_string()).get_error_id() === :invalid_type)
     test([array heap_string()].replace(heap_string(), null.scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace(null.scarlet__erase_info(), null.scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace((_ ++ _).scarlet__erase_info(), heap_string()).get_error_id() === :invalid_type)
     test([array heap_string()].replace((_ ++ _).scarlet__erase_info(), (_ ++ _).scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace((_ ++ heap_string()).scarlet__erase_info(), heap_string()).get_error_id() === :invalid_type)
     test([array heap_string()].replace((_ ++ heap_string()).scarlet__erase_info(), (_ ++ heap_string()).scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace([breaker heap_string()].scarlet__erase_info(), heap_string()).get_error_id() === :invalid_type)
     test([array heap_string()].replace(heap_string(), [breaker heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace([breaker heap_string()].scarlet__erase_info(), [breaker heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace(thread(fn() null).scarlet__erase_info(), heap_string()).get_error_id() === :invalid_type)
     test([array heap_string()].replace(thread(fn() null).scarlet__erase_info(), thread(fn() null).scarlet__erase_info()).get_error_id() === :invalid_type)
     test([array heap_string()].replace(make_channel()[0], heap_string()).get_error_id() === :invalid_type)
     test([array heap_string()].replace(make_channel()[0], make_channel()[0]).get_error_id() === :invalid_type)
     test([box heap_string()].scarlet__erase_info().replace([box heap_string()].scarlet__erase_info(), [box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)
     test([box heap_string()].scarlet__erase_info().replace([box heap_string()].scarlet__erase_info(), [box heap_string()].scarlet__erase_info()).get_error_id() === :invalid_type)

     test(to_broken_container__replace([array heap_string()]).replace(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(to_broken_custom_container__replace([array heap_string()]).replace(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(to_error_container__replace([array heap_string()]).replace(heap_string(), heap_string()).get_error_id() === :3)
     test(to_error_custom_container__replace([array heap_string()]).replace(heap_string(), heap_string()).get_error_id() === :4)
}