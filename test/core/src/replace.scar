     test("0001112201112200".replace('0', 'g') === "ggg11122g11122gg")

     test("0\00009000\000090\00009000002\00009000\000090\000090".replace('0', '\000091') === "\000091\000090\000091\000091\000090\000090\000091\000091\000091\0000912\000090\000091\000091\000090\000090")
