     test("0123456789abcdef".replace('9', 'g') === "012345678gabcdef")
     test("0123456789abcdef".replace('a', 'g') === "0123456789gbcdef")
     test("0123456789abcdef".replace('b', 'g') === "0123456789agcdef")
     test("0123456789abcdef".replace('c', 'g') === "0123456789abgdef")
     test("0123456789abcdef".replace('d', 'g') === "0123456789abcgef")
