let container__replace = [obj
     :value = [array]

     :_ = [obj
          :core_replace   = fn (container, old_item, new_item) to_container__replace(container:value.replace(old_item, new_item))
          :core___equal__ = fn (container_1, container_2) container_1:value === container_2:value
     ]
]

fn to_container__replace(arg) new (@main.container__replace):value <= arg

fn to_custom_container__replace(arg) custom__create(
     arg
     [obj
          :core_replace   = fn (container, old_item, new_item) to_custom_container__replace(custom__get_data(container).replace(old_item, new_item))
          :core___equal__ = fn (container_1, container_2) container_1.custom__get_data() === container_2.custom__get_data()
     ]
)

let broken_container__replace = [obj
     :value = [array]

     :_ = [obj
          :core_replace = fn (_, _, _) _ ++ heap_table()
     ]
]

fn to_broken_container__replace(arg) new (@main.broken_container__replace):value <= arg

fn to_broken_custom_container__replace(arg) custom__create(
     arg
     [obj
          :core_replace = fn (_, _, _) _ ++ heap_table()
     ]
)

let error_container__replace = [obj
     :value = [array]

     :_ = [obj
          :core_replace = fn (_, _, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_container__replace(arg) new (@main.error_container__replace):value <= arg

fn to_error_custom_container__replace(arg) custom__create(
     arg
     [obj
          :core_replace = fn (_, _, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__replace() {
     test("".replace('a', 'c') === "")
     test("1".replace('2', '3') === "1")
     test("2".replace('2', '3') === "3")
     test("0123456789abcde".replace('g', '0') === "0123456789abcde")
     test("0123456789abcde".replace('0', 'g') === "g123456789abcde")
     test("0123456789abcde".replace('1', 'g') === "0g23456789abcde")
     test("0123456789abcde".replace('2', 'g') === "01g3456789abcde")
     test("0123456789abcde".replace('3', 'g') === "012g456789abcde")
     test("0123456789abcde".replace('4', 'g') === "0123g56789abcde")
     test("0123456789abcde".replace('5', 'g') === "01234g6789abcde")
     test("0123456789abcde".replace('6', 'g') === "012345g789abcde")
     test("0123456789abcde".replace('7', 'g') === "0123456g89abcde")
     test("0123456789abcde".replace('8', 'g') === "01234567g9abcde")
     test("0123456789abcde".replace('9', 'g') === "012345678gabcde")
     test("0123456789abcde".replace('a', 'g') === "0123456789gbcde")
     test("0123456789abcde".replace('b', 'g') === "0123456789agcde")
     test("0123456789abcde".replace('c', 'g') === "0123456789abgde")
     test("0123456789abcde".replace('d', 'g') === "0123456789abcge")
     test("0123456789abcde".replace('e', 'g') === "0123456789abcdg")
     test("000111220111220".replace('0', 'g') === "ggg11122g11122g")

     test("0\00009000\000090\00009002".replace('0', '\000091') === "\000091\000090\000091\000091\000090\000090\0000912")
     test("0\00009000\000090\00009002".replace('\000090', '1') === "01001102")
     test("0\00009000\000090\00009002".replace('2', '\000089') === "0\00009000\000090\0000900\000089")
     test("0\00009000\000090\0000900200".replace('0', '\000091') === "\000091\000090\000091\000091\000090\000090\0000912\000091\000091")

     test("0123456789abcdef".replace('g', '0') === "0123456789abcdef")
     test("0123456789abcdef".replace('0', 'g') === "g123456789abcdef")
