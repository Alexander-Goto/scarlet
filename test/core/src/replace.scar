     test([table].replace(1, 4) === [table])
     test([table].init(10).replace(1, 4) === [table])
     test([table 1 = 2, 2 = 3, 3 = 4].replace(2, 5) === [table 1 = 5, 2 = 3, 3 = 4])
     test([table 1 = 2, 2 = 3, 3 = 4].replace(3, 5) === [table 1 = 2, 2 = 5, 3 = 4])
     test([table 1 = 2, 2 = 3, 3 = 4].replace(4, 5) === [table 1 = 2, 2 = 3, 3 = 5])
