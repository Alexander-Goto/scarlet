let broken_const__println = [obj
     :value = 0

     :_ = [obj
          :core_print = fn (_) heap_string()
     ]
]

fn to_broken_const__println(arg) new (@main.broken_const__println):value <= arg

fn to_broken_custom_const__println(arg) custom__create(
     arg
     [obj
          :core_print = fn (_) heap_string()
     ]
)

let error_const__println = [obj
     :value = 0

     :_ = [obj
          :core_print = fn (_) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_const__println(arg) new (@main.error_const__println):value <= arg

fn to_error_custom_const__println(arg) custom__create(
     arg
     [obj
          :core_print = fn (_) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__println() {
     test(expected_error(:1, heap_string(), heap_string()).println().get_error_id() === :1)
     test((_ ++ heap_string()).println().get_error_id() === :invalid_type)

     test(0.to_broken_const__println().println().get_error_id() === :invalid_type)
     test(0.to_broken_custom_const__println().println().get_error_id() === :invalid_type)
     test(0.to_error_const__println().println().get_error_id() === :3)
     test(0.to_error_custom_const__println().println().get_error_id() === :4)
}