          :core_filter = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__filter() {
     let items = "0123456".to_array()
     test("".filter(fn (char) char === items[0]) === "")
     test("1".filter(fn (char) char === items[1]) === "1")
     test("1".filter(fn (char) char =/= items[1]) === "")
     test("012233344445555".filter(fn (char) char =/= items[0]) === "12233344445555")
     test("012233344445555".filter(fn (char) char =/= items[1]) === "02233344445555")
     test("012233344445555".filter(fn (char) char =/= items[2]) === "0133344445555")
     test("012233344445555".filter(fn (char) char =/= items[3]) === "012244445555")
     test("012233344445555".filter(fn (char) char =/= items[4]) === "01223335555")
     test("012233344445555".filter(fn (char) char =/= items[5]) === "01223334444")
     test("012233344445555".filter(fn (char) char =/= items[6]) === "012233344445555")
     test("0a1b2c3d4e5f6g7".filter(_.digit?()) === "01234567")
     test("0a1b2c3d4e5f6g7".filter(_.letter?()) === "abcdefg")

     let items = "\000091\0000b3\0000ab!\0000a4\0000a7\0000b5f".to_array()
     test("\000091".filter(fn (char) char === items[0]) === "\000091")
     test("\000091".filter(fn (char) char =/= items[0]) === "")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(fn (char) char =/= items[0]) === "\0000b3\0000ab!!!\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(fn (char) char =/= items[1]) === "\000091\0000ab!!!\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(fn (char) char =/= items[2]) === "\000091\0000b3!!!\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(fn (char) char =/= items[3]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(fn (char) char =/= items[4]) === "\000091\0000b3\0000ab!!!\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(fn (char) char =/= items[5]) === "\000091\0000b3\0000ab!!!\0000a4\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(fn (char) char =/= items[6]) === "\000091\0000b3\0000ab!!!\0000a4\0000a7")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(fn (char) char =/= items[7]) === "\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(_.letter?()) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5")
     test("\000091\0000b3\0000ab!!!\0000a4\0000a7\0000b5".filter(_.symbol?()) === "!!!")

     let items  = "01234567fg".to_array()
     let string = ("0011012375611135f" ++ "g0")[1, 18]
     test(string.filter(fn (char) char =/= items[0]) === "1112375611135fg")
     test(string.filter(fn (char) char =/= items[1]) === "002375635fg")
     test(string.filter(fn (char) char =/= items[2]) === "01101375611135fg")
     test(string.filter(fn (char) char =/= items[3]) === "0110127561115fg")
     test(string.filter(fn (char) char =/= items[4]) === "011012375611135fg")
     test(string.filter(fn (char) char =/= items[5]) === "0110123761113fg")
     test(string.filter(fn (char) char =/= items[6]) === "01101237511135fg")
     test(string.filter(fn (char) char =/= items[7]) === "01101235611135fg")
     test(string.filter(fn (char) char =/= items[8]) === "011012375611135g")
     test(string.filter(fn (char) char =/= items[9]) === "011012375611135f")
     test(string.filter(_.digit?()) === "011012375611135")
     test(string.filter(_.letter?()) === "fg")
     string.ignore()

     let items = "01234567fg".to_array()
     test(("0011012375611135f" ++ "g0")[1, 18].filter(fn (char) char =/= items[0]) === "1112375611135fg")
     test(("0011012375611135f" ++ "g0")[1, 18].filter(fn (char) char =/= items[1]) === "002375635fg")
