     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(fn (char) char =/= items[4]) === "\000091\0000b3\0000ab\0000a4\0000b5 \0000af\0000ae\0000b7")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(fn (char) char =/= items[5]) === "\000091\0000b3\0000ab\0000a4\0000a7 \0000af\0000ae\0000b7")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(fn (char) char =/= items[6]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5\0000af\0000ae\0000b7")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(fn (char) char =/= items[7]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000ae\0000b7")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(fn (char) char =/= items[8]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000b7")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(fn (char) char =/= items[9]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(fn (char) char =/= items[10]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(_.letter?()) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5\0000af\0000ae\0000b7")
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(_.space?()) === " ")

     let items = "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7g".to_array()
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter(fn (char) char =/= items[0]) === "\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
