     test(("0011012375611135f" ++ "g0")[1, 18].filter(fn (char) char =/= items[5]) === "0110123761113fg")
     test(("0011012375611135f" ++ "g0")[1, 18].filter(fn (char) char =/= items[6]) === "01101237511135fg")
     test(("0011012375611135f" ++ "g0")[1, 18].filter(fn (char) char =/= items[7]) === "01101235611135fg")
     test(("0011012375611135f" ++ "g0")[1, 18].filter(fn (char) char =/= items[8]) === "011012375611135g")
     test(("0011012375611135f" ++ "g0")[1, 18].filter(fn (char) char =/= items[9]) === "011012375611135f")
     test(("0011012375611135f" ++ "g0")[1, 18].filter(_.digit?()) === "011012375611135")
     test(("0011012375611135f" ++ "g0")[1, 18].filter(_.letter?()) === "fg")

     let items = "01234567fg".to_array()
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[0]) === "1112375611135fg")
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[1]) === "002375635fg")
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[2]) === "01101375611135fg")
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[3]) === "0110127561115fg")
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[4]) === "011012375611135fg")
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[5]) === "0110123761113fg")
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[6]) === "01101237511135fg")
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[7]) === "01101235611135fg")
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[8]) === "011012375611135g")
     test(("011012375611135f" ++ "g").filter(fn (char) char =/= items[9]) === "011012375611135f")
     test(("011012375611135f" ++ "g").filter(_.digit?()) === "011012375611135")
     test(("011012375611135f" ++ "g").filter(_.letter?()) === "fg")

     let items  = "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7g".to_array()
     let string = ("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11]
     test(string.filter(fn (char) char =/= items[0]) === "\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
     test(string.filter(fn (char) char =/= items[1]) === "\000091\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
     test(string.filter(fn (char) char =/= items[2]) === "\000091\0000b3\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
     test(string.filter(fn (char) char =/= items[3]) === "\000091\0000b3\0000ab\0000a7\0000b5 \0000af\0000ae\0000b7")
     test(string.filter(fn (char) char =/= items[4]) === "\000091\0000b3\0000ab\0000a4\0000b5 \0000af\0000ae\0000b7")
     test(string.filter(fn (char) char =/= items[5]) === "\000091\0000b3\0000ab\0000a4\0000a7 \0000af\0000ae\0000b7")
     test(string.filter(fn (char) char =/= items[6]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5\0000af\0000ae\0000b7")
     test(string.filter(fn (char) char =/= items[7]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000ae\0000b7")
     test(string.filter(fn (char) char =/= items[8]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000b7")
     test(string.filter(fn (char) char =/= items[9]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae")
     test(string.filter(fn (char) char =/= items[10]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
     test(string.filter(_.letter?()) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5\0000af\0000ae\0000b7")
     test(string.filter(_.space?()) === " ")
     string.ignore()

     let items = "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7g".to_array()
     test(("0\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7" ++ "0")[1, 11].filter(fn (char) char =/= items[0]) === "\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae\0000b7")
