     test(to_custom_container__filter("1234").filter(_ =/= '3') === to_custom_container__filter("124"))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.filter(_ === heap_string()).get_error_id() === :1)
     test("".filter(error_1).get_error_id() === :1)
     test(error_1.filter(error_2).get_error_id() === :1)
     test(error_2.filter(error_1).get_error_id() === :2)
     test(error_1.filter(heap_string()).get_error_id() === :1)
     test((_ === heap_string()).scarlet__erase_info().filter(error_1).get_error_id() === :1)

