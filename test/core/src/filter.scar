     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter(fn (char) char =/= items[8]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000b7")
     test(("\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae" ++ "\0000b7").filter(fn (char) char =/= items[9]) === "\000091\0000b3\0000ab\0000a4\0000a7\0000b5 \0000af\0000ae")
