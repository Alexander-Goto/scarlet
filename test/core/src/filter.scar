let container__filter = [obj
     :value = [array]

     :_ = [obj
          :core_filter    = fn (container, func) to_container__filter(container:value.filter(func))
          :core___equal__ = fn (container_1, container_2) container_1:value === container_2:value
     ]
]

fn to_container__filter(arg) new (@main.container__filter):value <= arg

fn to_custom_container__filter(arg) custom__create(
     arg
     [obj
          :core_filter    = fn (container, func) to_custom_container__filter(custom__get_data(container).filter(func))
          :core___equal__ = fn (container_1, container_2) container_1.custom__get_data() === container_2.custom__get_data()
     ]
)

let broken_container__filter = [obj
     :value = [array]

     :_ = [obj
          :core_filter = fn (_, _) heap_table()
     ]
]

fn to_broken_container__filter(arg) new (@main.broken_container__filter):value <= arg

fn to_broken_custom_container__filter(arg) custom__create(
     arg
     [obj
          :core_filter = fn (_, _) heap_table()
     ]
)

let error_container__filter = [obj
