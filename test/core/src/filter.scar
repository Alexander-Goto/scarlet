     let items  = "01".to_array()
     let string = ("0101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 65]
     test(string.filter(fn (char) char === items[0]) === "00000000000000000000000000000000")
     test(string.filter(fn (char) char === items[1]) === "11111111111111111111111111111111")
     string.ignore()

     let items = "01".to_array()
     test(("0101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 65].filter(fn (char) char === items[0]) === "00000000000000000000000000000000")
     test(("0101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 65].filter(fn (char) char === items[1]) === "11111111111111111111111111111111")

     let items = "01".to_array()
     test(("101010101010101010101010101010101010101010101010101010101010101" ++ "0").filter(fn (char) char === items[0]) === "00000000000000000000000000000000")
     test(("101010101010101010101010101010101010101010101010101010101010101" ++ "0").filter(fn (char) char === items[1]) === "11111111111111111111111111111111")

     let items  = "01".to_array()
     let string = ("10101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 66]
     test(string.filter(fn (char) char === items[0]) === "000000000000000000000000000000000")
     test(string.filter(fn (char) char === items[1]) === "11111111111111111111111111111111")
     string.ignore()

     let items = "01".to_array()
     test(("10101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 66].filter(fn (char) char === items[0]) === "000000000000000000000000000000000")
     test(("10101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 66].filter(fn (char) char === items[1]) === "11111111111111111111111111111111")

     let items = "01".to_array()
     test(("0101010101010101010101010101010101010101010101010101010101010101" ++ "0").filter(fn (char) char === items[0]) === "000000000000000000000000000000000")
     test(("0101010101010101010101010101010101010101010101010101010101010101" ++ "0").filter(fn (char) char === items[1]) === "11111111111111111111111111111111")

     let items  = "01".to_array()
     let string = ("010101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 67]
     test(string.filter(fn (char) char === items[0]) === "000000000000000000000000000000000")
     test(string.filter(fn (char) char === items[1]) === "111111111111111111111111111111111")
     string.ignore()

     let items = "01".to_array()
     test(("010101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 67].filter(fn (char) char === items[0]) === "000000000000000000000000000000000")
     test(("010101010101010101010101010101010101010101010101010101010101010101" ++ "01")[1, 67].filter(fn (char) char === items[1]) === "111111111111111111111111111111111")

     let items = "01".to_array()
     test(("10101010101010101010101010101010101010101010101010101010101010101" ++ "0").filter(fn (char) char === items[0]) === "000000000000000000000000000000000")
     test(("10101010101010101010101010101010101010101010101010101010101010101" ++ "0").filter(fn (char) char === items[1]) === "111111111111111111111111111111111")

     let items = "0".to_array()
     test(("000000000000000000000000" ++ "0").filter(fn (char) char === items[0]) === "0000000000000000000000000")
     test(("000000000000000000000000" ++ "0").filter(fn (char) char =/= items[0]) === "")
     test(("100000000000000000000000" ++ "0").filter(fn (char) char =/= items[0]) === "1")
     test(("100000000000000000000000" ++ "0").filter(fn (char) char === items[0]) === "000000000000000000000000")
     test(("00000000012345600000000000000" ++ "0").filter(fn (char) char =/= items[0]) === "123456")
     test(("000000000123456789abcdefg00000000000000" ++ "0").filter(fn (char) char =/= items[0]) === "123456789abcdefg")

     let [box string_1, string_2] = if (rnd() & 1) === 0 {
          let string_1 = rnd_string()
          let string_2 = if (rnd() & 1) === 0; string_1 else null
          [box string_1, string_2]
     } else [box "Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let expected_string = string_1.foldl("", fn (expected_string, char) if char.lower?(); expected_string.append(char) else expected_string)
     test(string_1.filter(_.lower?()) === expected_string)
     string_2.ignore()

     let [box string_1, string_2] = if (rnd() & 1) === 0 {
          let string_1 = rnd_string()
          let string_2 = if (rnd() & 1) === 0; string_1 else null
          [box string_1, string_2]
     } else [box "Constant String \000093\0000ae\0000b6\0000ba\0000a2\0000ac\0000b0\0000a2\0000c2 \000093\0000b5\0000b3\0000b1\0000ad\0000a2", null]
     let expected_string = string_1.foldl("", fn (expected_string, char) if char.lower?(); expected_string.append(char) else expected_string)
     test(string_1.filter(fn (char) string_1 === 17 || char.lower?()) === expected_string)
     string_2.ignore()

     let items = u"0123456".to_array()
     test(u"".filter(fn (byte) byte === items[0]) === u"")
     test(u"1".filter(fn (byte) byte === items[1]) === u"1")
     test(u"1".filter(fn (byte) byte =/= items[1]) === u"")
     test(u"01223334444555".filter(fn (byte) byte =/= items[0]) === u"1223334444555")
     test(u"01223334444555".filter(fn (byte) byte =/= items[1]) === u"0223334444555")
     test(u"01223334444555".filter(fn (byte) byte =/= items[2]) === u"013334444555")
     test(u"01223334444555".filter(fn (byte) byte =/= items[3]) === u"01224444555")
     test(u"01223334444555".filter(fn (byte) byte =/= items[4]) === u"0122333555")
     test(u"01223334444555".filter(fn (byte) byte =/= items[5]) === u"01223334444")
     test(u"01223334444555".filter(fn (byte) byte =/= items[6]) === u"01223334444555")
