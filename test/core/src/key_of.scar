let array__key_of = [obj
     :value = [array]

     :_ = [obj
          :core___get_item__ = fn (container, key) container:value[key]
     ]
]

fn to_array__key_of(arg) new (@main.array__key_of):value <= arg

fn to_custom_array__key_of(container) custom__create(
     container
     [obj
          :core___get_item__ = fn (container, key) container.custom__get_data()[key]
     ]
)

let broken_array__key_of = [obj
     :value = [array]

     :_ = [obj
          :core___get_item__ = fn (_, _) [box heap_string()]
     ]
]

fn to_broken_array__key_of(arg) new (@main.broken_array__key_of):value <= arg

fn to_broken_custom_array__key_of(container) custom__create(
     container
     [obj
          :core___get_item__ = fn (_, _) [box heap_string()]
     ]
)

let error_array__key_of = [obj
     :value = [array]

     :_ = [obj
          :core___get_item__ = fn (_, _) expected_error(:3, heap_string(), null)
     ]
]

fn to_error_array__key_of(arg) new (@main.error_array__key_of):value <= arg

fn to_error_custom_array__key_of(container) custom__create(
     container
     [obj
          :core___get_item__ = fn (_, _) expected_error(:4, heap_string(), null)
     ]
)

`noinline`
fn test__key_of?() {
     test(:1.key_of?([obj :1 = 2]))
     test(not :2.key_of?([obj :1 = 2]))
     test(:1.key_of?([obj :1 = 2, :2 = 10]))
     test(:2.key_of?([obj :1 = 2, :2 = 10]))
     test(not :3.key_of?([obj :1 = 2, :2 = 10]))
     test(:1.key_of?([obj :1 = 2, :2 = 10, :_ = [obj :1 = 3]]))
     test(:2.key_of?([obj :1 = 2, :2 = 10, :_ = [obj :1 = 3]]))
     test(:_.key_of?([obj :1 = 2, :2 = 10, :_ = [obj :1 = 3]]))
     test(not :3.key_of?([obj :1 = 2, :2 = 10, :_ = [obj :1 = 3]]))

     let len  = (rnd() & 1023) + 1
     let keys = loop([array], fn (keys) {
          let key = rnd_token()
          if key =/= :_ {
               let keys = append(keys, key)
               break(len(keys) === len, keys)
          } else keys
     })
     let unexisted_keys = loop([array], fn (unexisted_keys) {
          let key = rnd_token()
          if key.look_in(keys).null?() {
               let unexisted_keys = append(unexisted_keys, key)
               break(len(unexisted_keys) === len, unexisted_keys)
          } else unexisted_keys
     })
     let obj = keys.foldl([obj].init(len(keys)), fn (obj, key) new (obj)[key] <= 1)
     test(keys.foldl(true, fn (result, key) result && key.key_of?(obj)))
     test(unexisted_keys.foldl(true, fn (result, key) result && not key.key_of?(obj)))

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     let string_3 = string_0 ++ "3"
     test(string_0.key_of?([table string_0 = string_1]))
     test(not string_1.key_of?([table string_0 = string_1]))
     test(string_0.key_of?([table string_0 = string_1, string_2 = string_3]))
     test(string_2.key_of?([table string_0 = string_1, string_2 = string_3]))
     test(not string_1.key_of?([table string_0 = string_1]))
     test(not string_3.key_of?([table string_0 = string_1]))
     test(not 13.key_of?([table string_0 = string_1]))

     let len  = (rnd() & 1023) + 1
     let keys = loop([array], fn (keys) {
          let keys = append(keys, rnd_string())
          break(len(keys) === len, keys)
     })
     let unexisted_keys = loop([array], fn (unexisted_keys) {
          let key = rnd_string()
          if key.look_in(keys).null?() {
               let unexisted_keys = append(unexisted_keys, key)
               break(len(unexisted_keys) === len, unexisted_keys)
          } else unexisted_keys
     })
     let table = keys.foldl([table].init(len(keys)), fn (table, key) new (table)[key] <= 1)
     test(keys.foldl(true, fn (result, key) result && key.key_of?(table)))
     test(unexisted_keys.foldl(true, fn (result, key) result && not key.key_of?(table)))

     let string_0 = heap_string()
     let string_1 = string_0 ++ "1"
     let string_2 = string_0 ++ "2"
     test(string_0.key_of?([set string_0]))
     test(not string_1.key_of?([set string_0]))
     test(string_0.key_of?([set string_0, string_1]))
     test(string_1.key_of?([set string_0, string_1]))
     test(not string_2.key_of?([set string_0, string_1]))
     test(not 13.key_of?([set string_0, string_1]))

     let len  = (rnd() & 1023) + 1
     let keys = loop([array], fn (keys) {
          let keys = append(keys, rnd_string())
          break(len(keys) === len, keys)
     })
     let unexisted_keys = loop([array], fn (unexisted_keys) {
          let key = rnd_string()
          if key.look_in(keys).null?() {
               let unexisted_keys = append(unexisted_keys, key)
               break(len(unexisted_keys) === len, unexisted_keys)
          } else unexisted_keys
     })
     let set = keys.foldl([set].init(len(keys)), fn (set, key) set.append(key))
     test(keys.foldl(true, fn (result, key) result && key.key_of?(set)))
     test(unexisted_keys.foldl(true, fn (result, key) result && not key.key_of?(set)))

     test(12.key_of?([set 12].to_array__key_of()))
     test(12.key_of?([set 12].to_custom_array__key_of()))
     test(not 13.key_of?([set 12].to_array__key_of()))
     test(not 13.key_of?([set 12].to_custom_array__key_of()))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(error_1.key_of?([set heap_string()]).get_error_id() === :1)
     test(heap_string().key_of?(error_1).get_error_id() === :1)
     test(error_1.key_of?(error_2).get_error_id() === :1)
     test(error_2.key_of?(error_1).get_error_id() === :2)

     test(heap_string().key_of?(heap_string()).get_error_id() === :invalid_type)
     test((_ ++ heap_string()).scarlet__erase_info().key_of?([set heap_string()]).get_error_id() === :invalid_type)
     test((_ ++ heap_string()).scarlet__erase_info().key_of?([table heap_string() = heap_string()]).get_error_id() === :invalid_type)
     test(heap_string().key_of?([obj :1 = heap_string()]).get_error_id() === :invalid_type)

     test(heap_string().key_of?(to_broken_array__key_of(heap_table())).get_error_id() === :invalid_type)
     test(heap_string().key_of?(to_broken_custom_array__key_of(heap_table())).get_error_id() === :invalid_type)
     test(heap_string().key_of?(to_error_array__key_of(heap_table())).get_error_id() === :3)
     test(heap_string().key_of?(to_error_custom_array__key_of(heap_table())).get_error_id() === :4)
}