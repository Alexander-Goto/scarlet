`noinline`
fn test__file() {
     test(open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin) == :not_exist)
     test(open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__begin) == :not_exist)
     test(open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__end) == :not_exist)
     test(open_file(fs_path("src/helpers"), @std.fom__read | @std.fom__begin) == :not_file)
     test(open_file(fs_path("src/helpers"), @std.fom__read | @std.fom__write | @std.fom__new) == :not_file)
     test(open_file(fs_path("src/helpers"), @std.fom__read | @std.fom__write | @std.fom__begin) == :not_file)
     test(open_file(fs_path("src/helpers"), @std.fom__read | @std.fom__write | @std.fom__end) == :not_file)
     test(open_file(fs_path("src/helpers"), @std.fom__write | @std.fom__new) == :not_file)
     test(open_file(fs_path("/root/1.txt"), @std.fom__read | @std.fom__begin) == :access)
     test(open_file(fs_path("/root/1.txt"), @std.fom__read | @std.fom__write | @std.fom__new) == :access)
     test(open_file(fs_path("/root/1.txt"), @std.fom__read | @std.fom__write | @std.fom__begin) == :access)
     test(open_file(fs_path("/root/1.txt"), @std.fom__read | @std.fom__write | @std.fom__end) == :access)
     test(open_file(fs_path("/root/1.txt"), @std.fom__write | @std.fom__new) == :access)
     let long_name = fs_path("/" ++ "a".repeat(16777214))
     test(open_file(long_name, @std.fom__read | @std.fom__begin) == :long)
     test(open_file(long_name, @std.fom__read | @std.fom__write | @std.fom__new) == :long)
     test(open_file(long_name, @std.fom__read | @std.fom__write | @std.fom__begin) == :long)
     test(open_file(long_name, @std.fom__read | @std.fom__write | @std.fom__end) == :long)
     test(open_file(long_name, @std.fom__write | @std.fom__new) == :long)

     let file = open_file(fs_path("__file__"), @std.fom__write | @std.fom__new)
     test(file.type() == "std.file")
     file->write(u"0123456789")->flush()

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     test(file.type() == "std.file")
     test(file->read_tail()[1] == u"0123456789")

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__new)
     test(file.type() == "std.file")
     let file = file->write(u"0123456789")->flush()->seek(4, false)
     file->write(u"ab")->flush()
     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     test(file->read_tail()[1] == u"0123ab6789")

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__begin)
     test(file.type() == "std.file")
     let file = file->write(u"cd")->flush()->seek(4, false)
     file->write(u"ef")->flush()
     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     test(file->read_tail()[1] == u"cd23ef6789")

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__end)
     test(file.type() == "std.file")
     let file = file->write(u"gh")->flush()->seek(4, false)
     file->write(u"zx")->flush()
     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     test(file->read_tail()[1] == u"cd23zx6789gh")

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     let path    = fs_path("1.txt")
     test(open_file(error_1, error_2).get_error_id() === :1)
     test(open_file(error_2, error_1).get_error_id() === :2)
     test(open_file(error_1, heap_string()).get_error_id() === :1)
     test(open_file(heap_string(), error_1).get_error_id() === :1)
     test(open_file(heap_string(), heap_string()).get_error_id() === :invalid_type)
     test(open_file(stdout(), @std.fom__read | @std.fom__begin).get_error_id() === :invalid_type)
     test(open_file(path, -1).get_error_id() === :mode)
     test(open_file(path, @std.fom__read).get_error_id() === :mode)
     test(open_file(path, @std.fom__read | @std.fom__end).get_error_id() === :mode)
     test(open_file(path, @std.fom__write).get_error_id() === :mode)
     test(open_file(path, @std.fom__write | @std.fom__begin).get_error_id() === :mode)
     test(open_file(path, @std.fom__write | @std.fom__end).get_error_id() === :mode)
     test(open_file(path, 32).get_error_id() === :mode)
     test(open_file(path, -1).get_error_id() === :mode)
     test(open_file(path, 0.max_val()).get_error_id() === :mode)
     test(open_file(path, 0.min_val()).get_error_id() === :mode)
     test(open_file(path, rnd() | 32).get_error_id() === :mode)

     test(stdout()->kajdfghkjdf(heap_string()).get_error_id() == :invalid_type)
     test(stdout()->kajdfghkjdf(error_1).get_error_id() == :1)
     test(stdout()->kajdfghkjdf(error_1, error_2).get_error_id() == :1)
     test(stdout()->kajdfghkjdf(error_2, error_1).get_error_id() == :2)

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__begin)->seek(4, false)
     test(file->cut()->flush().type() == "std.file")
     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     test(file->read_tail()[1] == u"cd23")
     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     test(file->cut() == :cut)
     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__begin)
     test(file->cut().get_error_id() == :duplicate)
     file.ignore()
     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     test(file->read_tail()[1] == u"cd23")

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->cut(error_1).get_error_id() == :1)
     test(file->cut(heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->cut(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->cut(error_1, heap_string()).get_error_id() == :1)
     test(file->cut(heap_string(), error_1).get_error_id() == :1)
     test(file->cut(error_1, error_2).get_error_id() == :1)
     test(file->cut(error_2, error_1).get_error_id() == :2)

     let file                 = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let [box file, position] = file->tell()
     test(position == 0)
     let file = file->end!()
     let [box file, position] = file->tell()
     test(file.type() == "std.file")
     test(position == 4)
     test(file->end!().get_error_id() == :duplicate)
     file.ignore()

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->end!(error_1).get_error_id() == :1)
     test(file->end!(heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->end!(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->end!(error_1, heap_string()).get_error_id() == :1)
     test(file->end!(heap_string(), error_1).get_error_id() == :1)
     test(file->end!(error_1, error_2).get_error_id() == :1)
     test(file->end!(error_2, error_1).get_error_id() == :2)

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     test(file->flush().get_error_id() == :duplicate)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->flush(error_1).get_error_id() == :1)
     test(file->flush(heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->flush(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->flush(error_1, heap_string()).get_error_id() == :1)
     test(file->flush(heap_string(), error_1).get_error_id() == :1)
     test(file->flush(error_1, error_2).get_error_id() == :1)
     test(file->flush(error_2, error_1).get_error_id() == :2)

     let buffer = u"a".repeat(16)
     let file   = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__new)
     let file   = file->write(u"a".repeat(26).map_kv(fn (idx, char) char + idx.to_byte()))->flush()
     let file   = file->start!()
     let [box file, readed_len, bytes] = file->read(u"")
     test(file.type() == "std.file")
     test(readed_len == 0)
     test(bytes == u"")
     let [box file, readed_len, bytes] = file->read(u"0")
     test(file.type() == "std.file")
     test(readed_len == 1)
     test(bytes == u"a")
     let [box file, readed_len, bytes] = file->read(u"00")
     test(file.type() == "std.file")
     test(readed_len == 2)
     test(bytes == u"bc")
     let [box file, readed_len, bytes] = file->read(u"000")
     test(file.type() == "std.file")
     test(readed_len == 3)
     test(bytes == u"def")
     let [box file, readed_len, bytes] = file->read(buffer)
     test(file.type() == "std.file")
     test(readed_len == 16)
     test(bytes == u"ghijklmnopqrstuv")
     let [box file, readed_len, bytes] = file->read(buffer)
     test(file.type() == "std.file")
     test(readed_len == 4)
     test(bytes == u"wxyzaaaaaaaaaaaa")
     let [box file, readed_len, bytes] = file->read(u"0132132")
     test(file.type() == "std.file")
     test(readed_len == 0)
     test(bytes == u"0132132")
     let [box file, readed_len, bytes] = file->read(u"0132132")
     test(file.type() == "std.file")
     test(readed_len == 0)
     test(bytes == u"0132132")
     test(file->read(u"0132132").get_error_id() == :duplicate)
     file.ignore()

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->read(error_1).get_error_id() == :1)
     test(file->read().get_error_id() == :wrong_num_fn_args)
     test(file->read(heap_string()).get_error_id() == :invalid_type)
     test(file->read(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->read(error_1, heap_string()).get_error_id() == :1)
     test(file->read(heap_string(), error_1).get_error_id() == :1)
     test(file->read(error_1, error_2).get_error_id() == :1)
     test(file->read(error_2, error_1).get_error_id() == :2)

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__new)
     let file = file->write_string("Hello \00001a000100!!!", :sys)->flush()
     let file = file->start!()
     let [box file, string] = file->read_string(:sys)
     test(file.type() == "std.file")
     test(string == "Hello \00001a000100!!!")
     let file = file->write_string("Hello \00001a000100!!!", :sys)->flush()
     let file = file->start!()
     let [box file, string] = file->read_string(:sys)
     test(file.type() == "std.file")
     test(string == "Hello \00001a000100!!!Hello \00001a000100!!!")

     let file = file->start!()
     let file = file->write_string("Hello \000100!!!", :ctf8)->cut()->flush()
     let file = file->start!()
     let [box file, string] = file->read_string(:ctf8)
     test(file.type() == "std.file")
     test(string == "Hello \000100!!!")
     let file = file->write_string("Hello \000100!!!", :ctf8)->cut()->flush()
     let file = file->start!()
     let [box file, string] = file->read_string(:ctf8)
     test(file.type() == "std.file")
     test(string == "Hello \000100!!!Hello \000100!!!")
     test(file->read_string(:ctf8).get_error_id() == :duplicate)
     file.ignore()

     let file = file->start!()
     let file = file->write([byte_array 0bff, 0bff, 0bff, 0bff, 0bff])->flush()
     let file = file->start!()
     let [box file, string] = file->read_string(:ctf8)
     test(file == :encoding)
     test(string.null?())

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->read_string(error_1).get_error_id() == :1)
     test(file->read_string().get_error_id() == :wrong_num_fn_args)
     test(file->read_string(heap_string()).get_error_id() == :invalid_type)
     test(file->read_string(:ctf8, heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->read_string(error_1, heap_string()).get_error_id() == :1)
     test(file->read_string(heap_string(), error_1).get_error_id() == :1)
     test(file->read_string(error_1, error_2).get_error_id() == :1)
     test(file->read_string(error_2, error_1).get_error_id() == :2)

     test(file->read_string(:ctf9).get_error_id() == :encoding)
     test(file->read_string(:ctf7).get_error_id() == :encoding)
     test(file->read_string(:sus).get_error_id() == :encoding)
     test(file->read_string(:_).get_error_id() == :encoding)
     test(file->read_string(:ctf8c).get_error_id() == :encoding)
     test(file->read_string(:ctf8ctf8).get_error_id() == :encoding)
     test(file->read_string(:ctf8sys).get_error_id() == :encoding)
     test(file->read_string(:sysctf8).get_error_id() == :encoding)
     test(file->read_string(:8ctf).get_error_id() == :encoding)
     test(file->read_string(:yss).get_error_id() == :encoding)

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__new)
     let file = file->write(u"0123456789")->flush()
     let file = file->start!()
     let [box file, bytes] = file->read_tail()
     test(file.type() == "std.file")
     test(bytes == u"0123456789")
     let [box file, bytes] = file->read_tail()
     test(file.type() == "std.file")
     test(bytes == u"")
     let file = file->seek(1, false)
     let [box file, bytes] = file->read_tail()
     test(file.type() == "std.file")
     test(bytes == u"123456789")
     let file = file->seek(2, false)
     let [box file, bytes] = file->read_tail()
     test(file.type() == "std.file")
     test(bytes == u"23456789")
     test(file->read_tail().get_error_id() == :duplicate)
     file.ignore()

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->read_tail(error_1).get_error_id() == :1)
     test(file->read_tail(heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->read_tail(error_1, heap_string()).get_error_id() == :1)
     test(file->read_tail(heap_string(), error_1).get_error_id() == :1)
     test(file->read_tail(error_1, error_2).get_error_id() == :1)
     test(file->read_tail(error_2, error_1).get_error_id() == :2)

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let file = file->seek(2, false)
     test(file.type() == "std.file")
     let [box file, bytes] = file->read_tail()
     test(file.type() == "std.file")
     test(bytes == u"23456789")
     let file = file->seek(2, false)
     test(file.type() == "std.file")
     let [box file, bytes] = file->read_tail()
     test(file.type() == "std.file")
     test(bytes == u"23456789")
     let file = file->seek(2, false)->seek(1, true)
     test(file.type() == "std.file")
     let [box file, bytes] = file->read_tail()
     test(file.type() == "std.file")
     test(bytes == u"3456789")
     let file = file->seek(3, false)->seek(-1, true)
     test(file.type() == "std.file")
     let [box file, bytes] = file->read_tail()
     test(file.type() == "std.file")
     test(bytes == u"23456789")
     let file = file->seek(10, false)
     test(file.type() == "std.file")
     let [box file, bytes] = file->read_tail()
     test(file.type() == "std.file")
     test(bytes == u"")
     test(file->seek(0, false).get_error_id() == :duplicate)
     file.ignore()

     test(open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)->seek(-1, false).get_error_id() == :out_of_bounds)
     test(open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)->seek(0.min_val(), false).get_error_id() == :out_of_bounds)
     test(open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)->seek(0.min_val(), true) == :seek)
     test(open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)->seek(0.max_val(), true) == :seek)

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->seek(error_1).get_error_id() == :1)
     test(file->seek(heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->seek(heap_string(), heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->seek(heap_string(), heap_string()).get_error_id() == :invalid_type)
     test(file->seek(10, heap_string()).get_error_id() == :invalid_type)
     test(file->seek(heap_string(), true).get_error_id() == :invalid_type)
     test(file->seek().get_error_id() == :wrong_num_fn_args)
     test(file->seek(error_1, heap_string()).get_error_id() == :1)
     test(file->seek(heap_string(), error_1).get_error_id() == :1)
     test(file->seek(error_1, error_2).get_error_id() == :1)
     test(file->seek(error_2, error_1).get_error_id() == :2)
     test(file->seek(error_2, error_1, heap_string()).get_error_id() == :2)

     let file                 = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let [box file, position] = file->tell()
     test(position == 0)
     let file = file->end!()
     let [box file, position] = file->tell()
     test(file.type() == "std.file")
     test(position == 10)
     let file = file->start!()
     let [box file, position] = file->tell()
     test(file.type() == "std.file")
     test(position == 0)
     test(file->start!().get_error_id() == :duplicate)
     file.ignore()

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->start!(error_1).get_error_id() == :1)
     test(file->start!(heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->start!(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->start!(error_1, heap_string()).get_error_id() == :1)
     test(file->start!(heap_string(), error_1).get_error_id() == :1)
     test(file->start!(error_1, error_2).get_error_id() == :1)
     test(file->start!(error_2, error_1).get_error_id() == :2)

     let file                 = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let [box file, position] = file->tell()
     test(file.type() == "std.file")
     test(position == 0)
     let file = file->end!()
     let [box file, position] = file->tell()
     test(file.type() == "std.file")
     test(position == 10)
     let file = file->start!()
     let [box file, position] = file->tell()
     test(file.type() == "std.file")
     test(position == 0)
     let file = file->seek(3, false)
     let [box file, position] = file->tell()
     test(file.type() == "std.file")
     test(position == 3)
     test(file->tell().get_error_id() == :duplicate)
     file.ignore()

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->tell(error_1).get_error_id() == :1)
     test(file->tell(heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->tell(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->tell(error_1, heap_string()).get_error_id() == :1)
     test(file->tell(heap_string(), error_1).get_error_id() == :1)
     test(file->tell(error_1, error_2).get_error_id() == :1)
     test(file->tell(error_2, error_1).get_error_id() == :2)

     let file              = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__begin)
     let [box file, bytes] = file->read_tail()
     test(bytes == u"0123456789")
     let file = file->start!()->write(u"")
     test(file.type() == "std.file")
     let [box file, bytes] = file->read_tail()
     test(bytes == u"0123456789")
     let file = file->start!()->write(u"abc")
     test(file.type() == "std.file")
     let file = file->write(u"defg")
     test(file.type() == "std.file")
     let file = file->write(u"01234")
     test(file.type() == "std.file")
     let [box file, bytes] = file->start!()->read_tail()
     test(bytes == u"abcdefg01234")
     let file = file->write(u"ghj")
     test(file.type() == "std.file")
     let [box file, bytes] = file->start!()->read_tail()
     test(bytes == u"abcdefg01234ghj")
     test(file->write(u"").get_error_id() == :duplicate)
     file.ignore()

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->write(error_1).get_error_id() == :1)
     test(file->write().get_error_id() == :wrong_num_fn_args)
     test(file->write(heap_string()).get_error_id() == :invalid_type)
     test(file->write(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->write(error_1, heap_string()).get_error_id() == :1)
     test(file->write(heap_string(), error_1).get_error_id() == :1)
     test(file->write(error_1, error_2).get_error_id() == :1)
     test(file->write(error_2, error_1).get_error_id() == :2)

     let file = open_file(fs_path("__file__"), @std.fom__read | @std.fom__write | @std.fom__new)
     let file = file->write_string("", :sys)->flush()
     test(file.type() == "std.file")
     let [box file, string] = file->start!()->read_string(:sys)
     test(string == "")
     let file = file->write_string("Hello \00001a000100!!!", :sys)->flush()
     test(file.type() == "std.file")
     let file = file->start!()
     let [box file, string] = file->read_string(:sys)
     test(string == "Hello \00001a000100!!!")
     let file = file->write_string("Hello \00001a000100!!!", :sys)->flush()
     test(file.type() == "std.file")
     let file = file->start!()
     let [box file, string] = file->read_string(:sys)
     test(string == "Hello \00001a000100!!!Hello \00001a000100!!!")

     let file = file->start!()
     let file = file->write_string("", :ctf8)->cut()->flush()
     test(file.type() == "std.file")
     let [box file, string] = file->start!()->read_string(:sys)
     test(string == "")
     let file = file->write_string("Hello \000100!!!", :ctf8)->cut()->flush()
     test(file.type() == "std.file")
     let file = file->start!()
     let [box file, string] = file->read_string(:ctf8)
     test(string == "Hello \000100!!!")
     let file = file->write_string("Hello \000100!!!", :ctf8)->cut()->flush()
     test(file.type() == "std.file")
     let file = file->start!()
     let [box file, string] = file->read_string(:ctf8)
     test(string == "Hello \000100!!!Hello \000100!!!")
     test(file->write_string("", :ctf8).get_error_id() == :duplicate)
     file.ignore()

     let file    = open_file(fs_path("__file__"), @std.fom__read | @std.fom__begin)
     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(file->write_string(error_1).get_error_id() == :1)
     test(file->write_string().get_error_id() == :wrong_num_fn_args)
     test(file->write_string(heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->write_string(:ctf8, heap_string()).get_error_id() == :invalid_type)
     test(file->write_string(heap_byte_array(), :ctf8).get_error_id() == :invalid_type)
     test(file->write_string(heap_string(), heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->write_string(heap_string(), :ctf8, heap_string()).get_error_id() == :wrong_num_fn_args)
     test(file->write_string(error_1, heap_string()).get_error_id() == :1)
     test(file->write_string(heap_string(), error_1).get_error_id() == :1)
     test(file->write_string(error_1, error_2).get_error_id() == :1)
     test(file->write_string(error_2, error_1).get_error_id() == :2)

     test(file->write_string("", :ctf9).get_error_id() == :encoding)
     test(file->write_string("", :ctf7).get_error_id() == :encoding)
     test(file->write_string("", :sus).get_error_id() == :encoding)
     test(file->write_string("", :_).get_error_id() == :encoding)
     test(file->write_string("", :ctf8c).get_error_id() == :encoding)
     test(file->write_string("", :ctf8ctf8).get_error_id() == :encoding)
     test(file->write_string("", :ctf8sys).get_error_id() == :encoding)
     test(file->write_string("", :sysctf8).get_error_id() == :encoding)
     test(file->write_string("", :8ctf).get_error_id() == :encoding)
     test(file->write_string("", :yss).get_error_id() == :encoding)

     test(file->write_string("\00001a00000", :sys).get_error_id() == :text_recoding)

     delete_file(fs_path("__file__"))
}