     test(fs_path("a")->prefix_of?(fs_path("a"), error_1).get_error_id() == :1)

     test(fs_path("a")->prefix_of?().get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->prefix_of?(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->prefix_of?(heap_string()).get_error_id() == :invalid_type)
     test(fs_path("a")->prefix_of?(stdout()).get_error_id() == :invalid_type)

     test(fs_path("/")->split() == [array])
     test(fs_path(".")->split() == [array "."])
     test(fs_path("..")->split() == [array ".."])
     test(fs_path("a")->split() == [array ".", "a"])
     test(fs_path("a.txt")->split() == [array ".", "a.txt"])
     test(fs_path("/a/a.txt")->split() == [array "a", "a.txt"])
     test(fs_path("./a/a.txt")->split() == [array ".", "a", "a.txt"])
     test(fs_path("0/1/hello/123/../343.txt/123/../12")->split() == [array ".", "0", "1", "hello", "123", "..", "343.txt", "123", "..", "12"])
     test(fs_path("/" ++ "dir_/".repeat(3'355'443))->split() == [array "dir_"].repeat(3'355'443))

     let error = expected_error(:1, heap_string(), heap_string())
     test(fs_path("a")->split(error).get_error_id() == :1)
     test(fs_path("a")->split(error, heap_string()).get_error_id() == :1)
     test(fs_path("a")->split(heap_string(), error).get_error_id() == :1)

     test(fs_path("a")->split(heap_string()).get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->split(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)
}