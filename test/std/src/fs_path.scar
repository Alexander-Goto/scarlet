`noinline`
fn test__fs_path() {
     test(fs_path("/").to_string() == "/")
     test(fs_path(".").to_string() == ".")
     test(fs_path("..").to_string() == "..")
     test(fs_path("...").to_string() == "./...")
     test(fs_path("./").to_string() == ".")
     test(fs_path("../").to_string() == "..")
     test(fs_path(".../").to_string() == "./...")
     test(fs_path("/...").to_string() == "/...")
     test(fs_path("/.../").to_string() == "/...")

     test(fs_path("a").to_string() == "./a")
     test(fs_path("a/").to_string() == "./a")
     test(fs_path("./a").to_string() == "./a")
     test(fs_path("./a/").to_string() == "./a")
     test(fs_path("../a").to_string() == "../a")
     test(fs_path("../a/").to_string() == "../a")
     test(fs_path("/a").to_string() == "/a")
     test(fs_path("/a/").to_string() == "/a")

     test(fs_path("\00001a10ffff").to_string() == "./\00001a10ffff")
     test(fs_path("\00001a10ffff/").to_string() == "./\00001a10ffff")
     test(fs_path("./\00001a10ffff").to_string() == "./\00001a10ffff")
     test(fs_path("./\00001a10ffff/").to_string() == "./\00001a10ffff")
     test(fs_path("../\00001a10ffff").to_string() == "../\00001a10ffff")
     test(fs_path("../\00001a10ffff/").to_string() == "../\00001a10ffff")
     test(fs_path("/\00001a10ffff").to_string() == "/\00001a10ffff")
     test(fs_path("/\00001a10ffff/").to_string() == "/\00001a10ffff")

     test(fs_path("0123456789abcdef").to_string() == "./0123456789abcdef")
     test(fs_path("0123456789abcdef/").to_string() == "./0123456789abcdef")
     test(fs_path("./0123456789abcdef").to_string() == "./0123456789abcdef")
     test(fs_path("./0123456789abcdef/").to_string() == "./0123456789abcdef")
     test(fs_path("../0123456789abcdef").to_string() == "../0123456789abcdef")
     test(fs_path("../0123456789abcdef/").to_string() == "../0123456789abcdef")
     test(fs_path("/0123456789abcdef").to_string() == "/0123456789abcdef")
     test(fs_path("/0123456789abcdef/").to_string() == "/0123456789abcdef")

     test(fs_path("0\00001a10ffff123456789abcdef").to_string() == "./0\00001a10ffff123456789abcdef")
     test(fs_path("0\00001a10ffff123456789abcdef/").to_string() == "./0\00001a10ffff123456789abcdef")
     test(fs_path("./0\00001a10ffff123456789abcdef").to_string() == "./0\00001a10ffff123456789abcdef")
     test(fs_path("./0\00001a10ffff123456789abcdef/").to_string() == "./0\00001a10ffff123456789abcdef")
     test(fs_path("../0\00001a10ffff123456789abcdef").to_string() == "../0\00001a10ffff123456789abcdef")
     test(fs_path("../0\00001a10ffff123456789abcdef/").to_string() == "../0\00001a10ffff123456789abcdef")
     test(fs_path("/0\00001a10ffff123456789abcdef").to_string() == "/0\00001a10ffff123456789abcdef")
     test(fs_path("/0\00001a10ffff123456789abcdef/").to_string() == "/0\00001a10ffff123456789abcdef")

     test(fs_path("a.txt").to_string() == "./a.txt")
     test(fs_path("a.txt/").to_string() == "./a.txt")
     test(fs_path("./a.txt").to_string() == "./a.txt")
     test(fs_path("./a.txt/").to_string() == "./a.txt")
     test(fs_path("../a.txt").to_string() == "../a.txt")
     test(fs_path("../a.txt/").to_string() == "../a.txt")
     test(fs_path("/a.txt").to_string() == "/a.txt")
     test(fs_path("/a.txt/").to_string() == "/a.txt")

     test(fs_path(".txt").to_string() == "./.txt")
     test(fs_path(".txt/").to_string() == "./.txt")
     test(fs_path("./.txt").to_string() == "./.txt")
     test(fs_path("./.txt/").to_string() == "./.txt")
     test(fs_path("../.txt").to_string() == "../.txt")
     test(fs_path("../.txt/").to_string() == "../.txt")
     test(fs_path("/.txt").to_string() == "/.txt")
     test(fs_path("/.txt/").to_string() == "/.txt")

     test(fs_path("0/1/hello/123/../343.txt/123/..").to_string() == "./0/1/hello/123/../343.txt/123/..")
     test(fs_path("0/1/hello/123/../343.txt/123/../").to_string() == "./0/1/hello/123/../343.txt/123/..")
     test(fs_path("./0/1/hello/123/../343.txt/123/..").to_string() == "./0/1/hello/123/../343.txt/123/..")
     test(fs_path("./0/1/hello/123/../343.txt/123/../").to_string() == "./0/1/hello/123/../343.txt/123/..")
     test(fs_path("../0/1/hello/123/../343.txt/123/..").to_string() == "../0/1/hello/123/../343.txt/123/..")
     test(fs_path("../0/1/hello/123/../343.txt/123/../").to_string() == "../0/1/hello/123/../343.txt/123/..")
     test(fs_path("/0/1/hello/123/../343.txt/123/..").to_string() == "/0/1/hello/123/../343.txt/123/..")
     test(fs_path("/0/1/hello/123/../343.txt/123/../").to_string() == "/0/1/hello/123/../343.txt/123/..")

     let long_path        = "/" ++ "dir_/".repeat(3'355'443)
     let long_path_to_str = long_path.take(long_path.len() - 1)
     test(fs_path(long_path).to_string() == long_path_to_str)

     let error = expected_error(:1, heap_string(), heap_string())
     let table = heap_table()
     test(fs_path(error).get_error_id() === :1)
     test(fs_path(table).get_error_id() === :invalid_type)

     test(fs_path("") === :empty)
     test(fs_path("/.//") === :separator)
     test(fs_path(".//") === :separator)
     test(fs_path("a/b//c/d") === :separator)
     test(fs_path("a/b//c/d/") === :separator)
     test(fs_path("./a/b//c/d/") === :separator)
     test(fs_path("../a/b//c/d/") === :separator)
     test(fs_path("../a/b///c/d/") === :separator)
     test(fs_path(long_path_to_str ++ "a") === :long)
     test(fs_path("a".repeat(2.power(24) - 2)) === :long)

     test(fs_path("\00001affffff").get_error_id() === :text_recoding)
     test(fs_path("\00001aa").get_error_id() === :text_recoding)
     test(fs_path("\00001aab").get_error_id() === :text_recoding)
     test(fs_path("\00001aabc").get_error_id() === :text_recoding)
     test(fs_path("\00001aabcd").get_error_id() === :text_recoding)
     test(fs_path("\00001aabcde").get_error_id() === :text_recoding)
     test(fs_path("\00001a000000").get_error_id() === :text_recoding)
     test(fs_path("\00001a000061").get_error_id() === :text_recoding)
     test(fs_path("\00001a00007f").get_error_id() === :text_recoding)

     test(fs_path([array "."]).to_string() == ".")
     test(fs_path([array ".."]).to_string() == "..")
     test(fs_path([array ".", "."]).to_string() == "./.")
     test(fs_path([array "..", ".."]).to_string() == "../..")
     test(fs_path([array heap_string(), ".", heap_string()][1, 2]).to_string() == ".")
     test(fs_path([array heap_string(), "..", heap_string()][1, 2]).to_string() == "..")
     test(fs_path([array heap_string(), ".", ".", heap_string()][1, 3]).to_string() == "./.")
     test(fs_path([array heap_string(), "..", "..", heap_string()][1, 3]).to_string() == "../..")

     test(fs_path([array "a"]).to_string() == "/a")
     test(fs_path([array heap_string(), "a", heap_string()][1, 2]).to_string() == "/a")

     test(fs_path([array "a", "0123456789abcdef"]).to_string() == "/a/0123456789abcdef")
     test(fs_path([array heap_string(), "a", "0123456789abcdef", heap_string()][1, 3]).to_string() == "/a/0123456789abcdef")

     test(fs_path([array "a", "b", "c", "d"]).to_string() == "/a/b/c/d")
     test(fs_path([array heap_string(), "a", "b", "c", "d", heap_string()][1, 5]).to_string() == "/a/b/c/d")

     test(fs_path([array ".", "a", "b", "c", "d"]).to_string() == "./a/b/c/d")
     test(fs_path([array heap_string(), ".", "a", "b", "c", "d", heap_string()][1, 6]).to_string() == "./a/b/c/d")

     test(fs_path([array "\00001a10ffff"]).to_string() == "/\00001a10ffff")
     test(fs_path([array heap_string(), "\00001a10ffff", heap_string()][1, 2]).to_string() == "/\00001a10ffff")

     test(fs_path([array ".", "\00001a000161", "b", "\00001a10ffff", "d"]).to_string() == "./\00001a000161/b/\00001a10ffff/d")
     test(fs_path([array heap_string(), ".", "\00001a000161", "b", "\00001a10ffff", "d", heap_string()][1, 6]).to_string() == "./\00001a000161/b/\00001a10ffff/d")

     test(fs_path([array "abcd"].repeat(3'355'443)).to_string() == "/abcd".repeat(3'355'443))

     test(fs_path([array]) === :empty)
     test(fs_path([array].init(10)) === :empty)
     test(fs_path([array ""]) === :empty)
     test(fs_path([array heap_string(), heap_string(), ""]) === :empty)
     test(fs_path([array rnd()]).get_error_id() === :invalid_type)
     test(fs_path([array heap_string(), heap_string(), rnd()]).get_error_id() === :invalid_type)
     test(fs_path([array heap_string(), heap_string(), "/"]) === :separator)
     test(fs_path([array "/"]) === :separator)
     test(fs_path([array heap_string(), heap_string(), "abc/dd"]) === :separator)

     test(fs_path([array "\00001affffff"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001affffff", heap_string()][1, 2]).get_error_id() === :text_recoding)
     test(fs_path([array "\00001aa"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001aa", heap_string()][1, 2]).get_error_id() === :text_recoding)
     test(fs_path([array "\00001aab"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001aab", heap_string()][1, 2]).get_error_id() === :text_recoding)
     test(fs_path([array "\00001aabc"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001aabc", heap_string()][1, 2]).get_error_id() === :text_recoding)
     test(fs_path([array "\00001aabcd"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001aabcd", heap_string()][1, 2]).get_error_id() === :text_recoding)
     test(fs_path([array "\00001aabcde"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001aabcde", heap_string()][1, 2]).get_error_id() === :text_recoding)
     test(fs_path([array "\00001a000000"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001a000000", heap_string()][1, 2]).get_error_id() === :text_recoding)
     test(fs_path([array "\00001a000061"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001a000061", heap_string()][1, 2]).get_error_id() === :text_recoding)
     test(fs_path([array "\00001a00007f"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001a00007f", heap_string()][1, 2]).get_error_id() === :text_recoding)
     test(fs_path([array "\00001a000", "020"]).get_error_id() === :text_recoding)
     test(fs_path([array heap_string(), "\00001a000", "020", heap_string()][1, 3]).get_error_id() === :text_recoding)

     test(fs_path("a").type() == "std.fs_path")
     test(fs_path("a").dump() == "[fs_path ./a]\n")

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(fs_path("a")->kajdfghkjdf(heap_string()).get_error_id() == :invalid_type)
     test(fs_path("a")->kajdfghkjdf(error_1).get_error_id() == :1)
     test(fs_path("a")->kajdfghkjdf(error_1, error_2).get_error_id() == :1)
     test(fs_path("a")->kajdfghkjdf(error_2, error_1).get_error_id() == :2)

     let [box in, out] = make_channel()
     push(in, fs_path("a"))
     test(pop(out) === fs_path("a"))

     test(fs_path("a")->core_to_string() == "./a")
     test(fs_path("a")->core_to_string(expected_error(:1, heap_string(), heap_string())).get_error_id() == :1)
     test(fs_path("a")->core_to_string(heap_string()).get_error_id() == :wrong_num_fn_args)

     test(fs_path("/") === fs_path("/"))
     test(fs_path(".") === fs_path("."))
     test(fs_path("..") === fs_path(".."))
     test(fs_path("/") =/= fs_path("."))
     test(fs_path("/") =/= fs_path(".."))
     test(fs_path(".") =/= fs_path("/"))
     test(fs_path(".") =/= fs_path(".."))
     test(fs_path("..") =/= fs_path("/"))
     test(fs_path("..") =/= fs_path("."))

     test(fs_path("a") === fs_path("a"))
     test(fs_path("a") =/= fs_path("aa"))
     test(fs_path("a") =/= fs_path("b"))
     test(fs_path("aa") =/= fs_path("a"))
     test(fs_path("aa") =/= fs_path("b"))
     test(fs_path("b") =/= fs_path("a"))
     test(fs_path("b") =/= fs_path("aa"))

     test(fs_path("\00001a10ffff") === fs_path("\00001a10ffff"))
     test(fs_path("0123456789abcdef\00001a10ffff") === fs_path("0123456789abcdef\00001a10ffff"))

     test(fs_path("a.txt") === fs_path("a.txt"))
     test(fs_path("a.txt") =/= fs_path("a.tx"))
     test(fs_path("a.txt") =/= fs_path(".txt"))
     test(fs_path("a.tx") =/= fs_path("a"))
     test(fs_path("a.tx") =/= fs_path(".txt"))
     test(fs_path(".txt") =/= fs_path("a"))
     test(fs_path(".txt") =/= fs_path("a.tx"))

     test(fs_path("0/1/hello/123/../343.txt/123/..") === fs_path("0/1/hello/123/../343.txt/123/.."))
     test(fs_path("0/1/hello/123/../343.txt/123/..") =/= fs_path("0/./1/hello/123/../343.txt/123/.."))

     test(not (fs_path("a") === stdout()))
     test(fs_path("a") =/= stdout())

     let long_path        = "/" ++ "dir_/".repeat(3'355'443)
     let long_path_to_str = long_path.take(long_path.len() - 1)
     test(fs_path(long_path) === fs_path(long_path))
     test(fs_path(long_path) =/= fs_path(long_path_to_str.take(long_path_to_str.len() - 1)))

     test((fs_path("a") === expected_error(:1, heap_string(), heap_string())).get_error_id() === :1)

     test(fs_path("a")->core___equal__(fs_path("a")))
     test(not fs_path("a")->core___equal__(fs_path("b")))
     test(not fs_path("a")->core___equal__(heap_string()))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(fs_path("a")->core___equal__(error_1).get_error_id() == :1)
     test(fs_path("a")->core___equal__(error_1, error_2).get_error_id() == :1)
     test(fs_path("a")->core___equal__(error_2, error_1).get_error_id() == :2)
     test(fs_path("a")->core___equal__(error_1, heap_string()).get_error_id() == :1)
     test(fs_path("a")->core___equal__(heap_string(), error_1).get_error_id() == :1)

     test(fs_path("a")->core___equal__().get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->core___equal__(fs_path("b"), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->core___equal__(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)

     test(fs_path("/") == fs_path("/"))
     test(fs_path(".") == fs_path("."))
     test(fs_path("..") == fs_path(".."))
     test(fs_path("/") /= fs_path("."))
     test(fs_path("/") /= fs_path(".."))
     test(fs_path(".") /= fs_path("/"))
     test(fs_path(".") /= fs_path(".."))
     test(fs_path("..") /= fs_path("/"))
     test(fs_path("..") /= fs_path("."))

     test(fs_path("a") == fs_path("a"))
     test(fs_path("a") /= fs_path("aa"))
     test(fs_path("a") /= fs_path("b"))
     test(fs_path("aa") /= fs_path("a"))
     test(fs_path("aa") /= fs_path("b"))
     test(fs_path("b") /= fs_path("a"))
     test(fs_path("b") /= fs_path("aa"))

     test(fs_path("\00001a10ffff") == fs_path("\00001a10ffff"))
     test(fs_path("0123456789abcdef\00001a10ffff") == fs_path("0123456789abcdef\00001a10ffff"))

     test(fs_path("a.txt") == fs_path("a.txt"))
     test(fs_path("a.txt") /= fs_path("a.tx"))
     test(fs_path("a.txt") /= fs_path(".txt"))
     test(fs_path("a.tx") /= fs_path("a"))
     test(fs_path("a.tx") /= fs_path(".txt"))
     test(fs_path(".txt") /= fs_path("a"))
     test(fs_path(".txt") /= fs_path("a.tx"))

     test(fs_path("0/1/hello/123/../343.txt/123/..") == fs_path("0/1/hello/123/../343.txt/123/.."))
     test(fs_path("0/1/hello/123/../343.txt/123/..") /= fs_path("0/./1/hello/123/../343.txt/123/.."))

     let long_path        = "/" ++ "dir_/".repeat(3'355'443)
     let long_path_to_str = long_path.take(long_path.len() - 1)
     test(fs_path(long_path) == fs_path(long_path))
     test(fs_path(long_path) /= fs_path(long_path_to_str.take(long_path_to_str.len() - 1)))

     test((fs_path("a") == expected_error(:1, heap_string(), heap_string())).get_error_id() == :1)

     test(fs_path("a")->core___strong_equal__(fs_path("a")))
     test(not fs_path("a")->core___strong_equal__(fs_path("b")))

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(fs_path("a")->core___strong_equal__(error_1).get_error_id() == :1)
     test(fs_path("a")->core___strong_equal__(error_1, error_2).get_error_id() == :1)
     test(fs_path("a")->core___strong_equal__(error_2, error_1).get_error_id() == :2)
     test(fs_path("a")->core___strong_equal__(error_1, heap_string()).get_error_id() == :1)
     test(fs_path("a")->core___strong_equal__(heap_string(), error_1).get_error_id() == :1)

     test(fs_path("a")->core___strong_equal__().get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->core___strong_equal__(fs_path("b"), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->core___strong_equal__(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)

     test((fs_path("a")->core___strong_equal__(heap_string())).get_error_id() == :invalid_type)
     test((fs_path("a")->core___strong_equal__(stdout())).get_error_id() == :invalid_type)

     test(fs_path("/").cmp(fs_path("/")) == :equal)
     test(fs_path(".").cmp(fs_path(".")) == :equal)
     test(fs_path("..").cmp(fs_path("..")) == :equal)
     test(fs_path("/").cmp(fs_path(".")) == :great)
     test(fs_path("/").cmp(fs_path("..")) == :great)
     test(fs_path(".").cmp(fs_path("/")) == :less)
     test(fs_path(".").cmp(fs_path("..")) == :less)
     test(fs_path("..").cmp(fs_path("/")) == :less)
     test(fs_path("..").cmp(fs_path(".")) == :great)

     test(fs_path("b").cmp(fs_path("b")) == :equal)
     test(fs_path("a").cmp(fs_path("a")) == :equal)
     test(fs_path("aa").cmp(fs_path("aa")) == :equal)
     test(fs_path("b").cmp(fs_path("a")) == :great)
     test(fs_path("b").cmp(fs_path("aa")) == :great)
     test(fs_path("a").cmp(fs_path("b")) == :less)
     test(fs_path("a").cmp(fs_path("aa")) == :less)
     test(fs_path("aa").cmp(fs_path("b")) == :less)
     test(fs_path("aa").cmp(fs_path("a")) == :great)

     test(fs_path("a").cmp(expected_error(:1, heap_string(), heap_string())).get_error_id() === :1)

     test(fs_path("a")->core_cmp(fs_path("a")) == :equal)
     test(fs_path("a")->core_cmp(fs_path("b")) == :less)
     test(fs_path("a")->core_cmp(heap_string()) == :not_equal)
     test(fs_path("a")->core_cmp(stdout()) == :not_equal)

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(fs_path("a")->core_cmp(error_1).get_error_id() == :1)
     test(fs_path("a")->core_cmp(error_1, error_2).get_error_id() == :1)
     test(fs_path("a")->core_cmp(error_2, error_1).get_error_id() == :2)
     test(fs_path("a")->core_cmp(error_1, heap_string()).get_error_id() == :1)
     test(fs_path("a")->core_cmp(heap_string(), error_1).get_error_id() == :1)

     test(fs_path("a")->core_cmp().get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->core_cmp(fs_path("b"), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->core_cmp(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)

     test(fs_path("a").hash(rnd()).type() == "core.int")
     test(fs_path("a")->core_hash(rnd()).type() == "core.int")

     let error_1 = expected_error(:1, heap_string(), heap_string())
     let error_2 = expected_error(:2, heap_string(), heap_string())
     test(fs_path("a").hash(error_1).get_error_id() === :1)
     test(fs_path("a")->core_hash(error_1).get_error_id() == :1)
     test(fs_path("a")->core_hash(error_1, error_2).get_error_id() == :1)
     test(fs_path("a")->core_hash(error_2, error_1).get_error_id() == :2)
     test(fs_path("a")->core_hash(error_1, heap_string()).get_error_id() == :1)
     test(fs_path("a")->core_hash(heap_string(), error_1).get_error_id() == :1)

     test(fs_path("a")->core_hash(heap_string()).get_error_id() == :invalid_type)
     test(fs_path("a")->core_hash().get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->core_hash(rnd(), heap_string()).get_error_id() == :wrong_num_fn_args)
     test(fs_path("a")->core_hash(heap_string(), heap_string()).get_error_id() == :wrong_num_fn_args)

